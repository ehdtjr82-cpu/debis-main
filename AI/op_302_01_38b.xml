    <script type="text/javascript"><![CDATA[

        scwin.onpageload = function() {
            scwin.vCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");

            lc_cargoCls.removeAll();
            lc_cargoCls.addItem("전체", "");
            lc_cargoCls.addItem("일반", "I");
            lc_cargoCls.addItem("T/S", "T");
            lc_cargoCls.setSelectedIndex(0);

            lc_sendYn.removeAll();
            lc_sendYn.addItem("전체", "1");
            lc_sendYn.addItem("승인(통관/보세/기타)", "2");
            lc_sendYn.addItem("미승인", "3");
            lc_sendYn.setSelectedIndex(0);

            $c.gus.cfDisableObjects([tb_retrieveData]);
        };

        scwin.onUdcCompleted = function() {
            udc_crryinDt.setInitDate("", scwin.vCurDate);
        };

        scwin.btn_retrieve_onclick = function(e) {
            scwin.f_Retrieve();
        };

        scwin.btn_fieldClear_onclick = function(e) {
            $c.gus.cfInitObjects(tbl_cond, []);
        };

        scwin.f_Retrieve = async function() {
            if (!(await $c.gus.cfValidate([ed_wrkPlCd]))) {
                return;
            }

            dma_search.set("wrkPlCd", ed_wrkPlCd.getValue());
            dma_search.set("crryinDtFrom", ica_crryinDtFrom.getValue());
            dma_search.set("crryinDtTo", ica_crryinDtTo.getValue());
            dma_search.set("sendYn", lc_sendYn.getValue());
            dma_search.set("cargoCls", lc_cargoCls.getValue());

            await $c.sbm.execute(sbm_Retrieve);
        };

        scwin.sbm_Retrieve_submitdone = async function(e) {
            let rowCnt = ds_Grid1.getRowCount();
            if (rowCnt == 0) {
                await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
            }

            spa_totalRow.setValue(ds_Grid1.getTotalRow());

            if (rowCnt > 0) {
                let curRow = ds_Grid1.getRowPosition();
                dma_search.set("wrkPlCd", ed_wrkPlCd.getValue().trim());
                dma_search.set("mrn", ds_Grid1.getCellData(curRow, "mrn"));
                dma_search.set("msn", ds_Grid1.getCellData(curRow, "msn"));
                dma_search.set("hsn", ds_Grid1.getCellData(curRow, "hsn"));

                await $c.sbm.execute(sbm_search);
            }
        };

        scwin.sbm_Retrieve_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.gr_Grid1_oncellclick = async function(rowIndex, columnIndex, columnId) {
            dma_search.set("wrkPlCd", ed_wrkPlCd.getValue().trim());
            dma_search.set("mrn", ds_Grid1.getCellData(rowIndex, "mrn"));
            dma_search.set("msn", ds_Grid1.getCellData(rowIndex, "msn"));
            dma_search.set("hsn", ds_Grid1.getCellData(rowIndex, "hsn"));

            await $c.sbm.execute(sbm_search);
        };

        scwin.sbm_search_submitdone = function(e) {
        };

        scwin.sbm_search_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.lc_cargoCls_onchange = function(e) {
            if (lc_cargoCls.getSelectedIndex() == 2) {
                lc_sendYn.setSelectedIndex(1);
                lc_sendYn.setDisabled(true);
            } else {
                lc_sendYn.setDisabled(false);
            }
        };

        scwin.f_chkOpenCommonPopUp = function(inObj, pairObj, disGubun, isCode) {
            if (!$c.gus.cfCanOpenPopup(inObj, pairObj)) {
                return;
            }

            $c.gus.cfClearPairObj(pairObj);

            let pVal = $c.gus.cfGetValue(inObj);

            if (isCode == null || isCode == true) {
                scwin.f_openPopUp(disGubun, pVal, "", "T", "T");
            } else {
                scwin.f_openPopUp(disGubun, "", pVal, "T", "T");
            }
        };

        scwin.f_openPopUp = function(disGubun, pCode, pName, pClose, pAllSearch) {
            if (disGubun == "6") {
                udc_wrkPl.ilCommonPopUp(scwin.callbackWrkPl,
                    pCode, pName, pClose, null, null, null, null, null, null, null, null, null, null, pAllSearch, "작업장,작업장코드,작업장명");
            }
        };

        scwin.callbackWrkPl = function(rtnList) {
            $c.gus.cfSetReturnValue(rtnList, ed_wrkPlCd, txt_wrkPlNm, null);
        };

        scwin.f_ConvertNumberTwo = function(number) {
            if (number <= 9) {
                return "0" + number;
            } else {
                return number + "";
            }
        };

    ]]></script>


<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:ev="http://www.w3.org/2001/xml-events"
      xmlns:w2="http://www.inswave.com/websquare"
      xmlns:xf="http://www.w3.org/2002/xforms">
<head>
    <w2:type>COMPONENT</w2:type>

    <xf:model>
        <w2:dataCollection baseNode="map">
            <w2:dataMap baseNode="map" id="ds_Query">
                <w2:keyInfo>
                    <w2:key id="bizLongCd" name="사업장코드" dataType="text"></w2:key>
                    <w2:key id="regDtFrom" name="등록시작일" dataType="text"></w2:key>
                    <w2:key id="regDtTo" name="등록종료일" dataType="text"></w2:key>
                    <w2:key id="messageNo" name="메시지번호" dataType="text"></w2:key>
                </w2:keyInfo>
            </w2:dataMap>

            <w2:dataList baseNode="list" repeatNode="map" id="ds_Fatigue" saveRemovedData="true">
                <w2:columnInfo>
                    <w2:column id="odrNo" name="오더번호" dataType="text"></w2:column>
                    <w2:column id="vehclShortCd" name="차량단축번호" dataType="text"></w2:column>
                    <w2:column id="vehclNo" name="차량번호" dataType="text"></w2:column>
                    <w2:column id="message" name="메세지" dataType="text"></w2:column>
                    <w2:column id="commCd" name="품명코드" dataType="text"></w2:column>
                    <w2:column id="commNm" name="품명" dataType="text"></w2:column>
                    <w2:column id="qty" name="수량" dataType="text"></w2:column>
                    <w2:column id="coshippingNo" name="합적번호" dataType="text"></w2:column>
                    <w2:column id="dptWrkPlCd" name="출발코드" dataType="text"></w2:column>
                    <w2:column id="dptWrkPlNm" name="출발지명" dataType="text"></w2:column>
                    <w2:column id="arvWrkPlCd" name="도착코드" dataType="text"></w2:column>
                    <w2:column id="arvWrkPlNm" name="도착지명" dataType="text"></w2:column>
                    <w2:column id="regDtm" name="등록일시" dataType="text"></w2:column>
                </w2:columnInfo>
            </w2:dataList>
        </w2:dataCollection>

        <w2:workflowCollection></w2:workflowCollection>

        <xf:submission id="sbm_retrieve"
            action="/ds.op.wrkrslts.transwrkrslts.RetrieveLafargeDriverFatigueCMD.do"
            method="post"
            mediatype="application/json"
            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"ds_Query","key":"IN_DS1"},{"id":"ds_Fatigue","key":"OUT_DS1"}]'
            target='data:json,[{"id":"ds_Fatigue","key":"OUT_DS1"}]'
            ev:submitdone="scwin.sbm_retrieve_submitdone"
            ev:submiterror="scwin.sbm_retrieve_submiterror">
        </xf:submission>
    </xf:model>

    <w2:layoutInfo></w2:layoutInfo>
    <w2:publicInfo method=""></w2:publicInfo>

    <script type="text/javascript"><![CDATA[
    scwin.hid_repClntNo = "";
    scwin.hid_wrkPlCd = "";

    scwin.onpageload = function() {
        scwin.vCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");

        let bizLongCdChoices = [
            { label: "전체", value: "" },
            { label: "당진공장", value: "5600" },
            { label: "여수공장", value: "600" },
            { label: "당진창고", value: "3333" }
        ];
        lc_bizLongCd.setItemSet(bizLongCdChoices, "label", "value");
        lc_bizLongCd.setValue("");

        let messageChoices = [
            { label: "전체", value: "" },
            { label: "전일 3회전 이상 운행 차량", value: "001" },
            { label: "장거리 운행 후 금일 2회 이상 배차", value: "002" },
            { label: "용차 차량 금일 2회 이상 배차", value: "003" }
        ];
        lc_message.setItemSet(messageChoices, "label", "value");
        lc_message.setValue("");
    };

    scwin.onUdcCompleted = function() {
        udc_regDt.setInitDate(scwin.vCurDate, scwin.vCurDate);
    };

    scwin.btn_retrieve_onclick = function(e) {
        scwin.f_Retrieve();
    };

    scwin.f_Retrieve = async function() {
        if (!(await $c.gus.cfValidate([udc_regDt]))) {
            return;
        }

        let stDt = ds_Query.get("regDtFrom");
        let edDt = ds_Query.get("regDtTo");
        if (!$c.gus.cfIsAfterDate(stDt, edDt)) {
            await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
            return;
        }

        await $c.sbm.execute(sbm_retrieve);
    };

    scwin.sbm_retrieve_submitdone = async function(e) {
        let rowCnt = ds_Fatigue.getRowCount();
        if (rowCnt == 0) {
            await $c.win.alert("조회된 데이터가 없습니다.");
        }
        spa_totalRow.setValue(ds_Fatigue.getTotalRow());
    };

    scwin.sbm_retrieve_submiterror = function(e) {
        $c.gus.cfShowError(e);
    };

    scwin.f_grdHeiht = function(gridNm, size) {
        let strHeight = gridNm.getStyle("height");
        let intHeight = parseInt(strHeight.replace("px", ""));
        intHeight = intHeight + size;
        if (intHeight > 0) {
            gridNm.setStyle("height", intHeight + "px");
        }
    };

    scwin.f_runExcel = async function(varGrNm) {
        let totCnt = ds_Fatigue.getRowCount();
        let sheetTitle = "크나우프운전자피로도이력관리";

        if (totCnt != 0) {
            let cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");
            if (cfrm) {
                $c.data.downloadGridViewExcel(varGrNm, { fileName: sheetTitle + ".xlsx", sheetName: sheetTitle });
            }
        } else {
            await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
        }
    };

    scwin.btn_fieldClear_onclick = function(e) {
        scwin.f_FieldClear();
    };

    scwin.f_FieldClear = function() {
        $c.gus.cfInitObjects([ds_Query]);
        lc_bizLongCd.setValue("");
        lc_message.setValue("");
        udc_regDt.setInitDate(scwin.vCurDate, scwin.vCurDate);
    };
    ]]></script>

    <w2:require as="udc_topGrdBtn" type="page" variableClone="true" src="/cm/udc/topGrdBtn.xml"></w2:require>
    <w2:require as="udc_fromToCalendar" type="page" variableClone="" src="/cm/udc/fromToCalendar.xml"></w2:require>
</head>


    								<xf:group class="w2tb_td" tagname="td">
    									<w2:attributes></w2:attributes>
    									<xf:input class=" w85" id="txt_commCd" style="" ref="data:oGDS_view_cond.commCd"></xf:input>
    								</xf:group>
    								<xf:group class="w2tb_th" tagname="th">
    									<w2:attributes>

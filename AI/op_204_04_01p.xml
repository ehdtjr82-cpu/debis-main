    											<w2:column displayMode="label" id="cd" inputType="text" style="" value=""
    												width="100" readOnly="true">
    											</w2:column>
    											<w2:column displayMode="label" id="cdNm" inputType="text" style="" textAlign="left"
    												value="" width="200" readOnly="true">
    											</w2:column>
    											<w2:column displayMode="label" id="grpCd" inputType="text" style="" value=""
    												width="100" readOnly="true">
    											</w2:column>
    											<w2:column width="70" inputType="text" style="" id="cdEngNmAbbr" value=""
    												displayMode="label" readOnly="true">
    											</w2:column>
    										</w2:row>
    									</w2:gBody>
    								</w2:gridView>
    							</xf:group>
    							<xf:group class="grid-bottom " id="" style="">
    								<xf:group class="left" id="">
    									<xf:group class="grid-total" id="">
    										<w2:textbox class="" id="" label="총" style="" tagname="span"></w2:textbox>
    										<w2:textbox class="num" id="" label="0" style="" tagname="span"></w2:textbox>
    										<w2:textbox class="" id="" label="건" style="" tagname="span"></w2:textbox>
    									</xf:group>
    								</xf:group>
    							</xf:group>
    						</xf:group>
    					</xf:group>
    					<xf:group class="shattle " id="" style="">
    						<xf:trigger class="btn ico btn-right" id="btn_right" style="" type="button">
    							<xf:label><![CDATA[엑셀 UP]]></xf:label>
    						</xf:trigger>
    					</xf:group>
    					<xf:group style="" id="" class="row-gap-8">
    						<xf:group style="" id="" class="grid-wrap flex_gvw">
    							<xf:group adaptiveThreshold="" style="" id="grp_group2" class="gvwbox">
    								<w2:gridView visibleRowNumFix="true" checkAllType="false" dataList="ds_workPlaceInfoDetail" style="" autoFit="allColumn"
    									id="gr_workPlaceInfoDetail" visibleRowNum="10" class="wq_gvw" readOnly="false">
    									<w2:caption style="" id="caption2" value="this is a grid caption."></w2:caption>
    									<w2:header style="" id="header1">
    										<w2:row style="" id="row1">
    											<w2:column width="100" inputType="text" style="" id="commCd" value="품목코드"

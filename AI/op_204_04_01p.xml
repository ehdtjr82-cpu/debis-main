    											<w2:column width="100" inputType="text" style="" id="cd" value="분류코드"
    												displayMode="label" hidden="true">
    											</w2:column>
    											<w2:column width="200" inputType="text" style="" id="cdNm" value="품명분류명"
    												displayMode="label" hidden="true">
    											</w2:column>
    											<w2:column width="100" inputType="text" style="" id="grpCd" value="그룹코드"
    												displayMode="label" hidden="true">
    											</w2:column>
    										</w2:row>
    									</w2:header>
    									<w2:gBody style="" id="gBody1">
    										<w2:row style="" id="row2">
    											<w2:column width="100" inputType="text" style="" id="commCd" value=""
    												displayMode="label" readOnly="true">
    											</w2:column>
    											<w2:column width="200" inputType="text" style="" id="commNm" value="" displayMode="label"
    												textAlign="left" readOnly="true">
    											</w2:column>
    											<w2:column width="100" inputType="text" style="" id="cd" value=""
    												displayMode="label" readOnly="true">
    											</w2:column>
    											<w2:column width="200" inputType="text" style="" id="cdNm" value="" displayMode="label"
    												textAlign="left" readOnly="true">
    											</w2:column>
    											<w2:column width="100" inputType="text" style="" id="grpCd" value=""
    												displayMode="label" readOnly="true">
    											</w2:column>
    										</w2:row>
    									</w2:gBody>
    								</w2:gridView>
    							</xf:group>
    							<xf:group style="" id="" class="grid-bottom ">
    								<xf:group id="" class="left">
    									<xf:group id="" class="grid-total">
    										<w2:textbox tagname="span" style="" id="" label="총" class=""></w2:textbox>
    										<w2:textbox tagname="span" style="" id="" label="0" class="num"></w2:textbox>
    										<w2:textbox tagname="span" style="" id="" label="건" class=""></w2:textbox>

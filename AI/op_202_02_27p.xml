            if (ds_odrWrkPathStepDetail.getCellData(curRowPos, "odrWrkStpSeq") >= scwin.v_odrWrkStpSeq) {
                await $c.win.alert("철송이후 단계를 수정하실수 없습니다.");
                scwin.f_Retrieve();
            }
        }
    };


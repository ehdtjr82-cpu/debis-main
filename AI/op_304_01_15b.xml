                    <w2:column id="copCoClntNm" name="협력업체" dataType="text"></w2:column>
                    <w2:column id="eqKndNm" name="차량종류" dataType="text"></w2:column>
                    <w2:column id="eqNrmNm" name="차량규격" dataType="text"></w2:column>

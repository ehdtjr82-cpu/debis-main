                    <w2:column id="invoiceNo" name="송장번호" dataType="text"></w2:column>
                    <w2:column id="unitCd" name="단위" dataType="text"></w2:column>
                    <w2:column id="cbm" name="CBM" dataType="number"></w2:column>
                    <w2:column id="sellAmt" name="내부매출액" dataType="number"></w2:column>
                    <w2:column id="odrKndCd" name="오더종류" dataType="text"></w2:column>
                    <w2:column id="shpCoClntNm" name="선사" dataType="text"></w2:column>
                    <w2:column id="vsslCd" name="모선" dataType="text"></w2:column>

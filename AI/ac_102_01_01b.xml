scwin.f_Print_InvoiceType3 = async function() {
    if (ds_InvoiceExcelType3.getRowCount() < 1) {
        await $c.win.alert("There is no data in Excel Type3");
        return;
    }
    let choice_count = 0;
    for (let i = 0; i < ds_InvoiceExcelType3.getRowCount(); i++) {
        if (ds_InvoiceExcelType3.getCellData(i, "choice") == "T") {
            choice_count = choice_count + 1;
        }
    }
    if (choice_count == 0) {
        await $c.win.alert("There is no Choice in Excel Type3");
        return;
    }
    if (chb_pre.getValue() == "T" && chb_sav.getValue() == "T") {
        await $c.win.alert("미리보기 와 바로저장을 동시에 체크할 수 없습니다.");
        chb_pre.setValue("F");
        chb_sav.setValue("F");
        return false;
    }
    ds_InvoiceOZ.removeAll();
    let check_sum;
    for (let j = 0; j < ds_InvoiceExcelType3.getRowCount(); j++) {
        if (ds_InvoiceExcelType3.getCellData(j, "choice") == "T") {
            check_sum = false;
            for (let k = 0; k < ds_InvoiceOZ.getRowCount(); k++) {
                if (ds_InvoiceOZ.getCellData(k, "prtnGrpNo") == ds_InvoiceExcelType3.getCellData(j, "prtnGrpNo")) {
                    check_sum = true;
                }
            }
            if (check_sum == false) {
                ds_InvoiceOZ.insertRow(ds_InvoiceOZ.getRowCount());
                let lastRow = ds_InvoiceOZ.getRowCount() - 1;
                ds_InvoiceOZ.setCellData(lastRow, "kcomcd", ds_InvoiceExcelType3.getCellData(j, "kcomcd"));
                ds_InvoiceOZ.setCellData(lastRow, "prtnGrpNo", ds_InvoiceExcelType3.getCellData(j, "prtnGrpNo"));
                ds_InvoiceOZ.setCellData(lastRow, "seaair", ds_InvoiceExcelType3.getCellData(j, "seaair"));
                ds_InvoiceOZ.setCellData(lastRow, "iogb", ds_InvoiceExcelType3.getCellData(j, "iogb"));
                ds_InvoiceOZ.setCellData(lastRow, "bilgClntNo", ds_InvoiceExcelType3.getCellData(j, "bilgClntNo"));
                ds_InvoiceOZ.setCellData(lastRow, "updid", ds_InvoiceExcelType3.getCellData(j, "updid"));
                ds_InvoiceOZ.setCellData(lastRow, "summary", ds_InvoiceExcelType3.getCellData(j, "summary"));
                ds_InvoiceOZ.setCellData(lastRow, "bilgPicNm", ds_InvoiceExcelType3.getCellData(j, "bilgPicNm"));
                ds_InvoiceOZ.setCellData(lastRow, "blNo", ds_InvoiceExcelType3.getCellData(j, "blNo"));
            }
        }
    }
    await $c.win.alert("You choose " + ds_InvoiceOZ.getRowCount() + " Invoice Numbers \nPress 'OK'");
    // TODO: OZStartBatch / OZExecuteBatch / cfOZReport - requires OZ Report batch integration
    for (let m = 0; m < ds_InvoiceOZ.getRowCount(); m++) {
        let odiParam = {};
        if (ds_InvoiceOZ.getCellData(m, "seaair") == "S") {
            odiParam.reportId = "ac_101_01_01_sea";
            odiParam.KCOMCD = ds_InvoiceOZ.getCellData(m, "kcomcd");
            odiParam.PRTN_GRP_NO = ds_InvoiceOZ.getCellData(m, "prtnGrpNo");
            odiParam.SEAAIR = "S";
            odiParam.IOGB = ds_InvoiceOZ.getCellData(m, "iogb");
            odiParam.BILG_CLNT_NO = ds_InvoiceOZ.getCellData(m, "bilgClntNo");
            odiParam.USER_ID = ds_InvoiceOZ.getCellData(m, "updid");
            odiParam.TYPE = acb_printOp.getValue();
            odiParam.RMK = rd_rmk.getValue();
            odiParam.REMARK = ds_InvoiceOZ.getCellData(m, "summary");
            odiParam.ENG = rd_enggb.getValue();
            if (ds_InvoiceOZ.getCellData(m, "bilgPicNm") != "") {
                odiParam.PIC = "1";
            } else {
                odiParam.PIC = "2";
            }
            // TODO: cfOZReport batch call for sea
            $c.gus.cfOZReport("", "chb_previewCheck", "/il/acc/ac_101_01_01_sea_01.ozr", odiParam, {}, {});
        } else {
            odiParam.reportId = "ac_101_01_01_air";
            odiParam.KCOMCD = ds_InvoiceOZ.getCellData(m, "kcomcd");
            odiParam.PRTN_GRP_NO = ds_InvoiceOZ.getCellData(m, "prtnGrpNo");
            odiParam.SEAAIR = "A";

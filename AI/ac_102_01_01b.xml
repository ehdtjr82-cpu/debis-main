            odiParam.TYPE = acb_printOp.getValue();
            odiParam.RMK = rd_rmk.getValue();
            odiParam.REMARK = ds_InvoiceOZ.getCellData(m, "summary");
            odiParam.ENG = rd_enggb.getValue();
            if (ds_InvoiceOZ.getCellData(m, "bilgPicNm") != "") {
                odiParam.PIC = "1";
            } else {
                odiParam.PIC = "2";
            }
            // TODO: cfOZReport batch call for air type12
            $c.gus.cfOZReport("", "chb_previewCheck", "/il/acc/ac_101_01_01_air_01.ozr", odiParam, {}, {});

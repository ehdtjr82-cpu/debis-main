scwin.f_Print = async function() {
    if (acb_jobgb.getValue() == "") {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_002, ["Job Type"]);
        acb_jobgb.setFocus();
        return;
    }
    if (ed_bldtfrom.getValue().trim() == "" || ed_bldtto.getValue().trim() == "") {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_002, ["ETD"]);
        ed_bldtfrom.setFocus();
        return;
    }
    if (!$c.gus.cfIsAfterDate(ed_bldtfrom.getValue().trim(), ed_bldtto.getValue().trim(), false)) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
        return;
    }
    // TODO: OZ Report (ODIParam/FormParam/ViewerParam) - requires OZ Report integration
    let odiParam = {};
    if (acb_jobgb.getValue() == "S") {
        odiParam.reportId = "ac_102_01_01";
        odiParam.KCOMCD = scwin.hid_kcomcd;
        odiParam.IOGB = acb_iogb.getValue().trim();
        odiParam.SEAAIR = acb_jobgb.getValue().trim();
        odiParam.FROM_DT = ed_bldtfrom.getValue().trim();
        odiParam.TO_DT = ed_bldtto.getValue().trim();
        odiParam.BILG_CLNT_NO = ed_cncd.getValue().trim();
        odiParam.BILG_LODEPT_CD = ed_dept.getValue().trim();
        odiParam.CNNM = txt_cnnm.getValue().trim();
        odiParam.ANNM = txt_annm.getValue().trim();
        odiParam.ADMINPIC = txt_adminPicNm.getValue().trim();
        odiParam.LOBRANCD = scwin.hid_lobranCd;
        odiParam.CERTI_NO = ed_certiNo.getValue().trim();
        odiParam.PRTN_GRP_NO = ed_prtnGrpNo.getValue().trim();
        let slipParam = "";
        if (ed_slipNo.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo.getValue().trim() + ")"; }
        if (ed_slipNo2.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo2.getValue().trim() + ")"; }
        if (ed_slipNo3.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo3.getValue().trim() + ")"; }
        if (ed_slipNo4.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo4.getValue().trim() + ")"; }
        odiParam.SLIP_NO = slipParam.substring(1);
        odiParam.PRINT_DT = acb_printDt.getValue().trim();
        odiParam.PIC = cnd_ed_picNo.getValue().trim();
    } else if (acb_jobgb.getValue() == "A") {
        odiParam.reportId = "ac_102_01_01_air";
        odiParam.KCOMCD = scwin.hid_kcomcd;
        odiParam.IOGB = acb_iogb.getValue().trim();
        odiParam.SEAAIR = acb_jobgb.getValue().trim();
        odiParam.FROM_DT = ed_bldtfrom.getValue().trim();
        odiParam.TO_DT = ed_bldtto.getValue().trim();
        odiParam.CUST = ed_cncd.getValue().trim();
        odiParam.DEPT = ed_dept.getValue().trim();
        odiParam.CERTI_NO = ed_certiNo.getValue().trim();
        odiParam.PRTN_GRP_NO = ed_prtnGrpNo.getValue().trim();
        let slipParam = "";
        if (ed_slipNo.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo.getValue().trim() + ")"; }
        if (ed_slipNo2.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo2.getValue().trim() + ")"; }
        if (ed_slipNo3.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo3.getValue().trim() + ")"; }
        if (ed_slipNo4.getValue().trim() != "") { slipParam = slipParam + ",TO_CHAR(" + ed_slipNo4.getValue().trim() + ")"; }
        odiParam.SLIP_NO = slipParam.substring(1);
        odiParam.PRINT_DT = acb_printDt.getValue().trim();
        odiParam.PIC = cnd_ed_picNo.getValue().trim();
    } else {
        odiParam.reportId = "ac_102_01_01_trans";
        odiParam.KCOMCD = scwin.hid_kcomcd;
        odiParam.IOGB = acb_iogb.getValue().trim();
        odiParam.SEAAIR = acb_jobgb.getValue().trim();
        odiParam.FROM_DT = ed_bldtfrom.getValue().trim();
        odiParam.TO_DT = ed_bldtto.getValue().trim();
        odiParam.CUST = ed_cncd.getValue().trim();
        odiParam.DEPT = ed_dept.getValue().trim();
        odiParam.CERTI_NO = ed_certiNo.getValue().trim();
        odiParam.PRTN_GRP_NO = ed_prtnGrpNo.getValue().trim();
        odiParam.SLIP_NO = ed_slipNo.getValue().trim();
        odiParam.PRINT_DT = acb_printDt.getValue().trim();
        odiParam.TRANSTYP = acb_transTyp.getValue().trim();
    }
    let check = "";
    if ("TYPE3" == scwin.processType) {
        for (let i = 0; i < ds_InvoiceExcelType3.getRowCount(); i++) {
            if (ds_InvoiceExcelType3.getCellData(i, "choice") == "T") {
                check += ",TO_CHAR(" + ds_InvoiceExcelType3.getCellData(i, "prtnGrpNo") + ")";
            }
        }
        odiParam.PRTN_GRP_NO2 = check.substring(1);
    }
    let choiceHouseNo = "";
    if ("TYPE11" == scwin.processType) {
        for (let i = 0; i < ds_InvoiceExcelType11.getRowCount(); i++) {
            if (ds_InvoiceExcelType11.getCellData(i, "chk") == "T") {
                if ((acb_jobgb.getValue().trim() + acb_iogb.getValue().trim()) != ds_InvoiceExcelType11.getCellData(i, "seaAir")) {
                    await $c.win.alert("선택 된 Invoice와 Job Type, 수출입 구분이 일치하지 않습니다.");
                    return false;
                }
                choiceHouseNo = choiceHouseNo + ",TO_CHAR(" + ds_InvoiceExcelType11.getCellData(i, "odrNo").substring(3) + ")";
            }
        }
        odiParam.ODR_NO = choiceHouseNo.substring(1);
    }
    // TODO: cfOZPreview call - requires OZ Report viewer integration
    if (acb_jobgb.getValue() == "S") {
        $c.gus.cfOZPreview("/il/acc/ac_102_01_01_01.ozr", odiParam, {}, {});
    } else if (acb_jobgb.getValue() == "A") {
        $c.gus.cfOZPreview("/il/acc/ac_102_01_01_01_air.ozr", odiParam, {}, {});
    } else {
        $c.gus.cfOZPreview("/il/acc/ac_102_01_01_01_trans.ozr", odiParam, {}, {});
    }
};


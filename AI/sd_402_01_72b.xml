                    if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i, "wrkLobranNm")) && ds_odrWrkPathStepDetail.getCellData(i, "selpchItemCd") != scwin.SELPCH_ITEM_CD_NOSELL)
                        ds_odrWrkPathStepDetail.setCellData(i, "wrkLobranNm", ds_odrWrkPathStepDetail.getCellData(i - 1, "wrkLobranNm"));
                    if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i, "dptWrkPlCd")))
                        ds_odrWrkPathStepDetail.setCellData(i, "dptWrkPlCd", ds_odrWrkPathStepDetail.getCellData(i - 1, "dptWrkPlCd"));
                    if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i, "arvWrkPlCd")) && i < ds_odrWrkPathStepDetail.getRowCount() - 1)
                        ds_odrWrkPathStepDetail.setCellData(i, "arvWrkPlCd", ds_odrWrkPathStepDetail.getCellData(i + 1, "dptWrkPlCd"));
                    if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i, "arvWrkPlNm")) && i < ds_odrWrkPathStepDetail.getRowCount() - 1)
                        ds_odrWrkPathStepDetail.setCellData(i, "arvWrkPlNm", ds_odrWrkPathStepDetail.getCellData(i + 1, "dptWrkPlNm"));
                    if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i, "internalSellLodeptCd")) && ds_odrWrkPathStepDetail.getCellData(i, "selpchItemCd") != scwin.SELPCH_ITEM_CD_NOSELL)
                        ds_odrWrkPathStepDetail.setCellData(i, "internalSellLodeptCd", ds_odrWrkPathStepDetail.getCellData(i - 1, "internalSellLodeptCd"));
                    if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i, "internalSellLodeptNm")) && ds_odrWrkPathStepDetail.getCellData(i, "selpchItemCd") != scwin.SELPCH_ITEM_CD_NOSELL && !$c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i - 1, "internalSellLodeptNm")))
                        ds_odrWrkPathStepDetail.setCellData(i, "internalSellLodeptNm", ds_odrWrkPathStepDetail.getCellData(i - 1, "internalSellLodeptNm"));
                }
            }
        }

        let chkValid = await $c.gus.cfValidate([gr_odrWrkPathStpDetail]);
        if (!chkValid) return;

        for (let idx = 0; idx < ds_odrWrkPathStepDetail.getRowCount(); idx++) {
            if (ds_odrWrkPathStepDetail.getRowStatus(idx) != "D") {
                if (!$c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(idx, "wrkPlClsCd").trim()) && $c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(idx, "dptWrkPlCd").trim())) {
                    await $c.gus.cfAlertMsg(MSG_CM_WRN_007, ["작업장"]);

    scwin.f_checkWorkStepEditMode = function(row) {
        if (row === undefined || row === null || row < 0) {
            if (ds_odrWrkPathStepDetail.getRowCount() > 0) {
                ds_odrWrkPathStepDetail.setRowPosition(0);
                row = 0;
            } else {
                return;
            }
        }

        if (row >= 0) {
            if (gr_odrWrkPathStpDetail.getReadOnly()) {
                btnInsertRow.setDisabled(true);
                btnDeleteRow.setDisabled(true);
                btnUndoMark.setDisabled(true);
                return false;
            }

            let v_odrWrkStpSeq = parseInt(ds_odrWrkPathStepDetail.getCellData(row, "odrWrkStpSeq"));

            if (row == 0) {
                btnInsertRow.setDisabled(false);
                btnDeleteRow.setDisabled(true);
                btnUndoMark.setDisabled(true);
                return false;
            }

            if (v_odrWrkStpSeq == 10) {
                btnInsertRow.setDisabled(false);
                btnDeleteRow.setDisabled(true);
                btnUndoMark.setDisabled(true);
                return false;
            }

            if (row == ds_odrWrkPathStepDetail.getRowCount() - 1) {
                btnInsertRow.setDisabled(true);
                btnDeleteRow.setDisabled(true);
                btnUndoMark.setDisabled(true);
                return false;
            }

            if (v_odrWrkStpSeq % 10 == 0) {
                if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(row, "wrkPlClsCd").trim())) {
                    if (ds_odrWrkPathStepDetail.getCellData(row, "wrkStpCd") == scwin.WRK_STP_CD_SHUTTLE
                        || ds_odrWrkPathStepDetail.getCellData(row, "wrkStpCd") == scwin.WRK_STP_CD_GROUND_TRANS) {
                        btnInsertRow.setDisabled(false);
                        btnDeleteRow.setDisabled(false);
                        btnUndoMark.setDisabled(false);
                        return false;
                    } else {
                        btnDeleteRow.setDisabled(true);
                        btnUndoMark.setDisabled(true);
                        if (row < ds_odrWrkPathStepDetail.getRowCount() - 1) {
                            let nextWrkPlClsCd = ds_odrWrkPathStepDetail.getCellData(row + 1, "wrkPlClsCd");
                            let nextOdrWrkStpSeq = parseInt(ds_odrWrkPathStepDetail.getCellData(row + 1, "odrWrkStpSeq"));
                            if (nextWrkPlClsCd == scwin.WRK_PL_CLS_CD_DOOR && nextOdrWrkStpSeq % 10 == 0) {
                                btnInsertRow.setDisabled(true);
                                return false;
                            } else if (nextWrkPlClsCd == scwin.WRK_PL_CLS_CD_RAILSTN && nextOdrWrkStpSeq % 10 == 0) {
                                btnInsertRow.setDisabled(true);
                                return false;
                            } else if (nextWrkPlClsCd == scwin.WRK_PL_CLS_CD_MARTRPIER && nextOdrWrkStpSeq % 10 == 0) {
                                btnInsertRow.setDisabled(true);
                                return false;
                            } else {
                                btnInsertRow.setDisabled(false);
                                return false;
                            }
                        }
                    }
                }

                let curWrkPlClsCd = ds_odrWrkPathStepDetail.getCellData(row, "wrkPlClsCd");
                if (curWrkPlClsCd == scwin.WRK_PL_CLS_CD_DOOR || curWrkPlClsCd == scwin.WRK_PL_CLS_CD_RAILSTN || curWrkPlClsCd == scwin.WRK_PL_CLS_CD_MARTRPIER) {
                    if (row < ds_odrWrkPathStepDetail.getRowCount() - 1) {
                        let nextWrkPlClsCd = ds_odrWrkPathStepDetail.getCellData(row + 1, "wrkPlClsCd");
                        let nextOdrWrkStpSeq = parseInt(ds_odrWrkPathStepDetail.getCellData(row + 1, "odrWrkStpSeq"));
                        if ($c.gus.cfIsNull(nextWrkPlClsCd.trim()) && nextOdrWrkStpSeq % 10 == 0) {
                            btnInsertRow.setDisabled(true);
                            btnDeleteRow.setDisabled(true);
                            btnUndoMark.setDisabled(true);
                            return false;
                        } else {
                            btnDeleteRow.setDisabled(true);
                            btnUndoMark.setDisabled(true);
                            btnInsertRow.setDisabled(false);
                            return false;
                        }
                    }
                }

                btnInsertRow.setDisabled(false);
                btnDeleteRow.setDisabled(false);
                btnUndoMark.setDisabled(false);
                return false;
            } else {
                btnInsertRow.setDisabled(false);
                btnDeleteRow.setDisabled(false);
                btnUndoMark.setDisabled(false);
                return false;
            }
        }
    };


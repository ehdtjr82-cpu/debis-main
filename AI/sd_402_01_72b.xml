    scwin.sbm_retrieve_submitdone = async function(e) {
        scwin.hid_chkUseFilter = "true";

        gr_odrCntrWrkPath.setReadOnly("grid", true);
        gr_odrWrkPathStpDetail.setReadOnly("grid", true);

        if (ds_order.getRowCount() == 0) {
            await $c.gus.cfAlertMsg(MSG_CM_ERR_003, ["조회결과"]);
            scwin.f_FieldClear();
            tbx_realMchtclntNm.setValue("");
            tbx_ctrtClntNm.setValue("");
            tbx_ctrtNo.setValue("");
            tbx_odrKndNm.setValue("");
            return;
        }

        let odrRow = ds_order.getRowPosition();
        let odrKndCd = ds_order.getCellData(odrRow, "odrKndCd");

        if (odrKndCd.substr(0, 1) == scwin.WRK_PL_CLS_CD_DOOR) {
            td_realMchtClntNm.setValue("수요가");
            tbx_realMchtclntNm.setValue(ds_order.getCellData(odrRow, "dmndNm"));
            scwin.hid_realMchtclntNo = ds_order.getCellData(odrRow, "dmndNo");
        } else {
            td_realMchtClntNm.setValue("실화주");
            tbx_realMchtclntNm.setValue(ds_order.getCellData(odrRow, "realMchtClntNm"));
            scwin.hid_realMchtclntNo = ds_order.getCellData(odrRow, "realMchtClntNo");
        }

        scwin.f_setDisplayOdrKndCd(odrKndCd);

        tbx_ctrtClntNm.setValue(ds_order.getCellData(odrRow, "ctrtClntNm"));
        tbx_ctrtNo.setValue(ds_order.getCellData(odrRow, "ctrtNo"));
        tbx_odrKndNm.setValue(ds_order.getCellData(odrRow, "odrKndNm"));

        scwin.hid_ctrtClntNo = ds_order.getCellData(odrRow, "ctrtClntNo");
        scwin.hid_ctrtNo = ds_order.getCellData(odrRow, "ctrtNo");
        scwin.hid_odrKndCd = ds_order.getCellData(odrRow, "odrKndCd");

        if (ds_order.getCellData(odrRow, "odrDcsnYn") != scwin.YN_YES) {
            btnUpdate.setDisabled(false);
            btnSave.setDisabled(true);
        } else {
            btnUpdate.setDisabled(false);
            btnSave.setDisabled(true);
            scwin.f_chkContainerWorkPath();
        }

        if (ds_order.getCellData(odrRow, "odrCompleteYn") != scwin.YN_YES) {
            btnUpdate.setDisabled(false);
            btnSave.setDisabled(true);
            scwin.f_chkContainerWorkPath();
        } else {
            btnUpdate.setDisabled(true);
            btnSave.setDisabled(true);
        }

        if (ds_odrCntrWrkPath.getRowCount() > 0 && ds_order.getCellData(odrRow, "odrDcsnYn") != scwin.YN_YES && ds_order.getCellData(odrRow, "odrCompleteYn") != scwin.YN_YES) {
            if (ds_odrCntrWrkPath.getCellData(ds_odrCntrWrkPath.getRowPosition(), "odrWrkPathSeq") == 0) {
                scwin.f_Update();
            }
        }

        btnInsertRow.setDisabled(true);
        btnDeleteRow.setDisabled(true);
        btnUndoMark.setDisabled(true);

        scwin.hid_chkReterieve = "retrieveIn";

        let v_odrWrkPathCnt = ds_order.getCellData(odrRow, "odrWrkPathCnt");
        if (v_odrWrkPathCnt > 0 && v_odrWrkPathCnt >= ds_odrCntrWrkPath.getRowCount()) {
            if (ds_order.getCellData(odrRow, "odrDcsnYn") != scwin.YN_YES) {
                btnConfirmOrder.setDisabled(false);
            } else {
                btnConfirmOrder.setDisabled(true);
                if (ds_order.getCellData(odrRow, "odrCompleteYn") == scwin.YN_YES) {
                    btnUpdate.setDisabled(true);
                }
            }
        } else {
            btnConfirmOrder.setDisabled(true);
        }

        if (ds_order.getCellData(odrRow, "autoOdrYn") == scwin.YN_YES) {
            btnUpdate.setDisabled(true);
            btnSave.setDisabled(true);
        }

        totalRows.setValue(ds_odrCntrWrkPath.getRowCount());

        if (ds_odrCntrWrkPath.getRowCount() > 0) {
            let curRow = ds_odrCntrWrkPath.getRowPosition();
            if (curRow >= 0 && ds_odrCntrWrkPath.getCellData(curRow, "ctrtWrkPathSeq") > 0) {
                ds_searchWrkStep.set("odrNo", ds_odrCntrWrkPath.getCellData(curRow, "odrNo"));
                ds_searchWrkStep.set("cntrSeq", ds_odrCntrWrkPath.getCellData(curRow, "cntrSeq"));
                ds_searchWrkStep.set("odrWrkPathSeq", ds_odrCntrWrkPath.getCellData(curRow, "odrWrkPathSeq"));
                ds_searchWrkStep.set("ctrtNo", ds_odrCntrWrkPath.getCellData(curRow, "ctrtNo"));
                ds_searchWrkStep.set("ctrtWrkPathSeq", ds_odrCntrWrkPath.getCellData(curRow, "ctrtWrkPathSeq"));
                await scwin.f_RetrieveWorkStep();
            }
        }
    };


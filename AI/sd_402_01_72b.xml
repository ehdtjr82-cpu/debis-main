        }

        for (let i = 0; i < ds_odrWrkPathStepDetail.getRowCount(); i++) {
            if (ds_odrWrkPathStepDetail.getRowStatus(i) != "D") {
                if (ds_odrWrkPathStepDetail.getCellData(i, "wrkPlClsCd").trim() == "" && i > 0) {
                    if ($c.gus.cfIsNull(ds_odrWrkPathStepDetail.getCellData(i, "wrkLobranCd")) && ds_odrWrkPathStepDetail.getCellData(i, "selpchItemCd") != scwin.SELPCH_ITEM_CD_NOSELL)

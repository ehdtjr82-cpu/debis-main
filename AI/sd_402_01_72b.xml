    scwin.f_CopyDataSetValueToTemp = async function(ds1, ds2) {
        let curRow = ds_odrCntrWrkPath.getRowPosition();
        if (curRow < 0) return;
        let v_cntrSeq = ds_odrCntrWrkPath.getCellData(curRow, "cntrSeq");
        let v_odrWrkPathSeq = ds_odrCntrWrkPath.getCellData(curRow, "odrWrkPathSeq");
        let v_ctrtWrkPathSeq = ds_odrCntrWrkPath.getCellData(curRow, "ctrtWrkPathSeq");
        let v_fullEmptyClsCd = ds_odrCntrWrkPath.getCellData(curRow, "fullEmptyClsCd");

        for (let i = 0; i < ds1.getRowCount(); i++) {
            if (ds1.getRowStatus(i) != "D") {
                let newRow = ds2.insertRow(ds2.getRowCount());
                let colCount = ds1.getColumnCount();
                for (let j = 0; j < colCount; j++) {
                    let colId = ds1.getColumnID(j);
                    switch (colId) {
                        case "cntrSeq":
                            ds2.setCellData(newRow, colId, v_cntrSeq);
                            break;
                        case "odrWrkPathSeq":
                            ds2.setCellData(newRow, colId, v_odrWrkPathSeq);
                            break;
                        case "ctrtWrkPathSeq":
                            ds2.setCellData(newRow, colId, v_ctrtWrkPathSeq);
                            break;
                        case "fullEmptyClsCd":
                            if (scwin.hid_odrKndCd != scwin.ODR_KND_CD_IMP_GNRL_CNTR_ODR && scwin.hid_odrKndCd != scwin.ODR_KND_CD_EXP_GNRL_CNTR_ODR) {
                                ds2.setCellData(newRow, colId, v_fullEmptyClsCd);
                            }
                            break;
                        default:
                            ds2.setCellData(newRow, colId, ds1.getCellData(i, colId));
                            break;
                    }
                }
            }
        }
    };


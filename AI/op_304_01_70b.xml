        </xf:submission>

        <xf:submission id="sbm_save"
            action="/ds.op.wrkrslts.transwrkrslts.SaveKnaufBillingrateCMD.do"
            method="post"
            mediatype="application/json"
            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"ds_update","key":"IN_DS1"}]'

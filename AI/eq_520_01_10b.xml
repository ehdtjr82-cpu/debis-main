            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"dma_search","key":"IN_DS1"},{"id":"ds_eq420","key":"OUT_DS1"}]'
            target='data:json,[{"id":"ds_eq420","key":"OUT_DS1"}]'
            ev:submitdone="scwin.sbm_retrieve_submitdone"
            ev:submiterror="scwin.sbm_retrieve_submiterror">
        </xf:submission>

        <xf:submission id="sbm_retrieveFixWrkPl"
            action="/cm.zz.RetrieveComboCMD.do"
            method="post"
            mediatype="application/json"
            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"dma_search","key":"IN_DS1"},{"id":"ds_fixWrkPl","key":"OUT_DS1"}]'
            target='data:json,[{"id":"ds_fixWrkPl","key":"OUT_DS1"}]'

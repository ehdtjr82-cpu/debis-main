        if (gubun == 7 || gubun == 8) {
            let cnt = ds.getCellData(row, nmColid).indexOf("]");
            pCode = ds.getCellData(row, cdColid);
            pName = ds.getCellData(row, nmColid).substr(cnt + 1);
        } else if (gubun == 13 || gubun == 14) {
            pCode = ds.getCellData(row, cdColid) + '';
            pName = ds.getCellData(row, nmColid) + '';
        } else {
            pCode = ds.getCellData(row, cdColid);
            pName = ds.getCellData(row, nmColid);
        }

        if (gubun == 1) {
            pSelectID = "retrieveClntInfo";
            pWtitleSearch = "청구처,청구처코드,청구처";
            pWhere = null;
        } else if (gubun == 2) {
            pSelectID = "retrieveLogisDeptInfo";
            pWtitleSearch = "청구부서,청구부서코드,청구부서";
            pWhere = ",,,,,,,1";
        } else if (gubun == 3) {
            pSelectID = "retrieveSelpchItemPchsInfo";
            pWtitleSearch = "매출항목,매출항목코드,매출항목";
            pDispCnt = "2";
            pHidden = "3,4,5,6,7,8,9,10";
            pWhere = ",,1";
        } else if (gubun == 4) {
            pSelectID = "retrieveBizDomCdInfo";
            pWtitleSearch = "사업영역,사업영역코드,사업영역";
        } else if (gubun == 5) {
            pSelectID = "retrieveSelpchItemPchsInfo";
            pWtitleSearch = "매입항목,매입항목코드,매입항목";
            pDispCnt = "2";
            pHidden = "3,4,5,6,7,8,9,10";
            pWhere = ",,1";
        } else if (gubun == 6) {
            pSelectID = "retrieveSelpchItemPchsInfo";
            pWtitleSearch = "할인할증,할인할증코드,할인할증";
            pDispCnt = "2";
            pHidden = "3,4,5,6,7,8,9,10";
            pWhere = ",,1";
        } else if (gubun == 7) {
            pSelectID = "retrieveCoopList";
            pWtitleSearch = "협력업체,협력업체번호,협력업체";
        } else if (gubun == 8) {
            pSelectID = "retrieveCoopList";
            pWtitleSearch = "매입거래처,매입거래처번호,매입거래처";
            pWhere = null;
        } else if (gubun == 9) {
            pSelectID = "retrieveOpDeptCdInfo";
            pWtitleSearch = "부서,부서코드,부서";
            pWhere = ",1";
        } else if (gubun == 10) {
            pSelectID = "retrieveCommInfo";
            pWtitleSearch = "품명,품명코드,품명";
            pWhere = "2,4,,,ZZZZ";
        } else if (gubun == 11) {
            pSelectID = "retrieveSellLodeptInfo";
            pWtitleSearch = "매출부서,매출부서코드,매출부서";
            pWhere = ",,,,,,1,";
        } else if (gubun == 12) {
            pSelectID = "retrieveWrkPlInfo";
            pWtitleSearch = "작업장,작업장코드,작업장";
            pWhere = null;
        } else if (gubun == 13) {
            pSelectID = "retrieveOdrWrkPathList";
            pWhere = null;
        } else if (gubun == 14) {
            pSelectID = "retrieveOdrWrkPathEachWrkStpList";
            if (ds.getCellData(row, "cntrSizCd") != "") {
                pWhere = ds.getCellData(row, "odrNo") + "," + ds.getCellData(row, "cntrWrkPathSeq");
            } else {
                pWhere = ds.getCellData(row, "odrNo") + "," + ds.getCellData(row, "bulkWrkPathSeq");
            }
        }

        let rtnList = $c.gus.cfCommonPopUp(pSelectID, pCode, pName, pWinCloseTF, pDispCnt, null, null, pHidden, pWhere, null, null, null, null, null, "F", pWtitleSearch);

        if (rtnList != null) {
            if (rtnList[0] == "N/A") {
                ds.setCellData(row, cdColid, ds.getOrgCellData(row, cdColid));
                ds.setCellData(row, nmColid, ds.getOrgCellData(row, nmColid));

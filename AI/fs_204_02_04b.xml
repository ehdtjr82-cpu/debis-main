    scwin.f_openPopUpGridBefore = function(colGubun, ds, cdColid, nmColid, olddata, gubun, pWinCloseTF) {
        let row = ds.getRowPosition();
        if (colGubun == "CD") {
            let cdVal = ds.getCellData(row, cdColid);
            if (cdVal == "") {
                ds.setCellData(row, nmColid, "");
            } else {
                let nmVal = ds.getCellData(row, nmColid);
                if (nmVal != olddata) {
                    ds.setCellData(row, nmColid, "");
                    scwin.f_openPopUpGrid(ds, cdColid, nmColid, gubun, pWinCloseTF);
                }
            }
        } else if (colGubun == "NM") {
            let nmVal = ds.getCellData(row, nmColid);
            if (nmVal == "") {
                ds.setCellData(row, cdColid, "");
            } else {
                if (nmVal != olddata) {
                    ds.setCellData(row, cdColid, "");
                    scwin.f_openPopUpGrid(ds, cdColid, nmColid, gubun, pWinCloseTF);
                }
            }
        }
    };


    scwin.f_ReqFieldChk = async function() {
        if (ed_blno.getValue() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["House B/L No"]);
            ed_blno.setFocus();
            return false;
        }
        if (ed_mblno.getValue() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Master B/L No"]);
            ed_mblno.setFocus();
            return false;
        }
        if (ed_ondt.getValue() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Onboard Date"]);
            ed_ondt.setFocus();
            return false;
        }
        if (ed_avdt.getValue() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Arrival Date"]);
            ed_avdt.setFocus();
            return false;
        }
        if (!$c.gus.cfIsAfterDate(ed_ondt.getValue(), ed_avdt.getValue())) {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_048, ["Onboard Date", "Arrival Date"]);
            ed_ondt.setFocus();
            return false;
        }
        if ($c.gus.cfMonthsBetween(scwin.strCurDate, ed_ondt.getValue()) > 3) {
            await $c.win.alert("Onboard Date가 저장하는 날짜로 부터 3개월 이상의 미래일 수 없습니다.");
            ed_ondt.setFocus();
            return false;
        }
        if ($c.gus.cfMonthsBetween(scwin.strCurDate, ed_avdt.getValue()) > 3) {
            await $c.win.alert("Arrival Date가 저장하는 날짜로 부터 3개월 이상의 미래일 수 없습니다.");
            ed_avdt.setFocus();
            return false;
        }
        if ($c.gus.cfYearsBetween(ed_ondt.getValue(), scwin.strCurDate) > 3) {
            await $c.win.alert("Onboard Date가 3년 이상의 과거 일 수 없습니다.");
            ed_ondt.setFocus();
            return false;
        }
        if ($c.gus.cfYearsBetween(ed_avdt.getValue(), scwin.strCurDate) > 3) {
            await $c.win.alert("Arrival Date가 3년 이상의 과거 일 수 없습니다.");
            ed_avdt.setFocus();
            return false;
        }
        if ($c.date.diffDate(ed_ondt.getValue(), ed_avdt.getValue()) > 149) {
            await $c.win.alert("Onboard Date-Arrival Date(transit time)가 150일을 초과할 수 없습니다.");
            ed_ondt.setFocus();
            return false;
        }
        if (ed_dept.getValue().trim() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Department Info"]);
            ed_dept.setFocus();
            return false;
        }
        if (ed_sacd.getValue().trim() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Salesman Info"]);
            ed_sacd.setFocus();
            return false;
        }
        if (ed_itcd.getValue().trim() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Item Info"]);
            ed_itcd.setFocus();
            return false;
        }
        if (txt_ngnm1.getValue().trim() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["EDI Item Info"]);
            txt_ngnm1.setFocus();
            return false;
        }
        if (ed_cjdt.getValue().trim() == "" || !$c.gus.cfValidateValue(ed_cjdt.getValue().trim(), "date=YYYYMMDD")) {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Result Date Date"]);
            ed_cjdt.setFocus();
            return false;
        }
        if (ed_dept.getValue().trim() == "1GG") {
            await $c.gus.cfAlertMsg(scwin.MSG_LO_WRN_010, ["Department Info"]);
            ed_dept.setFocus();
            return false;
        }
        if (lc_contractNo.getValue() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Contract No"]);
            lc_contractNo.setFocus();
            return false;
        }
        if (ds_customerInfo.getRowCount() > 0) {
            if (ed_dept.getValue() != ds_customerInfo.getCellData(ds_customerInfo.getRowPosition(), "col1")) {
                await $c.gus.cfAlertMsg(scwin.MSG_LO_WRN_013);
                ed_dept.setFocus();
                return false;
            }
        }
        let chk = await $c.gus.cfValidate([tbl_HouseBillInfo]);
        if (!chk) { return false; }
        return true;
    };


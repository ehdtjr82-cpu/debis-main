                $c.gus.cfEnableBtnOnly([btn_Create_freight]);
                scwin.f_GridSet_freight("Init");
                break;
            case "RETRIEVE":
                $c.gus.cfDisableKeyData();
                $c.gus.cfDisableBtnOnly([btn_Save_freight, btn_Cancel_freight]);
                $c.gus.cfEnableBtnOnly([btn_Create_freight, btn_Update_freight, btn_Delete_freight]);
                scwin.f_GridSet_freight("Retrieve");
                break;
            case "CREATE":
                $c.gus.cfEnableKeyData();
                $c.gus.cfDisableBtnOnly([btn_Create_freight, btn_Update_freight, btn_Delete_freight]);
                $c.gus.cfEnableBtnOnly([btn_Save_freight, btn_Cancel_freight]);
                scwin.f_DefaultValue_freight();
                scwin.f_GridSet_freight("Create");
                break;
            case "UPDATE":
                $c.gus.cfDisableBtnOnly([btn_Update_freight, btn_Create_freight]);
                $c.gus.cfEnableBtnOnly([btn_Save_freight, btn_Delete_freight, btn_Cancel_freight]);
                $c.gus.cfEnableBtnOnly([pu_Tariff_freight, pu_exRateChange_freight, pu_CustomerChange_freight, pu_ResultdateChange_freight]);
                $c.gus.cfDisableKey();
                scwin.f_GridSet_freight("Update");
                break;
            case "SAVE":
                $c.gus.cfDisableBtnOnly([btn_Save_freight, btn_Cancel_freight]);
                $c.gus.cfEnableBtnOnly([btn_Update_freight, btn_Create_freight, btn_Delete_freight]);
                scwin.f_Set_freight("RETRIEVE");
                break;
            case "DELETE":
                $c.gus.cfDisableBtnOnly([btn_Save_freight, btn_Cancel_freight]);
                $c.gus.cfEnableBtnOnly([btn_Create_freight, btn_Update_freight, btn_Delete_freight]);
                scwin.f_Set_freight("RETRIEVE");
                break;
        }
    };


    						<xf:group style="" tagname="col"></xf:group>
    						<xf:group style="width:90px;" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    					</xf:group>
    					<xf:group class="" id="" style="" tagname="tr">
    						<xf:group class="w2tb_th " style="" tagname="th">
    							<w2:textbox class="req" id="" label="점소 " style=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" style="" tagname="td">
    							<w2:autoComplete class="" editType="select" id="acb_transKnd" search="start" style="width: 150px;"
    								submenuSize="fixed">
    							</w2:autoComplete>
    						</xf:group>
    						<xf:group class="w2tb_th" style="" tagname="th">
    							<w2:textbox class="req" id="" label="매입일자 " style=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" id="" style="" tagname="td">
    							<w2:udc_fromToCalendar refStDt="" refDataMap="" style="" id="udc_srchWrkDt"
    								refEdDt="" edFromId="ica_srchWrkStDt" edToId="ica_srchWrkEndDt">
    							</w2:udc_fromToCalendar>
    						</xf:group>

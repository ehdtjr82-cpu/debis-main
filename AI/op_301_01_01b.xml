    <script type="text/javascript"><![CDATA[
        scwin.lobranCd = "";
        scwin.hid_vehclNoCd = "";

        scwin.onpageload = async function() {
            scwin.lobranCd = $c.ses.getLobranCd();
            if (scwin.lobranCd == null) scwin.lobranCd = "";

            scwin.f_Set("INIT");
        };

        scwin.onUdcCompleted = async function() {
            scwin.f_initCombos();
        };

        scwin.f_Set = async function(gubun) {
            if (gubun == "INIT") {
                let codeOptions = [
                    { grpCd: "OP197", compID: "lc_crryInOutCd,gr_Grid1:crryinoutClsCd", opt: {"chooseOption":"true", "chooseOptionLabel":"전체"} },
                    { grpCd: "SD114", compID: "lc_selfClsCd,gr_Grid1:selfClsCd", opt: {"chooseOption":"true", "chooseOptionLabel":"전체"} },
                    { grpCd: "SD113", compID: "lc_odrKndCd", opt: {"chooseOption":"true", "chooseOptionLabel":"전체", "range":"fltrCd1=C"} },
                    { grpCd: "SD060", compID: "gr_Grid1:impExpClsCd" }
                ];
                $c.data.setCommonCode(codeOptions);

                scwin.f_loadLobranCd();
            }
        };

        scwin.f_initCombos = async function() {
            lc_lobranCd.setFocus();
        };

        scwin.f_loadLobranCd = async function() {
            await $c.sbm.execute(sbm_lobranCd);
        };

        scwin.sbm_lobranCd_submitdone = async function(e) {
            let idx = -1;
            for (let i = 0; i < ds_lobranCd.getRowCount(); i++) {
                if (ds_lobranCd.getCellData(i, "col1") == scwin.lobranCd) {
                    idx = i;
                    break;
                }
            }
            if (idx >= 0) {
                lc_lobranCd.setSelectedIndex(idx);
            }

            let lobranVal = lc_lobranCd.getValue();
            if (lobranVal != null && lobranVal != "") {
                sbm_wrkPlCd.action = "/cm.zz.RetrieveCommonPopupCMD.do?sysCd=CommonEBC&queryId=retriveWrkLobranCd&param3=" + lobranVal;
                await $c.sbm.execute(sbm_wrkPlCd);
            }
        };

        scwin.sbm_wrkPlCd_submitdone = function(e) {
            if (ds_wrkPlCd.getRowCount() > 0) {
                lc_wrkPlCd.setSelectedIndex(0);
            }
        };

        scwin.btn_retrieve_onclick = async function(e) {
            scwin.f_Retrieve();
        };

        scwin.btn_fieldClear_onclick = async function(e) {
            $c.gus.cfInitObjects(null, [ica_srchFromDate, ica_srchToDate]);
        };

        scwin.f_Retrieve = async function() {
            let chk = await $c.gus.cfValidate([lc_lobranCd, ica_srchFromDate, ica_srchToDate]);
            if (!chk) {
                return;
            }

            let fromDate = ica_srchFromDate.getValue().trim();
            let toDate = ica_srchToDate.getValue().trim();

            if (!$c.gus.cfIsAfterDate(fromDate, toDate)) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
                ica_srchFromDate.setFocus();
                return;
            }

            oGDS_view_cond.set("stDt", fromDate);
            oGDS_view_cond.set("endDt", toDate);

            await $c.sbm.execute(sbm_retrieve);
        };

        scwin.sbm_retrieve_submitdone = async function(e) {
            let rowCnt = ds_Grid1.getRowCount();
            if (rowCnt == 0) {
                await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
            }
            spa_totalRow.setValue(rowCnt);
        };

        scwin.sbm_retrieve_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.f_chkOpenCommonPopUp = async function(inObj, pairObj, disGubun, isCode) {
            if (!$c.gus.cfCanOpenPopup(inObj, pairObj)) {
                return;
            }

            $c.gus.cfClearPairObj(pairObj);

            let pVal = $c.gus.cfGetValue(inObj);

            if (isCode == null || isCode == true) {
                scwin.f_openPopUp(disGubun, pVal, "", "T", "T");
            } else {
                scwin.f_openPopUp(disGubun, "", pVal, "T", "T");
            }
        };

        scwin.f_openPopUp = async function(disGubun, pCode, pName, pClose, pAllSearch) {
            if (disGubun == "1") {
                udc_vehclShort.ilCommonPopUp(scwin.callbackVehclNo,
                    pCode,
                    pName,
                    pClose,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    pAllSearch,
                    "차량번호,차량단축코드,차량번호"
                );
            } else if (disGubun == "2") {
                udc_line.ilCommonPopUp(scwin.callbackLineCd,
                    pCode,
                    pName,
                    pClose,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    pAllSearch,
                    null
                );
            } else if (disGubun == "4") {
                udc_vssl.ilCommonPopUp(scwin.callbackVsslCd,
                    pCode,
                    pName,
                    pClose,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    null,
                    "T",
                    null
                );
            }
        };

        scwin.callbackVehclNo = function(rtnList) {
            $c.gus.cfSetReturnValue(rtnList, ed_vehclShortCd, txt_vehclNo, null);
        };

        scwin.callbackLineCd = function(rtnList) {
            $c.gus.cfSetReturnValue(rtnList, ed_lineCd, txt_lineNm, null);
        };

        scwin.callbackVsslCd = function(rtnList) {
            $c.gus.cfSetReturnValue(rtnList, ed_vsslCd, txt_vsslNm, null);
        };

        scwin.udc_vehclShort_onblurCode = async function() {
            scwin.f_chkOpenCommonPopUp(ed_vehclShortCd, txt_vehclNo, "1", true);
        };

        scwin.udc_vehclShort_onblurName = async function() {
            scwin.f_chkOpenCommonPopUp(txt_vehclNo, ed_vehclShortCd, "1", false);
        };

        scwin.udc_vehclShort_onClick = async function() {
            scwin.f_openPopUp("1", ed_vehclShortCd.getValue(), txt_vehclNo.getValue(), "F", "F");
        };

        scwin.udc_line_onblurCode = async function() {
            scwin.f_chkOpenCommonPopUp(ed_lineCd, txt_lineNm, "2", true);
        };

        scwin.udc_line_onblurName = async function() {
            scwin.f_chkOpenCommonPopUp(txt_lineNm, ed_lineCd, "2", false);
        };

        scwin.udc_line_onClick = async function() {
            scwin.f_openPopUp("2", ed_lineCd.getValue(), txt_lineNm.getValue(), "F", "F");
        };

        scwin.udc_vssl_onblurCode = async function() {
            scwin.f_chkOpenCommonPopUp(ed_vsslCd, txt_vsslNm, "4", true);
        };

        scwin.udc_vssl_onblurName = async function() {
            scwin.f_chkOpenCommonPopUp(txt_vsslNm, ed_vsslCd, "4", false);
        };

        scwin.udc_vssl_onClick = async function() {
            scwin.f_openPopUp("4", ed_vsslCd.getValue(), txt_vsslNm.getValue(), "F", "T");
        };

        scwin.lc_lobranCd_onchange = async function(e) {
            let lobranVal = lc_lobranCd.getValue();
            if (lobranVal != null && lobranVal != "") {
                sbm_wrkPlCd.action = "/cm.zz.RetrieveCommonPopupCMD.do?sysCd=CommonEBC&queryId=retriveWrkLobranCd&param3=" + lobranVal;
                await $c.sbm.execute(sbm_wrkPlCd);
            }
        };

        scwin.lc_odrKndCd_onchange = function(e) {
            let selectedVal = lc_odrKndCd.getValue();
            if (selectedVal == "C2" || selectedVal == "C4") {
                lc_selfClsCd.setDisabled(false);
            } else {
                lc_selfClsCd.setSelectedIndex(0);
                lc_selfClsCd.setDisabled(true);
            }
        };

        scwin.gr_Grid1_oncellclick = async function(rowIndex, columnIndex, columnId) {
            if (rowIndex >= 0 && columnId == "odrNo") {
                let obj = {
                    dataList: ds_Grid1,
                    rowIndex: rowIndex
                };
                await $c.win.openPopup("/ui/ds/op/wrkrslts/cywrkrslts/op_301_01_04p.xml", {
                    width: 820,
                    height: 320,
                    modal: true,
                    data: obj
                });
            }
        };

        scwin.f_dateChange = function() {
            if (ica_srchToDate.getValue().trim() == "") {
                ica_srchToDate.setValue(ica_srchFromDate.getValue());
            }
        };

        scwin.cfGrdHeiht = function(objGrdId, size) {
            let objGrd = $p.getComponentById(objGrdId);
            let strHeight = objGrd.getStyle("height");
            let intHeight = parseInt(strHeight.replace("px", ""));
            intHeight = intHeight + size;
            if (intHeight > 0) {
                objGrd.setStyle("height", intHeight + "px");
            }
        };
    ]]></script>


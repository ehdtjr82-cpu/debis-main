    <script type="text/javascript"><![CDATA[
        scwin.vCurDate = "";

        scwin.onpageload = function() {
            scwin.vCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");
            $c.gus.cfDisableObjects(tb_retrieveData);
        };

        scwin.onUdcCompleted = function() {
            udc_doIssueDd.setInitDate(scwin.vCurDate, scwin.vCurDate);
            lc_lineCd.setSelectedIndex(0);
        };

        scwin.btn_search_onclick = function(e) {
            scwin.f_Retrieve();
        };

        scwin.btn_update_onclick = function(e) {
            scwin.f_FieldClear();
        };

        scwin.f_Retrieve = async function() {
            if (!(await $c.gus.cfValidate([tb_queryList]))) {
                return;
            }
            dma_condition.set("lineCd", lc_lineCd.getValue());
            dma_condition.set("doIssueDdStDt", ica_doIssueDdStDt.getValue());
            dma_condition.set("doIssueDdEndDt", ica_doIssueDdEndDt.getValue());
            dma_condition.set("doNo", ed_doNo.getValue().trim());
            dma_condition.set("mrn", ed_mrn.getValue().trim());
            dma_condition.set("cntrNo", ed_cntrNo.getValue().trim());
            dma_condition.set("dchrPort", ed_dchrPort.getValue().trim());
            await $c.sbm.execute(sbm_retrieve);
        };

        scwin.sbm_retrieve_submitdone = async function(e) {
            let rowCnt = ds_list.getRowCount();
            if (rowCnt == 0) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_003);
                return;
            } else {
                totalRowsGrid1.setValue(rowCnt);
            }
        };

        scwin.sbm_retrieve_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.f_Update = function() {
            $c.gus.cfEnableObjects([ed_cntrCrryoutCloseDt, ed_cntrRtrnDt, txt_selfYn, txt_transCoId]);
        };

        scwin.f_Save = async function() {
            if (!(await $c.gus.cfValidate([ed_cntrCrryoutCloseDt, txt_transCoId, txt_selfYn]))) {
                return;
            }
            let chk = await $c.win.confirm("저장하시겠습니까?");
            if (chk) {
                let curRow = ds_list.getRowPosition();
                if (ds_List2.getRowCount() == 0) {
                    ds_List2.insertRow(0);
                }
                ds_List2.setCellData(0, "cntrCrryoutCloseDt", ds_list.getCellData(curRow, "cntrCrryoutCloseDt"));
                ds_List2.setCellData(0, "cntrRtrnDt", ds_list.getCellData(curRow, "cntrRtrnDt"));
                ds_List2.setCellData(0, "doNo", ds_list.getCellData(curRow, "doNo"));
                ds_List2.setCellData(0, "cntrNo", ds_list.getCellData(curRow, "cntrNo"));
                ds_List2.setCellData(0, "selfYn", ds_list.getCellData(curRow, "selfYn"));
                ds_List2.setCellData(0, "transCoId", ds_list.getCellData(curRow, "transCoId"));
                await $c.sbm.execute(sbm_update);
            }
        };

        scwin.sbm_update_submitdone = async function(e) {
            await $c.gus.cfAlertMsg(MSG_CM_INF_001);
            $c.gus.cfDisableObjects(tb_retrieveData);
        };

        scwin.sbm_update_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.f_FieldClear = function() {
            $c.gus.cfInitObjects(tb_queryList, null);
            udc_doIssueDd.setInitDate(scwin.vCurDate, scwin.vCurDate);
            lc_lineCd.setSelectedIndex(0);
        };
    ]]></script>


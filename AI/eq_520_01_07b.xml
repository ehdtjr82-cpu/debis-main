    <script type="text/javascript"><![CDATA[
        scwin.vCurDate = "";
        scwin.vMonthFirstDate = "";
        scwin.eqHomeClsCd = "";
        scwin.fixWrkPlCd = "";

        scwin.onpageload = async function() {
            scwin.vCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");
            scwin.vMonthFirstDate = scwin.vCurDate.substring(0, 6) + "01";
            scwin.eqHomeClsCd = $c.ses.getEqHomeClsCd();
            scwin.fixWrkPlCd = $c.ses.getFixWrkPlCd();

            dma_search.set("tranDtFrom", scwin.vMonthFirstDate);
            dma_search.set("tranDtTo", scwin.vCurDate);

            scwin.f_defaultValue();
        };

        scwin.onUdcCompleted = function() {
            udc_tranDt.setInitDate(scwin.vMonthFirstDate, scwin.vCurDate);
        };

        scwin.f_defaultValue = async function() {
            if (scwin.eqHomeClsCd != null && scwin.eqHomeClsCd != "" && scwin.eqHomeClsCd != "null") {
                lc_homeClsCd.setValue(scwin.eqHomeClsCd);
            } else {
                lc_homeClsCd.setSelectedIndex(0);
            }
            scwin.f_RetrieveFixWrkPl(lc_homeClsCd.getValue());
            lc_homeClsCd.setFocus();
        };

        scwin.f_FieldClear = function() {
            $c.gus.cfInitObjects(tb_eq430, null);
        };

        scwin.f_Retrieve = async function() {
            let chk = await $c.gus.cfValidate([lc_homeClsCd, lc_fixWrkPlCd, udc_tranDt]);
            if (!chk) return;

            let tranDtFrom = udc_tranDt.getFromValue();
            let tranDtTo = udc_tranDt.getToValue();

            if (!$c.gus.cfIsAfterDate(tranDtFrom, tranDtTo)) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
                udc_tranDt.setFocusFrom();
                return;
            }

            dma_search.set("homeClsCd", lc_homeClsCd.getValue());
            dma_search.set("wrkPlCd", lc_fixWrkPlCd.getValue());
            dma_search.set("tranDtFrom", tranDtFrom);
            dma_search.set("tranDtTo", tranDtTo);

            await $c.sbm.execute(sbm_retrieve);
        };

        scwin.f_RetrieveFixWrkPl = async function(homeClsCd) {
            sbm_retrieveFixWrkPl.action = "/cm.zz.RetrieveComboCMD.do?sysCd=PsCommonEBC&queryId=retriveWrkplList&param1=" + homeClsCd;
            await $c.sbm.execute(sbm_retrieveFixWrkPl);
        };

        scwin.f_OzReport = async function() {
            let chk = await $c.gus.cfValidate([lc_homeClsCd, lc_fixWrkPlCd, udc_tranDt]);
            if (!chk) return;

            let tranDtFrom = udc_tranDt.getFromValue();
            let tranDtTo = udc_tranDt.getToValue();

            if (!$c.gus.cfIsAfterDate(tranDtFrom, tranDtTo)) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
                udc_tranDt.setFocusFrom();
                return;
            }

            let odiParam = new ODIParam("eq_520_01_07");
            odiParam.add("homeClsCd", lc_homeClsCd.getValue());
            odiParam.add("homeClsNm", lc_homeClsCd.getText());
            odiParam.add("wrkPlCd", lc_fixWrkPlCd.getValue());
            odiParam.add("wrkPlNm", lc_fixWrkPlCd.getText());
            odiParam.add("tranDtFrom", tranDtFrom);
            odiParam.add("tranDtTo", tranDtTo);

            let formParam = new FormParam();

            let viewerParam = new ViewerParam();
            viewerParam.add("viewer.useprogressbar", "false");

            $c.gus.cfOZReport("chb_printCheck", "chb_previewCheck", "/ps/eq/adjmmgnt/matprscond/eq_520_01_07.ozr", odiParam, viewerParam, formParam);
        };

        scwin.f_Excel = async function() {
            let chk = await $c.gus.cfValidate([lc_homeClsCd, lc_fixWrkPlCd, udc_tranDt]);
            if (!chk) return;

            let tranDtFrom = udc_tranDt.getFromValue();
            let tranDtTo = udc_tranDt.getToValue();

            if (!$c.gus.cfIsAfterDate(tranDtFrom, tranDtTo)) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
                udc_tranDt.setFocusFrom();
                return;
            }

            let count = ds_eq430.getRowCount();
            if (count > 0) {
                $c.data.downloadGridViewExcel(gr_eq430, {
                    fileName: "기간별 자가재고이관 내역 조회.xlsx",
                    sheetName: "기간별 자가재고이관 내역 조회"
                });
            } else {
                await $c.gus.cfAlertMsg(MSG_CM_WRN_018, ['[기간별 자가재고이관 내역 조회] 자료', '[조회]']);
            }
        };

        scwin.btn_retrieve_onclick = function(e) {
            scwin.f_Retrieve();
        };

        scwin.btn_ozReport_onclick = function(e) {
            scwin.f_OzReport();
        };

        scwin.lc_homeClsCd_onchange = function(e) {
            let luxIndex = lc_homeClsCd.getValue();
            scwin.f_RetrieveFixWrkPl(luxIndex);
        };

        scwin.sbm_retrieve_submitdone = function(e) {
        };

        scwin.sbm_retrieve_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.sbm_retrieveHomeClsList_submitdone = function(e) {
            let choicesArr = [];
            for (let i = 0; i < ds_homeClsList.getRowCount(); i++) {
                choicesArr.push({
                    label: ds_homeClsList.getCellData(i, "name"),
                    value: ds_homeClsList.getCellData(i, "code")
                });
            }
            lc_homeClsCd.setChoices(choicesArr);
            scwin.f_defaultValue();
        };

        scwin.sbm_retrieveFixWrkPl_submitdone = function(e) {
            let choicesArr = [];
            for (let i = 0; i < ds_fixWrkPl.getRowCount(); i++) {
                choicesArr.push({
                    label: ds_fixWrkPl.getCellData(i, "name"),
                    value: ds_fixWrkPl.getCellData(i, "code")
                });
            }
            lc_fixWrkPlCd.setChoices(choicesArr);

            if (scwin.fixWrkPlCd != null && scwin.fixWrkPlCd != "" && scwin.fixWrkPlCd != "null") {
                lc_fixWrkPlCd.setValue(scwin.fixWrkPlCd);
                scwin.fixWrkPlCd = "";
            }
            if (lc_fixWrkPlCd.getSelectedIndex() == -1) {
                lc_fixWrkPlCd.setSelectedIndex(0);
            }
        };

        scwin.ds_eq430_onloadcompleted = async function(e) {
            let rowCnt = ds_eq430.getRowCount();
            spa_totalRow.setValue(rowCnt);
            if (rowCnt == 0) {
                await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
            }
        };
    ]]></script>


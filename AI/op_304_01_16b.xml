                </w2:columnInfo>
            </w2:dataList>
        </w2:dataCollection>

        <w2:workflowCollection></w2:workflowCollection>

        <xf:submission id="sbm_retrieve"
            action="/ds.op.wrkrslts.transwrkrslts.RetrieveChassisMovePresentConditionCMD.do"
            method="post"
            mediatype="application/json"
            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"dma_chassisCond","key":"IN_DS1"},{"id":"ds_chassisPresent","key":"OUT_DS1"}]'
            target='data:json,[{"id":"ds_chassisPresent","key":"OUT_DS1"}]'
            ev:submitdone="scwin.sbm_retrieve_submitdone"
            ev:submiterror="scwin.sbm_retrieve_submiterror">
        </xf:submission>
    </xf:model>

    <w2:layoutInfo></w2:layoutInfo>
    <w2:publicInfo method=""></w2:publicInfo>

    <script type="text/javascript"><![CDATA[

    scwin.onpageload = function() {
        scwin.vCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");
        txt_chassisNo.setFocus();
        scwin.f_control();
    };

    scwin.onUdcCompleted = function() {
        udc_Dt.setInitDate(scwin.vCurDate, scwin.vCurDate);
    };

    scwin.f_control = function() {
        if (chb_chkYn.getValue() != "") {
            udc_Dt.setVisible(true);
        } else {
            udc_Dt.setVisible(false);
        }
    };

    scwin.chb_chkYn_onchange = function(e) {
        scwin.f_control();
    };

    scwin.f_Retrieve = async function() {
        let chk = await $c.gus.cfValidate([txt_chassisNo]);
        if (!chk) {
            return;
        }

        if (chb_chkYn.getValue() != "") {
            let chk2 = await $c.gus.cfValidate([ica_stDt, ica_endDt]);
            if (!chk2) {
                return;
            }

            if (!$c.gus.cfIsAfterDate(ica_stDt.getValue(), ica_endDt.getValue())) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
                return;
            }

            if ($c.date.diffDate(ica_stDt.getValue(), ica_endDt.getValue()) > 370) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_041, ["조회기간", "1년이상"]);
                ica_stDt.setFocus();
                return;
            }
        }

        dma_chassisCond.set("chassisNo", txt_chassisNm.getValue());
        dma_chassisCond.set("chk", chb_chkYn.getValue() != "" ? "1" : "0");
        dma_chassisCond.set("stDt", ica_stDt.getValue());
        dma_chassisCond.set("endDt", ica_endDt.getValue());

        await $c.sbm.execute(sbm_retrieve);
    };

    scwin.sbm_retrieve_submitdone = async function(e) {
        $c.gus.cfHideDSWaitMsg(gr_cntrWrkRslts);
        let rowCnt = ds_chassisPresent.getRowCount();
        if (rowCnt == 0) {
            await $c.gus.cfAlertMsg(MSG_CM_WRN_002, [""]);
        }
        $c.gus.cfShowTotalRows(spa_totalRow, rowCnt);
    };

    scwin.sbm_retrieve_submiterror = function(e) {
        $c.gus.cfHideDSWaitMsg(gr_cntrWrkRslts);
        $c.gus.cfShowError(e);
    };

    scwin.f_openPopUp = function(disGubun, pCode, pName, pClose, pAllSearch) {
        udc_chassis.ilCommonPopUp(scwin.callbackChassis,
            pCode,
            pName,
            pClose,
            null,
            null,
            null,
            null,
            null,
            null,
            null,
            null,
            null,
            null,
            pAllSearch,
            "샤시번호,샤시코드,샤시명");
    };

    scwin.callbackChassis = function(rtnList) {
        $c.gus.cfSetReturnValue(rtnList, txt_chassisNo, txt_chassisNm);
    };

    scwin.f_chkOpenCommonPopUp = function(inObj, pairObj, disGubun, isCode) {
        if (!$c.gus.cfCanOpenPopup(inObj, pairObj)) {
            return;
        }

        $c.gus.cfClearPairObj(pairObj);

        let pVal = $c.gus.cfGetValue(inObj);

        if (isCode == null || isCode == true) {
            scwin.f_openPopUp(disGubun, pVal, "", "T", "T");
        } else {
            scwin.f_openPopUp(disGubun, "", pVal, "T", "T");
        }
    };

    scwin.txt_chassisNo_onblur = function(e) {
        scwin.f_chkOpenCommonPopUp(txt_chassisNo, txt_chassisNm, "1");
    };

    scwin.txt_chassisNm_onchange = function(e) {
        scwin.f_chkOpenCommonPopUp(txt_chassisNm, txt_chassisNo, "", false);
    };

    scwin.btn_retrieve_onclick = function(e) {
        scwin.f_Retrieve();
    };

    scwin.btn_fieldClear_onclick = function(e) {
        scwin.f_Reset();
    };

    scwin.f_Reset = function() {
        $c.gus.cfInitObjects([txt_chassisNo, txt_chassisNm, chb_chkYn, ica_stDt, ica_endDt]);
        scwin.f_control();
    };

    scwin.f_toExcel = function() {
        $c.data.downloadGridViewExcel(gr_cntrWrkRslts, {
            fileName: "샤시이동현황.xlsx",
            sheetName: "샤시이동현황"
        });
    };

    ]]></script>


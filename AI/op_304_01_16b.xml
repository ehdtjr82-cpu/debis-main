                <w2:keyInfo>
                    <w2:key id="chassisNo" name="샤시번호" dataType="text"></w2:key>
                    <w2:key id="chk" name="기간조회여부" dataType="text"></w2:key>
                    <w2:key id="stDt" name="시작일자" dataType="text"></w2:key>
                    <w2:key id="endDt" name="종료일자" dataType="text"></w2:key>
                </w2:keyInfo>
            </w2:dataMap>

            <w2:dataList baseNode="list" repeatNode="map" id="ds_chassisPresent" saveRemovedData="true">
                <w2:columnInfo>
                    <w2:column id="wrkStpNm" name="작업단계" dataType="text"></w2:column>
                    <w2:column id="vehclNo" name="차량번호" dataType="text"></w2:column>
                    <w2:column id="clntNm" name="협력업체" dataType="text"></w2:column>
                    <w2:column id="odrNo" name="오더번호" dataType="text"></w2:column>
                    <w2:column id="cntrNo" name="컨테이너번호" dataType="text"></w2:column>
                    <w2:column id="dptWrkPlNm" name="출발지" dataType="text"></w2:column>
                    <w2:column id="arvWrkPlNm" name="도착지" dataType="text"></w2:column>
                    <w2:column id="dptDtm" name="출발일시" dataType="text"></w2:column>
                    <w2:column id="arvDtm" name="도착일시" dataType="text"></w2:column>
                    <w2:column id="wrkStsNm" name="작업상태" dataType="text"></w2:column>
                    <w2:column id="len" name="장비길이" dataType="text"></w2:column>
                    <w2:column id="nrm" name="장비규격" dataType="text"></w2:column>

            ev:submiterror="scwin.sbm_retrieve_submiterror">
        </xf:submission>

        <xf:submission id="sbm_create"
            action="/ds.op.wrkrslts.transwrkrslts.CreateBoralSalesCostCMD.do"
            method="post"
            mediatype="application/json"
            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"ds_search","key":"IN_DS1"},{"id":"ds_out","key":"OUT_DS1"}]'

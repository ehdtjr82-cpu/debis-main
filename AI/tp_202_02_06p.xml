            mediatype="application/json"
            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"ds_Query","key":"IN_DS1"},{"id":"ds_outInfo","key":"OUT_DS1"}]'
            target='data:json,[{"id":"ds_outInfo","key":"OUT_DS1"}]'

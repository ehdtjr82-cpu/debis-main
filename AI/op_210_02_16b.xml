    <script type="text/javascript"><![CDATA[
        scwin.v_workClsCd = "";
        scwin.bOnPopUp = false;
        scwin.vCurDate = "";
        scwin.vwrkStDt = "";
        scwin.vwrkEndDt = "";
        scwin.lobranCd = "";
        scwin.ed_staffNo = "";
        scwin.txt_staffNm = "";

        scwin.onpageload = function() {
            scwin.vCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");
            scwin.vwrkStDt = scwin.vCurDate.substring(0, 6) + "01";
            scwin.vwrkEndDt = scwin.vCurDate.substring(0, 6) + $c.date.getLastDate(scwin.vCurDate);
            scwin.lobranCd = $c.ses.getLobranCd();

            scwin.f_SetDefaultData();
        };

        scwin.f_SetDefaultData = function() {
            ed_wrkDt.setValue(scwin.vCurDate.substring(0, 6));
            lc_lobranCd.setValue(scwin.lobranCd);
            lc_occpgrdCd.setValue("01");
            lc_lobranCd.setFocus();
        };

        scwin.f_Retrieve = async function() {
            let chk = await $c.gus.cfValidate([lc_lobranCd, ed_wrkDt]);
            if (!chk) {
                return;
            }
            await $c.sbm.execute(sbm_retrieve);
        };

        scwin.sbm_retrieve_submitdone = async function(e) {
            if (ds_man.getRowCount() == 0) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_003);
            }
        };

        scwin.sbm_retrieve_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.f_widthEx = function() {
            gr_manCrs.setColumnWidth("vsslNm_", 120);
            gr_manCrs.setColumnWidth("mgntCommNm_", 80);
            gr_manCrs.setColumnWidth("workHh_", 80);
            gr_manCrs.setColumnWidth("berthNm_", 100);
            gr_manCrs.setColumnWidth("etcfee1_", 70);
            gr_manCrs.setColumnWidth("rmk_", 90);
            gr_manCrs.setColumnWidth("spcRmk_", 90);
            gr_manCrs.setColumnWidth("mgntCommCd_", 65);
            gr_manCrs.setColumnWidth("cont_", 60);
        };

        scwin.f_widthGr = function() {
            gr_manCrs.setColumnWidth("vsslNm_", 80);
            gr_manCrs.setColumnWidth("mgntCommNm_", 60);
            gr_manCrs.setColumnWidth("workHh_", 80);
            gr_manCrs.setColumnWidth("berthNm_", 70);
            gr_manCrs.setColumnWidth("etcfee1_", 65);
            gr_manCrs.setColumnWidth("rmk_", 65);
            gr_manCrs.setColumnWidth("spcRmk_", 65);
            gr_manCrs.setColumnWidth("mgntCommCd_", 65);
            gr_manCrs.setColumnWidth("cont_", 40);
        };

        scwin.f_gridToExcel = function(argGrid, argTitle) {
            let vDay = "점소 : " + lc_lobranCd.getText() + " / "
                     + "구분 : " + lc_occpgrdCd.getText() + " / "
                     + "작업일자 : " + ed_wrkDt.getValue();
            $c.data.downloadGridViewExcel(argGrid, {
                fileName: argTitle + ".xlsx",
                sheetName: argTitle,
                title: argTitle,
                subTitle: vDay
            });
        };

        scwin.f_openCommonPopUp = async function(disGubun, pCode, pName, pClose, pAllSearch) {
            let rtnList;

            switch (disGubun) {
                case 1:
                    let arrParam = {
                        param0: pCode,
                        param1: pName,
                        param2: lc_lobranCd.getValue(),
                        param3: lc_lobranCd.getText(),
                        param4: "",
                        param5: "",
                        param6: lc_dtlOccptypeCd.getValue(),
                        param7: "",
                        param8: "",
                        param9: "",
                        param10: "T",
                        param11: "1"
                    };

                    rtnList = await $c.win.openPopup("/ui/ds/op/rscconfirm/manpwrrscconfirm/op_103_01_10p.xml", {
                        width: 530,
                        height: 450,
                        modal: true,
                        data: arrParam
                    });

                    if (rtnList != null) {
                        scwin.ed_staffNo = rtnList[2];
                        scwin.txt_staffNm = rtnList[3];
                        return;
                    } else {
                        scwin.ed_staffNo = "";
                        scwin.txt_staffNm = "";
                        return;
                    }
                    break;
            }
        };

        scwin.f_InitObjects = function() {
            $c.gus.cfInitObjects(tb_mainData);
            scwin.f_SetDefaultData();
        };

        scwin.btn_fieldClear_onclick = function(e) {
            scwin.f_InitObjects();
        };

        scwin.btn_retrieve_onclick = function(e) {
            scwin.f_Retrieve();
        };
    ]]></script>


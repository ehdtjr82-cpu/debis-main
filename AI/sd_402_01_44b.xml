            </w2:dataMap>

            <w2:dataList baseNode="list" repeatNode="map" id="ds" saveRemovedData="true">
                <w2:columnInfo>
                    <w2:column id="dummy" name="" dataType="text"></w2:column>
                </w2:columnInfo>
            </w2:dataList>

            <w2:dataList baseNode="list" repeatNode="map" id="ds_crdtInfo" saveRemovedData="true">
                <w2:columnInfo>
                    <w2:column id="bilgClntNm" name="청구처명" dataType="text"></w2:column>

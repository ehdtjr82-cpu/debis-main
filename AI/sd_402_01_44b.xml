                    <w2:column id="sellCommNo" name="컨테이너번호" dataType="text"></w2:column>
                    <w2:column id="commNm" name="품명" dataType="text"></w2:column>
                    <w2:column id="selpchItemNm" name="매출항목명" dataType="text"></w2:column>

    <w2:layoutInfo></w2:layoutInfo>
    <w2:publicInfo method=""></w2:publicInfo>

    <script type="text/javascript"><![CDATA[
scwin.saveYn = "N";
scwin.retrieveYn = "N";

scwin.onpageload = function() {
    scwin.f_Set("INIT");
};

scwin.onUdcCompleted = function() {
    scwin.f_FieldClear();

    scwin.params = $c.data.getParameter();
    if (scwin.params != null && !$c.gus.cfIsNull(scwin.params["bilgClntNo"])) {
        ed_bilgClntNo.setValue(scwin.params["bilgClntNo"].trim());

        gr_crdtInfo.setStyle("height", "180px");

        if (ed_bilgClntNo.getValue() != "") {
            $c.gus.cfDisableObjects([ed_bilgClntNo]);
            scwin.f_Retrieve();
        }
    }
};

scwin.f_Set = function(gubun) {
    switch (gubun) {
        case "INIT":
            break;
    }
};

scwin.f_FieldClear = function() {
    $c.gus.cfInitObjects(tbl_searchArea, null);
};

scwin.f_Retrieve = async function() {
    if (ed_bilgClntNo.getValue().trim() == "") {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_002, ["청구처번호"]);
        return;
    }

    if (await $c.gus.cfValidate([tbl_searchArea])) {
        dma_clntInfo.set("bilgClntNo", ed_bilgClntNo.getValue().trim());

        scwin.retrieveYn = "Y";
        await $c.sbm.execute(sbm_retrieve);
    }
};

scwin.btn_retrieve_onclick = function(e) {
    scwin.f_Retrieve();
};

scwin.btn_close_onclick = function(e) {
    scwin.f_Close();
};

scwin.f_Close = function() {
    let arrRtnVal = [];
    arrRtnVal[0] = "N/A";
    arrRtnVal[1] = scwin.saveYn;
    $c.win.closePopup(arrRtnVal);
};

scwin.f_openCommonPopUp = function(disGubun, pCode, pName, pClose, pAllSearch) {
    let rtnList = [];
    let pWhere = "";

    switch (disGubun) {
        case 1:
            udc_bilgClnt.ilCommonPopUp(scwin.callbackBilgClnt,
                pCode,
                pName,
                pClose,
                null,
                null,
                null,
                null,
                null,
                null,
                null,
                null,
                null,
                null,
                pAllSearch,
                "청구 거래처,거래처코드,거래처명"
            );
            break;
        default:
            break;
    }
};

scwin.callbackBilgClnt = function(rtnList) {
    $c.gus.cfSetReturnValue(rtnList, ed_bilgClntNo, txt_bilgClntNm);
};

scwin.f_chkOpenCommonPopUp = function(inObj, pairObj, disGubun, isCode) {
    if (!$c.gus.cfCanOpenPopup(inObj, pairObj)) {
        return;
    }

    $c.gus.cfClearPairObj(pairObj);

    let pVal = $c.gus.cfGetValue(inObj);

    if (isCode == null || isCode == true) {
        scwin.f_openCommonPopUp(disGubun, pVal, '', 'T', 'T');
    } else {
        scwin.f_openCommonPopUp(disGubun, '', pVal, 'T', 'T');
    }
};

scwin.ed_bilgClntNo_onblur = function(e) {
    scwin.f_chkOpenCommonPopUp(ed_bilgClntNo, txt_bilgClntNm, 1, true);
};

scwin.ed_bilgClntNo_onkeyup = function(e) {
    if (e.keyCode == 13) {
        scwin.f_Retrieve();
    }
};

scwin.txt_bilgClntNm_onchange = function(e) {
    scwin.f_chkOpenCommonPopUp(txt_bilgClntNm, ed_bilgClntNo, 1, false);
};

scwin.sbm_retrieve_submitdone = async function(e) {
    let rowCnt = ds_crdtInfo.getRowCount();
    if (rowCnt == 0) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_003, ["조회결과"]);
    }

    spa_totalRow.setValue(rowCnt);

    scwin.retrieveYn = "N";
};

scwin.sbm_retrieve_submiterror = function(e) {
    $c.gus.cfShowError(e);
};

scwin.ds_crdtInfo_onrowpositionchange = function(rowIndex, oldRowIndex) {
    // 원본 OnRowPosChanged(row) 이벤트 블록이 빈 코드이므로 빈 핸들러 유지
};

scwin.gr_crdtInfo_ontextimageclick = function(rowIndex, columnIndex) {
    // 원본 OnPopup(row,colid,data) 이벤트 블록이 빈 코드이므로 빈 핸들러 유지
};

scwin.gr_crdtInfo_oncellclick = function(rowIndex, columnIndex, columnId) {
    // 원본 OnClick(row,colid) 이벤트 블록이 빈 코드이므로 빈 핸들러 유지
};
    ]]></script>


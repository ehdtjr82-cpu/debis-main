        <w2:workflowCollection></w2:workflowCollection>

        <xf:submission id="sbm_retrieve"
            action="/ds.sd.odrmgnt.odrreg.RetrieveClntCrdtInformationListCMD.do"
            method="post"
            mediatype="application/json"
            mode="asynchronous"
            encoding="UTF-8"
            ref='data:json,[{"id":"dma_clntInfo","key":"IN_DS1"},{"id":"ds_crdtInfo","key":"OUT_DS1"}]'
            target='data:json,[{"id":"ds_crdtInfo","key":"OUT_DS1"}]'
            ev:submitdone="scwin.sbm_retrieve_submitdone"
            ev:submiterror="scwin.sbm_retrieve_submiterror">
        </xf:submission>

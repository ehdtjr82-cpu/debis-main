<head>
    <w2:type>COMPONENT</w2:type>

    <xf:model>
        <w2:dataCollection baseNode="map">
            <w2:dataMap baseNode="map" id="dma_clntInfo">
                <w2:keyInfo>
                    <w2:key id="bilgClntNo" name="청구처번호" dataType="text"></w2:key>

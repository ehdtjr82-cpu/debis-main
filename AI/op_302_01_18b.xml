                    <w2:key id="odrNo" name="오더번호" dataType="text"></w2:key>
                </w2:keyInfo>
            </w2:dataMap>

            <w2:dataList baseNode="list" repeatNode="map" id="ds_retrieve" saveRemovedData="true">
                <w2:columnInfo>
                    <w2:column id="sndClsCdChk" name="선택" dataType="text"></w2:column>
                    <w2:column id="odrNo" name="오더번호" dataType="text"></w2:column>
                    <w2:column id="crryinoutClsCd" name="입출고구분" dataType="text"></w2:column>
                    <w2:column id="crryinoutDeclarNo" name="반출입신고번호" dataType="text"></w2:column>
                    <w2:column id="mrn" name="화물관리번호" dataType="text"></w2:column>
                    <w2:column id="msn" name="화물관리번호" dataType="text"></w2:column>
                    <w2:column id="hsn" name="화물관리번호" dataType="text"></w2:column>
                    <w2:column id="cargoMgntNo" name="화물관리번호" dataType="text"></w2:column>

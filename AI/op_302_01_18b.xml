                    <w2:column id="crryinoutPatternCd" name="반입유형" dataType="text"></w2:column>
                    <w2:column id="blNo" name="B/L번호" dataType="text"></w2:column>
                    <w2:column id="crryinoutCnt" name="출고갯수" dataType="text"></w2:column>
                    <w2:column id="crryinoutWt" name="출고중량" dataType="text"></w2:column>
                    <w2:column id="sndDt" name="전송일자" dataType="text"></w2:column>
                    <w2:column id="sndClsCd" name="전송구분" dataType="text"></w2:column>

    <script type="text/javascript"><![CDATA[
        scwin.vCurDate = "";

        scwin.onpageload = async function() {
            scwin.vCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");
        };

        scwin.onUdcCompleted = async function() {
            scwin.f_defaultValue();
            txt_dptWrkPlNm.setFocus();
        };

        scwin.f_defaultValue = async function() {
            udc_DtHh.setInitDate(scwin.vCurDate, scwin.vCurDate);
            rd_frtCarClsCd.setValue("");
        };

        scwin.btn_retrieve_onclick = async function(e) {
            scwin.f_Retrieve();
        };

        scwin.f_Retrieve = async function() {
            if (!$c.gus.cfIsAfterDate(ica_dptDtHh.getValue(), ica_arvDtHh.getValue())) {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_048, new Array("작업일자 From", "작업일자 To"));
                ica_dptDtHh.setFocus();
                return false;
            }
            if (!(await scwin.f_reqFieldChk())) return false;
            let strAction = "/ds.op.wrkrslts.railroadwrkrslts.RetrieveStationEachRailroadResultsCMD.do";
            sbm_retrieve.action = strAction;
            await $c.sbm.execute(sbm_retrieve);
        };

        scwin.f_retrieve2 = async function() {
            await $c.sbm.execute(sbm_retrieve2);
        };

        scwin.f_railroadResultsExcel = async function() {
            $c.data.downloadGridViewExcel(gr_railroadResults, {"fileName":"역별처리현황.xlsx", "sheetName":"역별처리현황"});
        };

        scwin.f_railroadTotalCountExcel = async function() {
            $c.data.downloadGridViewExcel(gr_railroadTotCnt, {"fileName":"역별처리현황.xlsx", "sheetName":"역별처리현황"});
        };

        scwin.f_reqFieldChk = async function() {
            if (ica_dptDtHh.getValue().trim() == "") {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_002, new Array("작업일자 From"));
                return false;
            }
            if (ica_arvDtHh.getValue().trim() == "") {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_002, new Array("작업일자 To"));
                return false;
            }
            let chk = await $c.gus.cfValidate([ica_dptDtHh, ica_arvDtHh]);
            if (!chk) {
                return false;
            }
            return true;
        };

        scwin.f_chkOpenCommonPopUp = async function(inObj, pairObj, disGubun, isCode) {
            if (!$c.gus.cfCanOpenPopup(inObj, pairObj))
                return;
            $c.gus.cfClearPairObj(pairObj);
            let pVal = $c.gus.cfGetValue(inObj);
            if (isCode == null || isCode == true)
                scwin.f_openCommonPopUp(disGubun, pVal, '', 'T', 'T');
            else
                scwin.f_openCommonPopUp(disGubun, '', pVal, 'T', 'T');
        };

        scwin.f_openCommonPopUp = async function(disGubun, pCode, pName, pClose, pAllSearch) {
            let rtnList;
            switch (disGubun) {
                case 1:
                    udc_dptWrkPl.ilCommonPopUp(scwin.callbackDptWrkPl,
                        pCode,
                        pName,
                        pClose,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        pAllSearch,
                        "출발역조회,출발역명코드,출발역명");
                    break;
                case 2:
                    udc_arvWrkPl.ilCommonPopUp(scwin.callbackArvWrkPl,
                        pCode,
                        pName,
                        pClose,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        null,
                        pAllSearch,
                        "도착역명조회,도착역명코드,도착역명");
                    break;
            }
        };

        scwin.callbackDptWrkPl = async function(rtnList) {
            $c.gus.cfSetReturnValue(rtnList, txt_dptWrkPlCd, txt_dptWrkPlNm);
        };

        scwin.callbackArvWrkPl = async function(rtnList) {
            $c.gus.cfSetReturnValue(rtnList, txt_arvWrkPlCd, txt_arvWrkPlNm);
        };

        scwin.f_crryInOutEDI = async function(bAlertFlag, bSaveFlag, bTransferFlag, row, bDeleteFlag) {
            if (ds_railroadResults.getRowCount() == 0) {
                return;
            }

            if ($c.gus.cfIsNull(ds_railroadResults.getCellData(row, "dptWrkPlCd")) || $c.gus.cfIsNull(ds_railroadResults.getCellData(row, "arvWrkPlCd"))) {
                await $c.gus.cfAlertMsg("컨테이너정보를 선택하십시오.");
                return;
            }

            let rtnList = new Array();
            let arrParam = new Array();

            arrParam[0] = new Array(
                "",
                ds_railroadResults.getCellData(row, "transWrkIndictNo"),
                ds_railroadResults.getCellData(row, "odrNo"),
                ds_railroadResults.getCellData(row, "cntrSeq"),
                ds_railroadResults.getCellData(row, "odrWrkPathSeq"),
                ds_railroadResults.getCellData(row, "odrWrkStpSeq"),
                "",
                "",
                "",
                ds_railroadResults.getCellData(row, "wrkStDt"),
                ds_railroadResults.getCellData(row, "wrkEndDt"),
                ds_railroadResults.getCellData(row, "cntrNo"),
                ds_railroadResults.getCellData(row, "dptWrkPlCd"),
                ds_railroadResults.getCellData(row, "arvWrkPlCd"),
                ds_railroadResults.getCellData(row, "dptWrkPlNm"),
                ds_railroadResults.getCellData(row, "arvWrkPlNm"),
                "CO",
                "CO"
            );

            let pURL = "/ui/ds/op/wrkplan/transwrkplan/op_202_02_21p.xml";
            let obj = {
                paramTitle: "반출입예정정보EDI등록",
                crryoutEdiType: "CO",
                crryinEdiType: "CO",
                arrParam: arrParam
            };
            rtnList = await $c.win.openPopup(pURL, {
                width: 820,
                height: 660,
                modal: true,
                data: obj
            });

            return true;
        };

        scwin.btn_fieldClear_onclick = async function(e) {
            scwin.f_FieldClear();
        };

        scwin.f_FieldClear = async function() {
            $c.gus.cfInitObjects([txt_dptWrkPlCd, txt_arvWrkPlCd, txt_dptWrkPlNm, txt_arvWrkPlNm, txt_transWrkIndictNo]);
            scwin.f_defaultValue();
        };

        scwin.btn_carryingInOutEDI_onclick = async function(e) {
            scwin.f_crryInOutEDI(true, false, false, ds_railroadResults.getRowPosition(), false);
        };

        scwin.sbm_retrieve_submitdone = async function(e) {
            if (ds_railroadResults.getRowCount() == 0) {
                await $c.win.alert("조회된 데이터가 없습니다.");
            } else {
                await scwin.f_retrieve2();
            }
            // TODO: subsum RealCount 로직 — GAUCE SubsumExpr/RealCount는 WebSquare에서 직접 지원하지 않음
            spa_totalRow.setValue(ds_railroadResults.getTotalRow());
        };

        scwin.sbm_retrieve_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.sbm_retrieve2_submitdone = function(e) {
            spa_totalRow2.setValue(ds_railroadTotCnt.getTotalRow());
        };

        scwin.sbm_retrieve2_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.gr_railroadResults_oncellclick = function(rowIndex, columnIndex, columnId) {
            // TODO: GAUCE SubsumExpr/SortExpr 동적 변경은 WebSquare에서 직접 지원하지 않음
            if (rowIndex >= 0) return;
            if (columnId == "dptDtHh") {
                ds_railroadResults.sort("dptDt", "asc");
            } else {
                ds_railroadResults.sort("dptWrkPlNm", "asc");
            }
        };
    ]]></script>


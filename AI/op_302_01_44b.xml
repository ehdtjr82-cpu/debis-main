    					<w2:gBody id="gBody1" style="">
    						<w2:row id="row2" style="">
    							<w2:column displayMode="label" id="wrkPlCd" inputType="text" width="100"></w2:column>
    							<w2:column displayMode="label" id="wrkPlNm" inputType="text" width="120"></w2:column>
    							<w2:column displayMode="label" id="clntCommCd" inputType="text" width="120"></w2:column>
    							<w2:column displayMode="label" id="commCd" inputType="text" width="80"></w2:column>
    							<w2:column displayMode="label" id="commNm" inputType="text" width="150"></w2:column>
    							<w2:column displayMode="label" id="bizLongCd" inputType="text" width="80"></w2:column>
    							<w2:column width="80" inputType="text" id="wrkPatternCd" displayMode="label"></w2:column>
    							<w2:column width="80" inputType="text" id="clntOdrNo" displayMode="label"></w2:column>
    							<w2:column width="80" inputType="text" id="wrkStDt" displayMode="label"></w2:column>
    							<w2:column width="80" inputType="text" id="qtyUnitCd" displayMode="label"></w2:column>

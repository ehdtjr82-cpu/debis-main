    							<w2:column width="80" inputType="text" id="smQty" displayMode="label" dataType="number" displayFormat="#,###"></w2:column>
    							<w2:column width="105" inputType="text" id="regDtm" displayMode="label"></w2:column>
    						</w2:row>

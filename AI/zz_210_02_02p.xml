    <script type="text/javascript"><![CDATA[
        scwin.clntNo = "";
        scwin.txt_wrkIndictNo = "";

        scwin.onpageload = function() {
            scwin.params = $c.data.getParameter();
            if (scwin.params != null && scwin.params["clntNo"] != null) {
                scwin.clntNo = scwin.params["clntNo"];
            }
            scwin.f_SetDefaultData();
            scwin.f_Retrieve();
            scwin.f_RetrieveHistory();
        };

        scwin.f_SetDefaultData = function() {
            dma_condition.set("clntNo", scwin.clntNo);
        };

        scwin.f_Retrieve = async function() {
            await $c.sbm.execute(sbm_queryCondition);
        };

        scwin.f_RetrieveHistory = async function() {
            await $c.sbm.execute(sbm_queryConditionHistory);
        };

        scwin.f_RunExcel = async function() {
            let countA = ds_List1.getRowCount();
            if (!(countA > 0)) {
                await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
                return;
            }
            $c.data.downloadGridViewExcel(gr_List1, {"fileName":"거래처이력목록.xlsx", "sheetName":"거래처이력목록"});
        };

        scwin.sbm_queryCondition_submitdone = async function(e) {
            let rowCnt = ds_List1.getRowCount();
            spa_totalRowGrid1.setValue(rowCnt);
            if (rowCnt == 0) {
                await $c.win.alert("거래처 이력현황 조회결과가 없습니다.");
            }
        };

        scwin.sbm_queryCondition_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.sbm_queryConditionHistory_submitdone = async function(e) {
            let rowCnt = ds_List2.getRowCount();
            spa_totalRowGrid2.setValue(rowCnt);
            if (rowCnt == 0) {
                await $c.win.alert("매입거래처 이력현황 조회결과가 없습니다.");
            }
        };

        scwin.sbm_queryConditionHistory_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };
    ]]></script>


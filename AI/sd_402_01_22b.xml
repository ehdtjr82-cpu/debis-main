    <script type="text/javascript"><![CDATA[
        scwin.lineCd = "";
        scwin.lineNm = "";
        scwin.bookingNo = "";

        scwin.ODR_KND_CD_EXP_GNRL_CNTR_ODR = "C4";
        scwin.ODR_KND_CD_ON_HIRE_ODR = "C5";
        scwin.ODR_KND_CD_OFF_HIRE_ODR = "C6";
        scwin.ODR_KND_CD_EMPTY_POSITION_ODR = "C7";

        scwin.onpageload = function() {
            scwin.params = $c.data.getParameter();
            if (scwin.params != null) {
                scwin.lineCd = scwin.params["lineCd"] || "";
                scwin.lineNm = scwin.params["lineNm"] || "";
                scwin.bookingNo = scwin.params["bookingNo"] || "";
            }
        };

        scwin.onUdcCompleted = function() {
            scwin.f_FieldClear();

            ed_cndLineCd.setValue(scwin.lineCd);
            txt_cndLineNm.setValue(scwin.lineNm);
            ed_cndBookingNo.setValue(scwin.bookingNo);

            if (ed_cndLineCd.getValue().trim() != "" && ed_cndBookingNo.getValue().trim() != "") {
                scwin.f_Retrieve();
            }

            $c.gus.cfDisableObjects([tbl_infoArea]);
            $c.gus.cfEnableObjects([txt_sizeTypeInfo]);
        };

        scwin.f_FieldClear = function() {
            $c.gus.cfInitObjects([tbl_cndArea]);
            ed_cndLineCd.setFocus();
            $c.gus.cfDisableBtnOnly([btn_confirm]);
            $c.gus.cfDisableObjects([btn_linkC4, btn_linkC5, btn_linkC6, btn_linkC7]);
        };

        scwin.f_Retrieve = async function() {
            if (await $c.gus.cfValidate([tbl_cndArea])) {
                await $c.sbm.execute(sbm_retrieve);
            }
        };

        scwin.f_Confirm = async function() {
            if (ds_bookingInfo.getRowCount() > 0 && ds_bookingInfo.getRowStatus(0) != "C") {
                await $c.sbm.execute(sbm_save);
            }
        };

        scwin.f_ChkOpenCommonPopUp = function(inObj, pairObj, isCode) {
            if (!$c.gus.cfCanOpenPopup(inObj, pairObj)) return;
            $c.gus.cfClearPairObj(pairObj);
            let pVal = $c.gus.cfGetValue(inObj);
            if (isCode == null || isCode == true) {
                scwin.f_OpenCommonPopUp(pVal, '', 'T', 'T');
            } else {
                scwin.f_OpenCommonPopUp('', pVal, 'T', 'T');
            }
        };

        scwin.f_OpenCommonPopUp = function(pCode, pName, pClose, pAllSearch) {
            let rtnList;
            rtnList = $c.gus.cfCommonPopUp('retrieveLineInfoList'
                            , pCode
                            , pName
                            , pClose
                            , null
                            , null
                            , null
                            , null
                            , null
                            , null
                            , null
                            , null
                            , null
                            , null
                            , pAllSearch
                            , "Line,Line코드,Line명"
                            );
            $c.gus.cfSetReturnValue(rtnList, ed_cndLineCd, txt_cndLineNm);
        };

        scwin.f_CntrOrderLink = function(odrKndCd) {
            let row = ds_bookingInfo.getRowPosition();
            if (row < 0) return;
            let param = {
                odrKndCd: odrKndCd,
                lineCd: ds_bookingInfo.getCellData(row, "lineCd"),
                bookingNo: ds_bookingInfo.getCellData(row, "bookingNo"),
                odrNo: ds_bookingInfo.getCellData(row, "mcomOdrNo"),
                pickupdt: ds_bookingInfo.getCellData(row, "pickupdt"),
                pickuphh: ds_bookingInfo.getCellData(row, "pickuphh"),
                linkPage: "bookingNo",
                type: "create"
            };
            $c.win.openMenu("컨테이너오더", "/ui/ds/sd/odrmgnt/odrreg/sd_402_01_11t.xml", "sd_402_01_11t.xml", param);
        };

        scwin.btn_retrieve_onclick = function(e) {
            scwin.f_Retrieve();
        };

        scwin.btn_confirm_onclick = function(e) {
            scwin.f_Confirm();
        };

        scwin.btn_linkC4_onclick = function(e) {
            scwin.f_CntrOrderLink(scwin.ODR_KND_CD_EXP_GNRL_CNTR_ODR);
        };

        scwin.btn_linkC5_onclick = function(e) {
            scwin.f_CntrOrderLink(scwin.ODR_KND_CD_ON_HIRE_ODR);
        };

        scwin.btn_linkC6_onclick = function(e) {
            scwin.f_CntrOrderLink(scwin.ODR_KND_CD_OFF_HIRE_ODR);
        };

        scwin.btn_linkC7_onclick = function(e) {
            scwin.f_CntrOrderLink(scwin.ODR_KND_CD_EMPTY_POSITION_ODR);
        };

        scwin.sbm_retrieve_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.sbm_retrieve_submitdone = async function(e) {
            if (ds_bookingInfo.getRowCount() > 0) {
                if (ds_bookingInfo.getCellData(0, "confirmPicNm") == ""
                    && ds_bookingInfo.getCellData(0, "confirmDt") == ""
                    && ds_bookingInfo.getCellData(0, "confirmHh") == ""
                ) {
                    $c.gus.cfEnableBtnOnly([btn_confirm]);
                } else {
                    $c.gus.cfDisableBtnOnly([btn_confirm]);
                }

                let mcomOdrNo = ds_bookingInfo.getCellData(0, "mcomOdrNo");
                if (!$c.gus.cfIsNull(mcomOdrNo)) {
                    let odrKndCd = mcomOdrNo.substring(1, 3);

                    if (odrKndCd == scwin.ODR_KND_CD_EXP_GNRL_CNTR_ODR) {
                        $c.gus.cfEnableObjects([btn_linkC4]);
                        $c.gus.cfDisableObjects([btn_linkC5, btn_linkC6, btn_linkC7]);
                    } else if (odrKndCd == scwin.ODR_KND_CD_ON_HIRE_ODR) {
                        $c.gus.cfEnableObjects([btn_linkC5]);
                        $c.gus.cfDisableObjects([btn_linkC4, btn_linkC6, btn_linkC7]);
                    } else if (odrKndCd == scwin.ODR_KND_CD_OFF_HIRE_ODR) {
                        $c.gus.cfEnableObjects([btn_linkC6]);
                        $c.gus.cfDisableObjects([btn_linkC4, btn_linkC5, btn_linkC7]);
                    } else if (odrKndCd == scwin.ODR_KND_CD_EMPTY_POSITION_ODR) {
                        $c.gus.cfEnableObjects([btn_linkC7]);
                        $c.gus.cfDisableObjects([btn_linkC4, btn_linkC5, btn_linkC6]);
                    }
                } else {
                    $c.gus.cfEnableObjects([btn_linkC4, btn_linkC5, btn_linkC6, btn_linkC7]);
                }

                if (ds_cntrInfo.getRowCount() > 0) {
                    let txt = "";
                    for (let i = 0; i < ds_cntrInfo.getRowCount(); i++) {
                        txt += "SIZE/TYPE: " + (ds_cntrInfo.getCellData(i, "cntrSizCd") + " " + ds_cntrInfo.getCellData(i, "cntrTypCd"))
                            + ", 총 수량: " + ds_cntrInfo.getCellData(i, "qty") + "대"
                            + ", 반출수량: " + ds_cntrInfo.getCellData(i, "gateQty") + "대"
                            + ", 잔량: " + (parseInt(ds_cntrInfo.getCellData(i, "qty")) - parseInt(ds_cntrInfo.getCellData(i, "gateQty"))) + "대";
                        if (i != ds_cntrInfo.getRowCount() - 1) txt += "\n";
                    }
                    txt_sizeTypeInfo.setValue(txt);
                } else {
                    txt_sizeTypeInfo.setValue("");
                }
            } else {
                await $c.gus.cfAlertMsg(MSG_CM_ERR_003, ["조회결과"]);
                scwin.f_FieldClear();
            }

            $c.gus.cfShowTotalRows(totalRows, ds_commInfo.getRowCount());
        };

        scwin.sbm_save_submiterror = function(e) {
            $c.gus.cfShowError(e);
        };

        scwin.sbm_save_submitdone = function(e) {
            ed_cndLineCd.setValue(txt_lineCd.getValue());
            txt_cndLineNm.setValue(txt_lineNm.getValue());
            ed_cndBookingNo.setValue(txt_bookingNo.getValue());
            scwin.f_Retrieve();
        };

        scwin.ed_cndLineCd_onblur = function(e) {
            scwin.f_ChkOpenCommonPopUp(ed_cndLineCd, txt_cndLineNm);
        };

        scwin.ed_cndBookingNo_onkeyup = function(e) {
            ed_cndBookingNo.setValue(ed_cndBookingNo.getValue().toUpperCase());
            $c.gus.cf_ValidateMaxByteLengthEmEdit(ed_cndBookingNo, 20, e.keyCode);
        };

        scwin.ed_cndBookingNo_onkeydown = function(e) {
            $c.gus.cf_ValidateMaxByteLengthEmEdit(ed_cndBookingNo, 20, e.keyCode);
        };
    ]]></script>


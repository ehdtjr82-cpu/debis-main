    scwin.txt_shnm4 = "";
    scwin.txt_shnm5 = "";
    scwin.txt_cnnm1 = "";
    scwin.txt_cnnm2 = "";
    scwin.txt_cnnm3 = "";
    scwin.txt_cnnm4 = "";
    scwin.txt_cnnm5 = "";
    scwin.txt_ntnm1 = "";
    scwin.txt_ntnm2 = "";
    scwin.txt_ntnm3 = "";
    scwin.txt_ntnm4 = "";
    scwin.txt_ntnm5 = "";
    scwin.ed_acRecv = "";
    scwin.ed_arPfm = "";

    scwin.onpageload = function() {
        scwin.strCurDate = WebSquare.date.getCurrentServerDate("yyyyMMdd");
        scwin.userId = $c.ses.getUserId();
        scwin.empNo = scwin.userId;
        scwin.vLobranCd = $c.ses.getLobranCd();
        scwin.vLobranNm = $c.ses.getLobranNm();
        scwin.params = $c.data.getParameter();
        if (scwin.params != null) {
            scwin.v_linkcheck = scwin.params["linkcheck"] || "";
            scwin.p_kcomcd = scwin.params["kcomcd"] || "";
            scwin.p_blno = scwin.params["blno"] || "";
            scwin.p_mblno = scwin.params["mblno"] || "";
            scwin.p_type = scwin.params["type"] || "";
            scwin.p_hblno2 = scwin.params["hblno"] || "";
            scwin.p_no = scwin.params["no"] || "";
            scwin.p_row_cnt = scwin.params["row_cnt"] || "";
            scwin.p_data = scwin.params["data"] || "";
        }
        scwin.f_Set("INIT");
        scwin.f_getParametrSetting();
        $c.gus.cfDisableObjects([txt_updid, txt_upddt]);
        scwin.f_OnLoad_freight();
    };

    scwin.f_getParametrSetting = async function() {
        let kcomcd = scwin.p_kcomcd || "";
        let blno = scwin.p_blno || "";
        let type = scwin.p_type || "";
        let mblno = scwin.p_mblno || "";
        scwin.linkType = type;
        if (scwin.linkType.trim() == "HawbCreate") {
            if (mblno == "null" || mblno == "") { return false; }
            scwin.f_Create();
            scwin.hd_kcomcd = kcomcd;
            ed_mblno.setValue(mblno);
            scwin.f_MasterConsolNoLoading();
            if (scwin.actionFlag == "Create") { scwin.f_RetrieveMasterInfo(); }
            ed_blno.setFocus();
        } else if (scwin.linkType.trim() == "ColoadHawbCreate") {
            if (mblno == "null" || mblno == "") { return false; }
            scwin.f_Create();
            scwin.hd_kcomcd = kcomcd;
            ed_mblno.setValue(mblno);
            scwin.f_MasterConsolNoLoading();
            if (scwin.actionFlag == "Create") { scwin.f_RetrieveMasterBookinInfo(); }
            ed_blno.setFocus();
        } else if (scwin.linkType.trim() == "HawbRetrieve") {
            if (blno == "null" || blno == "") { return false; }
            scwin.hd_kcomcd = kcomcd;
            ed_blno.setValue(blno);
            scwin.f_MhnoLoading();
            scwin.f_Retrieve();
        } else {
            if (blno == "null" || blno == "") { return false; }
            scwin.hd_kcomcd = kcomcd;
            ed_blno.setValue(blno);
            scwin.f_MhnoLoading();
            scwin.f_Retrieve();
        }
    };

    scwin.f_Retrieve = async function() {
        if (ed_blno.getValue() != "") {
            ds_HouseBillInfo.removeAll();
            ds_HouseLicenseInfo.removeAll();
            scwin.f_ProcessBinding(dma_HouseBillSearch, "HouseBillSearch");
            await $c.sbm.execute(sbm_Retrieve);
            if (ed_blpic.getValue() != "") {
                txt_blpic.setValue("");
                scwin.f_PopUp("B/L PIC", "T");
            }
        } else {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["House B/L No"]);
            ed_blno.setFocus();
        }
    };

    scwin.f_RetrieveMasterInfo = async function() {
        if (ed_mblno.getValue().trim() != "") {
            scwin.f_ProcessBinding(dma_HouseBillSearch, "RetrieveMasterInfo");
            await $c.sbm.execute(sbm_RetrieveMaster);
        }
    };

    scwin.f_RetrieveMasterBookinInfo = async function() {
        if (ed_mblno.getValue().trim() != "") {
            scwin.f_ProcessBinding(dma_MasterBillSearch, "MasterBillSearch");
            await $c.sbm.execute(sbm_RetrieveMasterBooking);
        }
    };

    scwin.f_RetrieveBookingInfo = async function() {
        if (ed_srno.getValue().trim() == "") {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Booking No"]);
        } else {
            scwin.f_ProcessBinding(dma_HouseBillSearch, "CustomerBookingSearch");
            await $c.sbm.execute(sbm_RetrieveBookigInfo);
        }
    };

    scwin.f_ProcessBinding = function(ds, gubun) {
        switch (gubun) {
            case "HouseBillSearch":
                dma_HouseBillSearch.set("kcomcd", scwin.hd_kcomcd);
                dma_HouseBillSearch.set("blno", ed_blno.getValue().trim());
                dma_HouseBillSearch.set("mhno", lc_hmhno.getValue());
                dma_HouseBillSearch.set("iogb", scwin.hd_iogb);
                break;
            case "HouseBillSave":
                ds_HouseBillInfo.setCellData(ds_HouseBillInfo.getRowPosition(), "kcomcd", scwin.hd_kcomcd);
                ds_HouseBillInfo.setCellData(ds_HouseBillInfo.getRowPosition(), "iogb", scwin.hd_iogb);
                ds_HouseBillInfo.setCellData(ds_HouseBillInfo.getRowPosition(), "blno", ed_blno.getValue().trim());
                ds_HouseBillInfo.setCellData(ds_HouseBillInfo.getRowPosition(), "mhno", lc_hmhno.getValue());
                break;
            case "HouseLicenseSave":
                ds_HouseLicenseInfo.setCellData(ds_HouseLicenseInfo.getRowPosition(), "kcomcd", scwin.hd_kcomcd);
                ds_HouseLicenseInfo.setCellData(ds_HouseLicenseInfo.getRowPosition(), "blno", ed_blno.getValue().trim());
                ds_HouseLicenseInfo.setCellData(ds_HouseLicenseInfo.getRowPosition(), "mhno", lc_hmhno.getValue());
                break;
            case "CustomerBookingSearch":
                dma_HouseBillSearch.set("kcomcd", scwin.hd_kcomcd);
                dma_HouseBillSearch.set("srno", ed_srno.getValue().trim());
                dma_HouseBillSearch.set("iogb", scwin.hd_iogb);
                break;
            case "HouseBillCheck":
                dma_HouseBillSearch.set("kcomcd", scwin.hd_kcomcd);
                dma_HouseBillSearch.set("blno", ed_blno.getValue().trim());
                dma_HouseBillSearch.set("iogb", scwin.hd_iogb);
                break;
            case "RetrieveMasterInfo":
                dma_HouseBillSearch.set("kcomcd", scwin.hd_kcomcd);
                dma_HouseBillSearch.set("iogb", scwin.hd_iogb);
                dma_HouseBillSearch.set("blno", ed_mblno.getValue().trim());
                break;
            case "MasterBillSearch":
                dma_MasterBillSearch.set("kcomcd", scwin.hd_kcomcd);
                dma_MasterBillSearch.set("blno", ed_mblno.getValue().trim());
                dma_MasterBillSearch.set("mhno", lc_hmhno.getValue());
                dma_MasterBillSearch.set("iogb", scwin.hd_iogb);
                break;
            case "FreightSearch":
                dma_SearchInfo_freight.set("kcomcd", scwin.hd_kcomcd);
                dma_SearchInfo_freight.set("blno", ed_blno.getValue().trim());
                dma_SearchInfo_freight.set("mhno", lc_hmhno.getValue().trim());
                dma_SearchInfo_freight.set("iogb", scwin.hd_iogb);
                dma_SearchInfo_freight.set("mblHblCls", "H");
                break;
            case "FreightSave":
                ds_HouseFreightInfo_freight.setCellData(ds_HouseFreightInfo_freight.getRowPosition(), "kcomcd", scwin.hd_kcomcd);
                ds_HouseFreightInfo_freight.setCellData(ds_HouseFreightInfo_freight.getRowPosition(), "blno", ed_blno.getValue().trim());
                break;
            default:
                break;
        }
    };

    scwin.f_ProcessResult = async function(gubun) {
        switch (gubun) {
            case "None":
                scwin.f_Set("INIT");
                await $c.gus.cfAlertMsg(E_MSG_CM_ERR_003);
                ed_blno.setFocus();
                break;
            case "HouseInfo":
                scwin.f_Set("RETRIEVE");
                scwin.f_SettingValue();
                scwin.f_MhnoLoading();
                await scwin.f_InvoiceCheck_All("B");
                break;
            case "NotExistMasterBookingInfo":
                scwin.processFlag = "None";
                ed_mblno.setValue("");
                break;
            case "ExistMasterBookingInfo":
                scwin.processFlag = "ExistMasterBookingInfo";
                scwin.f_MasterBookingListBinding("Retrieve", ds_MasterBookingInfo, ds_HouseBillInfo);
                break;
            default:
                break;
        }
    };

    scwin.f_RetrieveCustomerBookingResult = async function(gubun) {
        switch (gubun) {
            case "None":
                await $c.gus.cfAlertMsg(E_MSG_CM_ERR_003);
                ed_srno.setValue("");
                break;
            case "BookingInfo":
                let ds = ds_CustomerBookingInfo;
                let row = ds.getRowPosition();
                if (ds.getCellData(row, "blno") != "") {
                    await $c.gus.cfAlertMsg(scwin.MSG_LO_WRN_003, [ds.getCellData(row, "blno")]);
                    ed_srno.setValue("");
                    return false;
                }
                ed_srno.setValue(ds.getCellData(row, "srno"));
                ed_shcd.setValue(ds.getCellData(row, "shcd"));
                if (ed_shcd.getValue().trim() != "") { scwin.f_PopUp("Shipper", "T", "F", "F"); }
                ed_cncd.setValue(ds.getCellData(row, "cncd"));
                if (ed_cncd.getValue().trim() != "") { scwin.f_PopUp("Consignee", "T", "F", "F"); }
                ed_nocd.setValue(ds.getCellData(row, "pncd"));
                txt_nonm.setValue("");
                if (ed_nocd.getValue().trim() != "") { scwin.f_PopUp("Partner", "T", "F", "F"); }
                ed_ascd.setValue(ds.getCellData(row, "ascd"));
                txt_asnm.setValue("");
                if (ed_ascd.getValue().trim() != "") { scwin.f_PopUp("Customer", "T", "F", "F"); }
                ed_sacd.setValue(ds.getCellData(row, "sacd"));
                txt_sanm.setValue(ds.getCellData(row, "sanm"));
                ed_itcd.setValue(ds.getCellData(row, "itcd"));
                txt_itnm.setValue(ds.getCellData(row, "itnm"));
                if (txt_itnm.getValue() == "") {
                    ed_itcd.setValue("30000000");
                    txt_itnm.setValue("일반화물");
                }
                if (ed_ascd.getValue().trim() != "") { scwin.f_departmentInfo(); }
                if (scwin.processFlag == "Copy") {
                    ds_HouseBillInfo.setRowStatus(ds_HouseBillInfo.getRowPosition(), "C");
                    ds_HouseLicenseInfo.setRowStatus(ds_HouseLicenseInfo.getRowPosition(), "C");
                    scwin.f_Save();
                    scwin.processFlag = "None";
                }
                ed_blpic.setValue(scwin.userId);
                txt_blpic.setValue("");
                scwin.f_PopUp("B/L PIC", "T");
                break;
            default:
                break;
        }
    };

    scwin.f_SettingValue = function() {
        if (ed_srno.getValue() == "") { $c.gus.cfEnableObjects([ed_srno]); } else { $c.gus.cfDisableObjects([ed_srno]); }
        if (ed_mblno.getValue() == "") { $c.gus.cfEnableObjects([ed_mblno]); } else { $c.gus.cfDisableObjects([ed_mblno]); }
        scwin.f_FreightTypeGetting();
    };

    scwin.f_DefaultValue = function(gubun) {
        switch (gubun) {
            case "Create":
                rd_cgtype.setValue("L");
                rd_tplgb.setValue("N");
                ed_cucd.setValue("KRW");
                ed_acif1.setValue("FREIGHT PREPAID");
                ed_dvcr.setValue("N.V.D");
                ed_dvct.setValue("AS PER INV");
                ed_insu.setValue("NIL");
                rd_ergb.setValue("E");
                ed_blno.setValue("");
                ed_srno.setValue("");
                ed_mblno.setValue("");
                $c.gus.cfEnableObjects([ed_srno, ed_mblno]);
                ed_blno.setFocus();
                break;
            case "Copy":
                ed_blno.setValue("");
                ds_HouseBillInfo.setCellData(ds_HouseBillInfo.getRowPosition(), "mhno", "");
                ed_srno.setValue("");
                ed_mblno.setValue("");
                scwin.hd_oldmhno = "";
                ed_blno.setFocus();
                break;
            default:
                break;
        }
    };

    scwin.f_Set = function(gubun) {
        switch (gubun) {
            case "INIT":
                $c.gus.cfDisableKeyData();
                $c.gus.cfDisableBtnOnly([btn_Update, btn_Save, btn_Delete, btn_Cancel, btn_FileDownload]);
                $c.gus.cfDisableBtnOnly([btn_Copy, btn_Dimens, btn_Print, btn_MasterBill, btn_HawbNoChange, btn_dept]);
                $c.gus.cfEnableBtnOnly([btn_Create]);
                gr_HouseLicenseInfo.setReadOnly("grid", true);
                $c.gus.cfDisableObjects([ed_srno, ed_mblno]);
                ed_blno.setFocus();
                break;
            case "RETRIEVE":
                $c.gus.cfDisableKeyData();
                $c.gus.cfDisableBtnOnly([btn_Save, btn_Cancel]);
                $c.gus.cfEnableBtnOnly([btn_Create, btn_Update, btn_Delete, btn_FileDownload]);
                $c.gus.cfEnableBtnOnly([btn_Copy, btn_Dimens, btn_Print, btn_MasterBill, btn_HawbNoChange, btn_dept]);
                gr_HouseLicenseInfo.setReadOnly("grid", true);
                break;
            case "CREATE":
                $c.gus.cfEnableKeyData();
                $c.gus.cfDisableBtnOnly([btn_Create, btn_Update, btn_Delete]);
                $c.gus.cfEnableBtnOnly([btn_Save, btn_Cancel, btn_FileDownload]);
                scwin.f_DefaultValue("Create");
                gr_HouseLicenseInfo.setReadOnly("grid", false);
                scwin.freightYn = "";
                scwin.f_CustomerBookingInfo_booking();
                scwin.f_MasterBookingList_booking();
                scwin.f_MasterBL_master();
                break;
            case "UPDATE":
                $c.gus.cfDisableBtnOnly([btn_Update, btn_Create, btn_dept]);
                $c.gus.cfEnableBtnOnly([btn_Save, btn_Delete, btn_Cancel]);
                $c.gus.cfEnableBtnOnly([btn_Copy, btn_Dimens, btn_Print, btn_MasterBill, btn_HawbNoChange, btn_FileDownload]);
                gr_HouseLicenseInfo.setReadOnly("grid", false);
                break;
            case "SAVE":
                $c.gus.cfDisableBtnOnly([btn_Save, btn_Cancel]);
                $c.gus.cfEnableBtnOnly([btn_Update, btn_Create, btn_Delete]);
                scwin.f_Set("RETRIEVE");
                break;
            case "DELETE":
                $c.gus.cfDisableBtnOnly([btn_Save, btn_Cancel]);
                $c.gus.cfEnableBtnOnly([btn_Create, btn_Update, btn_Delete]);
                scwin.f_Set("RETRIEVE");
                break;
        }
        if (scwin.freightYn == "-1") {
            $c.gus.cfDisableObjects([ed_dept, txt_deptnm, ed_itcd, txt_itnm]);
        }
    };

    scwin.f_Create = function() {
        ds_HouseBillInfo.removeAll();
        ds_HouseBillInfo.insertRow();
        ds_HouseLicenseInfo.removeAll();
        scwin.actionFlag = "Create";
        scwin.f_Set("CREATE");
        scwin.f_Create_freight();
        txt_blpic.setValue("");
        ta_shnm.setValue("");
        ta_cnnm.setValue("");
        ta_ntnm.setValue("");
        if (txt_blpic.getValue() == "") {
            ed_blpic.setValue(scwin.userId);
            txt_blpic.setValue("");
            scwin.f_PopUp("B/L PIC", "T");
        }
        ed_itcd.setValue("30000000");
        txt_itnm.setValue("일반화물");
    };

    scwin.f_Update = function() {
        scwin.actionFlag = "Update";
        scwin.f_Set("UPDATE");
        if (ed_agcd.getValue().trim() == "") { $c.gus.cfDisableObjects([lc_lrgb]); } else { $c.gus.cfEnableObjects([lc_lrgb]); }
        scwin.f_Update_freight();
        $c.gus.cfDisableObjects([ed_dept, txt_deptnm]);
    };

    scwin.f_Cancel = function() {
        if (scwin.actionFlag == "Create") {
            scwin.f_Set("INIT");
            scwin.processFlag = "None";
        } else {
            scwin.f_Set("RETRIEVE");
        }
        ds_HouseBillInfo.undoAll();
        ds_HouseLicenseInfo.undoAll();
    };

    scwin.f_Save = async function() {
        if (scwin.actionFlag == "Create" || scwin.actionFlag == "Copy") {
            if (0 == lc_shipGb.getSelectedIndex()) { ed_mblno.setValue(ed_blno.getValue()); }
            scwin.f_ProcessBinding(dma_HouseBillSearch, "HouseBillCheck");
            await $c.sbm.execute(sbm_RetrieveHouseBillCheck);
            if (scwin.processFlag == "Exist") {
                await $c.gus.cfAlertMsg(E_MSG_CM_WRN_011, ["House B/L No"]);
                ed_blno.setFocus();
                return false;
            }
            ds_HouseBillInfo.setRowStatus(ds_HouseBillInfo.getRowPosition(), "C");
        }
        scwin.f_TextareaSave();
        scwin.f_FreightTypeSetting();
        if (!await scwin.f_Save_freight()) { return false; }
        if ((ds_HouseBillInfo.getUpdatedIndex().length > 0) || (ds_HouseLicenseInfo.getUpdatedIndex().length > 0) || (ds_HouseFreightInfo_freight.getUpdatedIndex().length > 0)) {
            scwin.f_ProcessBinding(ds_HouseBillInfo, "HouseBillSave");
            scwin.f_ProcessBinding(ds_HouseLicenseInfo, "HouseLicenseSave");
            scwin.f_FreightTypeSetting();
            if (await scwin.f_ReqFieldChk()) {
                scwin.actionFlag = "Save";
                scwin.f_HblNoStockPram();
                let row = ds_HouseBillInfo.getRowPosition();
                if (ds_HouseBillInfo.getCellData(row, "status") == "U") { ds_HouseBillInfo.setCellData(row, "status", ""); }
                else { ds_HouseBillInfo.setCellData(row, "status", "U"); }
                if (ed_shCtcd.getValue() == "") { await $c.win.alert("Shipper Country code is mandatory."); return false; }
                if (ed_cnCtcd.getValue() == "") { await $c.win.alert("Consignee Country code is mandatory."); return false; }
                if (ed_blpic.getValue() == "") { txt_blpic.setValue(""); ds_HouseBillInfo.setCellData(row, "pic", scwin.userId); }
                scwin.f_BookingSetting();
                if ("D" == ds_HouseBillInfo.getCellData(row, "shipgb")) { scwin.f_MasterBlSetting(); }
                await $c.sbm.execute(sbm_Save);
                scwin.f_Set("SAVE");
            }
        } else {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_001, ["House Info222"]);
        }
    };

    scwin.f_Delete = async function() {

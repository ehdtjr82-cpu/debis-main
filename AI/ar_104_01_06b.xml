    scwin.f_ReqFieldChk = async function() {
        if (scwin.txt_shnm1 == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Shipper Name"]); return false; }
        if (scwin.txt_shnm2 == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Shipper Name"]); return false; }
        if (scwin.txt_cnnm1 == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Consignee Name"]); return false; }
        if (scwin.txt_cnnm2 == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Consignee Name"]); return false; }
        if (ed_ondt.getValue() == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Onboard Date"]); ed_ondt.setFocus(); return false; }
        if (ed_avdt.getValue() == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Arrival Date"]); ed_avdt.setFocus(); return false; }
        if (!$c.gus.cfIsAfterDate(ed_ondt.getValue(), ed_avdt.getValue())) {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_048, ["Onboard Date", "Arrival Date"]);
            ed_ondt.setFocus();
            return false;
        }
        if ($c.gus.cfMonthsBetween(scwin.strCurDate, ed_ondt.getValue()) > 3) {
            await $c.win.alert("Onboard Date가 저장하는 날짜로 부터 3개월 이상의 미래일 수 없습니다.");
            ed_ondt.setFocus();
            return false;
        }
        if ($c.gus.cfMonthsBetween(scwin.strCurDate, ed_avdt.getValue()) > 3) {
            await $c.win.alert("Arrival Date가 저장하는 날짜로 부터 3개월 이상의 미래일 수 없습니다.");
            ed_avdt.setFocus();
            return false;
        }
        if ($c.gus.cfYearsBetween(ed_ondt.getValue(), scwin.strCurDate) > 3) {
            await $c.win.alert("Onboard Date가 3년 이상의 과거 일 수 없습니다.");
            ed_ondt.setFocus();
            return false;
        }
        if ($c.gus.cfYearsBetween(ed_avdt.getValue(), scwin.strCurDate) > 3) {
            await $c.win.alert("Arrival Date가 3년 이상의 과거 일 수 없습니다.");
            ed_avdt.setFocus();
            return false;
        }
        if ($c.date.diffDate(ed_ondt.getValue(), ed_avdt.getValue()) > 149) {
            await $c.win.alert("Onboard Date-Arrival Date(transit time)가 150일을 초과할 수 없습니다.");
            ed_ondt.setFocus();
            return false;
        }
        if (ed_dept.getValue().trim() == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Department Info"]); ed_dept.setFocus(); return false; }
        if (ed_sacd.getValue().trim() == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Salesman Info"]); ed_sacd.setFocus(); return false; }
        if (ed_itcd.getValue().trim() == "") { await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Item Info"]); ed_itcd.setFocus(); return false; }
        if (ed_ediwht.getValue().trim() == "" || ed_ediwht.getValue().trim() == "0") { ed_ediwht.setValue(ed_mftwht.getValue()); }
        if (ed_cjdt.getValue().trim() == "" || !$c.gus.cfValidateValue(ed_cjdt.getValue().trim(), "date=YYYYMMDD")) {
            await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Result Date Date"]);
            ed_cjdt.setFocus();
            return false;
        }
        if (ds_HouseLicenseInfo.getRowCount() > 0) {
            if (txt_ngnm1.getValue().trim() == "") {
                await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["Nature of Goods Info"]);
                txt_ngnm1.setFocus();
                return false;
            }
        }
        if (ed_dept.getValue().trim() == "1GG") {
            await $c.gus.cfAlertMsg(scwin.MSG_LO_WRN_010, ["Department Info"]);
            ed_dept.setFocus();
            return false;
        }
        // TODO: ds_customerInfo retrieval for dept validation
        let chk = await $c.gus.cfValidate([gr_HouseLicenseInfo]);
        if (chk == false) { return false; }
        for (let i = 0; i < ds_HouseLicenseInfo.getRowCount(); i++) {
            if (ds_HouseLicenseInfo.getCellData(i, "exno").trim() != "") {
                if (ds_HouseLicenseInfo.getCellData(i, "pkgs") == "0") {
                    await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["포장 갯수"]);
                    return false;
                }
                if (ds_HouseLicenseInfo.getCellData(i, "wht") == "0") {
                    await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["중량"]);
                    return false;
                }
            }
            if (ds_HouseLicenseInfo.getCellData(i, "elsplgb").trim() == "Y") {
                if (ds_HouseLicenseInfo.getCellData(i, "elmid").trim() == "") {
                    await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["분할 차수 "]);
                    return false;
                }
            }
            if (ds_HouseLicenseInfo.getCellData(i, "elcogb").trim() != "") {
                if (ds_HouseLicenseInfo.getCellData(i, "eldpkg") == "0") {
                    await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["동시 포장 수량"]);
                    return false;
                }
                if (ds_HouseLicenseInfo.getCellData(i, "eldpkgut").trim() == "") {
                    await $c.gus.cfAlertMsg(E_MSG_CM_ERR_002, ["동시포장단위"]);
                    return false;
                }
            }
        }
        return true;
    };


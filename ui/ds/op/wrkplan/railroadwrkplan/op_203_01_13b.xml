scwin.f_FieldClear = function () {
    $c.gus.cfInitObjects(tbl_search, null);
    ed_reqDt.focus();
    ed_reqDt.setValue(scwin.dateStr1);
    ed_reqDtTo.setValue(scwin.dateStr1);
    acb_bilgClntNo.setValue(scwin.pbilgClntCd);

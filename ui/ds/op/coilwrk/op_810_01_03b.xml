scwin.gr_coilList_CustomFormatter = function(data, formattedData, rowIndex, colIndex) {
    let columnId =  $c.util.getComponent(this.id).getColumnID(colIndex);
    let val = data, color = "black";

    var statuss = ds_coilList.getCellData(rowIndex, "statuss");
    if (columnId != "odrNo") {
        if (statuss != "처리") {
            color = "red";
        }
    }

    if (columnId == "thickness" || columnId == "width" || columnId == "length") {
        if (data != "") {
            val = scwin.fn_myNumFormatter(data, "dec2");
        }
    }

    if (columnId == "cnt" || columnId == "rsltsCnt" || columnId == "grossWgt" || columnId == "netWgt") {
        if (data != "") {
            val = scwin.fn_myNumFormatter(data, "dec0");
        }
    }

    gr_coilList.setCellColor(rowIndex, columnId, color);
    
    return val;
};


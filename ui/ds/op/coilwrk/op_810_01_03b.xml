// 조회 버튼 클릭
scwin.f_Retrieve = async function () {  
	// 검색조건 필수 입력 체크
	if (ed_clntNo.getValue() == "" ){
		if (ed_reqStDt.getValue() == "" && ed_reqEndDt.getValue() == "") {
			$c.win.alert("화주 또는 요청일자를 입력해 주시기 바랍니다.");
			return;
		}
	}
	if (ed_reqStDt.getValue() != "" ) {
		if(ed_reqStDt.getValue() >  ed_reqEndDt.getValue()){
	 	    $c.win.alert("요청일자를 확인해 주시기 바랍니다.");
			ed_reqStDt.focus();
	 	    return;
	 	}
 	}
 	
 	if (ed_arvIntendDt.getValue() != "" ) {
		if (ed_arvIntendDt.getValue() >  ed_dptIntendDt.getValue()) {
	 	    $c.win.alert("입항일자를 확인해 주시기 바랍니다.");
			ed_arvIntendDt.focus();
	 	    return;
	 	}
 	}
 	
    ds_search.setCellData(0, "lobranCd", acb_lobranCd.getValue());
	
    let e = await $c.sbm.execute(sbm_search);
    if (e.responseJSON.resultDataSet[0].Msg == "SUCC") {
        scwin.sbm_search_submitdone(e);
    }
};


scwin.f_Retrieve = function () {  
    if (ed_lodeptCd.getValue() == "")
    {
        $c.win.alert("물류부서는 필수입력 항목입니다.");
        ed_lodeptCd.focus();
    }
    else if(ica_vacaDt.getValue() == "")
    {
        $c.win.alert("해당 월은 필수입력 항목입니다.");
        ica_vacaDt.focus();
    }
    else if(ed_lodeptCd.getValue() != "")
    { 
        $c.sbm.execute(sbm_condition);
    }
}


		$c.gus.cfAlertMsg("[기능직직종별복리후생비현황조회] "+MSG_CM_ERR_003);
		return;
  	}
    spa_cnt.setValue(ds_WelfareSalaryPresentCondition.getRowCount());
};

scwin.ds_WelfareSalaryPresentCondition_ondataload = function () {
	var options = {};

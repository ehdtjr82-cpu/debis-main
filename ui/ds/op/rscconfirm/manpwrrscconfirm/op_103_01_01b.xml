scwin.f_retrieveVacation = async function () {
    //조회 필수 조건 check
    if (!await $c.gus.cfValidate([tbl_search], null, true)) {
        return;
    }

    ds_vacation.removeAll();
    dma_search.set("lobranCd", ed_dept_01.getValue());
    dma_search.set("wrkPlCd", ed_works_01.getValue());

//-------------------------------------------------------------------------
// 페이지로드
//-------------------------------------------------------------------------
scwin.onpageload = function () {    
    // 등록점소 콤보박스 SET
    const codeOptions2 = [
        {
            method: "getLuxeComboData",
            param1: "WorkImplementEBC",
            param2: "retriveLobran2CodeList",
            compID: "acb_assgnLobranCd"
        }
    ];

    //데이터리스트가 바인딩 되기전에 setValue()가 먼저 수행되므로 콜백 사용
    $c.data.setGauceUtil(codeOptions2, function() {
        if (scwin.sLobranCd) {
            acb_assgnLobranCd.setValue(scwin.sLobranCd);
            acb_assgnLobranCd.focus();

            //조회
            scwin.f_Retrieve();
        }
    });

    //장비구분
    dma_eqBun.set("sysCd", "EquipmentNonUsableEBC");
    dma_eqBun.set("queryId", "retriveEquipCombo2");
    $c.sbm.execute(sbm_retrieveEqBun);

    scwin.arrParam = $p.getAllParameter().paramData.data;

    acb_eqCndCd.setValue(scwin.arrParam[1]); // 중기종류

    if (scwin.arrParam[3] == null) // 중기사용일자
    {
        ica_usblDt.setValue($c.date.getServerDateTime("yyyyMMdd"));
    }
    else if (scwin.arrParam[3] != null) {
        ica_usblDt.setValue(scwin.arrParam[3]);
    }
    ed_eqNo.setValue(scwin.arrParam[4]); // 단축번호
    ed_eqNm.setValue(scwin.arrParam[5]); // FULL번호

    if (scwin.arrParam[6] == null || scwin.arrParam[6] == "F") {
        scwin.Tfgb = "F"; // WINDOW CLOSE 여부, F면 무조건 팝업
    }
    else if (scwin.arrParam[6] == "T") {
        scwin.Tfgb = "T"; // WINDOW CLOSE 여부, T면 하나조회시 팝업안됨
    }

    if (scwin.arrParam[7] == null) {
        ica_usblDt.setReadOnly(false); // 일자 수정불가능여부, F면 수정가능

    }
    else if (scwin.arrParam[7] == "T") {
        ica_usblDt.setReadOnly(true); // 일자 수정불가능여부, T면 수정불가능
    }

    //nouse = scwin.arrParam[8]; // 비가용조회여부, T면 조회가능(사용안되는것 같음)    
};


//조회
scwin.sbm_retrieve_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    if (ds_Grid1.getRowCount() == 0) {
		$c.win.alert($c.data.getMessage(MSG_CM_WRN_002)); // 조회결과가 존재하지 않습니다.
    }

    totalRows.setValue(ds_Grid1.getRowCount());
};


//작업장
scwin.sbm_wrkPlCd_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    ds_wrkPlCd.sort("col1", 0); // 작업장 코드 기준 정렬
    acb_wrkPlCd.setSelectedIndex(0);
};

//점소
scwin.sbm_lobranCd_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    acb_lobranCd.setValue(scwin.lobranCd);

    scwin.retrieveWrkPl(); // 작업장 조회
};

//반출입
scwin.sbm_crryInOutCd_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    acb_crryInOutCd.setSelectedIndex(0);
};

//자가구분
scwin.sbm_selfClsCd_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    acb_selfClsCd.setSelectedIndex(0);
};

//오더종류
scwin.sbm_odrKndCd_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    ds_odrKndCd.setFilter({ type: 'row', colIndex: 'fltrCd1', key: "C"}); // 오더종류코드 FLTR_CD_1 = 'C' 인것만
    acb_odrKndCd.setSelectedIndex(0);
};



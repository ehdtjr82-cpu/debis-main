		<script lazy="false" type="text/javascript"><![CDATA[scwin.lobranCd = $c.data.getMemInfo("lobranCd"); // 물류점소 코드
if (scwin.lobranCd == null) scwin.lobranCd = "";

scwin.onpageload = function () {
	// 코드 데이터 가져오기
    const codeOptions = [
        { grpCd: "OP197", compID: "gr_Grid1:crryinoutClsCd" },
        { grpCd: "SD060", compID: "gr_Grid1:impExpClsCd" },
        { grpCd: "SD114", compID: "gr_Grid1:selfClsCd" }
    ];

    $c.data.setCommonCode(codeOptions);

	// 점소
    dma_lobranCd.set("sysCd", "CommonEBC");
    dma_lobranCd.set("queryId", "retriveLobranCd");
    $c.sbm.execute(sbm_lobranCd);

	// 반출/반입
    dma_crryInOutCd.set("grpCd", "OP197");
    $c.sbm.execute(sbm_crryInOutCd);

	// 자가구분
    dma_selfClsCd.set("grpCd", "SD114");
    $c.sbm.execute(sbm_selfClsCd);

	// 오더종류
    dma_odrKndCd.set("grpCd", "SD113");
    $c.sbm.execute(sbm_odrKndCd);

    acb_lobranCd.focus();
};

///////////////////////////////////////////// B U S I N E S S   L O G I C /////////////////////////////////////////

// 점소 변경 시 작업장 조회
scwin.retrieveWrkPl = function() {
    dma_wrkPlCd.set("sysCd", "CommonEBC");
    dma_wrkPlCd.set("queryId", "retriveWrkLobranCd");
    dma_wrkPlCd.set("param3", acb_lobranCd.getValue());

    $c.sbm.execute(sbm_wrkPlCd);
};


//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function () {
    //debugger;
	let rtn = await $c.gus.cfValidate([acb_lobranCd, ed_srchFromDate, ed_srchToDate]);
    if (! rtn) {	// 본선관리번호, 작업일자
        return;
    }

    if (!$c.gus.cfIsAfterDate(ed_srchFromDate.getValue(), ed_srchToDate.getValue())) {
		await $c.win.alert($c.data.getMessage(MSG_CM_ERR_039)); // 시작일자가 종료일자 이전이어야 합니다.
        ed_srchFromDate.focus();
        return;
    }

    $c.sbm.execute(sbm_retrieve);
};

//-------------------------------------------------------------------------
// 팝업 처리시 검색된 데이터인 경우 팝업 처리 안함
//-------------------------------------------------------------------------
scwin.f_chkOpenCommonPopUp = function (inObj, pairObj, disGubun, isCode) {
	// 값이 입력이 안된 경우, 해당 Text Box가 readonly 인 경우, 이전값과 동일한 경우 팝업을 실행하지 않음.
	if (!$c.gus.cfCanOpenPopup(inObj, pairObj))
		return;

	// 짝이 되는 오브젝트의 값 제거
	$c.gus.cfClearPairObj(pairObj);

	// 검색어 세팅
	var pVal = $c.gus.cfGetValue(inObj);

	// inObj가 코드 필드일 경우 팝업
	if (isCode == null || isCode == true)
		scwin.f_openPopUp(disGubun, pVal, '', 'T', 'T');
	// inObj가 코드명 필드일 경우 팝업
	else
		scwin.f_openPopUp(disGubun, '', pVal, 'T', 'T');
};


//-------------------------------------------------------------------------
// 팝업 열기
//-------------------------------------------------------------------------
scwin.f_openPopUp = function (disGubun, pCode, pName, pClose, pAllSearch) {

	if (disGubun == "1"){ // 차량번호
		// Select ID : retrieveVehiclesNo
		udc_comCodeVehcl.cfCommonPopUp(
			scwin.udc_comCodeVehcl_callBackFunc // 팝업 콜백 리턴결과 Array 형태로 SQL Select 순서로 Return
			,pCode                  // 화면에서의 ??? Code Element의 Value
			,pName                  // 화면에서의 ??? Name Element의 Value
			,pClose                 // 결과가 1건 일때 원도우를 AutoClose 여부 (T:Close,F:Opened)
			,null					// 검색 결과 컬럼의 보여주는 개수 (SELECT절의 순서) 	MAX:10     null(2)   "5"
			,null					// Title명's                         	null    "100,200"
			,null					// 보여주는 각 컬럼들의 폭               null    "100,200"
			,null					// 컬럼중에서 숨기는 컬럼 지정           null    "7,8,9,10"		
			,null					// SQL절의 WHERE절에 원하는 조건을 선택함 MAX:12개까지 가능     null    "SHIP"
			,null					// POP-UP 띄울때 원도우의 사용자 정의 폭              null    "500"
			,null					// POP-UP 띄울때 윈도우의 사용자 정의 높이             null    "600"
			,null					// 윈도우 위치 Y좌표
			,null					// 윈도우 위치 X좌표  
			,null					// 중복체크여부
			,pAllSearch 			// 전체검색허용여부 ("F")
			,"차량번호,차량단축코드,차량번호"	// POP-UP Window Title 검색어1,2(각화면에서 변경할경우)        null    "Win타이틀,검색어1,검색어2"
			,null					// Data건수가 0건일때 Window를 띄우지 않음 리턴
		);

	} else if (disGubun == "2"){ // Line
		// Select ID : retrieveLineInfo
		udc_comCodeLine.cfCommonPopUp(
			scwin.udc_comCodeLine_callBackFunc, pCode, pName, pClose,
			null, null, null, null, null,
			null, null, null, null, null,
			pAllSearch, null, null
		);
  

	} else if (disGubun == "4"){ // 모선
		// Select ID : retrieveOrdVsslInfo
		udc_comCodeVsslCd.cfCommonPopUp(
			scwin.udc_comCodeVsslCd_callBackFunc, pCode, pName, pClose,
			null, null, null, null, null,
			null, null, null, null, null,
			pAllSearch, null, null
		);

	}
};



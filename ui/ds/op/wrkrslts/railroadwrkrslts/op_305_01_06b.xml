scwin.f_FieldClear = function(type='i') {
    if ( type == "i" ) {
        dma_search.set("stdYy"     ,scwin.yyyy);
    } else {
        dma_search.set("stdYy"     ,"");
    }
    ed_dptStn.setValue("");
    ed_dptStnNm.setValue("");
    dma_search.set("quarter","1");
    ica_ed_stdYY.focus();
}
//-------------------------------------------------------------------------
// 출발역 UDC 이벤트 호출 되는 함수 START

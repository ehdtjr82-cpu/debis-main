//-------------------------------------------------------------------------
// 조회
//------------------------------------------------------------------------- 
scwin.btn_retrieve_onclick = async function (e) {
    let check = await $c.gus.cfValidate([ica_ed_stdYY, acb_lc_quarter, ed_dptStn]);
    //필수입력항목 체크	  
  	if( !check ) return;
    dma_search.set("dptStnCd",ed_dptStn.getValue());

	$c.sbm.execute(sbm_retrieve);
};

scwin.sbm_retrieve_submitdone = function() {

    let nCnt = ds_railroadRslts.getRowCount();
    
    if( nCnt == 0 ){

		$c.gus.cfAlertMsg(MSG_CM_WRN_002);
  	
    } else {
        gr_railroadRslts.setFocusedCell(0, 0);
        total.setValue(nCnt);
    }

};

//-------------------------------------------------------------------------
// 엑셀저장
//-------------------------------------------------------------------------
scwin.f_GridToExcel = async function() {
    if ( ds_railroadRslts.getRowCount() <= 0) {
        $c.win.alert(MSG_CM_WRN_002);
        return false;
    }
    const options = {
        fileName : "기간별철송실적현황.xlsx"
        ,sheetName : "기간별철송실적현황"
    };
    await $c.data.downloadGridViewExcel(gr_railroadRslts, options);
};

scwin.udc_comCode_dpstn_onclickEvent = function(e) {
    udc_comCode_dpstn.cfCommonPopUp(scwin.udc_comCode_dpstn_callBackFunc
                                   , ed_dptStn.getValue()
                                   , ed_dptStnNm.getValue()
                                   ,"F", null, "역명코드,역명", null, null, null, null, null, null, null, null, "T", "역명조회,역명코드,역명");
};

scwin.udc_comCode_dpstn_onblurCodeEvent = function (e) {
    if ( ed_dptStn.originalValue != ed_dptStn.getValue() ) {
        const dptStn = ed_dptStn.getValue();
        const dptStnNm = ed_dptStnNm.getValue();
        ed_dptStnNm.setValue("");
        if ( dptStn != "" ) {
            udc_comCode_dpstn.cfCommonPopUp(scwin.udc_comCode_dpstn_callBackFunc, dptStn, dptStnNm,"T", null, "역명코드,역명", null, null, null, null, null, null, null, null, null, "역명조회,역명코드,역명");
        }
        }
};

scwin.udc_comCode_dpstn_onblurNameEvent = function (e) {
    if ( ed_dptStnNm.originalValue != ed_dptStnNm.getValue() ) {
        const dptStn = ed_dptStn.getValue();
        const dptStnNm = ed_dptStnNm.getValue();
        ed_dptStn.setValue("");
        if ( dptStnNm != "") {
            udc_comCode_dpstn.cfCommonPopUp(scwin.udc_comCode_dpstn_callBackFunc, dptStn, dptStnNm,"T", null, "역명코드,역명", null, null, null, null, null, null, null, null, null, "역명조회,역명코드,역명");
        }
    }
};
scwin.udc_comCode_dpstn_callBackFunc = function(ret) {
    $c.gus.cfSetReturnValue(ret, ed_dptStn, ed_dptStnNm);
    console.log(ret);
};

//-------------------------------------------------------------------------

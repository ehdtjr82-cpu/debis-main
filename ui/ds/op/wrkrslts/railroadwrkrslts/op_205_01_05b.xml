            // cfGridToExcel(varGrNm, sheetTitle, sheetTitle, 2+4+8+16);	

            var fileName = "사유화차저감실적";
            await $c.data.downloadGridViewExcel(gr_PrivatetrainCutResults, { fileName: fileName + ".xlsx", sheetName: fileName });
        }
    } else {
        await $c.gus.cfAlertMsg(MSG_CM_WRN_002);    
    }


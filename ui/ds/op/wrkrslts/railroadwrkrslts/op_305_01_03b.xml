<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map">
    			<w2:dataList baseNode="list" repeatNode="map" id="ds_railroadResults" saveRemovedData="true">
    				<w2:columnInfo>
    					<w2:column id="dptWrkPlNm" name="출발역" dataType="text"></w2:column>
    					<w2:column id="arvWrkPlNm" name="도착역" dataType="text"></w2:column>
    					<w2:column id="lineCd" name="Line" dataType="text"></w2:column>
    					<w2:column id="cntrNo" name="Cntr No" dataType="text"></w2:column>
    					<w2:column id="cntrSizCd" name="Size" dataType="text"></w2:column>
    					<w2:column id="cntrTypCd" name="Type" dataType="text"></w2:column>
    					<w2:column id="fullEmptyClsCd" name="E/F" dataType="text"></w2:column>
    					<w2:column id="sealNo" name="Seal No" dataType="text"></w2:column>
    					<w2:column id="dptDtHh" name="출발일시" dataType="text"></w2:column>
    					<w2:column id="arvDtHh" name="도착일시" dataType="text"></w2:column>
    					<w2:column id="odrNo" name="오더번호" dataType="text"></w2:column>
    					<w2:column id="clntNm" name="화주명" dataType="text"></w2:column>
    					<w2:column id="ordArvWrkPlNm" name="하차지" dataType="text"></w2:column>
    					<w2:column id="arvDtl" name="도착상세" dataType="text"></w2:column>
    					<w2:column id="vsslNm" name="선박명" dataType="text"></w2:column>
    					<w2:column id="portcnt" name="항차" dataType="text"></w2:column>
    					<w2:column id="chRailroadFare" name="청화차" dataType="number"></w2:column>
    					<w2:column id="saRailroadFare" name="사유화차" dataType="number"></w2:column>
    					<w2:column id="btRailroadFare" name="BT" dataType="number"></w2:column>
    					<w2:column id="transNm" name="운송명의" dataType="text"></w2:column>
    					<w2:column id="frtcarNo" name="화차번호" dataType="text"></w2:column>
    					<w2:column id="dptDt" name="출발일" dataType="text"></w2:column>
    					<w2:column id="wrkCnt" name="작업량" dataType="text"></w2:column>
    					<w2:column id="vsslCd" name="선박코드" dataType="text"></w2:column>
    					<w2:column id="transWrkIndictNo" name="운송작업지시번호" dataType="text"></w2:column>
    					<w2:column id="cntrSeq" name="컨테이너순번" dataType="text"></w2:column>
    					<w2:column id="odrWrkPathSeq" name="오더작업경로순번" dataType="text"></w2:column>
    					<w2:column id="odrWrkStpSeq" name="오더작업단계순번" dataType="text"></w2:column>
    					<w2:column id="wrkStDt" name="시작일자" dataType="text"></w2:column>
    					<w2:column id="wrkEndDt" name="종료일자" dataType="text"></w2:column>
    					<w2:column id="dptWrkPlCd" name="출발작업장" dataType="text"></w2:column>
    					<w2:column id="arvWrkPlCd" name="도착작업장" dataType="text"></w2:column>
						<!-- grpKey -->
						<w2:column id="grpKey" name="그룹키" dataType="text"></w2:column>
						<w2:column id="subsum1" name="서브토탈 중분류" dataType="text"></w2:column>
						<w2:column id="subsum2" name="서브토탈 대분류" dataType="text"></w2:column>
						<!-- 그리드 표시용 (실제 dptWrkPlNm/arvWrkPlNm은 변경하지 않음) -->
						<w2:column id="dptWrkPlNmView" name="출발역표시" dataType="text"></w2:column>
						<w2:column id="arvWrkPlNmView" name="도착역표시" dataType="text"></w2:column>
    				</w2:columnInfo>
    			</w2:dataList>
    			<w2:dataList baseNode="list" repeatNode="map" id="ds_railroadTotCnt" saveRemovedData="true">
    				<w2:columnInfo>
    					<w2:column id="sa" name="건" dataType="number"></w2:column>
    					<w2:column id="saTeu" name="TEU" dataType="number"></w2:column>
    					<w2:column id="saCnt40" name="40" dataType="number"></w2:column>
    					<w2:column id="saCnt20" name="20" dataType="number"></w2:column>
    					<w2:column id="ch" name="건" dataType="number"></w2:column>
    					<w2:column id="chTeu" name="TEU" dataType="number"></w2:column>
    					<w2:column id="chCnt40" name="40" dataType="number"></w2:column>
    					<w2:column id="chCnt20" name="20" dataType="number"></w2:column>
    					<w2:column id="bt" name="건" dataType="number"></w2:column>
    					<w2:column id="btTeu" name="TEU" dataType="number"></w2:column>
    					<w2:column id="btCnt40" name="40" dataType="number"></w2:column>
    					<w2:column id="btCnt20" name="20" dataType="number"></w2:column>
    				</w2:columnInfo>
    			</w2:dataList>
    			<w2:dataMap baseNode="map" id="oGDS_view_cond">
    				<w2:keyInfo>
    					<w2:key id="dptWrkPlCd" name="출발역작업장코드" dataType="text"></w2:key>
    					<w2:key id="arvWrkPlCd" name="도착역작업장코드" dataType="text"></w2:key>
    					<w2:key id="dptDtHh" name="출발시간From" dataType="text"></w2:key>
    					<w2:key id="arvDtHh" name="출발시간To" dataType="text"></w2:key>
    					<w2:key id="transWrkIndictNo" name="작업지시번호" dataType="text"></w2:key>
    					<w2:key id="frtCarClsCd" name="화차구분" dataType="text"></w2:key>
    				</w2:keyInfo>
    			</w2:dataMap>
    		</w2:dataCollection>
    		<w2:workflowCollection />
    		<xf:submission id="sbm_retrieve" action="/ds.op.wrkrslts.railroadwrkrslts.RetrieveStationEachRailroadResultsCMD.do"
    			method="post" mediatype="application/json"
    			ref='data:json,[{"id":"oGDS_view_cond","key":"IN_DS1"},{"id":"ds_railroadResults","key":"OUT_DS1"}]'
    			target='data:json,{"id":"ds_railroadResults","key":"OUT_DS1"}' encoding="UTF-8" instance="" replace="" errorHandler=""
    			customHandler="" mode="asynchronous" processMsg="" ev:submit="" ev:submitdone="scwin.sbm_retrieve_submitdone" ev:submiterror=""
    			abortTrigger="">
    		</xf:submission>
    		<xf:submission id="sbm_retrieve2" action="/ds.op.wrkrslts.railroadwrkrslts.RetrieveStationEachRailroadTotalCountCMD.do"
    			method="post" mediatype="application/json"
    			ref='data:json,[{"id":"oGDS_view_cond","key":"IN_DS1"},{"id":"ds_railroadTotCnt","key":"OUT_DS1"}]'
    			target='data:json,{"id":"ds_railroadTotCnt","key":"OUT_DS1"}' encoding="UTF-8" instance="" replace="" errorHandler=""
    			customHandler="" mode="asynchronous" processMsg="" ev:submit="" ev:submitdone="scwin.sbm_retrieve2_submitdone" ev:submiterror=""
    			abortTrigger="">
    		</xf:submission>
    	</xf:model>
    	<w2:layoutInfo />
    	<w2:publicInfo method="" />
    	<script lazy="false" type="text/javascript"><![CDATA[
			scwin.strCurDate =$c.date.getServerDateTime("yyyyMMdd");  // 서버를 기준으로 현재 날짜 반환

			scwin.onpageload = function() {
				// 정렬 상태 직접 관리
				scwin._sortState = { colID: "", order: 1 };
				scwin._viewInitialized = false;
			};

			scwin.onUdcCompleted = function() {
				scwin.f_defaultValue();
				ed_dptWrkPlNm.focus();
			};

			//-------------------------------------------------------------------------
			// 조회
			//-------------------------------------------------------------------------
			scwin.f_Retrieve = async function() {
				let chk = await scwin.f_reqFieldChk(); 
				if (!chk) return false;
				$c.sbm.execute(sbm_retrieve);
			};

			//-------------------------------------------------------------------------
			// function name : scwin.f_reqFieldChk
			// function desc : 필수항목 check
			//-------------------------------------------------------------------------
			scwin.f_reqFieldChk = async function() {
				let rtn = await $c.gus.cfValidate([ed_dptDtHh, ed_arvDtHh]);
				if (!rtn) return false;

				if (!$c.gus.cfIsAfterDate(ed_dptDtHh.getValue(), ed_arvDtHh.getValue())) {
					$c.win.alert($c.data.getMessage(MSG_CM_ERR_048, "작업일자 From", "작업일자 To")); // %1은(는) %2보다 작아야 합니다.
					ed_dptDtHh.focus();
					return false;
				}

				return true;
			};


			//-------------------------------------------------------------------------
			//조회(통계)
			//-------------------------------------------------------------------------
			scwin.f_retrieve2 = function() {
				$c.sbm.execute(sbm_retrieve2);
			};


			//-------------------------------------------------------------------------
			// 조회 조건 초기화
			//-------------------------------------------------------------------------
			scwin.f_FieldClear = function() {
				$c.gus.cfInitObjects([ed_dptWrkPlCd, ed_arvWrkPlCd, ed_dptWrkPlNm, ed_arvWrkPlNm, ed_transWrkIndictNo]);
				scwin.f_defaultValue();
			};

			//-------------------------------------------------------------------------
			// function name : f_defaultValue
			// function desc : 화면 open시 초기 데이타 setting
			//-------------------------------------------------------------------------
			scwin.f_defaultValue = function() {
				ed_dptDtHh.setValue(scwin.strCurDate);
				ed_arvDtHh.setValue(scwin.strCurDate);

				rd_frtCarClsCd.setValue("");
			};

			//-------------------------------------------------------------------------
			// function name : scwin.f_crryInOutEDI
			// function desc : 반출입예정정보EDI등록
			//-------------------------------------------------------------------------
			scwin.f_crryInOutEDI = function() {
				if (ds_railroadResults.getRowCount() == 0) return;

				let row = gr_railroadResults.getFocusedRowIndex();

				// [AS-IS] 누계정보 행을 클릭시 팝업창을 띄우지 않음.
				// [TO-BE] 누계정보 행을 클릭해도 FocusedRow로 잡히지 않기 때문에, 아무 행도 선택하지 않았을 경우만 처리
				// if ($c.gus.cfIsNull(ds_railroadResults.getCellData(row, "dptWrkPlCd")) || $c.gus.cfIsNull(ds_railroadResults.getCellData(row, "arvWrkPlCd"))) {
				if (row < 0) {
				$c.win.alert("컨테이너정보를 선택하십시오.");
				return;
				}

				var data = {
					arrParam: [
						[
							"",                                                          // [0] 조회구분 ("" : 운송작업지시, "1" : 반출입)
							ds_railroadResults.getCellData(row, "transWrkIndictNo"),    // [1]
							ds_railroadResults.getCellData(row, "odrNo"),               // [2]
							ds_railroadResults.getCellData(row, "cntrSeq"),             // [3]
							ds_railroadResults.getCellData(row, "odrWrkPathSeq"),       // [4]
							ds_railroadResults.getCellData(row, "odrWrkStpSeq"),        // [5]
							"",                                                          // [6]
							"",                                                          // [7]
							"",                                                          // [8]
							ds_railroadResults.getCellData(row, "wrkStDt"),             // [9]
							ds_railroadResults.getCellData(row, "wrkEndDt"),            // [10]
							ds_railroadResults.getCellData(row, "cntrNo"),              // [11]
							ds_railroadResults.getCellData(row, "dptWrkPlCd"),          // [12]
							ds_railroadResults.getCellData(row, "arvWrkPlCd"),          // [13]
							ds_railroadResults.getCellData(row, "dptWrkPlNm"),          // [14]
							ds_railroadResults.getCellData(row, "arvWrkPlNm"),          // [15]
							"CO",                                                        // [16] crryoutEdiType
							"CO"                                                         // [17] crryinEdiType
						],
						[]  // arrParam[1]
					]
				};

				var opts = {
					id : "smpPop",
					popupName : "반출입예정정보EDI등록",
					modal: true,
					type : "browserPopup",
					title : "win pop",
					width : "1100px",
					height: "850px"
				};

				$c.win.openPopup("/ui/ds/op/wrkplan/transwrkplan/op_202_02_21p.xml", opts, data);
				return true;
			};


			//-------------------------------------------------------------------------
			// 팝업 처리시 검색된 데이터인 경우 팝업 처리 안함
			//-------------------------------------------------------------------------
			scwin.f_chkOpenCommonPopUp = function (inObj, pairObj, disGubun, isCode) {
				// 값이 입력이 안된 경우, 해당 Text Box가 readonly 인 경우, 이전값과 동일한 경우 팝업을 실행하지 않음.
				if (!$c.gus.cfCanOpenPopup(inObj, pairObj))
					return;

				// 짝이 되는 오브젝트의 값 제거
				$c.gus.cfClearPairObj(pairObj);

				// 검색어 세팅
				var pVal = $c.gus.cfGetValue(inObj);

				// inObj가 코드 필드일 경우 팝업
				if (isCode == null || isCode == true)
					scwin.f_openCommonPopUp(disGubun, pVal, '', 'T', 'T');
				// inObj가 코드명 필드일 경우 팝업
				else
					scwin.f_openCommonPopUp(disGubun, '', pVal, 'T', 'T');
			};


			//-------------------------------------------------------------------------
			// 팝업
			//-------------------------------------------------------------------------
			scwin.f_openCommonPopUp = async function (disGubun, pCode, pName, pClose, pAllSearch) {
				switch (disGubun)
				{
					case 1: // 출발역
						// Select ID : retrieveTrainWorkPlace
						udc_comCodeDptWrkPl.cfCommonPopUp(
							scwin.udc_comCodeDptWrkPl_callBackFunc
							,pCode            		      	// 화면에서의 ??? Code Element의    Value,
							,pName            		      	// 화면에서의 ??? Name Element의    Value,
							,pClose           		      	// 결과가 1건 일때  원도우를    AutoClose 여부  (T:Close,F:Opened) "T", //pClose
							,null             		      	// 검색 결과    컬럼의 보여주는 개수 (SELECT절의 순서) MAX:10 - default (2)
							,null             		      	// Title순서    
							,null             		      	// 보여주는 각 컬럼들의 폭  
							,null             		      	// 컬럼중에서 숨기는    컬럼 지정   
							,null          		      	 	// SQL절의 WHERE절에    원하는 조건을 선택함 MAX:8개까지 가능
							,null            		       	// POP-UP뛰을때 원도우의    사용자 정의 폭
							,null            		       	// POP-UP뛰을때 우도우의    사용자 정의 높이    
							,null            		       	// 윈도우 위치 Y좌표    
							,null            		       	// 윈도우 위치 X좌표
							,null           		        // 중복체크여부 ("F") 
							,pAllSearch                 	// 전체검색허용여부 ("F") "T", //pAllSearch
							,"출발역조회,출발역명코드,출발역명" // POP-UP Window Title 검색어1,2     ("Win타이틀,첫번검색Nm,두번?검색Nm")
						);
						break;
					case 2: // 도착역
						// Select ID : retrieveTrainWorkPlace
						udc_comCodeArvWrkPl.cfCommonPopUp(
							scwin.udc_comCodeArvWrkPl_callBackFunc, pCode, pName, pClose
							,null, null, null, null,null
							,null, null, null, null, null
							,pAllSearch
							,"도착역명조회,도착역명코드,도착역명" 		// POP-UP Window Title 검색어1,2     ("Win타이틀,첫번검색Nm,두번?검색Nm")
						);
						break;

					default:
						break;
				}
			};


			///////////////////////////////////////////// U D C   E V E N T /////////////////////////////////////////

			// 출발역 클릭시 팝업
			scwin.udc_comCodeDptWrkPl_onclickEvent = function (e) {
				scwin.f_openCommonPopUp(1, ed_dptWrkPlCd.getValue(), ed_dptWrkPlNm.getValue(), "T", "T");
			};

			// 출발역 팝업 콜백함수
			scwin.udc_comCodeDptWrkPl_callBackFunc = function(ret) {
				$c.gus.cfSetReturnValue(ret, ed_dptWrkPlCd, ed_dptWrkPlNm);
			};

			// 출발역 코드 onBlur
			scwin.udc_comCodeDptWrkPl_onblurCodeEvent = function (e) {
				scwin.f_chkOpenCommonPopUp(ed_dptWrkPlCd, ed_dptWrkPlNm, 1, true);
			};

			// 출발역 Name onChange
			scwin.udc_comCodeDptWrkPl_onviewchangeNameEvent = function (info) {
				scwin.f_chkOpenCommonPopUp(ed_dptWrkPlNm, ed_dptWrkPlCd, 1, false);
			};


			// 도착역 클릭시 팝업
			scwin.udc_comCodeArvWrkPl_onclickEvent = function (e) {
				scwin.f_openCommonPopUp(2, ed_arvWrkPlCd.getValue(), ed_arvWrkPlNm.getValue(), "T", "T");
			};

			// 도착역 팝업 콜백함수
			scwin.udc_comCodeArvWrkPl_callBackFunc = function(ret) {
				$c.gus.cfSetReturnValue(ret, ed_arvWrkPlCd, ed_arvWrkPlNm);
			};

			// 도착역 코드 onBlur
			scwin.udc_comCodeArvWrkPl_onblurCodeEvent = function (e) {
			scwin.f_chkOpenCommonPopUp(ed_arvWrkPlCd, ed_arvWrkPlNm, 2, true);
			};

			// 도착역 Name onChange
			scwin.udc_comCodeArvWrkPl_onviewchangeNameEvent = function (info) {
				scwin.f_chkOpenCommonPopUp(ed_arvWrkPlNm, ed_arvWrkPlCd, 2, false);
			};



			///////////////////////////////////////////// S U B M I S S I O N    E V E N T /////////////////////////////////////////

			// 조회
			scwin.sbm_retrieve_submitdone = function (e) {
				if (e.responseJSON.resultDataSet[0].Code < 0) return;

				if (ds_railroadResults.getRowCount() == 0) {
					$c.win.alert("조회된 데이터가 없습니다.");
				} else {
					scwin.f_retrieve2();
				}
				totalRows1.setValue(ds_railroadResults.getRowCount());

				// 신규 데이터 로드 시 정렬 상태 초기화
				scwin._sortState = { colID: "", order: 1 };
				scwin._viewInitialized = false;
				scwin._doSort("", 1);
			};

			// 조회(통계)
			scwin.sbm_retrieve2_submitdone = function (e) {
				if (e.responseJSON.resultDataSet[0].Code < 0) {
					return;
				}

				totalRows2.setValue(ds_railroadTotCnt.getRowCount());
			};

			///////////////////////////////////////////// C O M P O N E N T   E V E N T /////////////////////////////////////////

			// BeforeSort
			scwin.gr_railroadResults_onbeforesort = function (sortInfo) {
				var colID = sortInfo.bodyColId || "";

				// 같은 컬럼 재클릭: 1(오름) → -1(내림) → 0(초기화) 순환
				// 다른 컬럼 클릭: 새 컬럼 1(오름)부터 시작
				if (colID === scwin._sortState.colID) {
					if (scwin._sortState.order === 1)       { scwin._sortState.order = -1; }
					else if (scwin._sortState.order === -1) { scwin._sortState.order = 0;  }
					else                                    { scwin._sortState.order = 1;  }
				} else {
					scwin._sortState.colID = colID;
					scwin._sortState.order = 1;
				}

				scwin._doSort(scwin._sortState.colID, scwin._sortState.order);
				return false; // 그리드 기본 정렬(indicator 포함) 완전 차단
			};

			// Sort
			// onbeforesort에서 return false로 막으므로 헤더 클릭 시 호출 안 됨
			// sbm_retrieve_submitdone에서 _doSort를 직접 호출하므로 여기서는 아무것도 하지 않음
			scwin.gr_railroadResults_onsort = function () {
			};

			// ========================== 직접 정렬 ==========================
			scwin._doSort = function (clickedColID, clickedOrder) {
				var ds = $p.getComponentById("ds_railroadResults");
				var rowCount = ds.getRowCount();

				// order=0(초기화): 컬럼 지정 없이 default 정렬 
				var effectiveColID = (clickedOrder === 0) ? "" : clickedColID;
				var isByDate = (effectiveColID === "dptDtHh");

				// subsum / view 컬럼 세팅
				for (var i = 0; i < rowCount; i++) {
					var dpt   = ds.getCellData(i, "dptWrkPlNm") || "";
					var arv   = ds.getCellData(i, "arvWrkPlNm") || "";
					var dptDt = ds.getCellData(i, "dptDt")      || "";

					if (isByDate) {
						// 대분류: dptDt, 중분류: dptDt+dpt+arv
						ds.setCellData(i, "subsum2", dptDt);
						ds.setCellData(i, "subsum1", dptDt + "||" + dpt + "||" + arv);
					} else {
						// 대분류: dptWrkPlNm, 중분류: dpt+arv
						ds.setCellData(i, "subsum2", dpt);
						ds.setCellData(i, "subsum1", dpt + "||" + arv);
					}

					// view 컬럼은 초기 로드 시에만 세팅
					//  - 정렬마다 setCellData하면 그리드 내부 sort indicator가 리셋되므로 skip
					if (!scwin._viewInitialized) {
						ds.setCellData(i, "dptWrkPlNmView", dpt);
						ds.setCellData(i, "arvWrkPlNmView", arv);
					}
				}
				scwin._viewInitialized = true;

				// multisort
				if (isByDate) {
					// 출발일시(사용자방향) → 출발역(오름) → 도착역(오름)
					ds.multisort({
						sortIndex: "dptDtHh dptWrkPlNmView arvWrkPlNmView",
						sortOrder: clickedOrder + " 1 1 " 
					});
				} else if (effectiveColID === "dptWrkPlNmView") {
					// 출발역: 사용자 방향, 도착역: 오름
					ds.multisort({
						sortIndex: "dptWrkPlNmView arvWrkPlNmView",
						sortOrder: clickedOrder + " 1"
					});
				} else if (effectiveColID === "arvWrkPlNmView") {
					// 도착역: 사용자 방향, 출발역: 오름
					ds.multisort({
						sortIndex: "arvWrkPlNmView dptWrkPlNmView",
						sortOrder: clickedOrder + " 1"
					});
				} else if (effectiveColID) {
					// 그 외 컬럼: 출발역+도착역 그룹 유지(1차), 클릭 컬럼 그룹 내 2차 정렬
					ds.multisort({
						sortIndex: effectiveColID + " dptWrkPlNmView arvWrkPlNmView",
						sortOrder: clickedOrder + " 1 1"
					});
				} else {
					// order=0 초기화 or 초기 로드: 출발역(오름) → 도착역(오름) 고정
					ds.multisort({
						sortIndex: "dptWrkPlNmView arvWrkPlNmView",
						sortOrder: "1 1"
					});
				}
			};

			// 출발역 반환
			scwin.getDptWrkPlNm = function(groupKey) {
				var parts = groupKey.split("||");
				// default: "dpt||arv" → parts[0]
				// byDate: "dptDt||dpt||arv" → "" (공백으로 표시)
				return parts.length === 3 ? "" : parts[0];
			};

			// 도착역 반환
			scwin.getArvWrkPlNm = function(groupKey) {
				var parts = groupKey.split("||");
				// default: "dpt||arv" → parts[1]
				// byDate: "dptDt||dpt||arv" → parts[2]
				return parts.length === 3 ? parts[2] : parts[1];
			};


			// 대분류 소계 레이블: Default=출발역명, byDate=출발일자
			scwin.getSubsum2Label = function(val) {
				// val이 숫자로만 이루어진 날짜형식(yyyyMMdd)이면 byDate → 빈칸
				// val이 역명이면 Default → 그대로 표시
				if (!val) return "";
				
				if (/^\d{8}$/.test(val)) { // byDate → 빈칸
					return ""; 
				}
				return val;   // Default → 출발역명
			};



		]]></script>

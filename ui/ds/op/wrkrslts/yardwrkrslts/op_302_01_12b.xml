scwin.arrowDtExp = function (data, formatData, rowIdx, colIdx) {
    if (data >= 3) {
        gr_crryInoutList.setCellStyle(rowIdx, colIdx, "color", "red");
    } else {
        gr_crryInoutList.setCellStyle(rowIdx, colIdx, "color", "black");
    }

    return $c.gus.decode(data, 0, "", data);
};


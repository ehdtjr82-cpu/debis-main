scwin.f_Retrieve = async function() {
    let chkwrkplcd = ed_wrkPlCd.getValue();
    if($c.gus.cfIsNull(chkwrkplcd)){
        await $c.win.alert("작업장 코드는 필수 입력 항목입니다.");
        ed_wrkPlCd.focus();
        return;
    }
	// 검색조건 필수 입력 체크
	if (!$c.gus.cfValidate([tb_searchCondition])) {
		return;
	}


	$c.sbm.execute(sbm_Retrieve);
};


scwin.calInputTime = function (hr,min) {
    console.log("hr : "+hr);
    var exp = ""
    if(hr != "" && hr != null && hr != "undefined") {
        console.log("min : "+ min);
        var totalHr = parseInt(hr) + parseInt(min/60);
        var totalMin = parseInt(min%60);
        var exp = totalHr + "H " + totalMin + "M";
    }

    return exp;
}

scwin.calNetOprttTime = function (hr,min) {
    var exp = ""
    if(hr != "" && hr != null && hr != "undefined") {
        var totalHr = parseInt(hr) + parseInt(min/60);
        var totalMin = parseInt(min%60);
        var exp = totalHr + "H " + totalMin + "M";
    }
    return exp;
}


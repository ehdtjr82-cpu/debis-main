scwin.sbm_retrieve_submitdone = async function (e) {
    if(ds_cvsslInfo.getRowCount() == 0){
		await $c.win.alert("미등록된 본선관리번호 입니다. 확인후 다시 입력해주세요");
		$c.gus.cfDisableKeyData();
		$c.gus.cfDisableAllBtn();
		$c.gus.cfEnableBtnOnly([btn_search]);
		$c.gus.cfEnableObj(ed_cvsslMgntNo, true);
		ed_cvsslMgntNo.setValue("");
		ed_cvsslMgntNo.focus();
	}else{
		$c.gus.cfEnableKeyData();
		$c.gus.cfEnableAllBtn();
	}

  	if( ds_eachHeavyEquipInputDetail.getRowCount() == 0 ){
		await $c.gus.cfAlertMsg("[본선별중기투입실적] "+MSG_CM_ERR_003);
  	}

    var options = {};
    options.sortIndex = "hveqKndNm impExpClsNm";
    options.sortOrder = "1 1";

    ds_eachHeavyEquipInputSumup.multisort( options );

    scwin.f_DivHoldEachWorkPlanList();

    spa_cnt1.setValue(ds_eachHeavyEquipInputDetail.getRowCount());
    spa_cnt2.setValue(ds_eachHeavyEquipInputSumup.getRowCount());


};


            console.log(ds_cvsslInfo.getCellData(0, "impPortcnt"));
            tr_imp.setStyle("display", "table-row");
        } else {
            tr_imp.setStyle("display", "none");
        }

        if(ds_cvsslInfo.getCellData(0, "expPortcnt") != "" && ds_cvsslInfo.getCellData(0, "expPortcnt") != null) {
            console.log(ds_cvsslInfo.getCellData(0, "expPortcnt"));
            tr_exp.setStyle("display", "table-row");
        } else {
            tr_exp.setStyle("display", "none");

//-------------------------------------------------------------------------
// 데이터 로드시
//-------------------------------------------------------------------------
scwin.ds_master_ondataload = function () {

    if ($c.gus.cfCheckCreateFlag() == true) {
        $c.gus.cfTurnCreateFlag(false);
    } else {
        if (ds_master.getTotalRow() == 0) {
            $c.win.alert(MSG_CM_WRN_002);
        }
    }

    for (i = 0; i < ds_master.getTotalRow(); i++) {
        if (ds_master.getCellData(i, "ioClsCd") == "I") {
            ds_master.setCellData(i, "savePrd", ds_master.getCellData(i, "savePrd"));
        } else {
            ds_master.setCellData(i, "savePrd", "");
        }

    }



    spa_totalRows.setValue(ds_master.getTotalRow());
};

//-------------------------------------------------------------------------
// 데이터 로드시
//-------------------------------------------------------------------------
scwin.gr_confirmYn = function (data) {
    return $c.gus.decode(data, 
        "0", "미확정",
        "1", "확정",
        "2", "완료"
    );

}


};

//조회 clear 버튼
scwin.btn_clear_onclick = function (e) {
    console.log("btn_clear_onclick");
    scwin.f_fieldClear();
};

//조회 버튼
scwin.btn_search_onclick = function (e) {
    console.log("btn_search_onclick");
    scwin.f_retrieve();
};



scwin.onpageload = async function() {
	scwin.valueObject  = $c.data.getParameter();  // 물류 점소 코드
    
};

//-------------------------------------------------------------------------
// onUdcCompleted : UDC 완료. 그리는 시점 차이 보완. 
//-------------------------------------------------------------------------
scwin.onUdcCompleted = function() {
    $p.setTimeout(async function() {
        scwin.f_createSearchHeader();
        $c.gus.cfDisableKeyData();
        
        if (typeof(scwin.valueObject) != "undefined" && scwin.valueObject != null) {
            var blNo = scwin.valueObject.blNo;
            
            ds_hidden.set("ser_blNo", blNo);
            
            if ( blNo != null ) {
                scwin.f_Retrieve();					
            }
            
        } else {  // 테스트용, 실제 적용시 제거.....
            ds_hidden.set("ser_blNo", "1234567890123456");
            scwin.f_Retrieve();
        }
    }, {"delay":50});
};

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = function () {  
    $c.sbm.execute(sbm_retrieve);
};

scwin.sbm_retrieve_submit = function (e) {
    ds_serach.set("ser_blNo", ds_hidden.get("ser_blNo"));
};
]]></script>

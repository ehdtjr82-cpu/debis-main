scwin.f_runExcel = async function (varGrNm) {
    var totCnt = ds_BillingrateDTOList.getRowCount();
    var sheetTitle = "청구요율일괄변경";

    if (totCnt != 0) {
        let cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");

        if (cfrm) {

            const options = {
                fileName: sheetTitle,
                sheetName: sheetTitle
            };

            $c.data.downloadGridViewExcel(gr_BillingrateDTOList, options);
        }

    } else {
        $c.gus.cfAlertMsg(MSG_CM_WRN_002);
    }
};



scwin.sbm_retrieve_submitdone = function (e) {
    if (ds_BillingrateDTOList.getRowCount() == 0) {
        $c.win.alert("조회된 데이터가 없습니다.");
    }
    totalRows.setValue(ds_BillingrateDTOList.getRowCount());
};



scwin.sbm_save_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code == 0) {
        await $c.win.alert("저장하였습니다.");
        scwin.f_Retrieve();
        ed_newData.setValue("");
    }
};



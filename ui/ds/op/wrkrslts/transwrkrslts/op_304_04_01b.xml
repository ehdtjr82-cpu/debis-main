scwin.f_sellItemDetail = function (arg) {
    let strOrderDetailUrl = "/ds/op/wrkrslts/transwrkrslts/op_304_04_02b.xml";
    let strOrderDetailTitle = "과태료등록";
    let strProgramId = "op_304_04_02b.jsp";

    let vehclNm = arg;
    let vehclNo = vehclNm.substring(5, 9);


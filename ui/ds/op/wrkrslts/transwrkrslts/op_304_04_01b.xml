    acb_con_branCd.setSelectedIndex(0);
    ed_con_dtStart.setValue(scwin.toMonth);
    ed_con_dtEnd.setValue(scwin.toDay);
    acb_con_fltRateKnd.setSelectedIndex(0);
    acb_con_retrvYn.setSelectedIndex(0);

//-------------------------------------------------------------------------
// 검색일 체크
//-------------------------------------------------------------------------
scwin.f_check = async function () {
    var value1 = ed_con_dtStart.getValue();
    var value2 = ed_con_dtEnd.getValue();

    if (! await $c.gus.cfIsAfterDate(value1, value2)) {
        $c.gus.cfAlertMsg("발생기간 종료일를 발생기간시작일보다 이전으로 선택[입력]하여 주십시오");
        return false;
    }

    return true;
};


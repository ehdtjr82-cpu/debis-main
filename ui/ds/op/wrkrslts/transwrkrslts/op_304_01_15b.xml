        fileName: "벌크작업실적 상세",
        sheetName: "벌크 작업실적 상세",
        colMerge: true
    }

    $c.data.downloadGridViewExcel(gr_cntrWrkRslts, options);
};

scwin.sbm_retreive_submitdone = function (e) {
    if (ds_cntrWrkRslts.getRowCount() == 0) {
        $c.gus.cfAlertMsg(MSG_CM_WRN_002, [""]);
    } else {
        gr_cntrWrkRslts.setVisibleRowNum(13);
    }

    // 그리드 푸터 셋팅 expression 사용하면 초기값이 0으로셋팅됌.
    let footer1 = 0;
    let footer2 = 0;
    let footer3 = 0;
    let footer4 = 0;
    let footer5 = 0;
    let footer6 = 0;

    for (let i = 0; i < ds_cntrWrkRslts.getRowCount(); i++) {
        let rowJson = ds_cntrWrkRslts.getRowJSON(i);

        footer1 += Number(rowJson.qty);
        footer2 += Number(rowJson.grossWt);
        footer3 += Number(rowJson.realSellAmt);
        footer4 += Number(rowJson.pchsAmt);
        footer5 += Number(rowJson.cbm);
        footer6 += Number(rowJson.sellAmt);
    }

    gr_cntrWrkRslts.setFooterValue("footer1", footer1);
    gr_cntrWrkRslts.setFooterValue("footer2", footer2);
    gr_cntrWrkRslts.setFooterValue("footer3", footer3);
    gr_cntrWrkRslts.setFooterValue("footer4", footer4);
    gr_cntrWrkRslts.setFooterValue("footer5", footer5);
    gr_cntrWrkRslts.setFooterValue("footer6", footer6);

    let count = ds_cntrWrkRslts.getRowCount();

    if (count == 0) {
        totalRows.setValue(count);
    } else {
        totalRows.setValue(count + gr_cntrWrkRslts.getSubtotalRowList().length + 1);
    }

    // -----------------------------------------------
    let sp = 0;

    for (let i = 0; i < ds_cntrWrkRslts.getRowCount(); i++) {
        let rowJson = ds_cntrWrkRslts.getRowJSON(i);
        let str1 = rowJson.odrNo + rowJson.mchtOdrNo;
        let str2 = rowJson.arvWrkPlNm + rowJson.arvDistrictNm;
        let str3 = rowJson.vehclNo + rowJson.eqKndNm + rowJson.eqNrmNm;

        if (rowJson.mchtOdrNo == "") {
            str1 = str1 + sp++;
        }

        if (rowJson.arvDistrictNm == "") {
            str2 = str2 + sp++;
        }

        if (rowJson.eqKndNm == "") {
            str3 = str3 + sp++;
        }

        ds_cntrWrkRslts.setCellData(i, "suppress12", str1);
        ds_cntrWrkRslts.setCellData(i, "suppress5", str2);
        ds_cntrWrkRslts.setCellData(i, "suppress1", str3);
    }

    gr_cntrWrkRslts.refreshRow(0);
};


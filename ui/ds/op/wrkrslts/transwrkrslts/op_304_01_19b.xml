scwin.f_Reset = async function () {
    await $c.gus.cfInitObjects(tb_searchCondition);

    ed_srchWrkStDt.setValue(scwin.strToDate);
    ed_srchWrkEndDt.setValue(scwin.strToDate);
};


//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function () {
    if (!await $c.gus.cfValidate([ed_srchWrkStDt]) || !await $c.gus.cfValidate([ed_srchWrkEndDt])) {
        return;
    }
    if (!await $c.gus.cfIsAfterDate(ed_srchWrkStDt.getValue(), ed_srchWrkEndDt.getValue())) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_039); // 시작일자를 종료일 이전으로 선택[입력]하여 주십시오.
        ed_srchWrkStDt.focus();
        return;
    }

    $c.sbm.execute(sbm_retreive);
};


scwin.sbm_retreive_submitdone = async function (e) {
    if (ds_cntrWrkRslts.getRowCount() == 0) {
        await $c.gus.cfAlertMsg(MSG_CM_WRN_002, [""]);
    }

    totalRows.setValue(ds_cntrWrkRslts.getRowCount());
};

scwin.sbm_retreive_submiterror = function (e) {
    $c.gus.cfShowError(e);
};


//작업구분 onchange
scwin.co_lc_srchWrkClsCd_onchange = function (info) {
    var chkVal = co_lc_srchWrkClsCd.getValue();

    if (chkVal == "B") {
        gr_cntrWrkRslts.setColumnVisible("cntrNo", false);
        gr_cntrWrkRslts.setColumnVisible("lineCd", false);
        gr_cntrWrkRslts.setColumnVisible("cntrSizCd", false);
        gr_cntrWrkRslts.setColumnVisible("cntrTypCd", false);
        gr_cntrWrkRslts.setColumnVisible("fullEmptyClsCd", false);
        gr_cntrWrkRslts.setColumnVisible("qty", true);
        gr_cntrWrkRslts.setColumnVisible("unitCd", true);
        gr_cntrWrkRslts.setColumnVisible("grossWt", true);
        gr_cntrWrkRslts.setColumnVisible("cbm", true);

        $c.gus.cfEnableObjects([udc_comCodeComm]);
        $c.gus.cfDisableObjects([acb_transKnd]);

    } else if (chkVal == "C") {
        gr_cntrWrkRslts.setColumnVisible("cntrNo", true);
        gr_cntrWrkRslts.setColumnVisible("lineCd", true);
        gr_cntrWrkRslts.setColumnVisible("cntrSizCd", true);
        gr_cntrWrkRslts.setColumnVisible("cntrTypCd", true);
        gr_cntrWrkRslts.setColumnVisible("fullEmptyClsCd", true);
        gr_cntrWrkRslts.setColumnVisible("qty", false);
        gr_cntrWrkRslts.setColumnVisible("unitCd", false);
        gr_cntrWrkRslts.setColumnVisible("grossWt", false);
        gr_cntrWrkRslts.setColumnVisible("cbm", false);

        $c.gus.cfDisableObjects([udc_comCodeComm]);
        $c.gus.cfEnableObjects([acb_transKnd]);
    }
};

//-------------------------------------------------------------------------
// 팝업 처리시 검색된 데이터인 경우 팝업 처리 안함.
//-------------------------------------------------------------------------
scwin.f_chkOpenCommonPopUp = async function (inObj, pairObj, disGubun, isCode) {
    // 값이 입력이 안된 경우, 해당 Text Box가 readonly 인 경우, 이전값과 동일한 경우 팝업을 실행하지 않음.
    if (!await $c.gus.cfCanOpenPopup(inObj, pairObj)) {
        if (disGubun == '4') txt_srchVehclNo.setValue("");
        return;
    }
    // 짝이 되는 오브젝트의 값 제거
    await $c.gus.cfClearPairObj(pairObj);
    // 검색어 세팅
    var pVal = await $c.gus.cfGetValue(inObj);

    // inObj가 코드 필드일 경우 팝업
    if (isCode == null || isCode == true)
        scwin.f_openPopUp(disGubun, pVal, '', 'T', 'T');
    // inObj가 코드명 필드일 경우 팝업
    else
        scwin.f_openPopUp(disGubun, '', pVal, 'T', 'T');
}



scwin.onpageload = function () {
    ed_srchMchtClntNo.hide();
    const codeOptions = [
        { grpCd: "SD113", compID: "lc_srchOdrKnd" }
    ];
    $c.data.setCommonCode(codeOptions);

    $c.sbm.execute(sbm_srchWrkClsCd);
    $c.sbm.execute(sbm_srchLobran);
};

scwin.onUdcCompleted = function () {
    ed_srchWrkStDt.setValue(scwin.strToDate);
    ed_srchWrkEndDt.setValue(scwin.strToDate);
};

scwin.sbm_srchWrkClsCd_submitdone = function (e) {
    co_lc_srchWrkClsCd.setSelectedIndex(0);

    co_lc_srchLobran.focus();
};

scwin.sbm_srchLobran_submitdone = function (e) {
    //전체조건 추가
    var sLoUpperLobranCd = scwin.sLobranCd;
    var eqIndex = false;
    for (i = 0; i < ds_srchLobran.getRowCount(); i++) {
        if (sLoUpperLobranCd == ds_srchLobran.getCellData(i, "lobranCd")) {
            eqIndex = true;
        }
    }

    if (eqIndex) {
        co_lc_srchLobran.setValue(sLoUpperLobranCd);
    } else {
        co_lc_srchLobran.setSelectedIndex(0);
    }
};


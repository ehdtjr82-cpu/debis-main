                , pAllSearch					// 전체검색허용여부	("F")
                , "차량번호,차량번호단축코드,차량번호명"				// POP-UP Window Title 검색어1,2	 ("Win타이틀,첫번검색Nm,두번?검색Nm")
            );
            break;

        default:
            break;
    }
}



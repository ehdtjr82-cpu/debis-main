scwin.f_runExcel = async function(varGrNm) {
    var totCnt = ds_Present.getRowCount();
    var sheetTitle = "크나우프보관료조회";

    if (totCnt != 0) {
        let cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");

        if (cfrm) {

            const options = {
                fileName: sheetTitle,
                sheetName: sheetTitle
            };
            
            $c.data.downloadGridViewExcel(gr_InIntendInformation, options);
        }

    } else {
        $c.gus.cfAlertMsg(MSG_CM_WRN_002);
    }
};







    				</xf:trigger>
    			</xf:group>
    		</xf:group>
    		<xf:group class="round-box" id="">
    			<xf:group adaptiveThreshold="" class="gvwbox" id="grd_section1" style="">
    				<w2:gridView autoFit="allColumn" checkAllType="false" class="wq_gvw" dataList="ds_out" id="gr_out" style="" readOnly="true" ev:oncelldblclick="scwin.gr_out_oncelldblclick">

    							<w2:column width="100" inputType="text" id="postAcctDeptNm" value="회계처리 귀속부서명" displayMode="label"></w2:column>
    							<w2:column width="100" inputType="text" id="drawEmpNo" value="작성자사원번호" displayMode="label" hidden="true"></w2:column>

		<script type="text/javascript"><![CDATA[
scwin.strDate = "";

//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function () {
    scwin.strDate = $c.date.getServerDateTime("yyyyMMdd");
};

scwin.onUdcCompleted = function () {
    ed_regStDt.setValue(scwin.strDate);
    ed_regEndDt.setValue(scwin.strDate);
};

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function () {
    let chk1 = await $c.gus.cfValidate([ed_regStDt, ed_regEndDt]);

    if (!chk1) {
        return;
    }

    let chk2 = await $c.gus.cfIsAfterDate(ed_regStDt.getValue(), ed_regEndDt.getValue());

    if (!chk2) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
        ed_regStDt.focus();
        return;
    }

    $c.sbm.execute(sbm_retrieve);
};

//-------------------------------------------
// 그리드 데이터 엑셀로 다운
//-------------------------------------------
scwin.f_runExcel = async function () {
    let totCnt = ds_Fatigue.getRowCount();
    let sheetTitle = "크나우프운전자피로도이력관리";

    if (totCnt != 0) {
        let cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");

        if (cfrm) {
            $c.data.downloadGridViewExcel(gr_Fatigue, { fileName: sheetTitle + ".xlsx", sheetName: sheetTitle });
        }
    } else {
        $c.gus.cfAlertMsg(MSG_CM_WRN_002);
    }
};

//-------------------------------------------
// 조회조건 초기화
//-------------------------------------------
scwin.f_FieldClear = function () {
    $c.gus.cfInitObjects(tb_mainData);

    ed_regStDt.setValue(scwin.strDate);
    ed_regEndDt.setValue(scwin.strDate);
};

scwin.sbm_retrieve_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    let rowCnt = ds_Fatigue.getRowCount();

    if (rowCnt == 0) {
        await $c.win.alert("조회된 데이터가 없습니다.");
    }

    totalRows.setValue(ds_Fatigue.getTotalRow());
};]]></script>

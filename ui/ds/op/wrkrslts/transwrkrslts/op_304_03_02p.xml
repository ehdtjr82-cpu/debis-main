		<script lazy="false" type="text/javascript"><![CDATA[
scwin.parentDs;
scwin.parentGr;

scwin.onpageload = function () {
    ds_parent.setJSON($c.data.getParameter("ds_emp2"));
   
    $c.sbm.execute(sbm_retrieve);
};

scwin.btn_Upt_onclick = function (e) {
    $c.win.closePopup();
};

scwin.btn_Add_onclick = function (e) {
    ds_parent2.removeAll();
    ds_parent2.setJSON(ds_parent.getAllJSON());
    chkRow = gr_emp.getCheckedIndex("che");
    for (var i = 0; i < chkRow.length; i++) {
        if (+ds_emp.getCellData(chkRow[i], "dcScAmt") == "") {
            $c.gus.cfAlertMsg(MSG_CM_WRN_003, ["할증액"]);
            return;
        }
        if (ds_parent2.getCellData(i, "odrNo") == "" && ds_parent2.getCellData(i, "dcScNm") == "") {
            idx = ds_parent2.insertRow();
            ds_parent2.setRowJSON(i, ds_parent.getRowJSON(0), true);
        }
        // ds_parent2.setRowJSON(ds_parent.getRowJSON(ds_parent.getMatchedIndex("dcScNm", ds_emp.getCellData(chkRow[i], "dcScCdNm"))));
        ds_parent2.setCellData(i, "dcScNm" , ds_emp.getCellData(chkRow[i], "dcScCdNm"));
        ds_parent2.setCellData(i, "dcScCd" , ds_emp.getCellData(chkRow[i], "dcScCd"));
        ds_parent2.setCellData(i, "dcScAmt", ds_emp.getCellData(chkRow[i], "dcScAmt"));
        ds_parent2.setCellData(i, "che"    , ds_emp.getCellData(chkRow[i], "che"));
    }
    // scwin.parentDs.removeAll();
    // scwin.parentDs.setJSON(ds_parent2.getAllJSON());
    $c.win.closePopup(JSON.stringify(ds_parent2.getAllJSON()));
};

scwin.sbm_retrieve_submitdone = function (e) {
    var dl = ds_emp;

    var json = dl.getAllJSON();
    var unique = {};
    var result = [];

    json.forEach(function (row) {
        if (!unique[row.dcScCdNm]) {
            unique[row.dcScCdNm] = true;
            result.push(row);
        }
    });

    dl.removeAll();
    dl.setJSON(result);
    if (ds_emp.getTotalRow() > 0) {
        for (var i = 0; i < ds_emp.getTotalRow(); i++) {
            for (var j = 0; j < ds_parent.getTotalRow(); j++) {
                if (ds_emp.getCellData(i, "dcScCdNm") == ds_parent.getCellData(j, "dcScNm")) {
                    ds_emp.setCellData(i, "che", "1");
                    ds_emp.setCellData(i, "dcScAmt", ds_parent.getCellData(j, "dcScAmt"));
                }
            }
        }
    } else {

    }
}]]></script>

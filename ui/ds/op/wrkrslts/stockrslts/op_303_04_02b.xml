		<script lazy="false" type="text/javascript"><![CDATA[
scwin.today = $c.date.getServerDateTime("yyyyMMdd");

scwin.onpageload = function () {
    let codeOptions = [
        { grpCd: "OP475", compID: "gr_master: frgtKndCd" }
    ];

    $c.data.setCommonCode(codeOptions);

    $c.sbm.execute(sbm_wrkPlCd);
};

scwin.onUdcCompleted = function () {
    $c.data.setPopupTitle("내국화물 반출입 재고현황");

    // 일자 setting
    ed_fromDt.setValue(scwin.today.substring(0, 6) + "01");
    ed_toDt.setValue(scwin.today);

    lc_wrkPlCd.focus();
};

//-------------------------------------------------------------------------
// RETRIEVE;
//-------------------------------------------------------------------------
scwin.f_retrieve = async function () {
    if (lc_wrkPlCd.getValue() == "") {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_002, ["작업장"]);
        lc_wrkPlCd.focus();
        return;
    }

    $c.sbm.execute(sbm_retrieve);
};

//-------------------------------------------------------------------------
// 조회조기 필드 Clear
//-------------------------------------------------------------------------
scwin.f_FieldClear = function () {
    $c.gus.cfInitObjects(tbl_search, null);
};

//-------------------------------------------------------------------------
// Excel
//-------------------------------------------------------------------------
scwin.f_runExcel = async function () {
    let totCnt = ds_master.getRowCount();
    let sheetTitle = "내국화물현황_" + ed_bondZoneCd.getValue() + "(" + scwin.today + ")";

    if (totCnt != 0) {
        let cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");

        if (cfrm) {
            let options = {
                fileName: sheetTitle + ".xlsx",
                sheetName: sheetTitle
            };

            $c.data.downloadGridViewExcel(gr_master, options);
        }
    } else {
        $c.win.alert(MSG_CM_WRN_002);
    }
};

scwin.sbm_wrkPlCd_submitdone = function (e) {
    let data = ds_wrkPlCd.getAllJSON();
    let resultVal = data.find(item => item.wrkPlCd == lc_wrkPlCd.getValue());

    ed_bondZoneCd.setValue(resultVal.bondZoneCd);
};

scwin.sbm_retreive_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) {
        return;
    }

    if (ds_master.getRowCount() == 0) {
        $c.gus.cfAlertMsg(MSG_CM_ERR_003);
    }

    totalRows.setValue(ds_master.getRowCount())
};

scwin.lc_wrkPlCd_onchange = function (info) {
    let data = ds_wrkPlCd.getAllJSON();
    let resultVal = data.find(item => item.wrkPlCd == info.newValue);

    ed_bondZoneCd.setValue(resultVal.bondZoneCd);
};]]></script>

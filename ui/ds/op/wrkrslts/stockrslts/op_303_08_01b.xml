		{ grpCd : "SD113", compID : "acb_cnd_odrKndCd", opt :{"range" :"1,C"}} //<%= GauceUtil.getCodeList("SD113", new int[] {1,3}, new String[] {DsConstants.ODR_CNTR, "1" }) %>">
	];
	
    $c.data.setCommonCode(codeOptions, scwin.callBackCommonCode);
};

scwin.callBackCommonCode = function () {
    dlt_commonCodeSD113.removeColumnFilter('cd');

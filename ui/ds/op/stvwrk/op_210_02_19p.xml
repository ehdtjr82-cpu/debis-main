scwin.sbm_retrieve_submitdone = function (e) {
    var rowCnt = gr_master.getTotalRow();

    if (rowCnt == 0) {
        $c.gus.cfAlertMsg("조회된 데이터가 없습니다.");
    } else {
        $c.gus.cfEnableAllBtn();
    }

    spn_totalRow.setValue(rowCnt);
};


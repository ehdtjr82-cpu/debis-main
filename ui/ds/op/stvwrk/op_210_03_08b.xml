    acb_lobranCd.focus();

    ica_newWageAgrmntDt.setValue(vLastYYYY + "0401");
    ica_oldWageAgrmntDt.setValue(vBefLastYYYY + "0401");
    acb_wrkPlClsCd.setValue("02");
    chk_includeRetireYn.setValue("1");
}


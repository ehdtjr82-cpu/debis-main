		<script lazy="false" type="text/javascript"><![CDATA[
			scwin.lobranCd = $c.data.getMemInfo("lobranCd") != null ? $c.data.getMemInfo("lobranCd") : ""; // 물류 점소 코드
			scwin.vCurDate = "";

			scwin.onpageload = function () {
				scwin.vCurDate = $c.date.getServerDateTime("yyyyMM"); // 입항예정일자 from(현재 날짜가 포함된 달의 시작 일자)

				// 점소
				dma_lobranCd.set("sysCd", "BerthNonUsableEBC");
				dma_lobranCd.set("queryId", "retriveLobranCodeList");
				$c.sbm.execute(sbm_lobranCd);

				// 구분
				const codeOptions = [
					{ grpCd : "OP316", compID : "lc_wrkPlClsCd", opt : {"range" : "1,1"}},
				];
				$c.data.setCommonCode(codeOptions);

				scwin.f_SetDefaultData();
				$c.gus.cfDisableObjects([lc_wrkPlClsCd]);
			};

			///////////////////////////////////////// I N I T /////////////////////////////////////////

			//-------------------------------------------------------------------------
			// 조회조건 초기화
			//-------------------------------------------------------------------------
			scwin.f_InitObjects = function () {
				$c.gus.cfInitObjects(tb_mainData);
				scwin.f_SetDefaultData();
			};

			//-------------------------------------------------------------------------
			// Default Data Setting
			//-------------------------------------------------------------------------
			scwin.f_SetDefaultData = function () {
				ed_stdYm.setValue(scwin.vCurDate);

				lc_lobranCd.setValue(scwin.lobranCd);
				lc_lobranCd.focus();
			};

			///////////////////////////////////////// B U S I N E S S   L O G I C /////////////////////////////////////////
			
			//-------------------------------------------------------------------------
			// 조회
			//-------------------------------------------------------------------------
			scwin.f_Retrieve = async function() {
				// validExp Setting
				$c.gus.setValidExp(lc_lobranCd, "점소:yes");
				$c.gus.setValidExp(ed_stdYm, "시작일자:yes:length=6");

				let rtn = await $c.gus.cfValidate([lc_lobranCd, ed_stdYm], null, true); 
				if (!rtn) return;

				dma_condition.set("wrkPlClsCd", lc_wrkPlClsCd.getValue());
				dma_condition.set("endYm", ed_stdYm.getValue() + "31");
				dma_condition.set("gubun", "1");

				$c.sbm.execute(sbm_retrieve);
			}; 


			///////////////////////////////////////// S U B M I S S I O N    E V E N T /////////////////////////////////////////
			
			// 조회
			scwin.sbm_retrieve_submitdone = function (e) {
				if (e.responseJSON.resultDataSet[0].Code < 0) return;

				const rowCount = ds_wrkList.getRowCount();
				if (rowCount == 0) {
					$c.win.alert($c.data.getMessage(MSG_CM_ERR_003)); // 해당되는 자료가 존재하지 않습니다.
				}

				totalRows.setValue(rowCount);
			};


			// 점소
			scwin.sbm_lobranCd_submitdone = function (e) {
				if (e.responseJSON.resultDataSet[0].Code < 0) return;

				lc_lobranCd.setValue(scwin.lobranCd);
				lc_lobranCd.focus();
			};
			

			// ds_wrkList 데이터 로드 
			scwin.ds_wrkList_ondataload = function (e) {
				// 직책코드 -> 직책명 변환
				const occpgrdMap = {
					"MN": "소장(총괄)",
					"91": "원치",
					"92": "홀드",
					"93": "장비",
					"97": "장비(BTC조정)",
					"98": "장비(TTCAR운전)",
					"94": "원치(신호수)"
				};
				const rowCount = ds_wrkList.getRowCount();
				for (let i = 0; i < rowCount; i++) {
					const cd = ds_wrkList.getCellData(i, "occpgrdCd");
					ds_wrkList.setCellData(i, "occpgrdNm", occpgrdMap[cd] || cd);
				}
			};



			///////////////////////////////////////// C O M P O N E N T   E V E N T /////////////////////////////////////////
			
			// 조회조건 초기화 
			scwin.btn_fieldClear_onclick = function (e) {
				scwin.f_InitObjects();
			};

			// 조회
			scwin.btn_retrieve_onclick = function (e) {
				scwin.f_Retrieve();
			};

			// 엑셀 다운로드
			scwin.f_gridToExcel = function() {
				const excelName = "상용직 급여(평택)";
				let infoArr = [{
					rowIndex: 0,
                    colIndex: 0,
                    rowSpan: 1,
                    colSpan: scwin.getVisibleColumnCount(),
                    text: excelName,
                    textAlign: "center",
                    fontSize: "22px", // 16pt
                    fontName: "돋움체",
                    color: "black",
                    bgColor: "#ffffff",
                    drawBorder: false // line-width:0pt
				}];

				$c.data.downloadGridViewExcel(gr_wrkList, {
                    "fileName": excelName + ".xlsx",
                    "sheetName": excelName,
                    "startRowIndex": 2  // 타이틀(0행) + skiprow:1(1행) + 헤더(2행~)
                }, infoArr);
			};

			// 실제 화면 기준 보여지는 그리드뷰 컬럼 수 확인
			scwin.getVisibleColumnCount = function() {
				const total = gr_wrkList.getColumnCount();

				let visibleCount = 0;
				for (let i = 0; i < total; i++) {
					if (gr_wrkList.getColumnVisible(i)) {
						visibleCount++;
					}
				}
				return visibleCount;
			};



		]]></script>

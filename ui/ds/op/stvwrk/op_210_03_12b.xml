                , null // 윈도우 위치 X좌표
                , null // 중복체크여부 ("F")
                , "T" // 전체검색허용여부 ("F")
                , "사원,사원코드,사원명" // POP-UP Window Title 검색어1,2     ("Win타이틀,첫번검색Nm,두번?검색Nm")

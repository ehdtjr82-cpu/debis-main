//-------------------------------------------------------------------------
// 팝업 처리시 검색된 데이터인 경우 팝업 처리 안함.
//-------------------------------------------------------------------------
scwin.f_chkOpenCommonPopUp = function(inObj, pairObj, disGubun, isCode) {

    // 값이 입력이 안된 경우, 해당 Text Box가 readonly 인 경우, 이전값과 동일한 경우 팝업을 실행하지 않음.
 	if (!$c.gus.cfCanOpenPopup(inObj, pairObj))
       return;

	// 짝이 되는 오브젝트의 값 제거
	$c.gus.cfClearPairObj(pairObj);

	// 검색어 세팅
	var pVal = $c.gus.cfGetValue(inObj);

   	// inObj가 코드 필드일 경우 팝업
    if (isCode == null || isCode == true)
        scwin.f_openCommonPopUp(disGubun, pVal, '', 'T', 'T');
        // inObj가 코드명 필드일 경우 팝업
    else
        scwin.f_openCommonPopUp(disGubun, '', pVal, 'T', 'T');
}

//-------------------------------------------------------------------------
// function name : f_openPopUp
// function desc : popup
//-------------------------------------------------------------------------
scwin.f_openCommonPopUp = function(disGubun, pCode, pName, pClose, pAllSearch) {

	var rtnList = new Array();

	switch (disGubun)
  	{
  		case 1:
  		    //장치장
            rtnList = udc_comCode_arv.cfCommonPopUp(scwin.udc_comCode_arv_callBackFunc
							        , pCode					// 화면에서의 ??? Code Element의	Value
							        , pName					// 화면에서의 ??? Name Element의	Value
							        , pClose					// 결과가 1건 일때  원도우를	AutoClose 여부	(T:Close,F:Opened)
							        , '5'					// 검색 결과	컬럼의 보여주는	개수 (SELECT절의 순서) MAX:10 - default (2)
							        , null					// Title순서
							        , '150,170'  		    // 보여주는 각 컬럼들의 폭
							        , null					// 컬럼중에서 숨기는	컬럼 지정
							        , ',,,1,,'				// SQL절의 WHERE절에	원하는 조건을 선택함 MAX:8개까지 가능
							        , null					// POP-UP뛰을때 원도우의	사용자 정의	폭
							        , null					// POP-UP뛰을때 우도우의	사용자 정의	높이
							        , null					// 윈도우 위치 Y좌표
							        , null					// 윈도우 위치 X좌표
							        , null					// 중복체크여부	("F")
							        , pAllSearch				// 전체검색허용여부	("F")
							        , "장치장,장지창코드,장치장명"	// POP-UP Window Title 검색어1,2	 ("Win타이틀,첫번검색Nm,두번?검색Nm")
							       );
			break;

		default:
  			break;
  	}
}
//조회
scwin.btn_retrieve_onclick = async function (e) {

    if (!await $c.gus.cfValidate([ed_arv])) {	// 필수조건 : 장치장
		return;
	}

  	if (!(ed_mrn.getValue().trim() != ""
            || ed_blNo.getValue().trim() != ""
            || ed_cntrNo.getValue().trim() != ""
            || (ed_dtFrom.getValue().trim() != "" && ed_dtTo.getValue().trim() != "")
            || ed_declarNo.getValue().trim() != "")) 
    {
  	 	await $c.gus.cfAlertMsg("MRN, BL NO, CNTR NO, 조회일자, 신고번호 중 한가지 조건은 입력하셔야 합니다.");
  		return;
	}

	if (ed_dtFrom.getValue().trim() == "" || ed_dtTo.getValue().trim() == "") {
		
        ds_condition.setCellData(1,"dtCls","");

	} else {
		if (ed_dtFrom.getValue().trim().length != 8) {
			await $c.gus.cfAlertMsg(MSG_CM_ERR_055, ["조회시작일자형식"]);
	    	ed_dtFrom.focus();
	    	return;
		}
		if (ed_dtTo.getValue().trim().length != 8) {
			await $c.gus.cfAlertMsg(MSG_CM_ERR_055, ["조회종료일자형식"]);
	    	ed_dtTo.focus();
	    	return;
		}
		if (ed_dtFrom.getValue() > ed_dtTo.getValue()) {
			await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
			ed_dtTo.focus();
			return;
		}
	}

    $c.sbm.execute(sbm_retrieve)
};

//조회callback
scwin.sbm_retrieve_submitdone = function() {

    let nCnt = ds_CarryInIntendReceivePresent.getRowCount();
    
    if( nCnt == 0 ){
		$c.gus.cfAlertMsg("[반입예정 수신현황] "+MSG_CM_ERR_003);
		ds_CarryInIntendReceivePresent.removeAll();
  	} else {
        gr_CarryInIntendReceivePresent.setFocusedCell(0, 0); //첫째 행
        total.setValue(nCnt);
    }

};

scwin.ds_CarryInIntendReceivePresent_onrowpositionchange = function (info) {

    var rowIndex = info.newRowIndex;

    if(rowIndex < 0) return;

	dma_condition1.set("mrn"     , ds_CarryInIntendReceivePresent.getCellData(rowIndex,"mrn"));
	dma_condition1.set("msn"     , ds_CarryInIntendReceivePresent.getCellData(rowIndex,"msn"));
	dma_condition1.set("hsn"     , ds_CarryInIntendReceivePresent.getCellData(rowIndex,"hsn"));
	dma_condition1.set("declarNo", ds_CarryInIntendReceivePresent.getCellData(rowIndex,"declarNo"));
	
	$c.sbm.execute(sbm_retrieve1)

};


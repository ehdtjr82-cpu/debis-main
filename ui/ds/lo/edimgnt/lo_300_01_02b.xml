scwin.f_Excel = async function() {
   if(ds_CarryInIntendReceivePresent.getRowCount() == 0) {
        await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
        return;
    }

    let sheetTitle = "반입예정 수신현황";
    let gridColCount = gr_CarryInIntendReceivePresent.hiddenList.filter(o=>o == false).length;

    let subTitle = "MRN : " + ed_mrn.getValue() + " : "
                 + "MSN : " + ed_msn.getValue() + " : "
                 + "HSN : " + ed_hsn.getValue() + " : "
                 + "BL NO : " + ed_blNo.getValue() + " : "
                 + "CNTR NO : " + ed_cntrNo.getValue() + " : "
                 + acb_lc_dtCls.getSelectedRow().label + " : " + ed_dtFrom.getValue() + " ~ " + ed_dtTo.getValue() + " : "
                 + "신고번호 : " + ed_declarNo.getValue() + " : "
                 + "도착지 : " + ed_arvNm.getValue();

    //그리드에 대한 내용을 추가 옵션
    let infoArr = [
        //제목
        {
              rowIndex  : 0               //제목을 표시할 행 index
            , colIndex  : 0               //제목을 표시할 열 index
            , rowSpan   : 1                //병합할 행의 수
            , colSpan   : gridColCount                //병합할 열의 수
            , text      : sheetTitle          //표시할 내용(제목)
            , textAlign : "center"       //표시할 내용의 정렬 방법(left, center, right)
            , fontSize  : "16px"          //폰트 size
            , fontName  : "돋움체"        //폰트이름 
            , drawBorder : false,  
        },{
        //Title Sub 중간라인
              rowIndex  : 1
            , colIndex  : 0
            , colSpan   : gridColCount
            , rowSpan   : 1
            , text      : ""
            , textAlign : "left"
            , fontSize  : "10px"
            , drawBorder : false,  
        },{
        //Sub 제목
              rowIndex  : 2
            , colIndex  : 0
            , colSpan   : gridColCount
            , rowSpan   : 1
            , text      : subTitle.replace(/:/g,'|').replace(/;/g,'')
            , textAlign : "left"
            , fontSize  : "10px"
            , drawBorder : false,  
        }
    ];

    let options = {
          fileName      : sheetTitle + ".xlsx"
        , sheetName     : sheetTitle
        , type          : "1"
        // , // hiddenVisible:"true",   //히든값(true : 포함, false : 미포함)
        , startRowIndex : 3       //시작되는 행의 번호(헤더 포함)
        , useFooter     :"true"        //다운로드시 Footer를 출력 할지 여부( "true"인경우 출력, "false"인경우 미출력)
    };


    $c.data.downloadGridViewExcel(gr_CarryInIntendReceivePresent, options, infoArr);
};



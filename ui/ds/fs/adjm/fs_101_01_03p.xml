//-------------------------------------------------------------------------
scwin.args = "";
scwin.selpchItemCd = "";


//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    scwin.popTitleCh();


    scwin.args = $p.getAllParameter().paramData.data;
    scwin.selpchItemCd = scwin.args[0];

    console.log("파라미터 체크"+scwin.selpchItemCd);

    //공통코드데이터 호출   
    const codeOptions = [
        { grpCd: "FS401", compID: "acb_selPchItemCd" } // 셀렉트
    ];
    $c.data.setCommonCode(codeOptions);	


    dma_QueryCondition.set("selpchItemCd", scwin.selpchItemCd);


    $c.sbm.execute(sbm_retrieve);

    
};

scwin.popTitleCh = function() {
    $c.data.setPopupTitle("매입항목 계정 연결 정보");

}

//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.btn_retrieveButton_onClick = function (e) {
    
    dma_QueryCondition.set("selpchItemCd", acb_selPchItemCd.getValue());
    
    $c.sbm.execute(sbm_retrieve);
};



//-------------------------------------------------------------------------
// 데이터 로드 완료시
//-------------------------------------------------------------------------
scwin.ds_RetrieveWorkResult_ondataload = function () {
    let rowCnt = ds_RetrieveWorkResult.getTotalRow();

    if(rowCnt == 0) {
        $c.win.alert($c.data.getMessage(MSG_CM_ERR_003, "매입항목 계정 연결 정보"));
    }

    spa_totalRows.setValue(rowCnt);
};


//-------------------------------------------------------------------------
// 닫기
//-------------------------------------------------------------------------
scwin.btn_close_onClick = function (e) {
    $c.win.closePopup();
};
]]></script>

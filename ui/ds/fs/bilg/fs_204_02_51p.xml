scwin.onpageload = function() {
	scwin.f_OnLoad();
};

    scwin.certiPatternCd = "V";  // 거래명세서유형코드
    scwin.fmlaClsCd      = "01"; // 서식구분코드          
    scwin.delYn          = 0; // 삭제구분코드          
	scwin.bilgLodeptCd   = ""; // 청구부서코드
    scwin.bilgLodeptNm   = ""; // 청구부서명
    scwin.p_pgmId        = ""; // 프로그램ID
    scwin.isFirstFlag    = true; //화면 최초 로딩

	//-------------------------------------------------------------------------
	// function name : f_OnLoad
	// function desc : 화면로딩시 
	//------------------------------------------------------------------------- 
    scwin.strCurDate = $c.date.getServerDateTime("yyyyMMdd");// 현재일자를 구한다.
    scwin.strPreDate = $c.date.addDate(scwin.strCurDate, -7);// -7일

    scwin.G_empNo = $c.data.getMemInfo("empNo");
    scwin.G_empNm = "";

	//-------------------------------------------------------------------------
 	// 화면로딩시
	//-------------------------------------------------------------------------
	scwin.f_OnLoad = function()  {

		//거래명세서 팝업 호출한 프로그램ID 
		//var	arrParent = window.dialogArguments ;
/*
        var	arrParent = new Array();
        arrParent.push("4A6");
        arrParent.push("인천북항");
        arrParent.push(scwin.p_pgmId);
*/
        var arrParent = $p.getAllParameter().paramData;
//console.log(arrParent);
		if(arrParent != "" && arrParent != undefined){
		  	scwin.bilgLodeptCd = arrParent.data[0];
		  	scwin.bilgLodeptNm = arrParent.data[1];
		  	scwin.p_pgmId      = arrParent.data[2];
		}
        
        const codeOptions = [
            { grpCd: "FS500", compID: "acb_dcsnClsCd" }  // 확정구분
        ]
        $c.data.setCommonCode(codeOptions);
	};

    //UDC 정보가 처리 완료된 후 처리(TOBE scwin.onpageload밑에 정의)
    scwin.onUdcCompleted = function() {
        ica_qryConDtFm.setValue(scwin.strPreDate);
		ica_qryConDtTo.setValue(scwin.strCurDate);
		ed_bilgLodeptCd.setValue(scwin.bilgLodeptCd);
		ed_bilgLodeptNm.setValue(scwin.bilgLodeptNm);
		ed_modId.setValue(scwin.G_empNo);

        //ed_bilgClntNo.setValue("");  //임시하드코딩
        //ds_merchantcertilist_con.set("bilgClntNo",    "V130072865"); //임시하드코딩

		scwin.f_openCommonPopUp(3, ed_modId.getValue(), scwin.G_empNm, 'T', 'T');
		//scwin.f_Retrieve(); //scwin.udc_modIdCallback에서 실행
    };

  	//-------------------------------------------------------------------------
  	// 조회
	//-------------------------------------------------------------------------
	scwin.f_Retrieve = async function() {
        
		if(acb_qryConKnd.getValue() == "품명명" || ed_qryConCd.getValue() == ""){
            //validation check
            let ret = await $c.gus.cfValidate([ed_bilgLodeptCd,ica_qryConDtFm,ica_qryConDtTo]); 
	    	if(!ret){
	    		return false;
	    	}
	  	}
	  	
	  	//조회시작일자가 더 클경우 체크
	  	if (!$c.gus.cfIsAfterDate(ica_qryConDtFm.getValue(), ica_qryConDtTo.getValue())) {
 	       $c.win.alert(MSG_CM_ERR_039);
 	       return;
    	}

     	ds_merchantcertilist_con.set("certiPatternCd",scwin.certiPatternCd );
     	ds_merchantcertilist_con.set("fmlaClsCd",     scwin.fmlaClsCd);
     	ds_merchantcertilist_con.set("delYn",         scwin.delYn);

/*
     	ds_merchantcertilist_con.set("qryDtConKnd",         ""); //임시추가
		if(acb_qryConKnd.getValue() == "품명명"){
	     	ds_merchantcertilist_con.set("qryConCd",ed_qryConCd.getValue());
	    } else {
	     	ds_merchantcertilist_con.set("qryConCd",ed_qryConCd.getValue());
	    }
*/

        ds_merchantcertilist_con.set("qryConCd",ed_qryConCd.getValue());
     	ds_merchantcertilist_con.set("pgmId",scwin.p_pgmId);
     	ds_merchantcertilist_con.set("upDownClsCd",'NULL');

        ds_merchantcertilist.setJSON([]);
        $c.sbm.execute(sbm_merchantcertilist_retrieve);
	};

  	//-------------------------------------------------------------------------
  	// 팝업창 처리
  	//-------------------------------------------------------------------------
	scwin.f_openCommonPopUp = function(disGubun, pCode, pName, pClose, pAllSearch) {
        
	  	// 선언부
		var rtnList  = new Array();  // 공통POP-UP -> 요청화면 
		
		switch (disGubun) {
			case 1:
				//청구부서코드팝업			
				//rtnList = cfCommonPopUp('retrieveOpDeptCdInfo',pCode.trim(),pName,pClose,null,null,null,null,null,null,null,null,null,null,pAllSearch,null);

				break;
			
	  		case 2:  			
				//청구처코드팝업			
				//rtnList = cfCommonPopUp('retrieveClntInfo',pCode.trim(),pName,pClose,null,null,null,null,null,null,null,null,null,null,pAllSearch,null);	  			
				
                udc_bilgClntNo.setSelectId('retrieveClntInfo');
				rtnList = udc_bilgClntNo.cfCommonPopUp(scwin.udc_bilgClntNoCallback,pCode.trim(),pName,pClose,null,null,null,null,null,null,null,null,null,null,pAllSearch,null);
	  				  									
				break;

	  		case 3:  		
				// 청구담당자코드 팝업			
				//rtnList = cfCommonPopUp('retrieveEmpInfo',pCode.trim(),pName,pClose,null,null,null,null,null,null,null,null,null,null,pAllSearch,null);	  				  			

                udc_modId.setSelectId('retrieveEmpInfo');
				rtnList = udc_modId.cfCommonPopUp(scwin.udc_modIdCallback,pCode.trim(),pName,pClose,null,null,null,null,null,null,null,null,null,null,pAllSearch,null);	  				  			
	  									
				break;

	  		case 4:  			
				//LINE코드팝업
                //rtnList = cfCommonPopUp('retrieveLineInfo',pCode.trim(),pName,pClose,null,null,null,null,null,null,null,null,null,null,pAllSearch,null);

                udc_bilgClntNo.setSelectId('retrieveLineInfo');	 //udc 대체.
				rtnList = udc_bilgClntNo.cfCommonPopUp(scwin.ed_lineCdCallback,pCode.trim(),pName,pClose,null,null,null,null,null,null,null,null,null,null,pAllSearch,null);	  			
	  				  									
				break;

	  		default:
	  			break;
		}
	};


//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function() {

scwin.params = $c.data.getParameter();
scwin.qryConDt = scwin.params.qryConDt;
scwin.headcomCd = scwin.params.headcomCd;
scwin.acctDeptCd = scwin.params.acctDeptCd;
scwin.acctDeptNm = scwin.params.acctDeptNm;
scwin.bilgClntNo = scwin.params.bilgClntNo;
scwin.bilgClntNm = scwin.params.bilgClntNm;
scwin.gubun = scwin.params.gubun;
scwin.newCtrtYr = scwin.params.newCtrtYr;
scwin.acctCd = scwin.params.acctCd;
scwin.ctrtNo = scwin.params.ctrtNo;




    scwin.f_FieldClear();
    scwin.onUdcCompleted();
};

//-------------------------------------------------------------------------
// 조회 필드 Clear
//-------------------------------------------------------------------------
scwin.f_FieldClear = function() {
    
    $c.gus.cfInitObjects(tbl_search, null);

}


scwin.onUdcCompleted = function() {
    ica_qryConDt.setValue(scwin.params.qryConDt);
    acb_headcomCd.setValue(scwin.params.headcomCd);
    ed_acctDeptCd.setValue(scwin.params.acctDeptCd);
    ed_acctDeptNm.setValue(scwin.params.acctDeptNm);
    ed_bilgClntNo.setValue(scwin.params.bilgClntNo);
    ed_bilgClntNm.setValue(scwin.params.bilgClntNm);
    scwin.hd_gubun = scwin.params.gubun;
    scwin.hd_newCtrtYr = scwin.params.newCtrtYr;
    scwin.hd_acctCd = scwin.params.acctCd;

    if(scwin.params.gubun == "A") {
        scwin.hd_ctrtNo = scwin.params.ctrtNo;
    };

    scwin.f_Retrieve();
}



//-------------------------------------------------------------------------
// 조회 클릭시
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function (e) {
    if(!await $c.gus.cfValidate([tbl_search])) return;

    dma_search.set("headcomCd", acb_headcomCd.getValue());
    dma_search.set("qryConDt", ica_qryConDt.getValue());
    dma_search.set("acctDeptCd", ed_acctDeptCd.getValue());
    dma_search.set("bilgClntNo", ed_bilgClntNo.getValue());
    dma_search.set("gubun", scwin.hd_gubun);
    dma_search.set("newCtrtYr", scwin.hd_newCtrtYr);
    dma_search.set("acctCd", scwin.hd_acctCd);
    dma_search.set("ctrtNo", scwin.hd_ctrtNo);

    
    $c.sbm.execute(sbm_search);

};




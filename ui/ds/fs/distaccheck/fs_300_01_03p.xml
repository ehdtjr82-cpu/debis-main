scwin.ds_result_ondataload = function () {
      let nRow = ds_result.getRowCount(); 

    if (nRow == 0) {

        $c.win.alert("조회결과가 존재하지 않습니다.");        
        return;
    }

    //조회 완료 후 총 검색 수 하단 노출
    spa_totalRows.setValue(nRow);

};


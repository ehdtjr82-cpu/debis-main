    	<script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// 페이지로드
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    scwin.params = $c.data.getParameter();
    ds_cond.set("cntrNo", scwin.params.cntr_no);

    scwin.popTitleCh();

	scwin.f_Retrieve();
};

//-------------------------------------------------------------------------
// 팝업타이틀 변경
//-------------------------------------------------------------------------
scwin.popTitleCh = function() {
    $c.data.setPopupTitle("HB/L 상세정보");
}

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = function () {
    $c.sbm.execute(sbm_retrieve);
};

//-------------------------------------------------------------------------
// BL 정보 화면에 셋팅
//-------------------------------------------------------------------------
scwin.f_settingBlInfo = function () {
	ed_cntrNo.setValue(ds_out.getCellData(0, "cntrNo")); //컨테이너번호
	ed_cargoManageNo.setValue(ds_out.getCellData(0, "cargoManageNo")); //화물관리번호
	ed_prgsStsNm.setValue(ds_out.getCellData(0, "prgsStsNm")); //진행상태
	ed_carrierNm.setValue(ds_out.getCellData(0, "carrierNm")); //선사/항공사
	ed_mblNo.setValue(ds_out.getCellData(0, "mblNo")); //MB/L
	ed_hblNo.setValue(ds_out.getCellData(0, "hblNo")); //HB/L
	ed_cargoTpNm.setValue(ds_out.getCellData(0, "cargoTpNm")); //화물구분
	ed_vsslNm.setValue(ds_out.getCellData(0, "vsslNm")); //선박/항공편명
	ed_cargoCsclSts.setValue(ds_out.getCellData(0, "cargoCsclSts")); //통관진행상태
	ed_prgsStsDtm.setValue(ds_out.getCellData(0, "prgsStsDtm")); //처리일시
	ed_vsslCntyNm.setValue(ds_out.getCellData(0, "vsslCntyNm")); //선박국적
	ed_agency.setValue(ds_out.getCellData(0, "agency")); //선박대리점
	ed_commNm.setValue(ds_out.getCellData(0, "commNm")); //품명
	ed_lodNm.setValue(ds_out.getCellData(0, "lodNm")); //적재항
	ed_totPkg.setValue(ds_out.getCellData(0, "totPkg")); //포장개수
	ed_totWgt.setValue(ds_out.getCellData(0, "totWgt")); //총중량
	ed_dichNm.setValue(ds_out.getCellData(0, "dichNm")); //양륙항
	ed_custom.setValue(ds_out.getCellData(0, "custom")); //입항세관
	ed_msr.setValue(ds_out.getCellData(0, "msr")); //용적
	ed_blTpNm.setValue(ds_out.getCellData(0, "blTpNm")); //B/L 유형
	ed_ata.setValue(ds_out.getCellData(0, "ata")); //입항일
	ed_vyg.setValue(ds_out.getCellData(0, "vyg")); //항차
	ed_mgntCargoSts.setValue(ds_out.getCellData(0, "mgntCargoSts")); //관리대상지정여부
	ed_cntrCnt.setValue(ds_out.getCellData(0, "cntrCnt")); //컨테이너개수
	ed_spcCargoCd.setValue(ds_out.getCellData(0, "spcCargoCd")); //특수화물코드
};

//-------------------------------------------------------------------------
// 조회 submitdone
//-------------------------------------------------------------------------
scwin.sbm_retrieve_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return; 
    
    if (ds_out.getRowCount() == 0) {
		await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
        $c.win.closePopup();
	} else {
		scwin.f_settingBlInfo();
	}
};

//-------------------------------------------------------------------------
// 닫기
//-------------------------------------------------------------------------
scwin.btn_close_onclick = function (e) {
    $c.win.closePopup();
};
]]></script>

scwin.btn_recreateAll_onclick = function (e) {
    console.log("scwin.btn_search_onclick");
    scwin.f_recreateAll();
};

//발행 버튼
scwin.btn_ctrtPrint_onclick = function (e) {
    scwin.f_ozReport();
};

]]></script>

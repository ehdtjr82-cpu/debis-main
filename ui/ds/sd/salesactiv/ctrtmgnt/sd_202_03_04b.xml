// ctrt(계약정보) 조회 완료
scwin.sbm_retrieve_submitdone = function (e) {
    // 조회 성공시
    if (e.responseJSON.resultDataSet[0].Code == 0) {
        if (ds_ctrt.getRowCount() == 0) {
            scwin.f_ContentsDisable(false);
            $c.win.alert("조회된 데이터가 없습니다.");
            $c.gus.cfDisableBtn([btn_Update, btn_Cancel, btn_Save]);
        } else {
            ds_ctrt.setRowPosition(0);
            gr_ctrt.setFocusedCell(0, 0);
            // 그리드 조회건수
            tbx_totalRows.setValue($c.gus.cfInsertComma(ds_ctrt.getRowCount()));
        }
    }
};


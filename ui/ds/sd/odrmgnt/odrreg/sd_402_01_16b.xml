<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map">
    			<w2:dataList baseNode="list" id="ds_odrInfo" repeatNode="map" saveRemovedData="true">
    				<w2:columnInfo>
    					<w2:column dataType="text" name="name1" id="odrNo"></w2:column>
    					<w2:column dataType="text" name="name2" id="cntrNo"></w2:column>
    				</w2:columnInfo>
    			</w2:dataList>
    			<w2:dataList baseNode="list" repeatNode="map" id="ds_cntrInfo" saveRemovedData="true">
    				<w2:columnInfo>
    					<w2:column dataType="text" name="name1" id="odrNo"></w2:column>
    					<w2:column dataType="text" name="name2" id="cntrSeq"></w2:column>
    					<w2:column dataType="text" name="name3" id="arrvlportDtm"></w2:column>
    					<w2:column dataType="text" name="name4" id="cntrNo"></w2:column>
    					<w2:column dataType="text" name="name5" id="cntrSizCd"></w2:column>
    					<w2:column dataType="text" name="name6" id="cntrTypCd"></w2:column>
    					<w2:column dataType="text" name="name7" id="fullEmptyClsCd"></w2:column>
    					<w2:column dataType="text" name="name8" id="arvWrkPlNm"></w2:column>
    				</w2:columnInfo>
    			</w2:dataList>
    		</w2:dataCollection>

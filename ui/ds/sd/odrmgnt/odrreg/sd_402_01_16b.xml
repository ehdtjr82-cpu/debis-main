    					</xf:group>
    				</xf:group>
    			</xf:group>
    			<xf:group class="btnbox" id="">
    				<xf:group class="right" id="">
    					<xf:trigger class="btn" id="btn_save" label="저장" style="" type="button" ev:onclick="scwin.btn_save_onclick">
    						<xf:label>저장</xf:label>
    					</xf:trigger>
    					<xf:trigger class="btn" id="btn_close" label="닫기" style="display:none;" type="button" ev:onclick="scwin.btn_close_onclick">

    		<xf:group class="shbox" id="" style="">
    			<xf:group class="shbox-inner" id="" style="">
    				<xf:group class="w2tb " id="tbl_odrCntrArea" style="" tagname="table">
    					<w2:attributes>
    						<w2:summary></w2:summary>
    					</w2:attributes>
    					<xf:group tagname="colgroup">
    						<xf:group style="" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    					</xf:group>
    					<xf:group class="" id="" style="" tagname="tr">
    						<xf:group class="w2tb_th " style="" tagname="th">
    							<w2:textbox class="req" id="" label="오더번호" style=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" style="" tagname="td">
    							<xf:input class="" id="ed_odrNo" placeholder="" style="width:150px;" ref="data:ds_odrInfo.odrNo" mandatory="true" objType="Data" maxlength="13"></xf:input>
    						</xf:group>
    						<xf:group class="w2tb_th" style="" tagname="th">
    							<w2:textbox class="" id="" label="컨테이너번호" style=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" id="" style="" tagname="td">
    							<xf:input class="" id="ed_cntrNo" placeholder="" style="width:150px;text-transform: uppercase;" ref="data:ds_odrInfo.cntrNo" objType="data" maxlength="11" allowChar="a-zA-Z0-9"></xf:input>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    			<xf:group class="btn-shbox" id="" style="">
    				<xf:trigger class="btn ico refresh" id="btn_fieldClear" style="" type="button" ev:onclick="scwin.btn_fieldClear_onclick">
    					<xf:label><![CDATA[엑셀 UP]]></xf:label>
    				</xf:trigger>
    				<xf:trigger class="btn sch" disabled="" escape="false" id="btn_retrieve" style="" type="button" ev:onclick="scwin.btn_retrieve_onclick">
    					<xf:label><![CDATA[조회]]></xf:label>
    				</xf:trigger>
    			</xf:group>
    		</xf:group>
    		<xf:group class="round-box" id="" style="">
    			<xf:group adaptiveThreshold="" class="gvwbox" id="" style="">
    				<w2:gridView autoFit="allColumn" checkAllType="false" class="wq_gvw" dataList="data:ds_cntrInfo" id="gr_cntrInfo" style=""
    					visibleRowNum="15" visibleRowNumFix="true" rowStatusVisible="true">
    					<w2:caption id="caption1" style="" value="this is a grid caption."></w2:caption>
    					<w2:header id="header1" style="">
    						<w2:row id="row1" style="">
    							<w2:column displayMode="label" id="column1" inputType="text" value="오더번호" width="100" hidden="true"></w2:column>
    							<w2:column displayMode="label" id="column17" inputType="text" value="순번" width="70"></w2:column>
    							<w2:column displayMode="label" id="column15" inputType="text" value="입항일시" width="100" hidden="true"></w2:column>
    							<w2:column displayMode="label" id="column13" inputType="text" value="컨테이너번호" width="120"></w2:column>
    							<w2:column displayMode="label" id="column11" inputType="text" value="Size" width="90"></w2:column>
    							<w2:column displayMode="label" id="column9" inputType="text" value="Type" width="90"></w2:column>
    							<w2:column displayMode="label" id="column3" inputType="text" value="F/E" width="90"></w2:column>
    							<w2:column displayMode="label" id="column5" inputType="text" value="도착작업장" width="130"></w2:column>
    						</w2:row>
    					</w2:header>
    					<w2:gBody id="gBody1" style="">
    						<w2:row id="row2" style="">
    							<w2:column displayMode="label" id="odrNo" inputType="text" width="100"></w2:column>
    							<w2:column displayMode="label" id="cntrSeq" inputType="text" width="70" readOnly="true"></w2:column>
    							<w2:column displayMode="label" id="arrvlportDtm" inputType="text" width="100"></w2:column>
    							<w2:column displayMode="label" id="cntrNo" inputType="text" width="120"></w2:column>
    							<w2:column displayMode="label" id="cntrSizCd" inputType="text" width="90" readOnly="true"></w2:column>
    							<w2:column displayMode="label" id="cntrTypCd" inputType="text" width="90" readOnly="true"></w2:column>
    							<w2:column displayMode="label" id="fullEmptyClsCd" inputType="text" width="90" readOnly="true"></w2:column>
    							<w2:column displayMode="label" id="arvWrkPlNm" inputType="text" width="130" textAlign="left" readOnly="true"></w2:column>
    						</w2:row>
    					</w2:gBody>
    				</w2:gridView>
    				<xf:group class="grid-bottom " id="" style="">
    					<xf:group class="left" id="">

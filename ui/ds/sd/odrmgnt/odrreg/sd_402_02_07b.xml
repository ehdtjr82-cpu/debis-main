    	<script lazy="false" type="text/javascript"><![CDATA[
			scwin.vCurDate   = $c.date.getServerDateTime("yyyyMMdd"); // 서버를 기준으로 현재 날짜 반환

			scwin.onpageload = function() {
				$c.gus.cfDisableObjects(tb_retrieveData);
				acb_lineCd.setSelectedIndex(0);	
			};

			scwin.onUdcCompleted = function() {
				doIssueDdStDt.setValue(scwin.vCurDate);
				doIssueDdEndDt.setValue(scwin.vCurDate);
			};

			//-------------------------------------------------------------------------
			// 조회
			//-------------------------------------------------------------------------
			scwin.f_Retrieve = async function() {
				let rtn = await $c.gus.cfValidate([tb_queryList]);
				if (! rtn) { return; }

				$c.sbm.execute(sbm_retrieve);
			};

			///////////////////////////////////////////// C O M P O N E N T   E V E N T /////////////////////////////////////////

			//조회조건 초기화
			scwin.btn_fieldClear_onclick = function (e) {
				$c.gus.cfInitObjects(tb_queryList);

				doIssueDdStDt.setValue(scwin.vCurDate);
				doIssueDdEndDt.setValue(scwin.vCurDate);
			};

			// DO_NO 대문자
			scwin.ed_doNo_onkeyup = function (e) {
				this.setValue(e.target.value.toUpperCase());
			};

			// MRN 대문자
			scwin.ed_mrn_onkeyup = function (e) {
				this.setValue(e.target.value.toUpperCase());
			};

			// 컨테이너 번호 대문자
			scwin.ed_cntrNo_onkeyup = function (e) {
				this.setValue(e.target.value.toUpperCase());
			};

			// 양륙항 대문자
			scwin.ed_dchrPort_onkeyup = function (e) {
				this.setValue(e.target.value.toUpperCase());
			};

			///////////////////////////////////////////// S U B M I S S I O N    E V E N T /////////////////////////////////////////

			// 조회
			scwin.sbm_retrieve_submitdone = function (e) {
				if (ds_list.getRowCount() == 0) {
					$c.win.alert($c.data.getMessage(MSG_CM_ERR_003)); // 해당되는 자료가 존재하지 않습니다.
					return;
				}
				
				totalRowsGrid1.setValue(ds_list.getRowCount()); 
				gr_list.setFocusedCell(0, "gateResult", false);
			};

		]]></script>

    	<script lazy="false" type="text/javascript"><![CDATA[scwin.odrNo = "";

scwin.onpageload = function () {
    scwin.odrNo = $c.gus.cfIsNull($c.data.getParameter("odrNo")) ? "" : $c.data.getParameter("odrNo");   

    scwin.f_dsOrderSearchHeader();
  	
  	// 초기값 설정
  	ed_odrNo.setValue(scwin.odrNo);	// 오더번호 설정
  	
  	$c.gus.cfEnableKeyData();
	$c.gus.cfDisableKey();
	
	$c.gus.cfDisableBtnOnly([btn_save]); 

	scwin.f_Retrieve();  
};

scwin.onUdcCompleted = function () {

};

scwin.ondataload = function () {
   
};

//-------------------------------------------------------------------------
// Function
//-------------------------------------------------------------------------
// DataSet Header 정의 - 조회
scwin.f_dsOrderSearchHeader = function () {
    ds_orderSearch.removeAll();
    
    // 조회 DataSet 초기화
    var rowIndex = ds_orderSearch.insertRow();
    ds_orderSearch.setRowPosition(rowIndex);
    ds_orderSearch.setCellData(rowIndex, "odrNo", "");
};

// 조회
scwin.f_Retrieve = async function () {  
    let searchChk = await $c.gus.cfValidate([ed_odrNo]);
    if (!searchChk) {
        return;
    } 

    // 조회
    $c.sbm.execute(sbm_retrieve);
};

// 복사
scwin.f_Save = async function () { 
	// 필수 입력사항을 체크
    if (scwin.f_validChk()) {
        let rtn = await $c.win.confirm("오더 터미널 EDI 정보를 저장하시겠습니까?");
        if(rtn){
            let e = await $c.sbm.execute(sbm_save);
            if (e.responseJSON.resultDataSet[0].Msg == "SUCC") {
                scwin.sbm_save_submitdone(e);
            }
        }
    }
};

// 저장전 validation check - 오더 정보
scwin.f_validChk = async function () {
    let searchChk = await $c.gus.cfValidate([tb_order]);
    if (searchChk) {	 
  		if (ds_order.getModifiedIndex().length == 0) {
            await $c.gus.cfAlertMsg(MSG_CM_ERR_001, ["오더정보"]);
		    return false;
	    }

        return true;  		
    } else {
  		return false;
    }
};

//-------------------------------------------------------------------------
// Sbm submitdone
//-------------------------------------------------------------------------
scwin.sbm_retrieve_submitdone = function (e) { 
    ds_order.setRowPosition(0);
    
    if (e.responseJSON.resultDataSet[0].Code < 0) { 
        $c.gus.cfDisableKeyData();
        $c.gus.cfDisableBtnOnly([btn_save]);
    }

    if(ds_order.getRowCount() > 0){
        $c.gus.cfEnableBtnOnly([btn_save]);
    }
};

scwin.sbm_save_submitdone = async function (e) {
	await $c.win.alert(MSG_CM_INF_001);
    scwin.f_Retrieve();
};

//-------------------------------------------------------------------------
// Event onClick
//-------------------------------------------------------------------------
// 저장 버튼 클릭 이벤트 
scwin.btn_save_onclick = function (e) {
    scwin.f_Save();
};

// 닫기 버튼 클릭 이벤트 
scwin.btn_close_onclick = function (e) {
    $c.win.closePopup(["N/A"]);
};

//-------------------------------------------------------------------------
// InputBox 대문자 설정
//-------------------------------------------------------------------------
scwin.ed_dptOprCd_onkeyup = function (e) {
    $c.win.chUpper(e);
};

scwin.ed_arvOprCd_onkeyup = function (e) {
    $c.win.chUpper(e);
};


        <script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    console.log("scwin.onpageload");
    scwin.params = $p.getAllParameter().paramData.data;
    scwin.memInfo = $c.data.getMemInfo();
    scwin.odrNo = scwin.params[0];
    scwin.bCgubunCd = $c.gus.cfIsNull(scwin.params[1])? "" : scwin.params[1];
    
    ed_odrNo.setValue(scwin.odrNo);
    $c.gus.cfEnableKeyData();
	$c.gus.cfDisableKey();
	$c.gus.cfDisableBtnOnly([btn_save]); 

    scwin.f_retrieve();
};

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_retrieve = async function() {
    console.log("scwin.f_retrieve");
    let chkVal = await $c.gus.cfValidate(ed_odrNo);
    if(chkVal) {
  	  	var strAtcion = "";
        
  	  	if (scwin.bCgubunCd == "B" ) strAtcion = "/ds.sd.odrmgnt.odrreg.RetrieveBulkOrderCMD.do";
  	  	if (scwin.bCgubunCd == "C" ) strAtcion = "/ds.sd.odrmgnt.odrreg.RetrieveContainerOrderCommodityCMD.do";

        $c.sbm.setAction(sbm_retrieve, strAtcion)
        $c.sbm.execute(sbm_retrieve);
    }
}

//-------------------------------------------------------------------------
// 저장
//-------------------------------------------------------------------------
scwin.f_save = async function() {
    let chkVal = await $c.gus.cfValidate(txt_rmk_new, null, true);
    if(!chkVal) return;

    let conf = await $c.win.confirm("오더 특이사항 정보를 저장하시겠습니까?");
   	if(conf) {
    	ds_order.setCellData(0, "rmk", txt_rmk_new.getValue());
    	txt_rmk_new.setValue("");

        $c.sbm.execute(sbm_save);
   	}
}

/* ----------------------------------------------------------------------------
  T R A N S A C T I O N   C O M P O N E N T S   D E C L A R A T I O N
------------------------------------------------------------------------------*/
//조회 완료
scwin.sbm_retrieve_submitdone = function (e) {
    console.log("scwin.sbm_retrieve_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) {
        $c.gus.cfDisableKeyData();
	    $c.gus.cfDisableBtnOnly([btn_save]);
        return; 
    }

    if(ds_order.getTotalRow() > 0) {
        txt_rmk.setValue(ds_order.getCellData(0, "rmk"))
        $c.gus.cfEnableBtnOnly([btn_save]);
    }
};

//저장 완료
scwin.sbm_save_submitdone = function (e) {
    console.log("scwin.sbm_save_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) return; 

    $c.gus.cfAlertMsg(MSG_CM_INF_001);
    scwin.f_retrieve();
};
/* ----------------------------------------------------------------------------
  C O M P O N E N T' S   E V E N T S  
-----------------------------------------------------------------------------*/
//저장 버튼
scwin.btn_save_onclick = function (e) {
    scwin.f_save();
};

//닫기 버튼
scwin.btn_close_onclick = function (e) {
    $c.win.closePopup();
};
]]></script>

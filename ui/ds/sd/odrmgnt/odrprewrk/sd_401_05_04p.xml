    	<script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    scwin.params = $c.data.getParameter();
    /*scwin.params = {
        docCd : "031"
        , declarNo : "03082010007020000579"
        , deg : "0" 
        , procclsCd : "E"
    }*/
    debugger;
    //공통코드 설정
    const codeOptions = [
        { grpCd : "SD152", compID : "lc_docCd" }
    ];
    $c.data.setCommonCode(codeOptions);

    scwin.f_fieldClear();
	$c.gus.cfDisableKey();
};

//-------------------------------------------------------------------------
// 조회 기본값 설정
//-------------------------------------------------------------------------
scwin.f_setSrchDefault = function() {
    console.log("scwin.f_setSrchDefault");
    $c.gus.cfInitHidVal(tbl_search);

    lc_docCd.setValue(scwin.params.docCd);
    ed_declarNo.setValue(scwin.params.declarNo);
    ed_deg.setValue(scwin.params.deg);
}

//-------------------------------------------------------------------------
// 조회 필드 Clear
//-------------------------------------------------------------------------
scwin.f_fieldClear = function() {
	console.log("scwin.f_fieldClear");
	$c.gus.cfInitObjects(tbl_search);
	scwin.f_setSrchDefault();

    scwin.f_retrieve();
}

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_retrieve = async function() { 
	console.log("scwin.f_retrieve");    

    let chkVal = await $c.gus.cfValidate([tbl_search]);
	if (!chkVal) return;
	
    dma_search.set("procClsCd", scwin.params.procClsCd);
    $c.sbm.execute(sbm_search);
}

/* ----------------------------------------------------------------------------
  T R A N S A C T I O N   C O M P O N E N T S   D E C L A R A T I O N
------------------------------------------------------------------------------*/
//조회 완료
scwin.sbm_search_submitdone = function(e) {
    console.log("scwin.sbm_search_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) return; 

    var rowCnt = ds_master.getTotalRow();
    spn_totalRow.setValue(rowCnt);
	
    if( rowCnt == 0 ){
	   if($c.gus.cfCheckCreateFlag() == true)   $c.gus.cfTurnCreateFlag(false);
	   else                                     $c.gus.cfAlertMsg(MSG_CM_WRN_002);
	} else {
        ds_master.sort("seqNo", 1);
        gr_master.setFocusedCell(0, 0);
	}	
};

/* ----------------------------------------------------------------------------
  C O M P O N E N T' S   E V E N T S  
-----------------------------------------------------------------------------*/
//조회조건 clear 버튼
scwin.btn_clear_onclick = function (e) {
    console.log("scwin.btn_clear_onclick");
    scwin.f_fieldClear();
};

//조회 버튼
scwin.btn_search_onclick = function (e) {
    console.log("scwin.btn_search_onclick");
    scwin.f_retrieve();
};

//닫기 버튼
scwin.btn_close_onclick = function (e) {
    $c.win.closePopup();
};
]]></script>

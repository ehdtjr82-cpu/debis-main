    	<script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// 화면 로딩
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    //공통코드 조회
    const codeOptions = [
		{ grpCd : "OP190", compID : "acb_cargoClsCd" }
	];
	$c.data.setCommonCode(codeOptions);

	const comboOptions = [
        {
            method : "getLuxeComboData", 
            param1 : "WorkImplementEBC", 
            param2 : "retriveLobran2CodeList",
            param3 : ["1"],
            compID : "acb_lobranCd" 
        }
    ];
    $c.data.setGauceUtil(comboOptions);

    dma_comSearch.set("sysCd"  , "CooperationCompanyEquipmentEBC");
    dma_comSearch.set("queryId", "retriveCarKindCodeListCombo");
    $c.sbm.execute(sbm_comSearch);
};

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_retrieve = function () {
    dma_search.set("returnVehclYn", "1");   // 회수차량여부
    dma_search.set("directMgntYn" , "0");    // 회수차량여부
    dma_search.set("cargoClsCd"   , acb_cargoClsCd.getValue());
    
    $c.sbm.execute(sbm_retrieve);
}

//-------------------------------------------------------------------------
// 공통 팝업 호출
//-------------------------------------------------------------------------
scwin.f_openClntnoPopUp = function(codeObj, nameObj, pClose, pAllSearch) {
    udc_clntNo.cfCommonPopUp(   scwin.callBackCarKindClnt
                              , codeObj.getValue()
                              , nameObj.getValue()
                              , pClose, null, null, null, null, null, null, null, null, null, null, pAllSearch, "협력업체조회, 협력업체코드/명", null);
}

//-------------------------------------------------------------------------
// 공통팝업호출 callBack
//-------------------------------------------------------------------------
scwin.callBackCarKindClnt = function(rtnList) {
    $c.gus.cfSetReturnValue(rtnList, ed_clntNo, ed_clntNm);  		
}

/* ----------------------------------------------------------------------------
  T R A N S A C T I O N   C O M P O N E N T S   D E C L A R A T I O N
------------------------------------------------------------------------------*/
//조회 완료
scwin.sbm_retrieve_submitdone = function(e) {
    console.log("scwin.sbm_retrieve_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) return; 

    var rowCnt = ds_commList.getTotalRow();
	spn_totalRow.setValue(rowCnt);
	
    if(rowCnt == 0) {
	    $c.win.alert("조회된 데이터가 없습니다.");
        acb_cargoClsCd.focus();
	} else {
		gr_commList.setFocusedCell(0, 0);
	}	
};

/* ----------------------------------------------------------------------------
  C O M P O N E N T' S   E V E N T S  
-----------------------------------------------------------------------------*/
//협력업체 찾기 버튼
scwin.udc_clntNo_onclickEvent = function (e) {
    scwin.f_openClntnoPopUp(ed_clntNo, ed_clntNm, 'F', 'T');
};

//협력업체 코드 삭제 > 명 삭제 
scwin.udc_clntNo_onblurCodeEvent = function (e) {
    scwin.f_openClntnoPopUp(ed_clntNo, ed_clntNm, 'T', 'T'); 
};

//조회 버튼
scwin.btn_search_onclick = function (e) {
    console.log("scwin.btn_search_onclick");
    scwin.f_retrieve(); 
};

//그리드 더블 클릭 > 메뉴 호출
scwin.gr_commList_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    var lobranCd   = ds_commList.getCellData(rowIndex, "lobranCd");
    var vehclNoLen = ds_commList.getCellData(rowIndex, "vehclNo").length;
    var vehclNo    = ds_commList.getCellData(rowIndex, "vehclNo").substring(vehclNoLen-4, vehclNoLen);

	var paramObj = {
          lobranCd : lobranCd
        , vehclNo  : vehclNo
    }
    
    $c.win.openMenu("귀로공차정보등록", "/ui/tn/cs/vehclmgnt/tn_101_02_02b.xml", "tn_101_02_02b.jsp", paramObj);    
};


]]></script>

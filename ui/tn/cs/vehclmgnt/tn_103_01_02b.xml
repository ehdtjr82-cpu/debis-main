		<script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// 화면 로딩
//-------------------------------------------------------------------------
scwin.onpageload = function() {
	scwin.strCurDate = $c.date.getServerDateTime();
    
    //공통코드 조회
    const comboOptions = [
        {
            method : "getLuxeComboData", 
            param1 : "WorkImplementEBC", 
            param2 : "retriveLobran2CodeList",
            param3 : ["1"],
            compID : "acb_lobranCd" 
        }
    ];
    
    $c.data.setGauceUtil(comboOptions);
    ica_rcvDt.setValue(scwin.strCurDate);
};

//-------------------------------------------------------------------------
// 조회 필드 Clear
//-------------------------------------------------------------------------
scwin.f_fieldClear = function() {
	console.log("scwin.f_fieldClear");

    ica_rcvDt.setValue(scwin.strCurDate);
    ed_vehclNo.setValue("");
}

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_retrieve = async function() {
	console.log("scwin.f_retrieve");
	
	let chkVal = await $c.gus.cfValidate(ica_rcvDt);
	if(!chkVal) return;
	
    dma_search.set("directOrcoclnt", "D");
	$c.sbm.execute(sbm_retrieve);
}

//-------------------------------------------------------------------------
// 차량비공개 행 추가 
//-------------------------------------------------------------------------
scwin.f_LMove = function() {
    let rowIdx = gr_results2.getAllFocusedRowIndex();
    for (var i=0; i < rowIdx.length; i++) {
        var insRow = ds_results1.insertRow();
        gr_results1.setFocusedCell(insRow, 0);
        scwin.f_copyData(ds_results2, rowIdx[i], ds_results1, insRow);
    }
}

//-------------------------------------------------------------------------
// 차량공개 행 추가
//-------------------------------------------------------------------------
scwin.f_RMove = function() {
    let rowIdx = gr_results1.getAllFocusedRowIndex();
    debugger;
    for (var i=0; i < rowIdx.length; i++) {
        var insRow = ds_results2.insertRow();
        gr_results2.setFocusedCell(insRow, 0);
        scwin.f_copyData(ds_results1, rowIdx[i], ds_results2, insRow);
    }
}

//-------------------------------------------------------------------------
// 선택 행 복사
//-------------------------------------------------------------------------
scwin.f_copyData = function(fromDs, fromRow, toDs, toRow) {
    //추가한 row를 더블클릭하면 추가해제 한다
    if(fromDs.getRowStatus(fromRow) == "C") {
        //목록 중 D인 경우 > R로 status 설정
        var idx = toDs.getMatchedIndex("vehclNo", fromDs.getCellData(fromRow, "vehclNo"))[0];
        toDs.modifyRowStatus(idx, "R");
        debugger;

        fromDs.removeRow(fromRow);
        toDs.removeRow(toRow);
        debugger;

        return;
    }

    //이미 추가한 차량을 또 다시 추가하려고 할때는 제외한다
    var copyYn = "YES";
    for(var i=0; i<toDs.getTotalRow(); i++) {
        if(     toDs.getCellData(i, "vehclNo") == fromDs.getCellData(fromRow, "vehclNo")
            &&  toDs.getCellData(i, "mtvehclDd") == fromDs.getCellData(fromRow, "mtvehclDd")
            &&  toDs.getCellData(i, "hdofficeIdx") == fromDs.getCellData(fromRow, "hdofficeIdx")
            &&  toDs.getCellData(i, "bhofficeIdx") == fromDs.getCellData(fromRow, "bhofficeIdx")
            &&  toDs.getCellData(i, "officeIdx") == fromDs.getCellData(fromRow, "officeIdx")
            &&  toDs.getCellData(i, "ez110Idx") == fromDs.getCellData(fromRow, "ez110Idx")) {
            
                $c.win.alert(fromDs.getCellData(fromRow, "vehclNo")+" 차량은 이미 옮기신 차량입니다");
                scwin.copyYn = "NO";
                toDs.removeRow(toRow);
                return;
        }
    }
    
    if(copyYn == "YES") {
        toDs.setRowJSON(toRow, fromDs.getRowJSON(fromRow), true);
        fromDs.deleteRow(fromRow);
    }

    //포커스 고정 추가
    if(gr_results1.getDataList() == fromDs.id) {
        gr_results1.setFocusedCell(fromRow, 0);
    } else {
        gr_results2.setFocusedCell(fromRow, 0);
    }
}

//-------------------------------------------------------------------------
// f_RMove
//-------------------------------------------------------------------------
scwin.f_save = async function() {  
    let conf = await $c.win.confirm("저장하시겠습니까?");
    if(conf) {
        $c.sbm.execute(sbm_save);
    } 
} 

/* ----------------------------------------------------------------------------
  T R A N S A C T I O N   C O M P O N E N T S   D E C L A R A T I O N
------------------------------------------------------------------------------*/
//조회 완료
scwin.sbm_retrieve_submitdone = function(e) {
    console.log("scwin.sbm_retrieve_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) return; 

    var rowCnt1 = ds_results1.getTotalRow();
	spn_totalRow1.setValue(rowCnt1);
	
    if(rowCnt1 == 0) {
	   $c.win.alert("차량비공개는 조회된 데이터가 없습니다.");
	} 	

    var rowCnt2 = ds_results2.getTotalRow();
	spn_totalRow2.setValue(rowCnt2);
	
    if(rowCnt2 == 0) {
	    $c.win.alert("차량공개는 조회된 데이터가 없습니다.");
	} else {
        ds_results2.sort("vehclNo", 0);
    }
};

//저장 완료
scwin.sbm_save_submitdone = function (e) {
    console.log("scwin.sbm_save_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) return; 

    scwin.f_retrieve();
};

/* ----------------------------------------------------------------------------
  C O M P O N E N T' S   E V E N T S  
-----------------------------------------------------------------------------*/
//조회조건 clear 버튼
scwin.btn_clear_onclick = function (e) {
    console.log("scwin.btn_clear_onclick");
    scwin.f_fieldClear();
};

//조회 버튼
scwin.btn_search_onclick = function (e) {

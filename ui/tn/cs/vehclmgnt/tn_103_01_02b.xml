    scwin.f_retrieve(); 
};

//차량비 그리드 더블 클릭 > 차량 공개 행 추가 
scwin.gr_results_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    let insRow = ds_results2.insertRow();
    scwin.f_copyData(ds_results1, rowIndex, ds_results2, insRow);

};

scwin.btn_rightMove_onclick = function (e) {
    scwin.f_RMove();
};

//차량 공개 그리드 더블 클릭 > 차량비 공개 행 추가
scwin.gr_results2_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    let insRow = ds_results1.insertRow();
    scwin.f_copyData(ds_results2, rowIndex, ds_results1, insRow);
};

scwin.btn_leftMove_onclick = function (e) {
    scwin.f_LMove();
};

//저장 버튼
scwin.btn_save_onclick = function (e) {
    scwin.f_save();
};

]]></script>

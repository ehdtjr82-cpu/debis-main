scwin.strCurrDate = $c.date.getServerDateTime("yyyyMMdd");
scwin.strPreMonth = $c.date.addMonth(scwin.strCurrDate, -1);
var lastDate = $c.date.getLastDateOfMonth(scwin.strPreMonth);
scwin.strFirstDate = scwin.strPreMonth.substring(0, 6) + "01";
scwin.strLastDate = scwin.strPreMonth.substring(0, 6) + lastDate;

scwin.memJson = $c.data.getMemInfo();
scwin.lobranCd = scwin.memJson.lobranCd; //상위물류점소코드


// 히든컴포넌트

    }
};



//-------------------------------------------------------------------------
// 팝업 처리시 검색된 데이터인 경우 팝업 처리 안함.
//-------------------------------------------------------------------------
scwin.f_chkOpenCommonPopUp = function(inObj, pairObj, disGubun, isCode) {
    // 값이 입력이 안된 경우, 해당 Text Box가 readonly 인 경우, 이전값과 동일한 경우 팝업을 실행하지 않음.
    if (!$c.gus.cfCanOpenPopup(inObj, pairObj)) {
        return;
    }
    
    // 짝이 되는 오브젝트의 값 제거
    $c.gus.cfClearPairObj(pairObj);
    
    // 검색어 세팅
    var pVal = $c.gus.cfGetValue(inObj);
            
    // inObj가 코드 필드일 경우 팝업
    if (isCode == null || isCode == true) {
        scwin.f_openCommonPopUp(disGubun, pVal, '', 'T', 'T');
    // inObj가 코드명 필드일 경우 팝업
    } else {
        scwin.f_openCommonPopUp(disGubun, '', pVal, 'T', 'T');
    }
};



scwin.sbm_Retrieve_submitdone = async function (e) {
    var rowCnt = ds_results1.getTotalRow();

    if ( rowCnt < 1 ) {
        // totalRows1.setValue("0");
        await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
        em_pchsClntNo.setValue("");
        txt_pchsClntNm.setValue("");
        em_clntNo.setValue("");
        txt_clntNm.setValue("");
        return;              
    }    

    totalRows1.setValue(rowCnt);
};



scwin.sbm_Retrieve_detail_submitdone = function (e) {
    var rowCnt = ds_results2.getTotalRow();
    totalRows2.setValue(rowCnt);

    for(var i = 0; i < rowCnt; i++)	{
    	if (ds_results2.getCellData(i, "carDivision") == "귀") {
    		ds_results2.setCellData(i, "carDivision", "귀로차량");
    	} else if (ds_results2.getCellData(i, "carDivision") == "당") {
			ds_results2.setCellData(i, "carDivision", "당사차량");		    	
    	} else if (ds_results2.getCellData(i, "carDivision") == "협") {
    		ds_results2.setCellData(i, "carDivision", "협력업체");
    	}	 
    }
};



scwin.gr_results1_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    ds_condition1.set("upperLobranCd", ds_results1.getCellData(rowIndex, "lobranCd"));
    ds_condition1.set("rsltsStdDt", em_rsltsStdDt.getValue());
    ds_condition1.set("rsltsStdDt2", em_rsltsStdDt2.getValue());
    ds_condition1.set("rsltsStdDt3", ds_condition.get("rsltsStdDt3"));
    ds_condition1.set("cargoClsCd", lc_cargoClsCd.getValue());
    ds_condition1.set("bilgClntNo", em_clntNo.getValue());
    ds_condition1.set("pchsClntNo", em_pchsClntNo.getValue());
    ds_condition1.set("retrieveCd", lc_retrieveCd.getValue());
    ds_condition1.set("retrieveCd2", lc_retrieveCd2.getValue());

    $c.sbm.execute(sbm_Retrieve_detail);
};



scwin.onpageload = async function() {
    const param= [
        {
            method: "getLuxeComboData",
            param1: "WorkImplementEBC",
            param2: "retriveLobran2CodeList",
            param3: ["1"],
            compID: "lc_upperLobranCd"
        }
    ];
    await $c.data.setGauceUtil(param, function() {
        lc_upperLobranCd.addItem("국제물류", "1GG", true, 1);
        if( scwin.lobranCd == "" ) {
            lc_upperLobranCd.setValue("");
        }
        else {
            lc_upperLobranCd.setValue(scwin.lobranCd);
        }
    });
};


scwin.onUdcCompleted = function() {
    em_rsltsStdDt.setValue($c.date.getServerDateTime("yyyyMM"));
    em_rsltsStdDt2.setValue($c.date.getServerDateTime("yyyyMM"));

    lc_retrieveCd.setValue("0");
    lc_retrieveCd2.setValue("0");
};



//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function() {
    if (em_rsltsStdDt.getValue() == "") {
        await $c.gus.cfAlertMsg("실적일은 필수 입력 항목입니다.");
        return;
    }
    
    if (em_rsltsStdDt.getValue().substring(0,4) == em_rsltsStdDt2.getValue().substring(0,4)) {
        //조회조건을 위한 바인드
        ds_condition.set("upperLobranCd", lc_upperLobranCd.getValue());
        ds_condition.set("cargoClsCd", lc_cargoClsCd.getValue());
        ds_condition.set("retrieveCd", lc_retrieveCd.getValue());
        ds_condition.set("retrieveCd2", lc_retrieveCd2.getValue());
        ds_condition.set("rsltsStdDt", em_rsltsStdDt.getValue());
        ds_condition.set("rsltsStdDt2", em_rsltsStdDt2.getValue());
        ds_condition.set("bilgClntNo", em_clntNo.getValue());
        ds_condition.set("pchsClntNo", em_pchsClntNo.getValue());

        if (em_rsltsStdDt.getValue().substring(0,4) == "2015") {
            ds_condition.set("rsltsStdDt3", "201501");
        } else {
            ds_condition.set("rsltsStdDt3", ds_condition.get("rsltsStdDt"));
        }

        $c.sbm.execute(sbm_Retrieve);

    } else {
        await $c.win.alert("실적일의 시작 년도와 종료 년도가 동일하여야 합니다.");
        return;
    }
};




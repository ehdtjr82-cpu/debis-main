scwin.f_runExcel1 = async function() {
    var totCnt      = ds_results1.getTotalRow();
    var sheetTitle  = "직접운송비율";

    if ( totCnt > 0) {
        var cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");
        
        if (cfrm) {
            await $c.data.downloadGridViewExcel(gr_results1, { fileName: sheetTitle + ".xlsx", sheetName: sheetTitle });
        }
    } else {
        await $c.gus.cfAlertMsg(MSG_CM_WRN_002);    
    }
};

scwin.f_runExcel2 = async function() {
    var totCnt      = ds_results2.getTotalRow();

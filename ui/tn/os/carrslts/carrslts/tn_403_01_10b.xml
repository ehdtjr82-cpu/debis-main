/*
    NTIS/운송현황/배차실적현황/최소운송의무 실적 조회

    ▶ 조회조건
       기간 : 2016/01 ~ 2016/12
 */

scwin.nowDt = $c.date.getServerDateTime("yyyyMM");

scwin.memJson = $c.data.getMemInfo();

scwin.loUpperLobranCd = scwin.memJson.loUpperLobranCd; //상위물류점소코드
scwin.userId = scwin.memJson.userId; //사용자아이디

scwin.lobranCd = $c.gus.cfIsNull(scwin.memJson.lobranCd) ? '' : scwin.memJson.lobranCd;
scwin.wrkStDt = $c.gus.cfIsNull(scwin.memJson.wrkStDt) ? '' : scwin.memJson.wrkStDt;
scwin.lobranCd = $c.gus.cfIsNull(scwin.memJson.wrkEndDt) ? '' : scwin.memJson.wrkEndDt;


scwin.onpageload = async function() {
    if (scwin.loUpperLobranCd == null) {
        scwin.loUpperLobranCd = "";
    }

    const param= [
        {
            method: "getLuxeComboData",
            param1: "WorkImplementEBC",
            param2: "retriveLobran2CodeList",
            param3: ["1"],
            compID: "lc_wrkLobranCd"
        }
    ];
    await $c.data.setGauceUtil(param, function() {
        lc_wrkLobranCd.addItem("국제물류", "1GG");

        var items = [];
        for (var i = 0; i < lc_wrkLobranCd.getDataListInfo().id.length; i++) {
            items[i] = lc_wrkLobranCd.getItem(i);
        }
        items.sort(function(a, b){
            return a.value.localeCompare(b.value);
        });
        lc_wrkLobranCd.removeAll();
        for (var i = 0; i < items.length; i++) {
            lc_wrkLobranCd.addItem(items[i].orgLabel, items[i].value);
        }

        lc_wrkLobranCd.changeChooseOption("", "전체");
    });
};

scwin.onUdcCompleted = function() {
    if (scwin.wrkStDt == "") {
        ed_srchFromDate.setValue(scwin.nowDt);
        ed_srchToDate.setValue(scwin.nowDt);
    } else {
        ed_srchFromDate.setValue(scwin.wrkStDt);
        ed_srchToDate.setValue(scwin.wrkEndDt);
    }

    scwin.f_defaultValue();	
};



//-------------------------------------------------------------------------
// 상세 조회
//-------------------------------------------------------------------------
scwin.f_RetrieveDetail = function(row, colid) {
    if(colid == "ton1Rs"){
        ds_search2.set("ton", "TON_1");
    }
    
    if(colid == "ton3Rs"){
        ds_search2.set("ton", "TON_3");
    }
    
    if(colid == "ton5Rs"){
        ds_search2.set("ton", "TON_5");
    }
    
    if(colid == "ton8Rs"){
        ds_search2.set("ton", "TON_8");
    }
    
    if(colid == "ton10Rs"){
        ds_search2.set("ton", "TON_10");
    }
    
    if(colid == "ton12Rs"){
        ds_search2.set("ton", "TON_12");
    }
    
    if(colid == "ton15Rs"){
        ds_search2.set("ton", "TON_15");
    }
    
    if(colid == "ton20Rs"){
        ds_search2.set("ton", "TON_20");
    }
    
    if(colid == "tonmaxRs"){
        ds_search2.set("ton", "TON_MAX");
    }

    ds_search2.set("minTrnsEqKndCd", ds_330.getCellData(row, "minTrnsEqKndCd"));
    ds_search2.set("upperLobranCd", lc_wrkLobranCd.getValue());
    ds_search2.set("stDt", ed_srchFromDate.getValue());
    ds_search2.set("endDt", ed_srchToDate.getValue());

    $c.sbm.execute(sbm_retrieveDetail);
};



//-----------------------------------------------------------------------------
// 조회조건 셋팅 
//-----------------------------------------------------------------------------
scwin.f_defaultValue = function() {
    var curDate = scwin.nowDt;
    ed_srchFromDate.setValue(curDate);
};



//-----------------------------------------------------------------------------
// 조회
//-----------------------------------------------------------------------------
scwin.f_Retrieve = async function() { 	
    var yearSt = ed_srchFromDate.getValue();
    var start = yearSt.substring(0,4);
    var yearEnd = ed_srchToDate.getValue();
    var end = yearEnd.substring(0,4);
    
    ds_search.set("start", start);
    
    if (start != end) {
        await $c.win.alert("같은 연도기간으로 설정해주십시오.");
        return false;
    }
    
    ds_search.set("upperLobranCd", lc_wrkLobranCd.getValue());
    ds_search.set("stDt", ed_srchFromDate.getValue());
    ds_search.set("endDt", ed_srchToDate.getValue());

    $c.sbm.execute(sbm_retrieve);
};



//-------------------------------------------------------------------------
// 엑셀 다운로드 
//-------------------------------------------------------------------------
scwin.f_Excel_1 = async function() {
    if (ds_330.getTotalRow() == 0) {
        return;
    }
    var title = "최소운송기준내역";
    await $c.data.downloadGridViewExcel(gr_330, { fileName: title + ".xlsx", sheetName: "최소운송기준" });
};

scwin.f_Excel2 = async function() {
    if (ds_detail.getTotalRow() == 0) {
        return;
    }
    var title = "최소운송기준내역상세";
    await $c.data.downloadGridViewExcel(gr_detail, { fileName: title + ".xlsx", sheetName: "최소운송기준" });
};


scwin.sbm_retrieve_submitdone = function (e) {
    // for=ds_330 event=OnLoadCompleted(rowCnt)
    var rowCnt = ds_330.getTotalRow();
    totalRows.setValue(rowCnt);

    if (rowCnt == 0) {
        $c.gus.cfAlertMsg("조회결과가 존재하지 않습니다.");
    }

    if (rowCnt > 0) {
        scwin.setCellBackgroundColor();
    }
};


scwin.setCellBackgroundColor = function() {
    var arr1 = ["ton1Rt", "ton1Rt", "ton3Rt", "ton5Rt", "ton8Rt", "ton10Rt", "ton12Rt", "ton15Rt", "ton20Rt", "tonmaxRt"];
    var arr2 = ["ton1Yn", "ton1Yn", "ton3Yn", "ton5Yn", "ton8Yn", "ton10Yn", "ton12Yn", "ton15Yn", "ton20Yn", "tonmaxYn"];
    var arr3 = ["totPr", "ton1Rs", "ton3Rs", "ton5Rs", "ton8Rs", "ton10Rs", "ton12Rs", "ton15Rs", "ton20Rs", "tonmaxRs"];
    var chkNum = -1;

    
    for (var i = 0; i < ds_330.getTotalRow(); i++) {
        for (var arrCnt = 0; arrCnt < arr1.length; arrCnt++) {
            if (ds_330.getCellData(i, arr1[arrCnt]) == "1" && ds_330.getCellData(i, arr2[arrCnt]) == "1") {
                // arr3[arrCnt]
                gr_330.setCellBackgroundColor(i, arr3[arrCnt], "yellow");
            }
        }
    }
    // gr_330.mergeCell({"rowIndex" : 1, "colIndex" : 1, "colSpan" : 1, "rowSpan" : 2});
    // gr_330.mergeCell({"rowIndex" : 1, "colIndex" : 2, "colSpan" : 1, "rowSpan" : 2});
};


scwin.gr_330_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    if (rowIndex >= 0) {
        if (columnId == "ton1Rs" || columnId == "ton3Rs"|| columnId == "ton5Rs"|| columnId == "ton8Rs"|| columnId == "ton10Rs"|| columnId == "ton12Rs"|| columnId == "ton15Rs"|| columnId == "ton20Rs"|| columnId == "tonmaxRs" ) {
            scwin.f_RetrieveDetail(rowIndex, columnId);
        }
    }
};



scwin.sbm_retrieveDetail_submitdone = function (e) {
    var rowCnt = ds_detail.getTotalRow();
    totalRows2.setValue(rowCnt);

    if (rowCnt == 0) {
        $c.gus.cfAlertMsg("조회결과가 존재하지 않습니다.");
    }
};


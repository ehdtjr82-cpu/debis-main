scwin.f_retrieve = async function() {
    if (!$c.gus.cfValidate(tbl_search)){
        return;
    }

    if (!$c.gus.cfIsAfterDate(ed_wrkStDt.getValue(), ed_wrkEndDt.getValue())) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_039);
        ed_wrkStDt.focus();
        return;
    }

    if (lc_cargoGub.getValue() != "") {
        if (lc_cargoGub.getValue() == "C") {
            gr_commList.setColumnVisible("wrkQty", "false"); //수량
            gr_commList.setColumnVisible("wrkWt", "false"); //중량
            gr_commList.setColumnVisible("wrkCubic", "false"); //CBM
            gr_commList.setColumnVisible("realCntrNo", "true"); //CNTR 넘버
            gr_commList.setColumnVisible("realSealNo", "true"); //SEAL 넘버
            gr_commList.setColumnVisible("cntrSizNm", "true"); //사이즈
            gr_commList.setColumnVisible("cntrTypNm", "true"); //타입
        }

        if(lc_cargoGub.getValue() =="B"){
            gr_commList.setColumnVisible("wrkQty", "true");
            gr_commList.setColumnVisible("wrkWt", "true");
            gr_commList.setColumnVisible("wrkCubic", "true");
            gr_commList.setColumnVisible("realCntrNo", "false");
            gr_commList.setColumnVisible("realSealNo", "false");
            gr_commList.setColumnVisible("cntrSizNm", "false");
            gr_commList.setColumnVisible("cntrTypNm", "false");
        }
    
    } else if (lc_cargoGub.getValue() == "") {
        gr_commList.setColumnVisible("wrkQty", "true"); //수량
        gr_commList.setColumnVisible("wrkWt", "true"); //중량
        gr_commList.setColumnVisible("wrkCubic", "true"); //CBM
        gr_commList.setColumnVisible("realCntrNo", "true"); //CNTR 넘버
        gr_commList.setColumnVisible("realSealNo", "true"); //SEAL 넘버
        gr_commList.setColumnVisible("cntrSizNm", "true"); //사이즈
        gr_commList.setColumnVisible("cntrTypNm", "true"); //타입
    }
    
    // gr_commList.Redraw = "False";
    
    //최초 화면 로딩시 selfVolume변수(자가물량 표시여부)가 세팅 되지 않음
    if (chb_selfVolume.getValue() == "1") {
        // ds_queryConditionDTO.ColumnString(1,9) = 1;

    } else {
        // ds_queryConditionDTO.ColumnString(1,9) = 0;
    }
    
    $c.sbm.execute(sbm_queryConditionDTO);
};



	// 선언부
	var rtnList;  // 공통POP-UP -> 요청화면

	switch (disGubun)
 	{
 		case 1:
		// 거래처  팝업
        udc_bilgClnt.setSelectId("retrieveClntList_tpro");
		rtnList = await udc_bilgClnt.cfCommonPopUp(scwin.retrieveClntList_tpro_callBack
								,pCode
								,pName
								,pClose
								,null
								,null
								,null
								,"3,4,5,6,7,8,9,10"
								,"" //" ,S"
								,null
								,null
								,null
								,null
								,null
								,pAllSearch
								,null
								,null
								); //

								  //거래처ID    거래처명
 		
		break;
	}
};

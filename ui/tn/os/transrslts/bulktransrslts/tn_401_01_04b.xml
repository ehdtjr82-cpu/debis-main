// 화면 로딩
//-------------------------------------------------------------------------
scwin.onpageload = function() {
	scwin.vCurDate = $c.date.getServerDateTime();
    scwin.prevRow = 0;

    //공통코드 조회
	const codeOptions = [
		{ grpCd : "SD113", compID : "acb_srchOdrKndCd" }
	];
	$c.data.setCommonCode(codeOptions, scwin.callBackSetCommonCode);
	
    const comboOptions = [
        {
            method : "getLuxeComboData", 
            param1 : "WorkImplementEBC", 
            param2 : "retriveLobran2CodeList",
            param3 : ["1"],
            compID : "acb_sellBilgCltLupCond" 
        }
    ];
    $c.data.setGauceUtil(comboOptions);
    cbx_totalYn.setValue("1");
};

//-------------------------------------------------------------------------
// UDC 로딩
//-------------------------------------------------------------------------
scwin.onUdcCompleted = function() {
    udc_fromToCalendar.setInitDate(scwin.vCurDate, scwin.vCurDate);

    ed_bilgClntNo.focus();
    acb_clntKndCd.setValue("0");
}

//-------------------------------------------------------------------------
// 조회 필드 Clear
//-------------------------------------------------------------------------
scwin.f_fieldClear = function() {
	console.log("scwin.f_fieldClear");
	$c.gus.cfInitObjects(tbl_search);
    scwin.onUdcCompleted();
}

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_retrieve = async function() {
    let chkVal = await $c.gus.cfValidate([tbl_search]);
    if(!chkVal) return ;

	if(!$c.gus.cfIsAfterDate(ed_rsltsStdDtFm.getValue(), ed_rsltsStdDtTo.getValue())) {
    	$c.gus.cfAlertMsg(MSG_CM_ERR_039);
    	ed_rsltsStdDtFm.focus();
    	return;
    }
    
    if(!$c.gus.cfIsAfterDate(ed_rsltsStdDtFm.getValue(), ed_rsltsStdDtTo.getValue())) {
    	$c.gus.cfAlertMsg(MSG_CM_ERR_039);
    	ed_rsltsStdDtFm.focus();
    	return;
    }

	$c.sbm.execute(sbm_retrieve);
}

//-------------------------------------------------------------------------
// 팝업 처리시 검색된 데이터인 경우 팝업 처리 안함.
//-------------------------------------------------------------------------
scwin.f_openCommonPopUp = function(disGubun, pCode, pName, pClose, pAllSearch) {
	switch (disGubun) {
 		case 1:
		// 거래처  팝업
		udc_bilgClntNo.cfCommonPopUp(    scwin.callBackClnt
                                        ,pCode
                                        ,pName
                                        ,pClose
                                        ,null
                                        ,null
                                        ,null
                                        ,"3,4,5,6,7,8,9,10"
                                        ,"" //" ,S"
                                        ,null
                                        ,null
                                        ,null
                                        ,null
                                        ,null
                                        ,pAllSearch
                                        ,null
                                        ,null
                                        ); // 
		break;
	}
}

scwin.callBackClnt = function(rtnList) {
    $c.gus.cfSetReturnValue(rtnList, ed_bilgClntNo, ed_bilgClntNm);
}

scwin.f_displayFormatter = function(data) {
    if(ds_master.getTotalRow() == 0) return "";
    else                             return $c.num.formatNumber($c.num.round(data, 1));
}


};

//거래처찾기 버튼
scwin.udc_bilgClntNo_onclickEvent = function (e) {
    scwin.f_openCommonPopUp(1, ed_bilgClntNo.getValue(), ed_bilgClntNm.getValue(), 'F', 'F');
};

scwin.udc_bilgClntNo_onblurCodeEvent = function (e) {

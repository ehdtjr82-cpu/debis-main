    	<script lazy="false" type="text/javascript"><![CDATA[
// NTIS/배차관리/컨테이너 운송지시 - 차량정보조회


scwin.onpageload = async function() {
	scwin.params = $c.data.getParameter();

    var eqCd = $c.gus.cfIsNull(scwin.params["eqCd"]) ? "" : scwin.params["eqCd"];
    var chassisEqCd = $c.gus.cfIsNull(scwin.params["chassisEqCd"]) ? "" : scwin.params["chassisEqCd"];

    dma_results.set("eqCd", eqCd);
    dma_results.set("chassisEqCd", chassisEqCd);

    scwin.f_Retrieve();
};


scwin.f_Retrieve = function() {
    // tr_Retrieve.post();
    $c.sbm.execute(sbm_retrieve);
};


// OnLoadCompleted(rowCnt)
scwin.sbm_retrieve_submitdone = async function (e) {
    if (ds_results.getTotalRow() == 0) {
	    await $c.win.alert("조회된 데이터가 없습니다.");
		$c.win.closePopup();

	} else {
        //setValue
        spn_vehclNo.setValue(ds_results.getCellData(0, "vehclNo"));
        spn_vehclClntNm.setValue(ds_results.getCellData(0, "vehclClntNm"));
        spn_regLobranCd.setValue(ds_results.getCellData(0, "regLobranCd"));
        spn_assgnLobranCd.setValue(ds_results.getCellData(0, "assgnLobranCd"));
        spn_drvNm.setValue(ds_results.getCellData(0, "drvNm"));
        spn_mpNo.setValue(ds_results.getCellData(0, "mpNo"));
        spn_eqKndNm.setValue(ds_results.getCellData(0, "eqKndNm"));
        spn_eqNrmNm.setValue(ds_results.getCellData(0, "eqNrmNm"));
        spn_chassisVehclNo.setValue(ds_results.getCellData(0, "chassisVehclNo"));
        spn_chassisKndNm.setValue(ds_results.getCellData(0, "chassisKndNm"));
    }
};

scwin.btn_close_onclick = function (e) {
    $c.win.closePopup();
};
]]></script>

    	<script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// PGM명 : 유류구매사용누계현황 (tr_270_07_12b)
// 작성자 : 송정희
// 최초작성일자 : 2026-01-02
//-------------------------------------------------------------------------

scwin.fromDate_YyMm = ""; // 작업날짜
scwin.fromDate_YyMm = WebSquare.date.getCurrentServerDate("yyyyMM");

scwin.onpageload = function() {
    const codeOptions = [
        { grpCd : "ZZ205", compID : "lc_homeClsCd",opt :{"range" : "2,TR"}}              // 소속구분
    ];
    $c.data.setCommonCode(codeOptions);  

    lc_homeClsCd.setValue("LO");
};

scwin.onUdcCompleted = function() {
    ed_stDt.setValue(scwin.fromDate_YyMm.substring(0,4)+"01");
    ed_endDt.setValue(scwin.fromDate_YyMm.substring(0,6));
    ed_stDt.focus();  	
};

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function () {    
    if ( ed_stDt.getValue().trim().length != 6 ) {
        await $c.win.alert("구매시작월은 필수입력 입니다.");
        ed_stDt.focus();
        return;
    }
    if ( ed_endDt.getValue().trim().length != 6 ) {
        await $c.win.alert("구매종료월은 필수입력 입니다.");
        ed_endDt.focus();
        return;
    }
    if ( ed_stDt.getValue() > ed_endDt.getValue() ) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_045, ['구매월'] );	//기간 체크
        ed_stDt.focus();
        return;
    } 
   
    ds_dummy.set("stDt", ed_stDt.getValue());
    ds_dummy.set("endDt", ed_endDt.getValue());
    ds_dummy.set("homeClsCd", lc_homeClsCd.getValue());

    $c.sbm.execute(sbm_master);   
}   

scwin.btn_Search_onclick = function (e) {
    scwin.f_Retrieve();
};

//-------------------------------------------------------------------------
// 엑셀 다운로드
//-------------------------------------------------------------------------
scwin.f_Excel = async function() {
   if(ds_MonthEachOilIn.getRowCount() == 0) {
        await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
        return;
    }
      
    let gridColCount = 0;
    for(let i = 0; i < gr_MonthEachOilIn.getTotalCol(); i++){
        if(gr_MonthEachOilIn.getColumnVisible(i)==true){
            gridColCount++;
        }
    }

    let str = $c.gus.cfGetFormatStr(ed_stDt.getValue(), "####/##");
    let str1 = $c.gus.cfGetFormatStr(ed_endDt.getValue(), "####/##");    
    let str2 = lc_homeClsCd.getText(true);
    let startRowIndex = 0;
    let infoArr = [{
        rowIndex : 0,             
        colIndex : 0,            
        colSpan : gridColCount,   
        rowSpan : 1,
        text : "유류 구매사용누계 현황",
        textAlign : "center",    
        fontSize : 12,
        drawBorder : false,       
        color : "black",          
        backgroundColor : "#ffffff" 
    },{
        rowIndex : 2,           
        colIndex : 0,            
        colSpan : gridColCount,   
        rowSpan : 1,
        text : "기준년월 ["+ str +" ~ "+ str1 +"]",
        textAlign : "left",    
        fontSize : 10,
        drawBorder : false,       
        color : "black",         
        backgroundColor : "#ffffff" 
    },{
        rowIndex : 3,           
        colIndex : 0,            
        colSpan : gridColCount,   
        rowSpan : 1,
        text : "소속구분 ["+ str2+"]",
        textAlign : "left",    
        fontSize : 10,
        drawBorder : false,       
        color : "black",         
        backgroundColor : "#ffffff"         
    }]

    const options = {
        fileName: "유류 구매사용누계 현황.xlsx",
//        sheetName: "기준년월" +  str +"_"+ str1  + "_소속" + str2 ,
        sheetName: "유류 구매사용누계 현황",
        startRowIndex : 4,        
        startColumnIndex : 0,
        type : 1
    };
    await $c.data.downloadGridViewExcel(gr_MonthEachOilIn, options, infoArr);
};


scwin.ds_MonthEachOilIn_ondataload = function () {
    let rowCnt = ds_MonthEachOilIn.getTotalRow();
    totalRows.setValue(rowCnt);       

	if( rowCnt == 0 ){
	    $c.win.alert("조회된 데이터가 없습니다.");   
	} 

};

]]></script>

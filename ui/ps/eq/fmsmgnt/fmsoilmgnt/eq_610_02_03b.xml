//전역변수
scwin.ed_stdDt = $c.date.getServerDateTime("yyyyMM") + "01"; //당월1일

scwin.onpageload = function () {
    var codeOptions = [
        { grpCd: "TL104", compID: "lc_preCoAfClsCd,gr_oilOutList:preCoAfClsCd" }, // 유류판매구분
        { grpCd: "TL105", compID: "lc_oilkndCd,gr_oilOutList:oilkndCd" }, // 유종구분
        { grpCd: "TL113", compID: "lc_payClsCd, gr_oilOutList:payClsCd" },  // 거래구분
        { grpCd: "TL103", compID: "gr_oilOutList:oilTskClsCd" }, //유류업무구분
        { grpCd: "TL100", compID: "gr_oilOutList:oilBizClsCd" }, //유류사업구분
        { grpCd: "TL101", compID: "gr_oilOutList:selpchClsCd" }, //매출입구분
        { grpCd: "ZZ701", compID: "gr_oilOutList:oilingPurpsCd" }, //주유용도
        { grpCd: "ZZ205", compID: "gr_oilOutList:homeClsCd" } //소속구분
    ];
    $c.data.setCommonCode(codeOptions);
};

//-------------------------------------------------------------------------
// onUdcCompleted : UDC 완료. 그리는 시점 차이 보완. onPageLoad 에서 호출 
//-------------------------------------------------------------------------
scwin.onUdcCompleted = function () {
    ed_stdDt.setValue(scwin.ed_stdDt);		                  // 시작날짜
    ed_endDt.setValue($c.date.getServerDateTime("yyyyMMdd")); // 종료날짜
    lc_oilkndCd.setSelectedIndex(0);
    lc_oilStatClsCd.setSelectedIndex(0);                      // 럭스 콤보 초기화
};

scwin.f_CheckAdptDt = async function () {
    var vAdptStDt = ed_stdDt.getValue();
    var vAdptEndDt = ed_endDt.getValue();
    var vReturn = true;

    if (vAdptStDt == "" || vAdptStDt.length < 8) {
        await $c.win.alert("적용시작일자를 정확하게 입력해주십시오.");
        ed_stdDt.focus();
        vReturn = false;
    }

    if (vAdptEndDt == "" || vAdptEndDt.length < 8) {
        await $c.win.alert("적용종료일자를 정확하게 입력해주십시오.");
        ed_endDt.focus();
        vReturn = false;
    }

    if (vAdptStDt > vAdptEndDt) {
        await $c.win.alert("적용시작일자가 종료일자보다 늦은 날짜입니다.");
        ed_stdDt.focus();
        vReturn = false;
    }
    return vReturn;
};

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function (e) {
    var vChkVal = await scwin.f_CheckAdptDt();	//날짜 체크한 결과 값을 리턴
    if (!vChkVal) {	//true or false 결과을 체크하여 잘못들어갔다면, false값 리턴
        return false;
    }

    //조회데이터셋팅
    dma_search.set("oilOilStatNo", ed_oilOilStatCd.getValue());
    dma_search.set("stdDt", ed_stdDt.getValue());
    dma_search.set("endDt", ed_endDt.getValue());
    dma_search.set("preCoAfClsCd", lc_preCoAfClsCd.getValue());
    dma_search.set("oilkndCd", lc_oilkndCd.getValue());
    dma_search.set("ioClsCd", "O");//출고
    dma_search.set("oilStatClsCd", lc_oilStatClsCd.getValue());
    dma_search.set("acctDeptCd", ed_acctDeptCd.getValue());
    dma_search.set("clntNo", ed_clntNo.getValue());
    dma_search.set("bpClntNo", ed_bpClntNo.getValue());
    dma_search.set("payClsCd", lc_payClsCd.getValue());

    //ds_search.UseChangeInfo = "false";
    $c.sbm.execute(sbm_retrieve);
};

scwin.sbm_retrieve_submitdone = async function (e) {
    var rowCnt = 0;
    if (e.responseJSON.resultDataSet[0].Msg != 'FAIL') {
        rowCnt = ds_oilOutList.getRowCount();

        if (rowCnt == 0) {
            await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
        }
    }

    totalRows.setValue(rowCnt);
};

//-------------------------------------------------------------------------
// 엑셀 출력
//-------------------------------------------------------------------------
scwin.f_Excel = function () {
    var count = ds_oilOutList.getRowCount();
    if (!(count > 0)) return;

    var oilkndCd = lc_oilkndCd.getText(true) || "선택"

    var hiddenCnt = 0;
    gr_oilOutList.hiddenList.sort(function (t) { if (t == true) hiddenCnt++; });
    var colSpan = gr_oilOutList.getColCnt() - hiddenCnt;

    var options = {
        fileName: "FMS유류출고현황조회.xlsx",
        sheetName: "FMS유류출고현황조회",
        startRowIndex: 5,
        startColumnIndex: 0,
        type: 1,
        columnMove: true, //그리드 컬럼이동시 이동된 상태로 다운로드 유무 ( "true"인경우 컬럼이동 순서대로 출력 )
        evenRowBackgroundColor: "#f5fff5"//excel파일에서 그리드 body의 짝수줄의 배경색
    };

    var infoArr = [{
        rowIndex: 0,
        colIndex: 0,
        rowSpan: 1,
        colSpan: colSpan,
        text: "FMS유류출고현황조회",
        textAlign: "center",
        fontSize: 12,
        drawBorder: false
    }, {
        rowIndex: 2,
        colIndex: 0,
        rowSpan: 1,
        colSpan: colSpan,
        text: `출고일자 [${$c.date.formatDate(ed_stdDt.getValue(), "date")} ~ ${$c.date.formatDate(ed_endDt.getValue(), "date")}]`,
        textAlign: "left",
        fontSize: 12,
        drawBorder: false
    }, {
        rowIndex: 3,
        colIndex: 0,
        rowSpan: 1,
        colSpan: colSpan,
        text: `주유소 [${ed_oilStatNm.getValue()}[${ed_oilOilStatCd.getValue()}]]`,
        textAlign: "left",
        fontSize: 12,
        drawBorder: false
    }, {
        rowIndex: 4,
        colIndex: 0,
        rowSpan: 1,
        colSpan: colSpan,
        text: `유종구분 [${oilkndCd}]`,
        textAlign: "left",
        fontSize: 12,
        drawBorder: false
    }];

    $c.data.downloadGridViewExcel(gr_oilOutList, options, infoArr);
};


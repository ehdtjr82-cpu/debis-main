    if( "" == scwin.vEqHomeClsCd ) {
    } else {
        lc_homeClsCd.setValue(scwin.vEqHomeClsCd);
    }
    scwin.f_searchCombo3(lc_homeClsCd.getValue());
	lc_homeClsCd.focus();
};


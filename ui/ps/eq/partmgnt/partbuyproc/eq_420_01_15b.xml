    	<script lazy="false" type="text/javascript"><![CDATA[scwin.curDate               = WebSquare.date.getCurrentServerDate().substring( 0 , 6 )


scwin.onpageload = function() {

};

scwin.onUdcCompleted = function(){
    scwin.f_defaultValue();
};

//-------------------------------------------------------------------------
// 초기화
//-------------------------------------------------------------------------
scwin.f_defaultValue = function() {	
    ed_inYmFrom.setValue(scwin.curDate);
    ed_inYmTo.setValue(scwin.curDate);
  	ed_inYmFrom.focus(); 
};

//-------------------------------------------------------------------------
// 조회 조건 지우기
//-------------------------------------------------------------------------
scwin.f_FieldClear = function () {
	$c.gus.cfInitObjects(tb_eq420, null);
};

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function () {	  
    if( ! await $c.gus.cfValidate([ed_inYmFrom, ed_inYmTo]) ) return;
	//필수입력항목 체크
    if (ed_inYmFrom.getValue() > ed_inYmTo.getValue()) {
        await $c.win.alert(MSG_CM_ERR_039);
        ed_inYmFrom.focus();
        return;
    }

	$c.sbm.execute(sbm_retrieve);
};


//------------------------------------------------------------------------
// script
//------------------------------------------------------------------------  
scwin.sbm_retrieve_submitdone = function (e) {
	// cfShowTotalRows(totalRows, rowCnt);
    let rowCnt = ds_eq420.getRowCount();
    totalRows.setValue(rowCnt);
	if (rowCnt == 0) {
		$c.win.alert(MSG_CM_WRN_002);
	};
};



scwin.gr_eq420_oncellclick = async function (rowIndex, columnIndex, columnId) {
    if ( columnId == "slipNo" ) { 
        var slipNo = ds_eq420.getCellData(rowIndex, "slipNo");
        if ( slipNo !=  "" ) {
            await $c.gus.cfShowSlipInfo( slipNo );
        } 
    }  
};



scwin.sbm_retrieve_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;
    let rowCnt = ds_eq420.getRowCount();
    totalRows.setValue(rowCnt);
};
]]></script>

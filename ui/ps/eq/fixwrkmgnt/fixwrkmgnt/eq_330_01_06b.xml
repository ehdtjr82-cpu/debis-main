    	<script lazy="false" type="text/javascript"><![CDATA[// 전역 변수
scwin.memJson = $c.data.getMemInfo();
scwin.strCurDate = $c.date.getServerDateTime("yyyyMMdd"); 

scwin.onpageload = function() {
	const codeOptions = [
        { grpCd: "ZZ205", compID: "lc_homeClsCd",opt :{"range" : "1,EQ"} },
    ];
    $c.data.setCommonCode(codeOptions);

    scwin.getWrkPlcd();
};

scwin.ondataload = function() {
    lc_homeClsCd.setSelectedIndex(-1);
    lc_homeClsCd.setValue(scwin.memJson.eqHomeClsCd);
}

/**
 * UDC값
 */
scwin.onUdcCompleted = function() {
    ica_wrkStDt.setValue(scwin.strCurDate);
    ica_wrkEndDt.setValue(scwin.strCurDate);
};

scwin.getWrkPlcd = function() {
    const params = {
        sysCd: "PsCommonEBC", 
        queryId: "retriveWrkplList",
        param1: lc_homeClsCd.getValue(),
    };

    //데이터셋에 정보설정
    dma_lc_wrkPlCd.setJSON(params);

    $c.sbm.execute(sbm_lc_wrkPlcd);
}

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function() {
    let ret = await $c.gus.cfValidate([tb_wrk]);
    if (!ret) return;

    let diff = $c.date.diffDate(ica_wrkStDt.getValue(), ica_wrkEndDt.getValue());
    if (diff > 30) {
        await $c.win.alert($c.data.getMessage(MSG_CM_ERR_041, ["조회기간"],["한달이상"]));
        ica_wrkStDt.focus();
        return;
    }

    if (!$c.gus.cfIsAfterDate(ica_wrkStDt.getValue(), ica_wrkEndDt.getValue()) < 0) {
        await $c.win.alert(MSG_CM_ERR_039); // 시작일자를 종료일 이전으로 선택[입력]하여 주십시오.
        ica_wrkStDt.focus();
        return;
    }

    await $c.sbm.execute(sbm_retrieve);
};

//-------------------------------------------------------------------------
// 조회 조건 지우기
//-------------------------------------------------------------------------
scwin.f_FieldClear = function() {
    $c.gus.cfInitObjects(tb_wrk, null);
    lc_homeClsCd.setSelectedIndex(0);
    lc_wrkPlCd.setValue(scwin.memJson.fixWrkPlCd); // 정비작업장코드
}

//-------------------------------------------							
// 그리드 데이터 엑셀로 다운							
//-------------------------------------------
scwin.f_runExcel = async function () {
    let totCnt = ds_fix_work_list.getRowCount();
    let sheetTitle = "수리순환품탈착목록현황";

    if (totCnt != 0) {
        $c.data.downloadGridViewExcel(gr_work_pl, {fileName: sheetTitle + ".xlsx", sheetName: sheetTitle});
    } else {
        await $c.win.alert(MSG_CM_WRN_002);
    }
}

scwin.btn_clear_onclick = function (e) {
    scwin.f_FieldClear();
};

scwin.btn_retrieve_onclick = function (e) {
    scwin.f_Retrieve();
};

scwin.sbm_retrieve_submitdone = function (e) {
    totalRows.setValue(ds_fix_work_list.getRowCount());

    if( ds_fix_work_list.CountRow > 0 ) {
        $c.gus.cfDisableBtn();
    }
}

scwin.sbm_lc_wrkPlcd_submitdone = function (e) {
    lc_wrkPlCd.setValue(scwin.memJson.fixWrkPlCd);

    if (lc_wrkPlCd.getSelectedIndex() == -1) {
        lc_wrkPlCd.setSelectedIndex(0);
    }
};

scwin.lc_homeClsCd_onchange = function (info) {
    scwin.getWrkPlcd();
};
]]></script>

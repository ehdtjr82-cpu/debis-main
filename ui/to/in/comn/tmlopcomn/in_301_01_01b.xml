scwin.subSum_SellUpr = function(agrWt , sellTotal) {
    var sellUpr = "";
    if(agrWt != 0) {
        sellUpr = Number(sellTotal)/Number(agrWt);
    }
    return sellUpr;
}

scwin.subSum_SellUpr2 = function(agrWt , sellTotal) {
    //console.log("agrWt : ", agrWt, "  sellTotal : ", sellTotal);
    var sellUpr = "";
    if(agrWt != 0) {
        sellUpr = Number(sellTotal)/Number(agrWt);
    }
    
    return sellUpr;
}

scwin.sum_SellUpr = function (agrWt , sellTotal) {
    var sellUpr = 0;

    if(agrWt != 0){
        sellUpr = Math.floor(parseInt(sellTotal)/parseInt(agrWt));
    }
    
    return sellUpr;
}

scwin.sum_SellUpr2 = function (sellVol , sellTotal) {
    /*
    var sellUpr = Math.floor(parseInt(sellTotal)/parseInt(agrWt));
    return sellUpr;
    */
    //console.log("agrWt : ", agrWt, "  sellTotal : ", sellTotal);

    var sellUpr = "";
    if(sellVol != 0) {
        sellUpr = Number(sellTotal)/Number(sellVol);
    }
    
    return sellUpr;
}

scwin.sumTotal = function (sellAmt1, sellAmt2, sellAmt3) {
    console.log(sellAmt1);
    var sellTotal = parseInt(sellAmt1) + parseInt(sellAmt2) + parseInt(sellAmt3);

    return sellTotal;
}

scwin.expFnAgrWt = function(avgNum) {
    scwin.subTotalAgrWtSum += parseFloat(avgNum);

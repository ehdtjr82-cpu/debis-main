scwin.btn_search_onclick = function (e) {
    scwin.f_retrieve();
};

scwin.f_retrieve = async function () { 
    var chkVal = await $c.gus.cfValidate([tb_search]); 
    if (!chkVal) {
        return;	
    } 
    var chkCal = await scwin.f_termChk(ed_arvStDt, ed_arvEndDt);
    if (chkCal) {
        return;	
    }
    //dma_condition.NameValue(1,"arvEndDt")=ed_arvEndDt.text;
    //tr_condition.post();
    $c.sbm.execute(sbm_condition);
}

scwin.f_termChk = async function (stObj, endObj) {
    if ( stObj.getValue().trim() > endObj.getValue().trim() ) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_045, ['기간'] );	//기간 체크
        stObj.focus();
        return true;
    }
    return false;
} 
scwin.sbm_condition_submitdone = function (e) {
    console.log( ds_result.getAllJSON() );
    var i=0;
    var sellAmt1;
    var sellAmt2;
    var sellAmt3;

    spa_cnt1.setValue(ds_result.getRowCount());
    spa_cnt2.setValue(ds_result1.getRowCount());

    // for(i=0; i<ds_result.getRowCount(); i++ ){
    //     sellAmt1 = ds_result.getCellData(i, "sellAmt1");
    //     sellAmt2 = ds_result.getCellData(i, "sellAmt2");
    //     sellAmt3 = ds_result.getCellData(i, "sellAmt3");

    //     var sellTotal1 = (parseInt(sellAmt1) + parseInt(sellAmt2) + parseInt(sellAmt3));
        
    //     ds_result.setCellData(i, "sellTotal", sellTotal1);
    // }

    if(ds_result.getRowCount() == 0){
        $c.win.alert(MSG_CM_ERR_003);
    } else {
        let subAllData = gr_copy._getExcelSubtotalData().split('","');
        console.log(subAllData);
        let tCol = gr_copy.getColCnt();
        console.log("tCol : "+ tCol);
        var tCnt = subAllData.length / tCol;
        var idxCnt1 = 0;
        var idxCnt2 = 0;
        let totAmt1 = 0;
        let totAmt2 = 0;

        for(let k = 0; k < tCnt; k++) {
            idxCnt1 = (tCol * k) + 8;
            idxCnt2 = (tCol * k) + 9;

            console.log("subAllData[idxCnt1] : "+subAllData[idxCnt1]);
            if(subAllData[idxCnt1] !== "") {
                totAmt1 += parseFloat(subAllData[idxCnt1].replace(/,/g, ""));
                totAmt2 += parseFloat(subAllData[idxCnt2].replace(/,/g, ""));
            }
        }

        gr_master.setFooterData("footer1", totAmt1);
        //gr_copy.setFooterData("footer1", totAmt1);
        gr_master.setFooterData("footer2", totAmt2);
        //gr_copy.setFooterData("footer2", totAmt1);
        console.log("totAmt1 :"+ totAmt1);
    }


    for(i=0; i<ds_result1.getRowCount(); i++ ){
        sellAmt1 = ds_result1.getCellData(i, "sellAmt1");
        sellAmt2 = ds_result1.getCellData(i, "sellAmt2");
        sellAmt3 = ds_result1.getCellData(i, "sellAmt3");

        var sellTotal2 = (parseInt(sellAmt1) + parseInt(sellAmt2) + parseInt(sellAmt3));
        
        ds_result1.setCellData(i, "sellTotal", sellTotal2);
        if(ds_result1.getCellData(i, "sellVol") == 0){
            ds_result1.setCellData(i, "sellUpr", "");
        } else {
            ds_result1.setCellData(i, "sellUpr", sellTotal2);
        }
    }
};


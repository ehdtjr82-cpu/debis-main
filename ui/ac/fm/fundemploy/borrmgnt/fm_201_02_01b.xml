}

//-------------------------------------------------------------------------
// 자회사 회계 시스템 추가에 따른 설정 
//-------------------------------------------------------------------------
scwin.f_setCompanyInfo = function(e) {
   
    // 사용자 구분이 자회사('SA')가 아닌 경우, 소속회사를  '동부 EXPRESS'로  Default set
    if( scwin.vUserHomeClsCd != ACConstants.SUBSIDIARY_USER_HOME_CLS_CD)  {  
        scwin.vLoginCoCd = ACConstants.CO_CD_DONGBU;
        scwin.vLoginCoClsCd = ACConstants.CO_CLS_CD_DONGBU;
    }

    ed_coCd.setValue( scwin.vLoginCoCd );
    scwin.f_PopUpCompanyInfo('T'); 
        
   if(scwin.txtCoClsCd > ACConstants.CO_CLS_CD_DONGBU)  {  	// 자회사 회계 시스템 
        scwin.isSubCompany = true;
    }else{
        scwin.isSubCompany = false;
    }
    $c.gus.cfDisableObjects([ed_coCd,ed_coNm,btn_company]);
}

scwin.f_PopUpCompanyInfo = function(pWinCloseTF){ 
    scwin.pWinClose = pWinCloseTF;
    var rtnList = udc_companyInfo.cfCommonPopUp(scwin.udc_coCd_callBackFunc
                                    ,ed_coCd.getValue(), ed_coNm.getValue()
                                    ,pWinCloseTF,null,null,null,null
                                    ,null,null,null,null,null);   
}

scwin.udc_coCd_callBackFunc = function(rtnList){
    // SET	 
    if(rtnList != null ) { 
        if (rtnList[0] == "N/A") return; 
			
        ed_coCd.setValue(rtnList[0]);	// 코드
        ed_coNm.setValue(rtnList[5]); // 회사명 
        ed_coCd.options.hidVal = rtnList[0];  // 히든값
        scwin.txtCoClsCd =rtnList[1];	// 회사구분  
    }else{
        ed_coCd.setValue("");
        ed_coNm.setValue("");
        ed_coCd.options.hidVal = ""; 
        scwin.txtCoClsCd = "";
    }
        
    if(scwin.txtCoClsCd > ACConstants.CO_CLS_CD_DONGBU)  {  	// 자회사 회계 시스템 
        scwin.isSubCompany = true;
    }else{
        scwin.isSubCompany = false;
    } 
}

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function() {  
    if (!await $c.gus.cfValidate([ica_postDt]))  return false;

    dma_search.set("ramtClsCd", acb_ramtClsCd.getValue());
    dma_search.set("postDt", ica_postDt.getValue());
    $c.sbm.execute(sbm_retrieveBorrow);
} 

//-------------------------------------------------------------------------
//  
//-------------------------------------------------------------------------
scwin.f_createSlip = async function() {
    var cnt=0;
    
    for ( i=0 ; i < ds_master.getTotalRow() ; i++ ) {
        if(ds_master.getCellData(i,"transSlipNo") == "" && ds_master.getCellData(i,"borrTransYn") == "Y"){
            ds_master.setCellData(i,"chkYn","1");
        }else{
            ds_master.setCellData(i,"chkYn","0");
        } 
        
        if(ds_master.getCellData(i,"chkYn")=="1"){
            cnt++;
        }
        
    }

    if(cnt == 0){
        await $c.gus.cfAlertMsg("처리할 대상이 없습니다.");
        return;
    }
        
    $c.sbm.execute(sbm_createSlip);
} 

scwin.f_deleteSlip = async function() { 

    var cnt = 0;
    for ( i=0; i<ds_master.getTotalRow() ; i++ ) {
        if(ds_master.getCellData(i,"transDelSlipNo") != "" && ds_master.getCellData(i,"chkYn") == "1"){
            await $c.gus.cfAlertMsg("차입번호 "+ds_master.getCellData(i,"borrLedgNo") +" 은 이미 유동성대체 삭제된 건 입니다.");
            ds_master.setCellData(i,"chkYn","0");
            return;
        }else if (ds_master.getCellData(i,"transSlipNo") == "" && ds_master.getCellData(i,"chkYn") == "1"){
            await $c.gus.cfAlertMsg("차입번호 "+ds_master.getCellData(i,"borrLedgNo") +" 은 삭제할 유동성 대체전표가 없습니다.");
            ds_master.setCellData(i,"chkYn","0");
            return;
        }else if (ds_master.getCellData(i,"borrTransDelYn") == "N" && ds_master.getCellData(i,"chkYn") == "1"){
            if(await $c.win.confirm("차입번호 "+ds_master.getCellData(i,"borrLedgNo") +" 은 유동성대체 삭제대상이 아닙니다 삭제하시겠습니까?")==true){
            
            }else{
                ds_master.setCellData(i,"chkYn","0");
                return;
            }
            
        } 
        if(ds_master.getCellData(i,"chkYn")=="1"){
            cnt++;
        }
    }
    
    if(cnt==0){
        await $c.gus.cfAlertMsg("선택된 항목이 없습니다.");
        return;
    }
    
    $c.sbm.execute(sbm_deleteSlip);
} 


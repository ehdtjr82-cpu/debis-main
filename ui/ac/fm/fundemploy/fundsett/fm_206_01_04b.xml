<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map">
    			<w2:dataMap baseNode="map" id="dma_condition">
    				<w2:keyInfo>
    					<w2:key id="closeYm" name="기준월" dataType="text"></w2:key>
    					<w2:key id="intCls" name="이자구분" dataType="text"></w2:key>
    				</w2:keyInfo>
    			</w2:dataMap>
    		</w2:dataCollection>
    		<w2:workflowCollection />
    		<xf:submission id="sbm_save" action="/ac.fm.fundemploy.fundsett.CreatePrepayUnPaymentInterestCMD.do" method="post"
    			mediatype="application/json" ref='data:json,{"id":"dma_condition","key":"IN_DS1"}' target="" encoding="UTF-8" instance="" replace=""
    			errorHandler="" customHandler="" mode="asynchronous" processMsg="" ev:submit="" ev:submitdone="scwin.sbm_save_submitdone" ev:submiterror="" abortTrigger="">
    		</xf:submission>
    	</xf:model>
    	<w2:layoutInfo />
    	<w2:publicInfo method="" />
    	<script lazy="false" type="text/javascript"><![CDATA[
scwin.currYyyyMM = WebSquare.date.getFormattedDate (new Date(), "yyyyMM");

//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    const codeOptions = [ 
        { grpCd : "FM077", compID : "lc_intCls" },
    ];
    $c.data.setCommonCode(codeOptions);
    
};

scwin.ondataload = function() {
    dma_condition.set("closeYm", scwin.currYyyyMM);
};

//-------------------------------------------------------------------------
// function name : f_Save
// function desc : 저장버튼 클릭
//-------------------------------------------------------------------------
scwin.f_Save = async function() {

    if (! await $c.gus.cfValidate([ica_closeYm])) 
        return;

    let confirmResult = await $c.win.confirm((lc_intCls.getText()).split(":")[1]+"이자금액을 생성하시겠습니까?");
    if (confirmResult) {
        $c.sbm.execute(sbm_save);
    }

};

scwin.sbm_save_submitdone = async function (e) {
    await $c.win.alert((lc_intCls.getText()).split(":")[1]+"이자금액계산을 완료하였습니다.");
};
]]></script>
    	<w2:require as="udc_topGrdBtn" type="page" variableClone="true" src="/cm/udc/topGrdBtn.xml"></w2:require>
    	<w2:require as="udc_fromToYearMon" type="page" variableClone="true" src="/cm/udc/fromToYearMon.xml"></w2:require>
    	<w2:require as="udc_fromToCalendarTime" type="page" variableClone="true" src="/cm/udc/fromToCalendarTime.xml"></w2:require>
    	<w2:require as="udc_comCode" type="page" variableClone="true" src="/cm/udc/comCode.xml"></w2:require>
    	<w2:require as="udc_fromToCalendar" type="page" variableClone="true" src="/cm/udc/fromToCalendar.xml"></w2:require>
    	<w2:require as="udc_fromToYear" type="page" variableClone="true" src="/cm/udc/fromToYear.xml"></w2:require>
    </head>
    <body ev:onpageload="scwin.onpageload">
    	<xf:group class="sub_contents" id="" style="">
    		<w2:wframe id="" src="/cm/xml/contentHeader.xml" style=""></w2:wframe>
    		<xf:group class="round-box" id="" style="">
    			<xf:group class="tbbox" id="" style="">
    				<xf:group class="w2tb" id="" style="" tagname="table">
    					<w2:attributes>
    						<w2:summary></w2:summary>
    					</w2:attributes>
    					<xf:group tagname="colgroup">
    						<xf:group style="width:120px;" tagname="col"></xf:group>
    						<xf:group tagname="col"></xf:group>
    						<xf:group style="width: 120px;" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    					</xf:group>
    					<xf:group style="" tagname="tr">
    						<xf:group class="w2tb_th" style="" tagname="th">
    							<w2:textbox class="req" id="" label="기준월" ref="" style="" userData2=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" style="" tagname="td">
    							<w2:inputCalendar calendarValueType="yearMonth" class="" id="ica_closeYm" style="" ref="data:dma_condition.closeYm" mandatory="true" title="기준월"></w2:inputCalendar>
    						</xf:group>
    						<xf:group class="w2tb_th" tagname="th">
    							<w2:attributes></w2:attributes>
    							<w2:textbox class="" id="" label="이자구분" ref="" style="" userData2=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" tagname="td">
    							<w2:attributes></w2:attributes>
    							<xf:select1 allOption="false" appearance="minimal" chooseOption="false" class="" direction="auto"
    								disabled="false" disabledClass="w2selectbox_disabled" id="lc_intCls" style="width: 150px;" submenuSize="fixed" ref="data:dma_condition.intCls" sortOption="value">
    							</xf:select1>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    			<xf:group class="btnbox" id="" style="">
    				<xf:group class="right" id="" style="">
    					<xf:trigger class="btn" id="btn_ctrtPrint" style="" type="button" userAuth="U" ev:onclick="scwin.f_Save">
    						<xf:label><![CDATA[생성]]></xf:label>
    					</xf:trigger>
    				</xf:group>
    			</xf:group>
    		</xf:group>
    	</xf:group>
    </body>
</html>

scwin.f_Retrieve = async function () {
if (ed_FromDate.getValue() > ed_ToDate.getValue()) {
    await $c.win.alert("ВА░ьџї ВІюВъЉВЮ╝Въљвіћ ВбЁвБїВЮ╝Въљ в│┤вІц ВЮ┤Ваё вѓаВДю ВЮ┤Вќ┤ВЋ╝ ьЋЕвІѕвІц.");
    ed_FromDate.focus();
    return;
}

if (! await $c.gus.cfValidate([ed_coCd]))
    return;

$c.sbm.execute(sbm_searchBankbook);
}



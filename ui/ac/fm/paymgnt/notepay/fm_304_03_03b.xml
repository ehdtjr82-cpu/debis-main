    	<script lazy="false" type="text/javascript"><![CDATA[scwin.strCurDate =  WebSquare.date.getCurrentServerDate()
scwin.strFromDate = scwin.strCurDate.substring(0, 6) + "01"; 
scwin.strToDate = scwin.strCurDate


//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    const codeOptions = [
        { grpCd : "FM012", compID : "gr_draft:draftCheckClsCd" },
    ];
    $c.data.setCommonCode(codeOptions);
};

scwin.onUdcCompleted = function() {

   	ed_stDt.setValue(scwin.strFromDate)
	ed_endDt.setValue(scwin.strToDate)
}

//-------------------------------------------------------------------------
// 조회 필드 Clear
//-------------------------------------------------------------------------
scwin.f_FieldClear = function () {
    $c.gus.cfInitObjects(tbl_search);
}

//-------------------------------------------------------------------------
// 조회(전표현황내역)
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function () {  
    if (! await $c.gus.cfValidate([ed_stDt, ed_endDt])) {
        return;
    }

    if (ed_stDt.getValue().trim() > ed_endDt.getValue().trim()) {
        await $c.win.alert(MSG_CM_ERR_039); 
        ed_stDt.focus();
        return;
    }

    dma_search.set("scClsCd", "3")

    $c.sbm.execute(sbm_search);
};

//-------------------------------------------------------------------------
// 저장
//-------------------------------------------------------------------------
scwin.f_Save = async function () {
if(ds_draft.getModifiedIndex().length > 0==false){
    await $c.gus.cfAlertMsg(MSG_CM_ERR_001, ["자료"]);
}else{
    if (! await $c.gus.cfValidate([gr_draft])) {
        return;
    }
        if(await $c.win.confirm(MSG_CM_CRM_001)){
        $c.sbm.execute(sbm_saveDraft);
    }  	       
    } 
}

// -----------------------------------------------------------------------------
// script
// -----------------------------------------------------------------------------


scwin.sbm_search_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;
    totalRows.setValue(ds_draft.getRowCount());
    let rowCnt = ds_draft.getRowCount()
	if( rowCnt == 0 ){
	   if($c.gus.cfCheckCreateFlag() == true){
	    	$c.gus.cfTurnCreateFlag(false);
	   }else{
			await $c.win.alert(MSG_CM_WRN_002);		
			ed_stDt.focus();
	   }
	} 
};

scwin.sbm_saveDraft_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;
    await $c.win.alert(MSG_CM_INF_001);
};
]]></script>

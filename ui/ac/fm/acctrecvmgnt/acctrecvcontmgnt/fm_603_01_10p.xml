<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
        <w2:type>COMPONENT</w2:type>
        <w2:buildDate/>
        <w2:MSA/>
        <xf:model>
        	<w2:dataCollection baseNode="map">
        		<w2:dataMap baseNode="map" id="dma_search">
        			<w2:keyInfo>
        				<w2:key id="acctRecvNo" name="name1" dataType="text"></w2:key>
        			</w2:keyInfo>
        		</w2:dataMap>
        		<w2:dataList baseNode="list" repeatNode="map" id="ds_overDayAcctRecvHist" saveRemovedData="true">
        			<w2:columnInfo>
        				<w2:column id="acctRecvNo" name="채권번호" dataType="text"></w2:column>
        				<w2:column id="seq" name="순번" dataType="text"></w2:column>
        				<w2:column id="recvReason" name="초과채권 발생사유" dataType="text"></w2:column>
        				<w2:column id="collectionActiv" name="회수 활동 내역" dataType="text"></w2:column>
        				<w2:column id="retrvDt" name="회수예정일" dataType="text"></w2:column>
        				<w2:column id="picId" name="담당자" dataType="text"></w2:column>
        				<w2:column id="picNm" name="담당자명" dataType="text"></w2:column>
        				<w2:column id="modId" name='수정자ID' dataType="text"></w2:column>
        				<w2:column id="modDt" name='수정일시' dataType="text"></w2:column>
        			</w2:columnInfo>
        		</w2:dataList>
        	</w2:dataCollection>
        	<w2:workflowCollection />
        	<xf:submission id="sbm_search" action="/ac.fm.acctrecvmgnt.acctrecvcontmgnt.RetrieveAccountReceivableOverDayHistCMD.do"
        		method="post" mediatype="application/json"
        		ref='data:json,[{"id":"dma_search","key":"IN_DS1"},{"id":"ds_overDayAcctRecvHist","key":"OUT_DS1"}]'
        		target='data:json,[{"id":"ds_overDayAcctRecvHist","key":"OUT_DS1"}]' encoding="UTF-8" instance="" replace="" errorHandler=""
        		customHandler="" mode="asynchronous" processMsg="" ev:submit="" ev:submitdone="scwin.sbm_search_submitdone" ev:submiterror=""
        		abortTrigger="">
        	</xf:submission>
        </xf:model>
        <w2:layoutInfo/>
        <w2:publicInfo method=""/>
        <script lazy="false" type="text/javascript"><![CDATA[
//전역변수
scwin.vAcctRecvNo = "";
scwin.login = "";
scwin.privAdmin = "";  // ADMIN 권한 CHK : 'T' : ADMIN , 'F': ADMIN 아님  
scwin.params = ""; 

//-------------------------------------------------------------------------
// TOBE : 초기로드(UDC 있으면 scwin.onUdcCompleted 초기값 세팅)
//-------------------------------------------------------------------------
scwin.onpageload = function() { 
    //로그인정보 추출
    scwin.login = $c.data.getMemInfo();
    scwin.privAdmin = scwin.login.privAdmin;
    
    scwin.params = $c.data.getParameter(); 
    scwin.vAcctRecvNo = scwin.params.acctRecvNo || "";

    dma_search.set("acctRecvNo",scwin.vAcctRecvNo);

    $c.sbm.execute(sbm_search);

};

scwin.sbm_search_submitdone = function(e){
    // 조회된 건수를 Grid 왼쪽 하단에 표시한다.
    totalRows.setValue(ds_overDayAcctRecvHist.getRowCount());
};

scwin.btn_close_onclick = function (e) {
    $c.win.closePopup();
};
]]></script>
    </head>
    <body ev:onpageload="scwin.onpageload">
    	<xf:group class="pop_contents" id="" meta_componentContainer="true" style="">
    		<w2:wframe id="" src="/cm/xml/contentHeader.xml" style=""></w2:wframe>
    		<xf:group class="round-box" id="">
    			<xf:group adaptiveThreshold="" class="gvwbox" id="grp_group1" style="">
    				<w2:gridView autoFit="allColumn" checkReadOnlyOnPasteEnable="" class="wq_gvw" dataList="data:ds_overDayAcctRecvHist"
    					id="" scrollByColumn="false" scrollByColumnAdaptive="false" style="" visibleRowNum="10" visibleRowNumFix="true" readOnly="true">
    					<w2:caption id="caption1" style="" value="this is a grid caption."></w2:caption>
    					<w2:header id="header2" style="">
    						<w2:row id="row3" style="">
    							<w2:column displayMode="label" id="column23" inputType="text" style="" value="채권번호" width="100"></w2:column>
    							<w2:column displayMode="label" id="column21" inputType="text" style="" value="순번" width="50"></w2:column>
    							<w2:column displayMode="label" id="column19" inputType="text" style="" value="초과채권&lt;/br&gt;발생사유"
    								width="150">
    							</w2:column>
    							<w2:column displayMode="label" id="column17" inputType="text" style="" value="회수 활동 내역" width="150"></w2:column>
    							<w2:column displayMode="label" id="column13" inputType="text" style="" value="회수예정일" width="90"></w2:column>
    							<w2:column displayMode="label" id="column15" inputType="text" style="" value="담당자" width="100"
    								hidden="true">
    							</w2:column>
    							<w2:column width="100" inputType="text" style="" id="column37" value="담당자명" displayMode="label"></w2:column>
    							<w2:column width="90" inputType="text" style="" id="column31" value="수정자ID" displayMode="label"></w2:column>
    							<w2:column width="150" inputType="text" style="" id="column34" value="수정일시" displayMode="label"></w2:column>
    						</w2:row>
    					</w2:header>
    					<w2:gBody id="gBody2" style="">
    						<w2:row id="row4" style="">
    							<w2:column displayMode="label" id="acctRecvNo" inputType="text" style="" value="" width="100"></w2:column>
    							<w2:column displayMode="label" id="seq" inputType="text" style="" value="" width="50" dataType="number"></w2:column>
    							<w2:column displayMode="label" id="recvReason" inputType="text" style="" value="" width="150" textAlign="left"></w2:column>
    							<w2:column displayMode="label" id="collectionActiv" inputType="text" style="" value="" width="150" textAlign="left"></w2:column>
    							<w2:column displayMode="label" id="retrvDt" inputType="text" style="" value="" width="90" displayFormat="####/##/##"></w2:column>
    							<w2:column displayMode="label" id="picId" inputType="text" style="" value="" width="100"></w2:column>
    							<w2:column width="100" inputType="text" style="" id="picNm" value="" displayMode="label"></w2:column>
    							<w2:column width="90" inputType="text" style="" id="modId" value="" displayMode="label"></w2:column>
    							<w2:column width="150" inputType="text" style="" id="modDt" value="" displayMode="label"></w2:column>
    						</w2:row>
    					</w2:gBody>
    					<w2:footer style="" id="footer1">
    						<w2:row style="" id="row5">
    							<w2:column width="100" inputType="text" style="" id="column30" value="" displayMode="label"></w2:column>
    							<w2:column width="50" inputType="text" style="" id="column29" value="" displayMode="label"></w2:column>
    							<w2:column width="150" inputType="text" style="" id="column28" value="" displayMode="label"></w2:column>
    							<w2:column width="150" inputType="text" style="" id="column27" value="" displayMode="label"></w2:column>
    							<w2:column width="90" inputType="text" style="" id="column26" value="" displayMode="label"></w2:column>
    							<w2:column width="100" inputType="text" style="" id="column25" value="" displayMode="label"></w2:column>
    							<w2:column width="100" inputType="text" style="" id="column39" value="" displayMode="label"></w2:column>
    							<w2:column width="90" inputType="text" style="" id="column33" value="" displayMode="label"></w2:column>
    							<w2:column width="150" inputType="text" style="" id="column36" value="" displayMode="label"></w2:column>
    						</w2:row>
    					</w2:footer>
    				</w2:gridView>
    				<xf:group class="grid-bottom " id="" style="">
    					<xf:group class="left" id="">
    						<xf:group class="grid-total" id="">
    							<w2:textbox class="" id="" label="총" style="" tagname="span"></w2:textbox>
    							<w2:textbox class="num" dataType="number" displayFormat="#,##0" id="totalRows" label="0" style="" tagname="span"></w2:textbox>
    							<w2:textbox class="" id="" label="건" style="" tagname="span"></w2:textbox>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    		</xf:group>
    		<xf:group class="pop-btnbox" id="" style="">
    			<xf:trigger class="btn" id="btn_close" style="" type="button" ev:onclick="scwin.btn_close_onclick">
    				<xf:label><![CDATA[닫기]]></xf:label>
    			</xf:trigger>
    		</xf:group>
    	</xf:group>
    </body>
</html>

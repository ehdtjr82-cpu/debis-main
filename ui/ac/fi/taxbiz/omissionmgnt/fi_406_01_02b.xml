//-------------------------------------------------------------------------
// function name : f_SendEmail()
// function desc : 저장 
//-------------------------------------------------------------------------
scwin.f_SendEmail = async function(){
    // 시작, 종료일자 체크
    if(ed_startDt.getValue() == "" || ed_endDt.getValue() == ""){
        $c.gus.cfAlertMsg(MSG_CM_ERR_002, ["공급일자 "]);
        ed_startDt.focus();
        return;
    }
    
    //시작일자가 종료일자 이전인지 check
    if (!$c.gus.cfIsAfterDate(ed_startDt.getValue(), ed_endDt.getValue())){
        $c.gus.cfAlertMsg(MSG_CM_ERR_039);
        return;
    }
    
    let chkCnt = 0;
    
    for (i=0; i< ds_evid.getRowCount() ; i++){ 	 
        if(ds_evid.getCellData(i,"userSec") != ''){
            chkCnt++;
        }
    }

    if(chkCnt == 0){
        $c.win.alert("2차대상에 등록된 이메일이 하나도 없습니다.\n\n'대체e메일등록' 화면에서 2차대상 이메일을 등록 하시기 바랍니다.");
        return;
    }
    
    //ds_search.UseChangeInfo = false;
    
    let ret;
    ret = await $c.win.confirm("저장 하시겠습니까?");
    if(ret==true) {      
        //tr_save1.post();
        $c.sbm.execute(sbm_save1);
    }
}

//-------------------------------------------------------------------------
// function name : f_CreateMailInfo()
// function desc : 저장 	tr_save2
//-------------------------------------------------------------------------
scwin.f_CreateMailInfo = async function(){
    
    for (i=0; i<ds_evid.getRowCount(); i++) {
        if(ds_evid.getCellData(i,"chk") == 'T' && ds_evid.getCellData(i,"puRegYn") == 'Y'){
            $c.win.alert(i + "번째 행의 데이터는 이미 발송제외 등록이 되어 있습니다.");
            return;
        }
    }
    
    let chkCnt = 0;
    for (i=0; i<ds_evid.getRowCount() ; i++){ 	 
        if(ds_evid.getCellData(i,"chk")=="T"){
            chkCnt++;
            break;
        }
    }
    
    if(chkCnt == 0){
        $c.win.alert("선택한 항목이 없습니다.");
        return false;
    }
    
    let ret;
    ret = await $c.win.confirm("저장 하시겠습니까?"); 
    if(ret==true) {        
        //tr_save2.post();
        $c.sbm.execute(sbm_save2);
    }
}

//-------------------------------------------------------------------------
// function name : f_DeleteMailInfo()
// function desc : 저장 	tr_save3
//-------------------------------------------------------------------------
scwin.f_DeleteMailInfo = async function(){
    for (i=0; i<ds_evid.getRowCount() ; i++){ 	 
        if(ds_evid.getCellData(i,"chk") == 'T' && ds_evid.getCellData(i,"puRegYn") == 'N'){
            $c.win.alert(i + "번째 행의 데이터는 발송제외 등록이 되어 있지 않습니다.");
            return;
        }
    }
    
    let chkCnt = 0;
    for (i=0; i<ds_evid.getRowCount() ; i++){ 	 
        if(ds_evid.getCellData(i,"chk")=="T"){
            chkCnt++;
            break;
        }
    }
    
    if(chkCnt == 0){
        $c.win.alert("선택한 항목이 없습니다.");
        return false;
    }
    
    let ret;
    ret = await $c.win.confirm("저장 하시겠습니까?");
    if(ret==true) {        
        ds_evid.setCellData(0,"userFir", 'e메일발송');
        //tr_save3.post();
        $c.sbm.execute(sbm_save3);
    }
}


    let gridId = (lc_sapuCls.getSelectedIndex() == 0) ? gr_evid0 : gr_evid1;

    let sheetTitle = "누락 리스트";
	const infoArr = [];
	const options = {
		fileName: sheetTitle + ".xls",    // + ".xls",
		sheetName: sheetTitle
	};

	$c.data.downloadGridViewExcel(gridId, options, infoArr);
}


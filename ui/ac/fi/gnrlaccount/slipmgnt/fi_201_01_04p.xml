		<script lazy="false" type="text/javascript"><![CDATA[

scwin.popTitleCh = function() {
    $c.data.setPopupTitle("전자결재요청-예산실적조회");
};


// var valueObject = window.dialogArguments;
scwin.onpageload = function () {
    scwin.valueObject = $c.data.getParameter();
    scwin.approveRequestNumber = $c.data.getParameter("approveRequestNumber")
    // txt_approveRequestNumber.value = valueObject.approveRequestNumber;
    txt_approveRequestNumber.setValue(scwin.approveRequestNumber);
    //cfDisableKey();
    scwin.f_Retrieve();
};

//-------------------------------------------------------------------------
//scwin.onpageload 후 UDC관련 처리
//-------------------------------------------------------------------------
scwin.onUdcCompleted = function () {
    //공통코드 적용
    const codeOptions = [
        { grpCd: "CO001", compID: "gr_master:cntlUnitClsCd" }, //GauceUtil.getGridCombo("CO001",false) 
    ];
    $c.data.setCommonCode(codeOptions);
};

//-------------------------------------------------------------------------
// 조회 : 데이터를 조회한다.
//-------------------------------------------------------------------------
scwin.f_Retrieve = function () {
    if (!$c.gus.cfValidate([txt_approveRequestNumber]) == true) {
        return;
    }

    // var condition = "?approveRequestNumber=" + txt_approveRequestNumber.value;
    // ds_master.DataID = "/ac.co.budgetmgnt.RetrieveApproveRequestBudgetResultsCMD.do" + condition;
    // ds_master.Reset();
    dma_master.set("approveRequestNumber", txt_approveRequestNumber.getValue());
    // ds_master.set("approveRequestNumber", txt_approveRequestNumber.getValue());
    $c.sbm.execute(sbm_master);
}

// for=ds_master event=OnLoadCompleted(rowCnt)
scwin.sbm_master_submitdone = function (e) {
    let rowCnt = ds_master.getTotalRow();
    if (rowCnt == 0) {
        $c.win.alert("조회된 데이터가 없습니다.");
    } else {
        // cfShowTotalRows(totalRows, rowCnt);
        totalRows.setValue(rowCnt);
    }
};

scwin.btn_close_onclick = function (e) {
    window.close();
};
]]></script>

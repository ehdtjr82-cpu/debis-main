scwin.f_grdHeiht = function() {

};  

  //-------------------------------------------------------------------------
  // 전표삭제
  //-------------------------------------------------------------------------
scwin.f_Reverse = async function() {
    if(ds_master.getRowCount() < 1){
   		return;
   	}
   	
   	if(ds_master.getCellData(0, "reverseSlipNo")!= ""){
   		await $c.win.alert("이미 삭제처리 했습니다.");   		
   		return;
   	}
   	ds_search.setCellData(0, "ChargeSlipNo", ds_master.getCellData(0, "ChargeSlipNo"));

    let confirm = await $c.win.confirm("전표(" + ds_search.getCellData(0, "ChargeSlipNo")+ ")를 삭제 하시겠습니까?");
    if( confirm ) {
        $c.sbm.execute(sbm_tr_reverse);
    }
};

//-------------------------------------------------------------------------
// 엑셀 파일 다운로드
//-------------------------------------------------------------------------
// 엑셀다운 8+16
scwin.f_Excel = async function() {
    let confirm = await $c.win.confirm("Excel로 다운로드 하시겠습니까?")
    if( confirm ) {
        const options = {
            fileName : ed_stdYm.getValue()+"외화환산전표조회.xlsx", 
            sheetName : ed_stdYm.getValue()+"외화환산전표조회",
            type : 1
        };
        await $c.data.downloadGridViewExcel(gr_master, options);
    } 
};

// 서브미션
scwin.sbm_tr_search_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;
    totalRows.setValue(ds_master.getRowCount());
    if(ds_master.getRowCount() == 0){
        $c.gus.cfAlertMsg(MSG_CM_WRN_002);
    }else{
        ds_master.setRowPosition(0);
        $c.gus.cfGoPrevPosition(gr_master, 0);
    }
};

// 서브미션
scwin.sbm_tr_reverse_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;
    await $c.win.alert(MSG_CM_INF_004);
    scwin.f_Retrieve();
};

scwin.gr_master_oncellclick = function (rowIndex, columnIndex, columnId) {
	if(columnId=="slipNo" ){
        $c.gus.cfShowSlipInfo(ds_master.getCellData(rowIndex, "slipNo"));
	}
	
	if(columnId=="chargeSlipNo"  && ds_master.getCellData(rowIndex, "chargeSlipNo") != ""){
        $c.gus.cfShowSlipInfo(ds_master.getCellData(rowIndex, "chargeSlipNo"));
	}
	
	if(columnId=="reverseSlipNo"  && ds_master.getCellData(rowIndex, "reverseSlipNo") != ""){
        $c.gus.cfShowSlipInfo(ds_master.getCellData(rowIndex, "reverseSlipNo"));
	}
};
]]></script>

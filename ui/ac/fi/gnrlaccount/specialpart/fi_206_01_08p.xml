};

	//-------------------------------------------------------------------------
	// 엑셀 파일 다운로드
	//-------------------------------------------------------------------------
scwin.f_Excel1  = async function () {
    let confirm = await $c.win.confirm("Excel로 다운로드 하시겠습니까?");
    if( confirm ) {
        const options = {
            fileName : "특수관계자거래내역.xlsx", 
            sheetName : "특수관계자거래내역",
        };
        $c.data.downloadGridViewExcel(gr_concernedCd1, options);
    }
};

	//-------------------------------------------------------------------------
    // function name : f_grdHeiht
    // function desc : 그리드 높이 늘리기

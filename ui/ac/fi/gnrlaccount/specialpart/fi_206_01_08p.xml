    $c.win.closePopup();
};

scwin.sbm_retrieve_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;
    totalRows.setValue(ds_concernedCd1.getRowCount());
    $c.gus.cfGoPrevPosition(gr_concernedCd1,0);
};

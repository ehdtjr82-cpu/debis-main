scwin.onpageload = function() {
    // getCodeList
    const codeOptions = [
        { grpCd : "FI060", compID : "lc_concernedCd" },
        { grpCd : "FI059", compID : "lc_speclCntHourCls" },
    ];
    $c.data.setCommonCode(codeOptions);    
    $c.gus.cfDisableObjects([ed_crn, udc_fromToYearMon1, lc_speclCntHourCls, lc_concernedCd, lc_printStd, lc_speclCntHourCls ]);
};

scwin.onUdcCompleted = function() {
    $c.util.setTimeout(function() {
        scwin.f_Header();
    }, {"delay":200});  
    
};

scwin.popTitleCh = function() {
    $c.data.setPopupTitle("거래처거래내역 상세 조회");
};

	//-------------------------------------------------------------------------
	// 재조회

/**
 * 초기세팅(TOBE 그리드, 총건수)
 */
scwin.setInit = function() {
    $c.gus.cfDisableObjects(grp_save);
    $c.gus.cfDisableBtn([btn_update, btn_save]);
    gr_evidCode.setNoResultMessageVisible(false);
    ds_evidCode.reform();
    ds_evidCode.removeAll();
    totalRows.setValue("0");
    lc_evidClsCd.focus();
};

/**
 * UDC값 초기화(scwin.onpageload 이후 세팅됨)
 */
scwin.onUdcCompleted = function() {
    scwin.setInit();
};

/**
 * 조회필드 CLEAR
 */
scwin.f_FieldClear = function() {
    $c.gus.cfInitObjects(tbl_search);
};

/**
 * 조회
 */
scwin.f_Retrieve = async function () {
    // ds_search.UseChangeInfo = false
    // sbm_search.setAction = "/ac.fi.stdinfomgnt.RetrieveEvidenceClassificationListCMD.do";
    scwin.setInit();
    $c.sbm.execute(sbm_retrieve);
};

scwin.sbm_retrieve_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    gr_evidCode.setNoResultMessageVisible(true);
    let rowCnt = ds_evidCode.getRowCount();
    totalRows.setValue(rowCnt);

    if (e.responseJSON.resultDataSet[0].Msg != "FAIL") {
        if (rowCnt == 0) {
            $c.gus.cfAlertMsg(MSG_CM_WRN_002); // 조회결과가 존재하지 않습니다

        } else {
            //조회된 결과 정렬(asis:<param name=SortExpr 참조)
            ds_evidCode.sort("vatDeclarAcctDeptCd", 0);
            gr_evidCode.setFocusedCell(0, 0);
            $c.gus.cfDisableBtn([btn_save]);
        }
    }
};

/**
 * 행추가
 */
scwin.f_Create = async function() {
    if(ds_evidCode.getInsertedIndex().length > 0) {
        let ret = await scwin.f_Validation();
        if(!ret) {
            return false;
        }
    }

    let row = ds_evidCode.insertRow();
    gr_evidCode.setFocusedCell(row, 0, false);

    //disable 처리
    $c.gus.cfEnableKeyData();
    $c.gus.cfDisableBtn([btn_update]);
    $c.gus.cfEnableObjects(grp_save);
    lc_useYn.setValue(1);
    ed_evidClsCd.focus();
};


/**
 * 수정버튼
 */
scwin.f_Update = function() {
    // disable 처리
    $c.gus.cfDisableKey();
    $c.gus.cfEnableObjects(grp_save);
    $c.gus.cfDisableObjects([ed_evidClsCd]);
    $c.gus.cfDisableBtn([btn_update]);
    //focus 설정
    ed_evidClsNm.focus();
};

/**
 * 취소
 */
scwin.f_Cancel = function(e) {
    $c.data.undoRow(ds_evidCode, "N");

    $c.gus.cfDisableObjects(grp_save);
    $c.gus.cfDisableBtn([btn_save]);
};

/**
 * 저장 시 입력 Validation
 */
scwin.f_Validation = async function () {
    //Mandatory 항목이 누락하지 않았는지 체크한다.
    // if (!cfCheckMandatory())
    // return false;

    // 체크(전표종류코드, 전표종류명)
    let ret = await $c.gus.cfValidate([ed_evidClsCd, ed_evidClsNm, ed_limitAmt]);
    if(!ret) {
        return false;
    }
    return true;
};

/**
 * scwin.f_ValidationSync 사용하기 위한 함수
 */
scwin.myCfValidate = function (oElement) {
    let obj = $c.gus.object(oElement);
    if (obj.length != null) {
		for (var i = 0; i < obj.length; i++) {
            let id = obj[i];
            if($c.gus.cfIsNull(id.getValue())) {
                $c.win.alert(id.options.title + "은(는) 필수 입력 항목입니다.");
                id.focus();
                return false;
            }
        }
    }
    return true;
};

/**
 * onbeforerowpositionchange 사용을 위한 validation 체크
 */
scwin.f_ValidationSync = function() {
    //필수값 임의로 체크(증빙구분코드, 증빙명, 한도금액)
    let ret = scwin.myCfValidate([ed_evidClsCd, ed_evidClsNm, ed_limitAmt]);
    if(!ret) {
        return false;
    }
    return true;
};


/**
 * 저장버튼
 */
scwin.f_Save = async function () {
    //변경한 데이터가 있는지 체크한다.
    // if (ds_evidCode.IsUpdated == false) {
    if (ds_evidCode.getModifiedIndex().length < 1) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_001, ["데이타"]);
        return;
    }

    // 체크
    if (!await scwin.f_Validation()) {
        return;
    }

    let ret = await $c.gus.cfValidate([gr_evidCode]);
    if (!ret) {
        return false;
    }
    if (await $c.win.confirm(MSG_CM_CRM_001)) {
	    sbm_save.userData1="noError";
        $c.sbm.execute(sbm_save);
    }
};

scwin.sbm_save_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) {
        await $c.gus.cfAlertMsg(e.responseJSON.resultDataSet[1].Msg);
        return;
    }

    if (e.responseJSON.resultDataSet[0].Msg != "FAIL") {
        ds_evidCode.reform();
        await $c.gus.cfAlertMsg(MSG_CM_INF_001);
        scwin.f_Retrieve(); 
    }
};

scwin.sbm_save_submiterror = function (e) {
    $c.gus.cfAlertMsg(e.responseJSON.resultDataSet[1].Msg);
};



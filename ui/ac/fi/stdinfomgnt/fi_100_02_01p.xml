 * 수정이력 :
 *    - 2025-09-30      배기원    최초작성
 */
/**
 * TOBE : 초기로드(UDC 있으면 scwin.onUdcCompleted 초기값 세팅)
 */
scwin.onpageload = function() {
    scwin.params = $c.data.getParameter();
    if (!$c.util.isEmpty(scwin.params["crn"])) {
        dma_search.set("crn", scwin.params["crn"]);
    }

    scwin.setInit();

    scwin.f_RetrieveCompanyHistory();
    scwin.f_RetrieveDefaultHistory();
};

/**
 * 초기세팅(TOBE 그리드, 총건수)
 */
scwin.setInit = function() {
    ds_List1.removeAll();
    ds_List2.removeAll();
    totalRows1.setValue("0");
    totalRows2.setValue("0");
};

/**
 *  DataSet의 Header 정보 생성(TODO:TOBE 데이터맵으로 셋팅하므로 필요없음)
 */
scwin.f_SetDataHeader = function() {

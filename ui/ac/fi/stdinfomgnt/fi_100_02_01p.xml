    // var GAUCE_DATASET_HEADER = "crn:STRING";

    // ds_condition.SetDataHeader(GAUCE_DATASET_HEADER);
    // ds_condition.AddRow();
};

/**
 * 신용정보관리거래처 이력조회
 */
scwin.f_RetrieveCompanyHistory = function() {
    $c.sbm.execute(sbm_queryCompanyHistory);
};

scwin.sbm_queryCompanyHistory_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    if (e.responseJSON.resultDataSet[0].Msg != "FAIL") {
        let rowCnt = ds_List1.getRowCount();
        totalRows1.setValue(rowCnt);
        if (rowCnt > 0) {
            gr_List1.setFocusedCell(0, 0);
        }
    }
};

/**
 * 채무불이행정보 이력조회
 */
scwin.f_RetrieveDefaultHistory = function() {
    //dma_search.set("crn", "6218500916");
    $c.sbm.execute(sbm_queryDefaultHistory);
};

scwin.sbm_queryDefaultHistory_submitdone = function (e) {
    if (e.responseJSON.resultDataSet[0].Code < 0) return;

    if (e.responseJSON.resultDataSet[0].Msg != "FAIL") {
        let rowCnt = ds_List2.getRowCount();
        totalRows2.setValue(rowCnt);
        if (rowCnt > 0) {
            gr_List2.setFocusedCell(0, 0);
        }
    }
};


/**
 * 닫기
 */
scwin.f_WinClose = function (e) {
    let rt = ["N/A"];
    $c.win.closePopup(rt);
};]]></script>

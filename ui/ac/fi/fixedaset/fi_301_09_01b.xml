scwin.f_srchDeptPopUp = function(sIsEvent) {

    let param = ''; 
    // 자회사 회계 시스템인 경우에는 자회사 소속 귀속부서만 조회   
    if(scwin.isSubCompany)  {   
        param=","+scwin.vCoCd+","+scwin.vCoClsCd;
    }
    
    scwin.f_PopUp('1', ed_srchAcctDeptCd, ed_srchAcctDeptNm
                        , scwin.hid_srchAcctDeptCd, ed_srchAcctDeptCd
                        , sIsEvent, "retrieveAcctDeptCdInfo6"
                        , param, "410");
  	 
} 

scwin.udc_srchAcctDeptCd_cb = function(rtnList) {
    if (rtnList != null ) {
        if (rtnList[0] == "N/A") return;

        ed_srchAcctDeptCd.setValue( rtnList[0] );
        ed_srchAcctDeptCd.options.hidVal = rtnList[0];
        ed_srchAcctDeptNm.setValue( rtnList[1] );
        //if (nextObj != null) nextObj.focus();
    } else {
        ed_srchAcctDeptCd.setValue( "" );
        ed_srchAcctDeptCd.options.hidVal = "";
        ed_srchAcctDeptNm.setValue( "" );
        //(bReverse) ? nmObj.focus() : cdObj.focus();
    }

    ed_srchAcctDeptNm.focus();	   
            
    //회사 정보 set
    scwin.txtCoCd       = rtnList[8];		//회사코드 
    scwin.txtCoClsCd    = rtnList[9];		//회사구분코드  
    
}

//-------------------------------------------------------------------------
// 팝업
//-------------------------------------------------------------------------
scwin.f_PopUp = function(flag, cdObj, nmObj, hidObj, nextObj, sIsEvent, sQueryID, sWhere, sWidth) {
    let param1, param2;

    if ( typeof cdObj == "object") {
        param1 = (sIsEvent == 'T' ? cdObj.getValue().trim() : "");
        param2 = "";
        bReverse = false;
    } else {
        param1 = "";
        param2 = (sIsEvent == 'T' ? nmObj.getValue().trim() : "");
        bReverse = true;
    }
    
    switch (flag) {
        case "1" :
            udc_srchAcctDeptCd.setSelectId(sQueryID);
            udc_srchAcctDeptCd.cfCommonPopUp(scwin.udc_srchAcctDeptCd_cb,param1,param2
                            ,sIsEvent,null,null,null,null
                            ,sWhere,sWidth,null,null,null);
        break;

        case "2" :
            
        break;

        default :
        break;
    }
}

scwin.sbm_search_submitdone = function(e) {

    ed_totalRows.setValue( ds_master.getRowCount() );
    if(ds_master.getRowCount() > 0 ){
        scwin.setGridData();
    }

    if(scwin.sortType != ""){
        var sortType = scwin.sortOrder == -1 ? 1 : 0; //1 내림차순 0 오름차순
        ds_master.sort(scwin.sortType, sortType);
    } else {
        ds_master.sort('fixedAsetNo', 0);
    }
}
scwin.sbm_search_submiterror = function(e) {
    $c.gus.cfAlertMsg(e.responseJSON.resultDataSet[1].Msg);
}

scwin.ed_srchFixedAsetNo_onblur = function (e) {
    if (ed_srchFixedAsetNo.getValue().trim() == "") return;
	ed_srchFixedAsetNo.setValue( $c.gus.cfGetLeftPad(ed_srchFixedAsetNo.getValue(),10) );
};

scwin.udc_srchAcctDeptCd_onblurCodeEvent = function (e) {
    if ($c.gus.cfIsNull(ed_srchAcctDeptCd.getValue())) {
		ed_srchAcctDeptNm.setValue("");
		scwin.hid_srchAcctDeptCd = "";
		return;
	}

	if (ed_srchAcctDeptCd.getValue().trim() == scwin.hid_srchAcctDeptCd) return;

	scwin.f_srchDeptPopUp('T');
};

scwin.udc_srchAcctDeptCd_onclickEvent = function (e) {
    scwin.f_srchDeptPopUp(ed_srchAcctDeptCd,ed_srchAcctDeptNm,scwin.hid_srchAcctDeptCd,'F');
};

scwin.setGridData = function () {
    for(var idx=0; idx < ds_master.getRowCount(); idx++ ){
        // 고정자산명과 자산명이 같으므로 다른 아이디에 동일 값 부여
        var grdFixedAsetNm = ds_master.getCellData(idx, "fixedAsetNm");
        ds_master.setCellData(idx, "grdFixedAsetNm", grdFixedAsetNm);
        var addr1 = ds_master.getCellData(idx, "siteAddr1");
        var addr2 = ds_master.getCellData(idx, "siteAddr2");
        var address = addr1 + ' ' + addr2;
        ds_master.setCellData(idx, "address", address);//주소
        var tempTaxDeductYn = '';
        if(ds_master.getCellData(idx, "tempTaxDeductYn") == 1 ||
        ds_master.getCellData(idx, "tempTaxDeductYn") == '1'
        ){
            tempTaxDeductYn = 'Y';
        }else {
            tempTaxDeductYn = 'N';
        }
        ds_master.setCellData(idx, "tempTaxDeductYn", tempTaxDeductYn);
        //ds_master.sort('fixedAsetNo', 0);
    }

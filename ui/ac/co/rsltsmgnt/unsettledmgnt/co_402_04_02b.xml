//-------------------------------------------------------------------------
// 저장
//-------------------------------------------------------------------------
scwin.f_Save = async function () {
    if(ds_master.getRowCount() < 1){
        await $c.gus.cfAlertMsg("조회된 자료가 없습니다.");
    } else {
        let ret = await $c.gus.cfValidate([ica_srchCloseYm]);
        if (!ret) {
            return false;
        }

        let confirmResult = await $c.win.confirm(MSG_CM_CRM_001);
        if (confirmResult) {
            //ds_master.UseChangeInfo = false;
            //tr_master.post();

            //submit 처리.
            let masterSubmit = await $c.sbm.execute(sbm_master);

            if(masterSubmit.responseJSON.resultDataSet[0].Msg == "SUCC") {   
                await scwin.sbm_master_submitdone();
            }
        }    
    }
};

scwin.sbm_master_submitdone = async function (e) {
    await $c.gus.cfAlertMsg(MSG_CM_INF_001);	// 성공적으로 저장하였습니다
    await scwin.f_Retrieve();
};


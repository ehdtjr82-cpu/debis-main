scwin.onpageload = function() {
console.log("PGM :  고객사 비교(NGLS) (co_404_01_56b)");    
    const codeOptions = [
        { grpCd : "CO012", compID : "lc_unit"}     // 단위               
    ];
    $c.data.setCommonCode(codeOptions);

    ed_yyyyMm.setValue(scwin.fromDate_YyMm);	

    lc_deptClsCd.setValue("A");	//부서-전체
};

//-------------------------------------------------------------------------
// Default Unit 을 설정

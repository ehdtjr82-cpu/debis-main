scwin.f_Retrieve = async function () {
    // 조회조건 필수사항 체크
    if ( ed_yyyyMm.getValue().trim().length != 6 ) {
        await $c.win.alert("조회년월은 필수입력 입니다.");
        ed_yyyyMm.focus();
        return;
    }    
    //if (!$c.gus.cfValidate([ed_yyyyMm])) {
    //    return;
    //}
    dma_search.set("yyyyMm",  ed_yyyyMm.getValue());
    dma_search.set("deptClsCd", lc_deptClsCd.getValue());
    $c.sbm.execute(sbm_master);
}

//-------------------------------------------							
// 그리드 높이 늘리고 줄이기							
//-------------------------------------------							
scwin.f_grdHeiht = function(gridNm, size) {							
    							
    let strHeight = gridNm.style.height ;							
    let intHeight = parseInt(strHeight.replace("px",""));							
    intHeight = intHeight + size;							
    if (intHeight > 0 ) {							
        gridNm.style.height = intHeight + "px";							
    }							
}  

//-------------------------------------------------------------------------
// 엑셀 출력
//-------------------------------------------------------------------------
scwin.f_Excel = async function() {
   if(ds_master.getRowCount() == 0) {
        await $c.gus.cfAlertMsg(MSG_CM_WRN_002);
        return;
    }
     cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");
    if (!cfrm) {
        return;
    }
    let gridColCount = 0;
    for(let i = 0; i < gr_master.getTotalCol(); i++){
        if(gr_master.getColumnVisible(i)==true){
            gridColCount++;
        }
    }

    let str = $c.gus.cfGetFormatStr(ed_yyyyMm.getValue().trim(), "####");

    let startRowIndex = 0;
    let infoArr = [{
        rowIndex : 0,             
        colIndex : 0,            
        colSpan : gridColCount,   
        rowSpan : 1,
        text : "고객사 비교(NGLS)",
        textAlign : "center",    
        fontSize : 12,
        drawBorder : false,       
        color : "black",          
        backgroundColor : "#ffffff" 
    },{
        rowIndex : 2,             
        colIndex : 0,           
        colSpan : gridColCount,  
        rowSpan : 1,
        text : "조회년도 ["+ str +"]",
        textAlign : "left",    
        fontSize : 10,
        drawBorder : false,       
        color : "black",       
        backgroundColor : "#ffffff" 
    }]

    const options = {
        fileName: "고객사 비교(NGLS)_"+str+".xlsx",
        sheetName: "고객사 비교(NGLS)_"+str ,
        startRowIndex : 3,        
        startColumnIndex : 0,
        type : 1
    };
    await $c.data.downloadGridViewExcel(gr_master, options, infoArr);
};

scwin.btn_search_onclick = function (e) {
    scwin.f_Retrieve();
};

scwin.ds_master_ondataload = function () {
    scwin.rowCnt = ds_master.getTotalRow();

//------------------------------------------------------------------------
// 그리드 컬럼의 금액단위를 정한다. 
//------------------------------------------------------------------------
scwin.f_changeUnitAmt = function(unitAmt) {
    var ds_master_rcnt = ds_master.getRowCount();
    if (ds_master_rcnt == 0) {
        return;
    }
 
    const cols_co4040156b = ["nmonSaleCost", "nmonBusinessProfit", "bmonSaleCost", "bmonBusinessProfit"
                           , "byearSaleCost", "byearBusinessProfit", "monSaleCost", "monBusinessProfit"
                           , "yearSaleCost", "yearBusinessProfit", "nyearSaleCostSum", "nyearBusinessProfitSum"
                           , "byearSaleCostSum", "byearBusinessProfitSum", "yearSaleCostSum", "yearBusinessProfitSum"];

    var t_gridUnitAmt = 0;  
    for (var i=0; i < ds_master_rcnt; i++) {
        for (j=0; j < cols_co4040156b.length; j++) {
            t_gridUnitAmt = 0;            
            if ( $c.gus.cfIsNull(ds_master.getCellData(i, cols_co4040156b[j])) || !$c.num.isNumber(ds_master.getCellData(i, cols_co4040156b[j]))) { 
                ds_master.setCellData(i, cols_co4040156b[j], 0); 
            } else { 
                t_gridUnitAmt = $c.num.round($c.num.parseInt(ds_master.getCellData(i, cols_co4040156b[j]))/unitAmt, 1);    
                ds_master.setCellData(i, cols_co4040156b[j], t_gridUnitAmt);
            }
        }
    }  
}


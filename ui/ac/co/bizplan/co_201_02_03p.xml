<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map">
    			<w2:dataMap baseNode="map" id="dma_master">
    				<w2:keyInfo>
    					<w2:key id="planYr" name="기준년도" dataType="text"></w2:key>
    					<w2:key id="planYm" name="반영년도" dataType="text"></w2:key>
    					<w2:key id="coCd" name="회사코드" dataType="text"></w2:key>
    				</w2:keyInfo>
    			</w2:dataMap>
    		</w2:dataCollection>
    		<w2:workflowCollection />
    		<xf:submission id="sbm_master" action="/ac.co.bizplan.CreateSellingPlanClassificationAutoCMD.do" method="post" mediatype="application/json" ref='data:json,{"id":"dma_master","key":"IN_DS1"}' target="" encoding="UTF-8"
    			instance="" replace="" errorHandler="" customHandler="" mode="asynchronous" processMsg="" ev:submit="" ev:submitdone="scwin.sbm_master_submitdone"
    			ev:submiterror="" abortTrigger="">
    		</xf:submission>
    	</xf:model>
    	<w2:layoutInfo />
    	<w2:publicInfo method="" />
    	<script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// 화면로딩시
//-------------------------------------------------------------------------
scwin.onpageload = function() {
    scwin.params = $c.data.getParameter();
    if(!$c.util.isEmpty(scwin.params["planYr"])) {
        ica_planYr.setValue(scwin.params["planYr"]);
    }
    ica_planYr.focus();

    if(!$c.util.isEmpty(scwin.params["CO_CD"])) {
        ed_coCd.setValue(scwin.params["CO_CD"]);
    }

    if(!$c.util.isEmpty(scwin.params["CO_NM"])) {
        ed_coNm.setValue(scwin.params["CO_NM"]);
    }

    $c.gus.cfDisableObjects([ed_coCd,ed_coNm]);
};

//-------------------------------------------------------------------------
// 생성 : 
//-------------------------------------------------------------------------
scwin.f_Create = async function() {
    //생성조건 입력여부 및 형식 체크
    let ret = await $c.gus.cfValidate([ica_planYr,ica_planYm,ed_coCd]);
    if (!ret) {
        return false;
    }

    //반영할 년도와 기준년도가 같은 지 체크
    if (ica_planYr.getValue() >= ica_planYm.getValue()) {
        await $c.win.alert("기준년도는 반영할 년도 이전이여야 합니다.");
        ica_planYm.focus();
        return;
    }

    if (await $c.win.confirm("반영할 년도의 기존 자료는 삭제됩니다.\n\n계속하시겠습니까?")) {
        $c.sbm.execute(sbm_master);
    }
};

scwin.sbm_master_submitdone = async function (e) {
    await $c.win.alert(MSG_CM_INF_001);
    $c.win.closePopup();
};

scwin.btn_create_onclick = function (e) {
    scwin.f_Create();
};

scwin.btn_close_onclick = function (e) {
    $c.win.closePopup();
};
]]></script>
    	<w2:require as="udc_topGrdBtn" type="page" variableClone="true" src="/cm/udc/topGrdBtn.xml"></w2:require>
    </head>
    <body ev:onpageload="scwin.onpageload">
    	<xf:group class="pop_contents" id="" meta_componentContainer="true" style="">
    		<w2:wframe id="" src="/cm/xml/contentHeader.xml" style=""></w2:wframe><xf:group class="round-box" id="">
    					<xf:group class="tbbox" id="" style="">
    						<xf:group class="w2tb" id="" style="" tagname="table">
    							<w2:attributes>
    								<w2:summary></w2:summary>
    							</w2:attributes>
    							<xf:group tagname="colgroup">
    								<xf:group style="width:120px;" tagname="col"></xf:group>
    								<xf:group style="" tagname="col"></xf:group>
    							</xf:group>
    							<xf:group style="" tagname="tr">
    								<xf:group class="w2tb_th" style="" tagname="th">
    									<w2:textbox class="req" id="" label="회사코드" ref="" style="" userData2=""></w2:textbox>
    								</xf:group>
    								<xf:group class="w2tb_td" style="" tagname="td">
    									<xf:group class="form-group col7" id="" style="">
    										<xf:input class="w85" id="ed_coCd" placeholder="" style="" objType="data" validExp="회사코드:yes" mandatory="true" allowChar="0-9" maxlength="3" title="회사코드" ref="data:dma_master.coCd">
    										</xf:input>
    										<xf:input class="" id="ed_coNm" placeholder="" style="" objType="data"></xf:input>
    									</xf:group>
    								</xf:group>
    							</xf:group>
    							<xf:group tagname="tr">
    								<xf:group class="w2tb_th" tagname="th">
    									<w2:attributes>
    										<w2:scope>row</w2:scope>
    									</w2:attributes>
    									<w2:textbox class="req" id="" label="기준년도" ref="" style="" userData2=""></w2:textbox>
    								</xf:group>
    								<xf:group class="w2tb_td" tagname="td">
    									<w2:attributes>
    										<w2:colspan>1</w2:colspan>
    										<w2:rowspan>1</w2:rowspan>
    									</w2:attributes>
    									<w2:inputCalendar calendarValueType="year" class="" id="ica_planYr" style="" objType="key" mandatory="true" validExp="기준년도:yes:date=YYYY" placeholder=" " displayFormat="yyyy" validateOnInput="true" title="기준년도" ref="data:dma_master.planYr">
    									</w2:inputCalendar>
    								</xf:group>
    							</xf:group>
    							<xf:group tagname="tr">
    								<xf:group class="w2tb_th" tagname="th">
    									<w2:attributes>
    										<w2:scope>row</w2:scope>
    									</w2:attributes>
    									<w2:textbox class="req" id="" label="반영할 년도" ref="" style="" userData2=""></w2:textbox>
    								</xf:group>
    								<xf:group class="w2tb_td" tagname="td">
    									<w2:attributes></w2:attributes>
    									<w2:inputCalendar calendarValueType="year" class="" id="ica_planYm" style="" objType="data" mandatory="true" validExp="년도:yes:date=YYYY" placeholder=" " validateOnInput="true" displayFormat="yyyy" title="반영할 년도" ref="data:dma_master.planYm">
    									</w2:inputCalendar>
    								</xf:group>
    							</xf:group>
    						</xf:group>
    					</xf:group>
    				</xf:group><xf:group class="pop-btnbox" id="" style="">
    					<xf:trigger class="btn" id="btn_close" style="" title="엑셀 UP" type="button" ev:onclick="scwin.btn_close_onclick">
    						<xf:label><![CDATA[닫기]]></xf:label>
    					</xf:trigger><xf:trigger class="btn" id="btn_create" style="" type="button" userAuth="C" objType="bSave" ev:onclick="scwin.btn_create_onclick">
    						<xf:label><![CDATA[생성]]></xf:label>
    					</xf:trigger>
    					
    				</xf:group>
    	</xf:group>
    </body>
</html>

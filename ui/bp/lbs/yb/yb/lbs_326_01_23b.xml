    	<script lazy="false" type="text/javascript"><![CDATA[//-------------------------------------------------------------------------
// 화면 로딩
//-------------------------------------------------------------------------
scwin.onpageload = function() {
	scwin.strCurrDate  = $c.date.getServerDateTime();
    scwin.strStartDate = $c.date.addDate(scwin.strCurrDate, -2);
    scwin.strFirstDate = scwin.strCurrDate.substring(0, 6) + "01";   
    
 	//사용자 정보 가져오기
 	scwin.memInfo   = $c.data.getMemInfo();
    var vClntNo     = $c.gus.cfIsNull(scwin.memInfo.clntNo)?    "" : scwin.memInfo.clntNo;
    var vClntNm     = scwin.memInfo.clntNm;
    var vUserClsCd  = scwin.memInfo.userClsCd;

    dma_condition.set("repClntNo", "000001");
    lc_mntrYn.setSelectedIndex(0);
    
    //2020.05.20 협력업체 조건 추가 
    if(vUserClsCd == "FB") { // 사용자구분이 협력업체인_NTIS 인 경우 수정 불가 
        ed_partnersNo.setValue(vClntNo);
        ed_partnersNm.setValue(vClntNm);
        $c.gus.cfDisableObjects([udc_partnersNo, lc_wrkLobranCd]);   
    }else {
        $c.gus.cfEnableObjects([udc_partnersNo]);    
    }  

    if(scwin.memInfo.userId == "281963" || scwin.memInfo.userId == "281807") {
        btn_schMobile.show("");
    } else {
        btn_schMobile.hide();
    }
};

//-------------------------------------------------------------------------
// UDC 로딩
//-------------------------------------------------------------------------
scwin.onUdcCompleted = function() {
    udc_fromToCalendar.setInitDate(scwin.strCurrDate, scwin.strCurrDate);
}

//-------------------------------------------------------------------------
// 조회 필드 Clear
//-------------------------------------------------------------------------
scwin.f_fieldClear = function() {
	console.log("scwin.f_fieldClear");
	$c.gus.cfInitObjects(tbl_search);
    udc_fromToCalendar.setInitDate(scwin.strCurrDate, scwin.strCurrDate);
    
    dma_condition.set("repClntNo", "000001");
}

//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.f_retrieve = function() {
    if(em_dptIntendDd.getValue() == "" || em_dptIntendDd2.getValue() == ""){
        $c.win.alert("배차일자는 필수 입력 항목입니다.");
        return;
    }
    
    if($c.date.diffDate(em_dptIntendDd.getValue(), em_dptIntendDd2.getValue()) > 31) {
        $c.win.alert("최대 검색기간은 1달입니다.");                                   
        return;
    }   
    
    dma_condition.set("clntNo", ed_partnersNo.getValue());
    ds_resultDetail.removeAll();                //재조회시 Detail Data Clear
    $c.sbm.execute(sbm_retrieve);
}

//-------------------------------------------------------------------------
// 관제내역 조회
//-------------------------------------------------------------------------
scwin.f_retrieveDetail = function () {
    dma_conditionDetail.setJSON(ds_result.getRowJSON(ds_result.getRowPosition()));
    $c.sbm.execute(sbm_retrieveDetail);
}

//-------------------------------------------------------------------------
// 팝업
//------------------------------------------------------------------------- 
scwin.f_openCommonPopUp = function(disGubun, pCode, pName, pClose, pAllSearch) {
    switch (disGubun) {
        case 1:     // 거래처 팝업           
            udc_partnersNo.cfCommonPopUp(    scwin.callBackClntInfo
                                            ,pCode                 
                                            ,pName                 
                                            ,pClose                
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,null                  
                                            ,pAllSearch            
                                            ,"계약 거래처,거래처코드/명"  
                                            );
            break;

        default:
            break;  
    }   
}

//-------------------------------------------------------------------------
// 공통팝업호출 callBack
//-------------------------------------------------------------------------
scwin.callBackClntInfo = function(rtnList) {
    $c.gus.cfSetReturnValue(rtnList, ed_partnersNo, ed_partnersNm);
}

//-------------------------------------------------------------------------
// Formatter
//-------------------------------------------------------------------------
scwin.f_customFormatter = function(data, formattedData, rowIndex, colIndex) {
    let columnId =  $c.util.getComponent(this.id).getColumnID(colIndex);
    
    if(columnId == "noGpsCnt") {
        data = $c.gus.decode(data, "0", "", data);
    } else if(columnId == "vehclSts") {
        data = $c.gus.decode(data, "1", "대기", "3", "상차보고", "4", "운행중", "5", "하차보고");
    }  else if(columnId == "notDataSaverMode") {
        data = $c.gus.decode(data, "N", "Y", "Y", "N");
    } 

    return data;
};

//-------------------------------------------------------------------------
// 모바일 이력조회 팝업 호출
//-------------------------------------------------------------------------
scwin.f_retrieveMobileLog = function() {
    var data = {
          PIC_NM  : ds_result.getCellData(ds_result.getRowPosition(), "picNm")
        , PDA_NO  : ds_result.getCellData(ds_result.getRowPosition(), "pdaNo")
        , DT_FROM : em_dptIntendDd.getValue()
        , DT_TO   : em_dptIntendDd2.getValue()
    };

    var opts = {
          id : "lbs_326_01_23p"
        , popupName : "모바일이력"
        , type : "browserPopup"  
        , title : "모바일이력" 
        , width : 1200
        , height : 800
    };

    $c.win.openPopup("/ui/bp/lbs/yb/yb/lbs_326_01_23p.xml", opts, data);
}

/* ----------------------------------------------------------------------------
  T R A N S A C T I O N   C O M P O N E N T S   D E C L A R A T I O N
------------------------------------------------------------------------------*/
//조회 완료
scwin.sbm_retrieve_submitdone = function(e) {
    console.log("scwin.sbm_retrieve_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) return; 

    var rowCnt = ds_result.getTotalRow();
	spn_totalRow.setValue(rowCnt);

    if(rowCnt == 0) {
        $c.gus.cfAlertMsg(MSG_CM_WRN_002);
    }
};

//상세조회 완료
scwin.sbm_retrieveDetail_submitdone = function (e) {
    console.log("scwin.sbm_retrieveDetail_submitdone");
	if (e.responseJSON.resultDataSet[0].Code < 0) return; 

    var rowCnt = ds_resultDetail.getTotalRow();
	spn_totalRowDtl.setValue(rowCnt);

    if(rowCnt == 0) {
        $c.gus.cfAlertMsg(MSG_CM_WRN_002);
    }
};

/* ----------------------------------------------------------------------------
  C O M P O N E N T' S   E V E N T S  
-----------------------------------------------------------------------------*/
//협력업체 찾기 버튼
scwin.udc_partnersNo_onclickEvent = function (e) {
    scwin.f_openCommonPopUp(1, ed_partnersNo.getValue(), ed_partnersNm.getValue(), 'F', 'T');
};

scwin.udc_partnersNo_onviewchangeCodeEvent = function (info) {
    if(info.oldValue != info.newValue && ed_partnersNo.getValue() != "") {
        scwin.f_openCommonPopUp(1, ed_partnersNo.getValue(), ed_partnersNm.getValue(), 'T', 'T');
    } else {
        ed_partnersNo.setValue("");
        ed_partnersNm.setValue("");        
    } 
};

//모바일이력 버튼
scwin.btn_schMobile_onclick = function (e) {
    scwin.f_retrieveMobileLog();
};

//조회조건 clear 버튼
scwin.btn_clear_onclick = function (e) {
    console.log("scwin.btn_clear_onclick");
    scwin.f_fieldClear();
};

//조회 버튼
scwin.btn_search_onclick = function (e) {
    console.log("scwin.btn_search_onclick");
    scwin.f_retrieve(); 
};

//관제통계현황 상세(크나우프)현황 그리드 더블 클릭 > 관제내역 조회
scwin.gr_results_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    scwin.f_retrieveDetail();
};


]]></script>

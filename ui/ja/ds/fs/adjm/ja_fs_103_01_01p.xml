        <script lazy="false" type="text/javascript"><![CDATA[
scwin.memJson           = $c.data.getMemInfo();
scwin.vLoginCoCd        = $c.gus.cfIsNull(scwin.memJson.coCd)    ? '' : scwin.memJson.coCd; // 소속 자회사  
scwin.vLoginCoClsCd     = $c.gus.cfIsNull(scwin.memJson.coClsCd) ? '' : scwin.memJson.coClsCd  ;//회계_회사구분('CO035' : 0:동부 EXPRESS)
scwin.vUserHomeClsCd    = scwin.memJson.userHomeClsCd;        // 사용자소속구분코드 

scwin.vCoCd             = $c.gus.cfIsNull(scwin.memJson.coCd)    ? '' : scwin.memJson.coCd; // 소속 자회사  
scwin.vCoClsCd          = $c.gus.cfIsNull(scwin.memJson.coClsCd) ? '' : scwin.memJson.coClsCd  ;//회계_회사구분('CO035' : 0:동부 EXPRESS)
scwin.slipNo            = "";

scwin.onpageload = function() {

console.log(scwin.memJson);
    scwin.vCoCd = scwin.vLoginCoCd;

    scwin.setParentParamSettion();
};

scwin.setParentParamSettion = function(){

    //부모로부터 전달받은 데이타셋
    const arg = $p.getAllParameter();
    scwin.slipNo = arg.paramData.slipNo;

// debugger;
//      console.log("slipNo : " + scwin.slipNo);

    if (!$c.gus.cfIsNull(scwin.slipNo)) {
        //데이타 mpa에 세팅
        ds_searchPurchaseEvidence.set("slipNo", scwin.slipNo);

        scwin.f_SetDataHeader();
    }
}


//-------------------------------------------------------------------------
// DataSet의 Header 정보 생성
//-------------------------------------------------------------------------
scwin.f_SetDataHeader = function() {

    ds_searchPurchaseEvidence.set("slipNo", scwin.slipNo);
    ds_searchPurchaseEvidence.set("coCd", scwin.vLoginCoCd);

    $c.sbm.execute(sbm_searchPurchaseEvidence);
};

scwin.sbm_searchPurchaseEvidence_submitdone = function (e) {
    var rowcnt = ds_purchaseEvidence.getRowCount();
    ds_purchaseEvidence.setRowPosition(0);
    var nVat = 0;
    var nSpplyAmt = 0;
    if (rowcnt > 0) {
            if(!$c.gus.cfIsNull(ds_purchaseEvidence.getCellData(ds_purchaseEvidence.getRowPosition(), "spplyAmt"))){
                nSpplyAmt = parseInt(ds_purchaseEvidence.getCellData(ds_purchaseEvidence.getRowPosition(), "spplyAmt"));
            }
            if(!$c.gus.cfIsNull(ds_purchaseEvidence.getCellData(ds_purchaseEvidence.getRowPosition(), "vat"))){
                nVat = parseInt(ds_purchaseEvidence.getCellData(ds_purchaseEvidence.getRowPosition(), "vat"));
            }

			tbx_sumAmt.setValue($c.gus.cfInsertComma(nSpplyAmt + nVat));  // 금액합계
	}
    tbx_totalRows.setValue(ds_purchaseCertiList.getRowCount());
};

scwin.sbm_searchPurchaseEvidence_submiterror = function (e) {

};

scwin.btn_Close_onclick = function (e) {

    $c.win.closePopup();
};
]]></script>

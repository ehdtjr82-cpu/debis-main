//-------------------------------------------------------------------------
// 조회
//-------------------------------------------------------------------------
scwin.btn_retrieve_onclick = async function (e) {
    //validation check
    if (acb_lc_qryConKnd.getValue() == "YM") {
        let ret1 = await $c.gus.cfValidate([ed_homeClntNo, ica_ed_adptYm]);
        if (!ret1) {
            return;
        }
    } else {
        let ret2 = await $c.gus.cfValidate([ed_homeClntNo, ed_qryConDtFm, ed_qryConDtTo]);
        if (!ret2) {
            return;
        }

        //조회시작일자가 더 클경우 체크
        let ret3 = $c.gus.cfIsAfterDate(ed_qryConDtFm.getValue(), ed_qryConDtTo.getValue());
        if (!ret3) {
            $c.gus.cfAlertMsg(MSG_CM_ERR_039);
            return;
        }
    }

    $c.sbm.execute(sbm_retrieve);
};

scwin.sbm_retrieve_submitdone = function (e) {
    
    let ds_out_count = ds_out.getRowCount();
    totalRowsOut.setValue(ds_out_count);
    if(ds_out_count < 1) {
        totalRowsDetail.setValue("0");
    }
    

    if( e.responseJSON.resultDataSet[0].Code == 0 )
    {
        if(ds_out_count == 0) {
            $c.gus.cfAlertMsg(MSG_CM_WRN_002);
            $c.gus.cfDisableBtn([btn_save, btn_delete]);
        } else if(ds_out_count > 0) {
            //ds_out.UseFilter = true;
            gr_out.setFocusedCell(0, 0);
            
            if(acb_lc_qryConKnd.getValue() == "YM") {
                $c.gus.cfEnableBtnOnly([btn_save]);
                $c.gus.cfDisableBtn([btn_delete]);
            }
            else if(acb_lc_qryConKnd.getValue() == "CERTI") {
                $c.gus.cfEnableBtnOnly([btn_delete]);
                $c.gus.cfDisableBtn([btn_save]);
            }
        }
    }
};


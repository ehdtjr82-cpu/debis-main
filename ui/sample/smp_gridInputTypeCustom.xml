    							displayMode="label" checkboxLabel="" chooseOptionLabel="" sortable="false">
    						</w2:column>
    						<w2:column width="105" inputType="text" style="" id="column7" value="name2" blockSelect="false"
    							displayMode="label">
    						</w2:column>
    						<w2:column width="120" inputType="text" style="" id="column5" value="name3" blockSelect="false"
    							displayMode="label">

    							typeGetter="">
    						</w2:column>
    						<w2:column width="100" inputType="text" style="" id="col4" value="" blockSelect="false" displayMode="label"
    							typeGetter="">
    						</w2:column>
    						<w2:column width="70" inputType="select" style="" id="col5" value="" blockSelect="false" displayMode="label"
    							allOption="" chooseOption="true" ref="" chooseOptionLabel="-- 변경 --" viewType="icon">
    							<w2:choices>
    								<w2:item>
    									<w2:label><![CDATA[text]]></w2:label>

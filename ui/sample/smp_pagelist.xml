    	<script lazy="false" type="text/javascript">
scwin.onpageload = function() {
    ds_pageIN.set(&quot;targetRow&quot;, 1);
    $c.sbm.execute(submission1);    //페이지 조회
};

scwin.submission1_done = function (e) {//debugger;

    let totrowcnt = ds_pageOUT.getCellData(0, &quot;totalRecords&quot;);
    scwin.setPageListCount(totrowcnt);  //페이징 갯수 세팅
};

//페이징 갯수 세팅
scwin.setPageListCount = function(totrowcnt) {
    let cnt = Number(totrowcnt) / ds_pageOUT.getCellData(0, &quot;totalPage&quot;);
    cnt = Math.ceil(cnt);
    console.log(cnt);
    if(pgl_msgpageList.getCount() !== cnt)
        pgl_msgpageList.setCount(cnt);
};

scwin.pgl_msgpageList_onclick = function (index) {//debugger;
    ds_pageIN.set(&quot;targetRow&quot;, ((index -1) * 10) +1);
    $c.sbm.execute(submission1);
};
</script>

<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
        <w2:type>COMPONENT</w2:type>
        <w2:buildDate />
        <w2:MSA />
        <xf:model>
            <w2:dataCollection baseNode="map">
                <w2:dataMap baseNode="map" id="dma_flag">
                    <w2:keyInfo>
                        <w2:key id="flag" name="flag" dataType="text"></w2:key>
                    </w2:keyInfo>
                </w2:dataMap>
            </w2:dataCollection>
            <w2:workflowCollection />
        </xf:model>
        <w2:layoutInfo />
        <w2:publicInfo method="" />
        <script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function() {
    scwin.params = $c.data.getParameter() || {};

    const receiverFlag = (scwin.params.flag2 === "01" || scwin.params.flag2 === "02") ? scwin.params.flag2 : "01";

    rd_flag.setValue(receiverFlag);
};

scwin.closePopup = function (returnValue) {
    $c.win.closePopup(returnValue);
};

scwin.btn_close_onclick = function (e) {
    scwin.closePopup("999");
};

scwin.btn_send_onclick = function (e) {
    const returnValue = rd_flag.getValue() || "01";
    scwin.closePopup(returnValue);
};
]]></script>
        <w2:require as="udc_ilcomCode" type="page" variableClone="true" src="/ui/il/common/udc/ilcomCode.xml"></w2:require>
        <w2:require as="udc_topGrdBtn" type="page" variableClone="true" src="/cm/udc/topGrdBtn.xml"></w2:require>
        <w2:require as="udc_bottomGrdBtn" type="page" variableClone="true" src="/cm/udc/bottomGrdBtn.xml"></w2:require>
    </head>
    <body ev:onpageload="scwin.onpageload">
        <xf:group class="pop_contents" id="" meta_componentContainer="true" style="">
            <w2:wframe id="" src="/cm/xml/contentHeader.xml" style=""></w2:wframe>
            <xf:group class="round-box" id="">
                <xf:group class="tbbox" id="" style="">
                    <xf:group class="w2tb" id="" style="" tagname="table">
                        <w2:attributes>
                            <w2:summary></w2:summary>
                        </w2:attributes>
                        <xf:group tagname="colgroup">
                            <xf:group style="width:120px;" tagname="col"></xf:group>
                            <xf:group style="" tagname="col"></xf:group>
                        </xf:group>
                        <xf:group tagname="tr">
                            <xf:group class="w2tb_th tac" tagname="th">
                                <w2:attributes>
                                    <w2:scope>row</w2:scope>
                                <w2:colspan>2</w2:colspan><w2:rowspan>1</w2:rowspan></w2:attributes>
                                <w2:textbox class="" id="" label='"KT NET 적하 목록 정정 신청 수신 대상"' ref="" style="" userData2=""></w2:textbox>
                            </xf:group>
                        </xf:group>
                        <xf:group tagname="tr">
                            <xf:group class="w2tb_th" tagname="th">
                                <w2:attributes>
                                    <w2:scope>row</w2:scope>
                                </w2:attributes>
                                <w2:textbox class="" id="" label="수신대상" ref="" style="" userData2=""></w2:textbox>
                            </xf:group>
                            <xf:group class="w2tb_td" tagname="td">
                                <w2:attributes></w2:attributes>
                                <xf:select1 appearance="full" class="" cols="" id="rd_flag" ref="" renderType="radiogroup" rows=""
                                    selectedIndex="0" style="">
                                    <xf:choices>
                                        <xf:item>
                                            <xf:label><![CDATA[세관]]></xf:label>
                                            <xf:value><![CDATA[01]]></xf:value>
                                        </xf:item>
                                        <xf:item>
                                            <xf:label><![CDATA[항공사]]></xf:label>
                                            <xf:value><![CDATA[02]]></xf:value>
                                        </xf:item>
                                    </xf:choices>
                                </xf:select1>
                            </xf:group>
                        </xf:group>
                    </xf:group>
                </xf:group>
            </xf:group>
            <xf:group class="pop-btnbox" id="" style="">
                <xf:trigger class="btn" id="btn_close" style="" type="button" ev:onclick="scwin.btn_close_onclick">
                    <xf:label><![CDATA[Close]]></xf:label>
                </xf:trigger>
                <xf:trigger class="btn" id="btn_send" style="" type="button" ev:onclick="scwin.btn_send_onclick">
                    <xf:label><![CDATA[EDI Send]]></xf:label>
                </xf:trigger>
            </xf:group>
        </xf:group>
    </body>
</html>

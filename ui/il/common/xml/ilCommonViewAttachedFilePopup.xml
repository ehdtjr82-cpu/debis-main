<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map">
    			<w2:dataMap baseNode="map" id="ds_condition">
    				<w2:keyInfo>
    					<w2:key id="houseNo" name="houseNo" dataType="text"></w2:key>
    					<w2:key id="regId" name="regId" dataType="text"></w2:key>
    					<w2:key id="modId" name="modId" dataType="text"></w2:key>
    				</w2:keyInfo>
    			</w2:dataMap>
    		</w2:dataCollection>
    		<w2:workflowCollection />
    	</xf:model>
    	<w2:layoutInfo />
    	<w2:publicInfo method="" />
    	<script lazy="false" type="text/javascript"><![CDATA[let memJson = $c.data.getMemInfo(); // 로그인 정보를 가져온다.
scwin.privAdmin = $c.data.getMemInfo("privAdmin");// ADMIN 권한 CHK : 'T' : ADMIN , 'F': ADMIN 아님    
scwin.empNo = $c.data.getMemInfo("empNo");// 사용자 아이디
scwin.blNo = $p.getPopupParam("blNo") || "";

scwin.onpageload = function() {
	ed_blNo.setValue(scwin.blNo);
    ds_condition.set(regId, scwin.empNo);
    ds_condition.set(modId, scwin.empNo);

    scwin.strCurDate = WebSquare.date.getCurrentServerDate();
};
]]></script>
    	<w2:require as="udc_fileMultiUpload" type="page" variableClone="" src="/cm/udc/fileMultiUpload.xml"></w2:require>
    </head>
    <body ev:onpageload="scwin.onpageload">
    	<xf:group class="pop_contents" id="" meta_componentContainer="true" style="">
    		<w2:wframe src="/cm/xml/contentHeader.xml" style="" id=""></w2:wframe>
    		<xf:group class="shbox" id="" style="">
    			<xf:group class="shbox-inner" id="" style="">
    				<xf:group class="w2tb tb" id="" style="" tagname="table">
    					<w2:attributes>
    						<w2:summary></w2:summary>
    					</w2:attributes>
    					<xf:group tagname="colgroup">
    						<xf:group style="" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    					</xf:group>
    					<xf:group id="" tagname="tr">
    						<xf:group class="w2tb_th" tagname="th">
    							<w2:attributes>
    								<w2:scope>row</w2:scope>
    							</w2:attributes>
    							<w2:textbox class="req" id="" label="House No" style=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" tagname="td">
    							<w2:attributes></w2:attributes>
    							<xf:input class=" w200" id="ed_blNo" placeholder="" style=""></xf:input>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    			<xf:group class="btn-shbox" id="" style="">
    				<xf:trigger class="btn ico refresh" id="" style="" type="button">
    					<xf:label><![CDATA[엑셀 UP]]></xf:label>
    				</xf:trigger>
    				<xf:trigger class="btn sch" disabled="" escape="false" id="btn_search" style="" type="button">
    					<xf:label><![CDATA[Search]]></xf:label>
    				</xf:trigger>
    			</xf:group>
    		</xf:group>
    		<xf:group class="round-box" id="" style="">
    			<xf:group id="" class="lybox">
    				<xf:group id="" class="file-wrap col">
    					<xf:group style="" id="" class="title-wrap">
    						<xf:group id="" class="title">
    							<w2:textbox tagname="h3" style="" id="" label="파일첨부(예정)" class="tit"></w2:textbox>
    						</xf:group>
    					</xf:group>
    					<w2:udc_fileMultiUpload filter="gif, jpg, bmp, png, zip, txt, ppt, pptx, xls, xlsx, doc, docx, xml, csv, pdf"
    						maxFileCount="10" style="" totalFileSize="2009715200" maxFileSize="536870912" fileGrpSeq="">
    					</w2:udc_fileMultiUpload>
    				</xf:group>
    				<xf:group style="" id="" class="file-wrap col">
    					<xf:group style="" id="" class="title-wrap">
    						<xf:group id="" class="title">
    							<w2:textbox tagname="h3" style="" id="" label="파일첨부(완료)" class="tit"></w2:textbox>
    						</xf:group>
    						<xf:group id="" class="right">
    							<xf:trigger ev:onclick="scwin.btn_excelUp_onclick" style="" id="btn_trigger4" title="파일업로드" type="button"
    								class="btn file-del">
    								<xf:label><![CDATA[파일삭제]]></xf:label>
    							</xf:trigger>
    						</xf:group>
    					</xf:group>
    					<w2:udc_fileMultiUpload filter="gif, jpg, bmp, png, zip, txt, ppt, pptx, xls, xlsx, doc, docx, xml, csv, pdf"
    						maxFileCount="10" style="" totalFileSize="2009715200" maxFileSize="536870912" fileGrpSeq="">
    					</w2:udc_fileMultiUpload>
    				</xf:group>
    			</xf:group>
    			<xf:group style="" id="" class="info-list red">
    				<w2:textbox tagname="p" style="" id="" label="파일명, 파일경로에 특수문자를 입력하실 수 없습니다.(특수문자 종류:'!,+&amp;^%$#@~;)" class=""></w2:textbox>
    			</xf:group>
    		</xf:group>
    		<xf:group class="pop-btnbox" id="" style="">
    			<xf:trigger class="btn" id="btn_trigger5" style="" type="button">
    				<xf:label><![CDATA[닫기]]></xf:label>
    			</xf:trigger>
    		</xf:group>
    	</xf:group>
    </body>
</html>

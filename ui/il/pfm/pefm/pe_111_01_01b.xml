scwin.gr_partnerEachPerformanceDetail_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    if (rowIndex < 0) {
		return;
	}

	let paramObj = {};
	let strTitle = "";
	let strPath = "";
	let programId = "";

	let autono = ds_partnerEachPerformanceDetail.getCellData(rowIndex, "autono");	//업무구분
	let hhbltype = ds_partnerEachPerformanceDetail.getCellData(rowIndex, "hhbltype");//컨테이너/벌크 구분

	let blno = ds_partnerEachPerformanceDetail.getCellData(rowIndex, "hblNo");	// house B/L No
	let mhno = ds_partnerEachPerformanceDetail.getCellData(rowIndex, "mhno");

	if (ds_partnerEachPerformanceDetail.getCellData(rowIndex, "hhio") == "O") {  // OUTBOUND
		if (autono == "DIRECT" && hhbltype != "B") {  //Direct
			paramObj = {
				linkcheck: "2"
				, kcomcd: scwin.hd_kcomcd
				, blno: blno
				, mhno: mhno
			};
			programId = "se_107_01_01b.xml";
			strPath = "/ui/il/seaout/sobl/" + programId;
			strTitle = "Export House B/L";

		} else if (autono == "DIRECT" && hhbltype == "B") {  // bulk 
			paramObj = {
				linkcheck: "2"
				, kcomcd: scwin.hd_kcomcd
				, mhno: mhno
			};
			programId = "se_108_01_01b.xml";
			strPath = "/ui/il/seaout/sobl/" + programId;
			strTitle = "Export Bulk B/L";
		} else {  //  house 
			paramObj = {
				linkcheck: "2"
				, kcomcd: scwin.hd_kcomcd
				, blno: blno
				, mhno: mhno
			};
			programId = "se_105_01_01b.xml";
			strPath = "/ui/il/seaout/sobl/" + programId;
			strTitle = "Export House B/L";
		}
	} else {  // INBOUND ,우선 bulk ,house
		if (autono == "DIRECT" && hhbltype == "B") {  //Bulk
			paramObj = {
				linkcheck: "2"
				, kcomcd: scwin.hd_kcomcd
				, mhno: mhno
			};
			programId = "se_203_01_01b.xml";
			strPath = "/ui/il/seainb/sibl/" + programId;
			strTitle = "Import Bulk B/L";
		} else {  //HOuse
			paramObj = {
				linkcheck: "2"
				, kcomcd: scwin.hd_kcomcd
				, blno: blno
				, mhno: mhno
			};
			programId = "se_201_01_01b.xml";

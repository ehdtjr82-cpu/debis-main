            gr_partnerEachPerformance.setFocusedCell(0, 1);
            scwin.f_RetrieveDetail(0);
        } else {
            $c.win.alert(E_MSG_CM_WRN_002); // 조회결과가 존재하지 않습니다. 
        }
    }

    // 그리드 조회건수 초기화
    tbx_totalRows.setValue(ds_partnerEachPerformance.getRowCount());
    tbx_totalRows2.setValue(ds_partnerEachPerformanceDetail.getRowCount());
};


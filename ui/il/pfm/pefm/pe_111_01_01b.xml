// 소수점 5자리를 유지해주는 formatter
scwin.formatToFiveDecimals = function(data) {
	//data 에서 소숫점을 기준으로 나눠서 앞자리와 뒷자리를 분리한다.
	let index = data.indexOf(".");
	if(index == -1) { //소수점이 없는 경우 
		//정수 부분에 3자리마다 콤마를 찍고 뒤에 소수점 0을 5개 붙여서 반환한다.
		return data.replace(/\B(?=(\d{3})+(?!\d))/g, ",") + ".00000"; 
	}	

	let intPart = data.substring(0, index); //정수 부분	
	let decimalPart = data.substring(index + 1); //소수 부분
	
	//정수 부분은 3자리마다 콤마를 찍어준다.
	intPart = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
	//소수부분은 무조건 5자리까지 유지하고 5자리보다 짧으면 0으로 채워준다.
	if(decimalPart.length < 5) {
		decimalPart = decimalPart.padEnd(5, "0");
	} else if(decimalPart.length > 5) {
		decimalPart = decimalPart.substring(0, 5);
	}

	return intPart + "." + decimalPart;	
    
}

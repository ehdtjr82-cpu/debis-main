//-------------------------------------------------------------------------
// 파트너별  Performance List 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = async function (e) {
    // VALIDATE
    let ret = $c.gus.cfValidate([ed_cnd_ed_resultDtFrom, ed_cnd_ed_resultDtTo]);
    if (!ret) {  //validExp 가 yes일때 check
        return;
    }

    // 날짜 범위 확인
	if( !$c.gus.cfIsAfterDate(ed_cnd_ed_resultDtFrom.getValue(), ed_cnd_ed_resultDtTo.getValue()) ){
		await $c.win.alert($c.data.getMessage(E_MSG_CM_ERR_048, "Date From", "Date To"));  //@은(는) 보다 작아야 합니다.
		ed_cnd_ed_resultDtFrom.focus();
		return false;
	}	  		
	
    /* DataSet Clear */
    ds_partnerEachPerformance.removeAll();
    ds_partnerEachPerformanceDetail.removeAll();

    $c.sbm.execute(sbm_partnerEachPerformance);
};


//-------------------------------------------------------------------------
// 파트너별 Performance Detail List 미확정 조회
//-------------------------------------------------------------------------
scwin.f_RetrieveDetail = function (row) {
    ds_retrieveDetail.setJSON(ds_retrieve.getJSON());
    ds_retrieveDetail.set("pnCd", ds_partnerEachPerformance.getCellData(row, "pnCd"));         //파트너코드
    ds_retrieveDetail.set("pnNm", ds_partnerEachPerformance.getCellData(row, "pnNm"));         //파트너명

    $c.sbm.execute(sbm_partnerEachPerformanceDetail);
};



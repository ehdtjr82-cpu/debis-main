		<script lazy="false" type="text/javascript"><![CDATA[
//---------------------------------------------------------
// 전역변수
//---------------------------------------------------------   
scwin.onpageload = function () {
    const codeOptions = [
        { grpCd: "FM017", compID: "lc_payStsCd" }
    ];
    $c.data.setCommonCode(codeOptions, scwin.setInit);


};

//---------------------------------------------------------
// UDC
//---------------------------------------------------------    
scwin.onUdcCompleted = function () {
    today = WebSquare.date.getCurrentServerDate("yyyyMMdd");
    ed_dcsnStDt.setValue(today.substr(0, 6) + "01");
    ed_dcsnEndDt.setValue(today);

}
//---------------------------------------------------------
// 사용자 함수
//--------------------------------------------------------- 
scwin.setInit = function () {
    lc_payStsCd.addItem("", "전체", 0);
    lc_payStsCd.setSelectedIndex(0);
}
scwin.f_openPopUp = function (flag, cdVal, nmVal, check) {
    switch (flag) {
        case '1':
            udc_clntNo.setSelectId("retrieveClntList");
            udc_clntNo.cfCommonPopUp(scwin.udc_clntNo_callbackFunc, cdVal.getValue().trim(), nmVal.getValue(), check, null, null, null, null, null, null, null, null, null);
            break;

        case '2':
            udc_dept.setSelectId("retrieveAcctDeptCdInfo6");
            udc_dept.cfCommonPopUp(scwin.udc_dept_callbackFunc, cdVal.getValue().trim(), nmVal.getValue(), check, null, null, null, null, null, null, null, null, null);

            break;

        default:
            break;
    }

}
scwin.udc_clntNo_callbackFunc = function (rtnList) {
    scwin.f_resultPopEd(ed_clntNo, txt_clntNm, rtnList);
}

scwin.udc_dept_callbackFunc = function (rtnList) {
    scwin.f_resultPopEd(ed_reqAcctDeptCd, txt_reqAcctDeptNm, rtnList);
}

scwin.f_resultPopEd = function (strCd, strNm, rtnList) {

    if (rtnList != null) {
        if (rtnList[0] == "N/A") {
            return;
        }
        strCd.setValue(rtnList[0]);	// 코드
        strNm.setValue(rtnList[1]);	// 명
        strCd.setValue(rtnList[0]);  // 히든값
    } else {
        strCd.setValue("");
        strNm.setValue("");
        strCd.setValue("");
    }
}
scwin.f_checkPopEd = function (strCd, strNm, flag) {
    if (strCd.getValue() != "") scwin.f_openPopUp(flag, strCd, strNm, 'T');
    else strNm.setValue("");
}

//---------------------------------------------------------
// 컴포넌트 이벤트
//--------------------------------------------------------- 
scwin.btn_trigger1_onclick = function (e) {
    if (ed_dcsnStDt.getValue() == "" || ed_dcsnEndDt.getValue() == "") {
        $c.gus.cfAlertMsg("요청일자은(는) 필수 입력 항목입니다.");
        return;
    }

    //조회시작일자가 더 클경우 체크
    if (!$c.gus.cfIsAfterDate(ed_dcsnStDt.getValue(), ed_dcsnEndDt.getValue())) {
        $c.gus.cfAlertMsg(MSG_CM_ERR_039);
        return;
    }
    $c.sbm.execute(sbm_retrievePaymgnt);
};

scwin.btn_retrieve_onclick = function (e) {
    scwin.sort = "";
    scwin.sortColumnId = "";
    ds_paymgnt.clearSort();
    ds_condition.setEmptyValue();
    txt_clntNm.setValue("");
    txt_reqAcctDeptNm.setValue("");
    today = WebSquare.date.getCurrentServerDate("yyyyMMdd");
    ed_dcsnStDt.setValue(today.substr(0, 6) + "01");
    ed_dcsnEndDt.setValue(today);
};

scwin.sbm_retrievePaymgnt_submitdone = function (e) {
    if (ds_paymgnt.getTotalRow() == 0) {
        ed_totalRow.setValue("0");
        $c.win.alert("조회된 데이터가 없습니다");
    } else {
        ed_totalRow.setValue(ds_paymgnt.getTotalRow());

        ds_paymgnt.sort("payNo", 0);
        // scwin.applySuppressLikeGauce(ds_paymgnt, scwin.SUPPRESS_CONFIG_PAY, {
        //     preserveOriginal: true
        // });

    }
}

scwin.udc_clntNo_onblurCodeEvent = function (e) {
    scwin.f_checkPopEd(ed_clntNo, txt_clntNm, '1');
};

scwin.udc_clntNo_onclickEvent = function (e) {
    scwin.f_openPopUp('1', ed_clntNo, txt_clntNm, 'T');
};

scwin.udc_clntNo_onviewchangeNameEvent = function (info) {
    scwin.f_openPopUp('1', ed_clntNo, txt_clntNm, 'T');
};

scwin.udc_dept_onclickEvent = function (e) {
    scwin.f_openPopUp('2', ed_reqAcctDeptCd, txt_reqAcctDeptNm, 'T');
};

scwin.udc_dept_onviewchangeNameEvent = function (info) {
    scwin.f_openPopUp('2', ed_reqAcctDeptCd, txt_reqAcctDeptNm, 'T');
};

scwin.udc_dept_onblurCodeEvent = function (e) {
    scwin.f_checkPopEd(ed_reqAcctDeptCd, txt_reqAcctDeptNm, '2');
};

scwin.udc_dept_onblurCodeEvent = function (e) {
    scwin.f_checkPopEd(ed_reqAcctDeptCd, txt_reqAcctDeptNm, '2');
};
scwin.sort = "";
scwin.sortColumnId = "";

scwin.gr_paymgnt_onheaderclick = function (headerId) {
    var hId = headerId.replace("h_", "");
    var options = {};
    if (scwin.sortColumnId == hId) {
        scwin.sort = (scwin.sort == "1") ? "-1" : "1";
    } else {
        scwin.sort = "1";
    }
    scwin.sortColumnId = hId;
    options.sortIndex = hId + " payNo";
    options.sortOrder = scwin.sort + " 1";
    console.log("정렬컬럼:", options.sortIndex);
    console.log("정렬순서:", options.sortOrder);
    ds_paymgnt.multisort(options);
};
]]></script>

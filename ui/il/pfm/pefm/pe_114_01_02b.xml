        <script lazy="false" type="text/javascript"><![CDATA[scwin.strCurDate = WebSquare.date.getCurrentServerDate();  // 서버를 기준으로 현재 날짜 반환
scwin.strPreDate = $c.date.addMonth(scwin.strCurDate, -1); //한달전

scwin.memJson = $c.data.getMemInfo();
scwin.userId = scwin.memJson.userId;  //사용자

scwin.onpageload = function() {
	
    udc_fromToCalendar.setInitDate(scwin.strPreDate,scwin.strCurDate); //udc
};

//초기화
scwin.btn_fieldClear_onclick = function (e) {

    $c.gus.cfInitObjects(tb_searchCondition);
};

//조회
scwin.btn_retrieve_onclick = function (e) {

    if (ed_stDt.getValue() == "" || ed_endDt.getValue() == ""){
		$c.gus.cfAlertMsg("실적일자 is mandatory.");	
		ed_stDt.focus();
		return;  		
	} else { 
		
		//dataMap set
        dma_search.set("stDt",ed_stDt.getValue());
        dma_search.set("endDt",ed_endDt.getValue());

        $c.sbm.execute(sbm_retrieve);
	}
};

//조회 callback
scwin.sbm_retrieve_submitdone = function() {

    let nCnt = ds_master.getRowCount();

    if (nCnt == 0) {
		$c.gus.cfAlertMsg("결과값이 없습니다.");
		total.setValue(nCnt);
	} else {
        
        gr_master.setFocusedCell(0, 0);
        total.setValue(nCnt);
	}
};
]]></script>

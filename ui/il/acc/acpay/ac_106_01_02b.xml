    console.log("조회 클릭!!!");

    if(cnd_ed_dateFrom.getValue() == "" || cnd_ed_dateTo.getValue() == ""){
		$c.win.alert("ETD/ETA is mandatory.");
		cnd_ed_dateFrom.focus();
		return;
	}


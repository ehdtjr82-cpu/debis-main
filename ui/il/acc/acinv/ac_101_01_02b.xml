        //let strPath = "/il/acc/acinv/ac_101_01_01b.xml?seaair="+seaair+"&iogb="+iogb+"&mblno="+mblno+"&blno="+blno+"&mhno="+mhno+"&prtnGrpNo="+prtnGrpNo+"&bilgClntNo="+bilgClntNo;

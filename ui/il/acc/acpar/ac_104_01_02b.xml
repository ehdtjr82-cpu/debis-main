scwin.f_FieldClear = function () {
    $c.gus.cfInitObjects(tb_retrieve, null);
};

//-------------------------------------------------------------------------
//엑셀 다운로드
//-------------------------------------------------------------------------
scwin.f_downExcelSheet = async function () {
    let cntRow = ds_partnerInvoiceList.getRowCount();

    if (cntRow != 0) {
        let cfrm = await $c.win.confirm("EXCEL로 다운로드 받으시겠습니까?");

        if (cfrm) {
            let options = {
                fileName: "Partner Invoice List" + ".xlsx",
                sheetName: "Partner Invoice List"
            };

            $c.data.downloadGridViewExcel(gr_invoiceList, options);
        }
    } else {
        $c.gus.cfAlertMsg(MSG_CM_WRN_002);
    }
};

scwin.sbm_retrieve_submitdone = async function (e) {
    let rowCount = ds_partnerInvoiceList.getRowCount();

    if (rowCount == 0) {
        await $c.gus.cfAlertMsg(E_MSG_CM_WRN_002);
        return;
    } else {
        for (let i = 0; i < rowCount; i++) {
            let rowJson = ds_partnerInvoiceList.getRowJSON(i);

            ds_partnerInvoiceList.setCellData(i, "stdt2", rowJson.stdt);
            ds_partnerInvoiceList.setCellData(i, "prtnGrpNo2", rowJson.prtnGrpNo);
        }
    }

    totalRows.setValue(rowCount);
};


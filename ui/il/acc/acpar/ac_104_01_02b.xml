    scwin.f_MhnoLoading("H", cnd_ed_blno.getValue().trim());
};

scwin.cnd_ed_mblno_onblur = function (e) {
    scwin.f_MhnoLoading("M", cnd_ed_mblno.getValue().trim());
};

scwin.gr_invoiceList_oncelldblclick = function (rowIndex, columnIndex, columnId) {
    let rowJson = ds_partnerInvoiceList.getRowJSON(rowIndex);
    let seaair = rowJson.seaair;
    let iogb = rowJson.iogb;
    let mblno = rowJson.mblno;
    let mhno = rowJson.mhno;
    let blno = rowJson.blno;
    let prtnGrpNo = rowJson.prtnGrpNo;
    let bilgClntNo = rowJson.bilgClntNo;

    let paramData = {
        "seaair": seaair,
        "iogb": iogb,
        "mblno": mblno,
        "mhno": mhno,
        "blno": blno,
        "prtnGrpNo": prtnGrpNo,
        "bilgClntNo": bilgClntNo,
        "moveOpenMenu": "true"
    };

    let options = {
        "openAction": "exist"
    };

    $c.win.openMenu("Partner Invoice", "/ui/il/acc/acpar/ac_104_01_01b.xml", "ac_104_01_01b.xml", paramData, options);
};


};

scwin.cnd_ed_mblno_oneditkeyup = function (info, e) {
    let val = info.newValue;
    this.setValue(val.toUpperCase());
};

scwin.sbm_HouseLicenseInfo_submitdone = function (e) {
    totalTxt2.setValue(dlt_HouseLicenseInfo.getRowCount());
};]]></script>

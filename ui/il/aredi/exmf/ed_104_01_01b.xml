        , picNm.getValue() //pName
        , "T" //pWinCloseTF
        , ""//pDispCnt
        , "PIC"//pTitle
        , null//pWidth
        , null //pHidden
        , null //pWhere
        , null // pW
        , null //pH
        , null //pTop
        , null //pLeft
        , null //pExistTF
        , "F" //pAllSearchTF
        , null //pWtitleSearch
        , null //pNoDataCloseTF
        , null //tmpDataSet

    )
};

//담당자 코드 블러 이벤트 콜백
scwin.udc_ilcomCode_onblurCodeEvent_callBackFunc = function (data) {
    if (data[0] == "N/A") {
        picNm.setValue("");
        picCd.setValue("");
    } else {
        picCd.setValue(data[0]);
        picNm.setValue(data[1]);
    }
};

scwin.gr_AirCargoManifast_onviewchange = function (info) {
    const colId = gr_AirCargoManifast.getColumnID(info.colIndex);
    const rowIdx = info.rowIndex;
    const newValue = info.newValue;
    if (colId == "chk") {
        if (newValue == "T") {
            dlt_AirCargoManifast.setCellData(rowIdx, "chk", "T")
            dlt_AirCargoManifast.modifyRowStatus(rowIdx, "U");
        } else {
            dlt_AirCargoManifast.setCellData(rowIdx, "chk", "F")
            dlt_AirCargoManifast.undoRow(rowIdx);
        }
    }
};

//휴지통 온클릭 이벤트
scwin.btn_fieldClear_onclick = function (e) {
    $c.gus.cfInitObjects(tb_searchCondition);
};

scwin.cnd_ed_fltno_oneditkeyup = function (info, e) {

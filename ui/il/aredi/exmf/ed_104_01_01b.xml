		<script lazy="false" type="text/javascript"><![CDATA[
scwin.memJson = $c.data.getMemInfo();
scwin.userId = $c.data.getMemInfo("userId");
scwin.today = $c.date.getServerDateTime("yyyyMMdd");

scwin.onpageload = function () {
};

scwin.onUdcCompleted = function () {
    scwin.f_DefaultValue();
    scwin.f_Set("INIT");

    cnd_lc_send.focus();
};

scwin.f_DefaultValue = function () {
    let strPreDate = $c.date.addDate(scwin.today, -7);

    cnd_ed_ondtFrom.setValue(strPreDate);
    cnd_ed_ondtTo.setValue(scwin.today);
};

scwin.f_Set = function (gubun) {
    switch (gubun) {
        case "INIT":
            $c.gus.cfDisableBtnOnly([btn_save]);
            gr_HouseLicenseInfo.setGridReadOnly(true);
            break;
        case "RETRIEVE":
            $c.gus.cfEnableKeyData();
            $c.gus.cfEnableBtnOnly([btn_save]);
            break;
        case "CREATE":
            $c.gus.cfDisableKey();
            $c.gus.cfEnableBtnOnly([btn_save]);
            break;
        case "UPDATE":
            $c.gus.cfEnableBtnOnly([btn_save]);
            $c.gus.cfDisableKey();
            break;
        case "SAVE":
            $c.gus.cfDisableBtnOnly([btn_save]);
            break;
        case "DELETE":
            $c.gus.cfDisableBtnOnly(btn_save);
            break;
    }
};

scwin.btn_retrieve_onclick = async function (e) {
    if (!$c.gus.cfValidate(cnd_ed_ondtFrom.getValue(), cnd_ed_ondtTo.getValue())) {  //validExp 가 yes일때 check
        return false;
    }

    if (cnd_ed_ondtFrom.getValue().trim() == "") {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_002, ["OnBoard Date From"])
        cnd_ed_ondtFrom.focus();
        return false;
    }

    if (cnd_ed_ondtTo.getValue().trim() == "") {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_002, ["OnBoard Date To"])
        cnd_ed_ondtTo.focus();
        return false;
    }

    if (!$c.gus.cfIsAfterDate(cnd_ed_ondtFrom.getValue().trim(), cnd_ed_ondtTo.getValue().trim(), false)) {
        await $c.gus.cfAlertMsg(E_MSG_CM_ERR_039); // 시작일자를 종료일 이전으로 선택[입력]하여 주십시오.
        return;
    }

    dma_search.set("kcomcd", "DBEX");

    $c.sbm.execute(sbm_retrieve);
};

scwin.sbm_retrieve_submitdone = async function (e) {
    if (dlt_AirCargoManifast.getRowCount() == 0) {
        await $c.win.alert("Data not found.");
        return;
    } else {
        scwin.f_Set("RETRIEVE");

        for (let i = 0; i < dlt_AirCargoManifast.getRowCount(); i++) {
            dlt_AirCargoManifast.setCellData(i, "ediCd2", dlt_AirCargoManifast.getCellData(i, "ediCd"));
        }

        totalTxt.setValue(dlt_AirCargoManifast.getRowCount());
    }
};

scwin.gr_AirCargoManifast_oncellclick = function (rowIndex, columnIndex, columnId) {
    let rowJson = dlt_AirCargoManifast.getRowJSON(rowIndex);

    dma_search.set("kcomcd", rowJson.kcomcd);
    dma_search.set("blno", rowJson.blno);

    $c.sbm.execute(sbm_HouseLicenseInfo);
};

scwin.btn_edit_onclick = function (e) {
    $c.sbm.execute(sbm_SaveDetail);
};

scwin.sbm_SaveDetail_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Msg == "SUCC") {
        await $c.win.alert("성공적으로 저장하였습니다.");
        scwin.btn_retrieve_onclick();
    }
};

scwin.btn_save_onclick = async function (e) {
    let strValue = await scwin.f_ReqFieldChk();

    if (strValue) {
        let vChkCnt = 0;

        for (let i = 0; i < dlt_AirCargoManifast.getRowCount(); i++) {
            let rowJson = dlt_AirCargoManifast.getRowJSON(i);
            let vChkYn = rowJson.chk;
            let vMftpkg = rowJson.mftpkg;
            let vEdiwht = rowJson.ediwht;
            let vExnoCnt = rowJson.exnoCnt;

            dlt_AirCargoManifast.setCellData(i, "updid", scwin.userId);

            if (vChkYn == "T") {
                if (vMftpkg < 1) {
                    await $c.gus.cfAlertMsg(MSG_CM_ERR_013, ["항공수출 적하목록에 " + (i + 1) + "째 데이터에서 Package는  1"]);
                    return;
                }

                if (vEdiwht < 1) {
                    await $c.gus.cfAlertMsg(MSG_CM_ERR_013, ["항공수출 적하목록에 " + (i + 1) + "째 데이터에서EDI/Weight 1"]);
                    return;
                }

                if (vExnoCnt < 1) {
                    await $c.gus.cfAlertMsg(MSG_CM_ERR_013, ["항공수출 적하목록에 " + (i + 1) + "째 데이터에서License CNT 1"]);
                    return;
                }
            }

            if (vChkYn == "T") {
                vChkCnt++
                dlt_AirCargoManifast.modifyRowStatus(i, "C");
            }

            if (vChkYn == "T" && rowJson.sendDt != "") {
                vChkCnt++
                dlt_AirCargoManifast.modifyRowStatus(i, "C");
            }

            if (vChkYn == "F") {
                dlt_AirCargoManifast.modifyRowStatus(i, "R");
            }
        }

        if (vChkCnt < 1) {
            await $c.gus.cfAlertMsg("Nothing has been selected.");
            // $c.gus.f_cfAlertMsg(E_MSG_CM_ERR_056, ["Row"]) ; //선택된 @가 없습니다.
            return;
        }

        $c.sbm.execute(sbm_Save);
    }
};

scwin.sbm_Save_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Msg == "SUCC") {
        await $c.win.alert("성공적으로 저장하였습니다.");
        scwin.btn_retrieve_onclick();
    }
};

scwin.f_ReqFieldChk = async function () {
    let vaildArray = [
        { id: "ngnm1", name: "Goods", mandatory: true }
    ];

    let strValue = await $c.gus.cfValidateGrid(gr_AirCargoManifast, null, null, vaildArray, "항공수출 적하목록");

    return strValue;
};


        			<w2:key id="rcvDt" name="수신일시From" dataType="text"></w2:key>
        			<w2:key id="rcvDt2" name="수신일시To" dataType="text"></w2:key>
        			<w2:key id="admitYn" name="승인여부" dataType="text"></w2:key>

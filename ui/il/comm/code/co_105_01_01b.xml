    grp_2.setDisabled(true);
    grp_3.setDisabled(true);
    grp_4.setDisabled(true);
    grp_5.setDisabled(true);
    lc_seaExgbEx.setSelectedIndex(-1);
    lc_seaExgbIm.setSelectedIndex(-1);
    lc_airExgbEx.setSelectedIndex(-1);
    lc_airExgbIm.setSelectedIndex(-1);
    lc_mfcsVenSea.setSelectedIndex(-1);
    lc_mfcsVenAir.setSelectedIndex(-1);
    $c.gus.cfDisableBtn([btn_save]);
};

//---------------------------------------------------------
// UDC
//---------------------------------------------------------    
scwin.onUdcCompleted = function () {
    ed_code.setValue(scwin.acctDeptCd);
    txt_codeNm.setValue(scwin.acctDeptNm);
    ed_code.focus();
}

//---------------------------------------------------------
// 사용자 함수
//---------------------------------------------------------   
scwin.f_ReqFieldChk = async function () {
    // if (txt_mcode.getValue() == ""
    //     || txt_name1.getValue() == ""
    //     || txt_name1.getValue() == ""
    //     || txt_addr1.getValue() == ""
    //     || lc_seaExgbEx.getValue() == ""
    //     || lc_seaExgbIm.getValue() == ""
    //     || lc_airExgbEx.getValue() == ""
    //     || lc_airExgbIm.getValue() == "") {
    //     return false;
    // }
    ret = await $c.gus.cfValidate([grp_1, grp_2]);
    return ret;
}
scwin.f_ChkPopUp = function (inObj, pairObj, disGubun, isCode) {

    // 값이	입력이 안된	경우, 해당 Text	Box가 readonly 인 경우,	이전값과 동일한	경우 팝업을	실행하지 않음.
    if (!$c.gus.cfCanOpenPopup(inObj, pairObj))
        return;
    // 짝이	되는 오브젝트의	값 제거
    $c.gus.cfClearPairObj(pairObj);
    // 검색어 세팅
    var pVal = $c.gus.cfGetValue(inObj);
    // inObj가 코드	필드일 경우	팝업
    if (isCode == null || isCode == true) {
        scwin.f_DeptPopUp();
    }
    // inObj가 코드명 필드일 경우 팝업
    else {
        scwin.f_DeptPopUp();
    }
}

scwin.f_DeptPopUp = function () {
    udc_code.setSelectId("retrieveOpDeptCdInfo");
    udc_code.ilCommonPopUp(scwin.udc_code_callbackFunc
        , ed_code.getValue().trim()
        , txt_codeNm.getValue()
        , 'T'			// 결과가 1건 일때	원도우를	AutoClose 여부	(T:Close,F:Opened)
        , '2'					// 검색	결과	컬럼의 보여주는	개수 (SELECT절의 순서) MAX:10 -	default	(2)
        , "DEPT Code, DEPT Name,"			// Title순서
        , '130,300'              // 보여주는 각 컬럼들의 폭
        , "3,4,5,6,7,8,9,10"     // 컬럼중에서 숨기는	컬럼 지정
        , null                   // SQL절의 WHERE절에	원하는 조건을 선택함 MAX:8개까지 가능
        , '500'                  // POP-UP뛰을때 원도우의	사용자 정의	폭
        , '500'				// POP-UP뛰을때	우도우의	사용자 정의	높이
        , null				// 윈도우 위치 Y좌표
        , null				// 윈도우 위치 X좌표
        , null				// 중복체크여부	("F")
        , 'F'			// 전체검색허용여부	("F")
        , "DEPT Search,DEPT Code,DEPT Name"	// POP-UP Window Title 검색어1,2	 ("Win타이틀,첫번검색Nm,두번?검색Nm")
        , null		// Data	건수가 0 일때 Window를 뛰우지 않음 리턴	: "N/A"
    );
}

scwin.udc_code_callbackFunc = function (rtnList) {
    $c.gus.cfSetReturnValue(rtnList, ed_code, txt_codeNm);
}
//---------------------------------------------------------
// 컴포넌트 이벤트
//---------------------------------------------------------   

scwin.btn_retrieve_onclick = function (e) {
    if (ed_code.getValue().trim() == '') {
        $c.gus.cfAlertMsg(MSG_CM_ERR_002, Array("귀속부서코드"));
        ed_code.focus();
        return;
    }
    $c.sbm.execute(sbm_search)
};

scwin.btn_fieldClear_onclick = function (e) {
    ed_code.setValue("");
    txt_codeNm.setValue("");
    ed_code.focus();
};

scwin.btn_save_onclick = async function (e) {
    if (scwin.jsonString == JSON.stringify(ds_company.getJSON())) {
        $c.win.alert("There have been no changes for Basic Infomation.");
        // $c.gus.cfAlertMsg(MSG_CM_ERR_001, ["기본정보 관리"]);//"@은(는) 변경된 사항이 없습니다.";
        return;
    }


    if (ed_code.getValue() == '') {
        $c.gus.cfAlertMsg(MSG_CM_ERR_002, Array("귀속부서코드"));
        ed_code.focus();
        return;
    }

    if (await scwin.f_ReqFieldChk()) {
        if (await $c.win.confirm("Do you wish to save?")) {
            // ds_companyList.removeAll();
            debugger;
            if(ds_companyList.getTotalRow() == 0) ds_companyList.insertRow();
            ds_companyList.setRowJSON(0, ds_company.getJSON(), true);
            ds_companyList.setCellData(0, "code", ed_code.getValue());
            // ds_companyList.modifyRowStatus(0, "U");
            $c.sbm.execute(sbm_save);
        }
    }
};

scwin.sbm_search_submitdone = function (e) {
    ds_company.setEmptyValue();
    if (ds_companyList.getTotalRow() == 0) {
        $c.win.alert("Data not found.");
        return;
    }
    ds_company.setJSON(ds_companyList.getRowJSON(0));
    scwin.jsonString = JSON.stringify(ds_company.getJSON());
    grp_1.setDisabled(false);
    grp_2.setDisabled(false);
    grp_3.setDisabled(false);
    grp_4.setDisabled(false);
    grp_5.setDisabled(false);
    btn_save.setDisabled(false);
}

scwin.sbm_save_submitdone = async function (e) {
    if (e.responseJSON.resultDataSet[0].Code == -1) return;
    await $c.win.alert("Data was saved successfully.");
}

scwin.udc_code_onviewchangeCodeEvent = function (info) {
    var cdObjVal = ed_code.getValue().trim();
    if (cdObjVal == "") {
        txt_codeNm.setValue("");
    } else {
        txt_codeNm.setValue("");
        scwin.f_DeptPopUp();
    }
};

scwin.udc_code_onclickEvent = function (e) {
    scwin.f_DeptPopUp();
};

scwin.udc_code_onviewchangeNameEvent = function (info) {
    scwin.f_ChkPopUp(txt_codeNm, ed_code, 'DEPT', false);
};

]]></script>

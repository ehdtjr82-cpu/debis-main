		<script lazy="false" type="text/javascript"><![CDATA[/* 국제물류/Common/ */
//---------------------------------------------------------
// 전역변수
//---------------------------------------------------------   

scwin.acctDeptCd = $c.data.getMemInfo($p).lobranCd;
scwin.acctDeptNm = $c.data.getMemInfo($p).lobranNm;

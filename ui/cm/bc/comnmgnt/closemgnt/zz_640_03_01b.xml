" target='data:json,{"id":"ds_closeLog","key":"GAUCE"}' encoding="UTF-8"
    			instance="" replace="" errorHandler="" customHandler="" mode="asynchronous" processMsg="" ev:submit=""
    			ev:submitdone="scwin.sbm_closeLog_submitdone" ev:submiterror="" abortTrigger="">
    		</xf:submission>

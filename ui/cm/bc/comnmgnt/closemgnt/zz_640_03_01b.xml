    					<w2:column displayMode="label" id="wrkNm" inputType="text" style="" value="" width="100"></w2:column>
    					<w2:column displayMode="label" id="errNo" inputType="text" style="" value="" width="100"></w2:column>
    					<w2:column displayMode="label" id="wrkDesc" inputType="text" style="" value="" width="100" textAlign="left"></w2:column>
    				</w2:row>
    			</w2:gBody>
    		</w2:gridView>
    		<xf:group class="grid-bottom " id="" style="">

    					<w2:column displayMode="label" id="column36" inputType="text" style="" value="종료일시" width="100"></w2:column>
    					<w2:column displayMode="label" id="column34" inputType="text" style="" value="작업자ID" width="100"></w2:column>
    					<w2:column displayMode="label" id="column32" inputType="text" style="" value="작업자명" width="100"></w2:column>
    					<w2:column displayMode="label" id="column28" inputType="text" style="" value="오류번호" width="100"></w2:column>

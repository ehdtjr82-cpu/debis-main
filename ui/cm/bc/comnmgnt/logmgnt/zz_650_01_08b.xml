    	<script lazy="false" type="text/javascript"><![CDATA[
scwin.memJson = $c.data.getMemInfo();
scwin.currDateFrom = WebSquare.date.getFormattedDate (new Date(), "yyyyMM") + "01";
scwin.currDate = WebSquare.date.getFormattedDate (new Date(), "yyyyMMdd");

scwin.onpageload = function() {
    // setLogQueryConditionHeader(); 
	dma_search.set("modDateFrom", scwin.currDateFrom);
	dma_search.set("modDateTo", scwin.currDate);
    ed_qryCntn.focus();
};

// 조회
scwin.f_Retrieve = async function() {

    let ret = await $c.gus.cfValidate([ica_modDateFrom, ica_modDateTo]);
    if (!ret) {
        return false;
    }

    if (!$c.gus.cfIsAfterDate(ica_modDateFrom.getValue(), ica_modDateTo.getValue())) {
        await $c.gus.cfAlertMsg(MSG_CM_ERR_039); 
        ica_modDateFrom.focus();
        return ;
    }

    if ( "" == ed_qryCntn.getValue() ) {
        await $c.win.alert("검색조건은 필수 입력 항목입니다.");
        ed_qryCntn.focus();
        return;
    }

    $c.sbm.execute(sbm_retrievePgmLogPage);

};

scwin.f_downExcelSheet = function() {
    let sheetTitle = "사용자별권한 이력 목록";
    const options = {
        fileName: sheetTitle + ".xlsx",
        sheetName: sheetTitle
    };
    $c.data.downloadGridViewExcel(gr_pgmLog, options);
};

scwin.sbm_retrievePgmLogPage_submitdone = function (e) {
    var rowCnt = ds_pgmLog.getRowCount();
    gr_pgmLog_spanTotal.setLabel(rowCnt);
    if (rowCnt == 0) {
        $c.win.alert(MSG_CM_WRN_002); // 조회결과가 존재하지 않습니다
    }
    gr_pgmLog.setFocusedCell(0, 0);
};

scwin.sbm_retrievePgmLogPage_submiterror = function (e) {

};
]]></script>

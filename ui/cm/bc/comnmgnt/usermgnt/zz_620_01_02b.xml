scwin.memJson = $c.data.getMemInfo();
scwin.userId = scwin.memJson.userId;
scwin.userNm = scwin.memJson.userNm;
console.log("##### userId : " + scwin.userId);
console.log("##### userNm : " + scwin.userNm);

scwin.MSG_LO_ERR_001 = "E-Mail를 입력하세요.";
scwin.MSG_LO_ERR_002 = "휴대전화번호를 입력하세요.";
scwin.MSG_LO_ERR_003 = "우편번호를 선택하세요.";
scwin.MSG_LO_ERR_004 = "상세주소를 입력하세요.";

scwin.onpageload = function() {
	// $c.gus.cfDisableKeyData();
	// scwin.f_Retrieve();
};

// 공통코드가 셋팅이 되고 scwin.ondataload 이벤트가 호출
scwin.ondataload = function() { 
    console.log("===========scwin.ondataload==========");
    // $c.gus.cfDisableKeyData();
};

// UDC 셋팅이 이후..
scwin.onUdcCompleted = function() {
    console.log("===========scwin.onUdcCompleted==========");
	$c.gus.cfDisableKeyData();
	scwin.f_Retrieve();
};


//-------------------------------------------------------------------------
// 조회 : 데이터를 조회한다.
//-------------------------------------------------------------------------
scwin.f_Retrieve = function() {
	dma_search.set("userId", scwin.userId);
    $c.sbm.execute(sbm_search);
};

//-------------------------------------------------------------------------
// 저장 : 
//-------------------------------------------------------------------------
scwin.f_Update = async function() {
    console.log("===========scwin.f_Update==========");
	if (await scwin.f_ReqFieldChk()) {
		let ret = await $c.win.confirm(MSG_CM_CRM_001);
		if (ret) {
			$c.sbm.execute(sbm_save);
		}
	}
};

scwin.f_ReqFieldChk = function (e) {
    console.log("===========scwin.f_ReqFieldChk==========");
    //필수입력항목 체크
    var eMail    = ed_email.getValue();
    var userMpNo = ed_userMpNo.getValue();
    var addr1 = ed_addr1.getValue();
    var addr2 = ed_addr2.getValue();
    if (eMail.trim() == "" ) {
        $c.win.alert(scwin.MSG_LO_ERR_001);
        return false;
    }

    if (userMpNo.trim() == "" ) {
        $c.win.alert(scwin.MSG_LO_ERR_002);
        return false;
    }
    
    if (addr1.trim() == "" ) {
        $c.win.alert(scwin.MSG_LO_ERR_003);
        return false;
    }
    
    if (addr2.trim() == "" ) {
        $c.win.alert(scwin.MSG_LO_ERR_004);
        return false;
    }
    
    return true;
};
  
scwin.f_zipcodePopup = function (e) {
	// var popupResult = window.showModalDialog("/cm/zz/newzipcodePopup.jsp", "", 
	// 	"dialogHeight:400px;dialogWidth:530px;center:yes;scroll:no;status:no;help:no");
	
	// // Modal Dialog를 리턴값 없이 닫을 경우에 대비해
	// if (popupResult != null) {
	// 	ed_zip.Text = popupResult.zip;
	// 	txt_addr1.value = popupResult.addr1;
	// }

    var data = {
        callbackFn : scwin.newZip_callBackFunc
    };
    var opts = {
        id : "smpPop",	
        popupName : "우편번호 검색",
        modal : true,
        type : "browserPopup",
        title : "우편번호 검색"
    }
    $c.win.openPopup("/ui/cm/zz/newzipcodePopup.xml", opts, data);
};

scwin.newZip_callBackFunc = function(ret) {
    ed_zip.setValue(ret.zip);
    ed_addr1.setValue(ret.addr1);
};

scwin.sbm_search_submitdone = function (e) {
    var json = e.responseJSON;
    dma_result.setJSON(json["GAUCE"][0]);
};

scwin.sbm_save_submitdone = function (e) {
	$c.win.alert(MSG_CM_INF_001);
};

scwin.sbm_save_submiterror = function (e) {
	//cfShowError(tr_saveEmp);
};

]]></script>

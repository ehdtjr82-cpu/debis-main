scwin.onpageload = function() {
    let params = $p.getParameter("paramData");

    // 메인화면에서 호출시 초기화면설정 노출
    try {
        if(params.init == "Y") {
            scwin.tabCange(3);
        }
    } catch(e) {
        console.log(e);
    }
};

/**
 * @method
 * @name tabCange
 * @description 탭 변경
 * @param {number} idx tab index
 * @returns
 * @hidden N
 * @exception
 * @example
 */
scwin.tabCange = function (idx) {
	tac_main.setSelectedTabIndex(idx);
};

]]></script>

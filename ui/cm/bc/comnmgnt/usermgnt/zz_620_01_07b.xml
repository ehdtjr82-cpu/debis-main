<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map">
    			<w2:dataMap baseNode="map" id="dma_condition">
    				<w2:keyInfo>
    					<w2:key id="userId" name="name1" dataType="text"></w2:key>
    					<w2:key id="crn" name="name2" dataType="text"></w2:key>
    				</w2:keyInfo>
    			</w2:dataMap>
    			<w2:dataList baseNode="list" repeatNode="map" id="ds_results" saveRemovedData="true">
    				<w2:columnInfo>
    					<w2:column id="userId" name="userId" dataType="text"></w2:column>
    					<w2:column id="passwd" name="passwd" dataType="text"></w2:column>
    					<w2:column id="clntNo" name="clntNo" dataType="text"></w2:column>
    					<w2:column id="clntNm" name="clntNm" dataType="text"></w2:column>
    					<w2:column id="crn" name="crn" dataType="text"></w2:column>
    				</w2:columnInfo>
    			</w2:dataList>
    		</w2:dataCollection>
    		<w2:workflowCollection />
    		<xf:submission id="sbm_retrieve" action="/cm.bc.comnmgnt.usermgnt.cmd.RetrieveUserPasswordCMD.do" method="post" mediatype="application/json"
    			ref='data:json,[{"id":"dma_condition","key":"IN_DS1"},{"id":"ds_results","key":"OUT_DS1"}]'
    			target='data:json,{"id":"ds_results","key":"OUT_DS1"}' encoding="UTF-8" instance="" replace="" errorHandler="" customHandler=""
    			mode="asynchronous" processMsg="" ev:submit="" ev:submitdone="scwin.sbm_retrieve_submitdone"
    			ev:submiterror="" abortTrigger="">
    		</xf:submission>
    	</xf:model>
    	<w2:layoutInfo />
    	<w2:publicInfo method="" />
    	<script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function() {
	$c.gus.cfDisableKeyData();
};

  //-------------------------------------------------------------------------
  // 조회 : 데이터를 조회한다.
  //-------------------------------------------------------------------------
  
scwin.f_Retrieve = async function() {
    if(ed_id.getValue() == "" || ed_crn.getValue() == ""){
        await $c.win.alert("ID와 사업자번호를 입력해 주세요");
        return ;
    }

    $c.sbm.execute(sbm_retrieve);
}  

//-------------------------------------------------------------------------
// 조회 : 데이터를 조회한다.
//-------------------------------------------------------------------------

scwin.f_Trash = function() {
    // txt_id.value = "";
    // txt_crn.value = "";
};

scwin.btn_search1_init_onclick = function (e) {
    $c.gus.cfInitObjects(table1);
};

scwin.sbm_retrieve_submitdone = function (e) {
    var rowCnt = ds_results.getRowCount();
    spanTotal.setLabel(rowCnt);
    if (rowCnt > 0) {
        gr_emp.setFocusedCell(0, 0);
    } else {
        $c.win.alert(MSG_CM_WRN_002); // 조회결과가 존재하지 않습니다
    }
};
]]></script>
    	<w2:require as="udc_schInput" type="page" variableClone="true" src="/cm/udc/schInput.xml"></w2:require>
    	<w2:require as="udc_topGrdBtn" type="page" variableClone="true" src="/cm/udc/topGrdBtn.xml"></w2:require>
    	<w2:require as="udc_fromToYearMon" type="page" variableClone="true" src="/cm/udc/fromToYearMon.xml"></w2:require>
    	<w2:require as="udc_fromToCalendarTime" type="page" variableClone="true" src="/cm/udc/fromToCalendarTime.xml"></w2:require>
    	<w2:require as="udc_comCode" type="page" variableClone="true" src="/cm/udc/comCode.xml"></w2:require>
    	<w2:require as="udc_fromToCalendar" type="page" variableClone="true" src="/cm/udc/fromToCalendar.xml"></w2:require>
    	<w2:require as="udc_fromToYear" type="page" variableClone="true" src="/cm/udc/fromToYear.xml"></w2:require>
    </head>
    <body ev:onpageload="scwin.onpageload">
    	<xf:group class="sub_contents" id="" style="">
    		<w2:wframe id="" src="/cm/xml/contentHeader.xml" style=""></w2:wframe>
    		<xf:group class="shbox" id="" style="">
    			<xf:group class="shbox-inner" id="" style="">
    				<xf:group class="w2tb " id="table1" style="" tagname="table">
    					<w2:attributes>
    						<w2:summary></w2:summary>
    					</w2:attributes>
    					<xf:group tagname="colgroup">
    						<xf:group style="width:70px;" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    						<xf:group style="width:105px;" tagname="col"></xf:group>
    						<xf:group style="" tagname="col"></xf:group>
    					</xf:group>
    					<xf:group class="" id="" style="" tagname="tr">
    						<xf:group class="w2tb_th " style="" tagname="th">
    							<w2:textbox class="" id="" label="아이디" style=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" style="" tagname="td">
    							<xf:input class="" id="ed_id" style="width: 150px;" ref="data:dma_condition.userId" maxlength="20"></xf:input>
    						</xf:group>
    						<xf:group class="w2tb_th" style="" tagname="th">
    							<w2:textbox class="" id="" label="사업자번호" style=""></w2:textbox>
    						</xf:group>
    						<xf:group class="w2tb_td" id="" style="" tagname="td">
    							<xf:input class="" id="ed_crn" style="width: 150px;" ref="data:dma_condition.crn" maxlength="20"></xf:input>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    			<xf:group class="btn-shbox" id="" style="">
    				<xf:trigger class="btn ico refresh" id="btn_search1_init" style="" type="button" ev:onclick="scwin.btn_search1_init_onclick">
    					<xf:label><![CDATA[새로고침]]></xf:label>
    				</xf:trigger>
    				<xf:trigger class="btn sch" disabled="" escape="false" id="btn_Retrieve" style="" type="button" ev:onclick="scwin.f_Retrieve">
    					<xf:label><![CDATA[조회]]></xf:label>
    				</xf:trigger>
    			</xf:group>
    		</xf:group>
    		<xf:group class="round-box" id="" style="">
    			<xf:group adaptiveThreshold="" class="gvwbox" id="grp_group1" style="">
    				<w2:gridView autoFit="allColumn" checkReadOnlyOnPasteEnable="" class="wq_gvw" dataList="data:ds_results" focusMode="row"
    					id="" scrollByColumn="false" scrollByColumnAdaptive="false" style="" visibleRowNum="5" visibleRowNumFix="true" readOnly="true">
    					<w2:caption id="caption1" style="" value="this is a grid caption."></w2:caption>
    					<w2:header id="header2" style="">
    						<w2:row id="row3" style="">
    							<w2:column displayMode="label" id="column30" inputType="text" style="" value="ID" width="70"></w2:column>
    							<w2:column displayMode="label" id="column38" inputType="text" style="" value="PASSWORD" width="120"></w2:column>
    							<w2:column displayMode="label" id="column36" inputType="text" style="" value="거래처번호" width="120"></w2:column>
    							<w2:column displayMode="label" id="column34" inputType="text" style="" value="거래처명" width="100"></w2:column>
    							<w2:column displayMode="label" id="column32" inputType="text" style="" value="사업자번호" width="120"></w2:column>
    						</w2:row>
    					</w2:header>
    					<w2:gBody id="gBody2" style="">
    						<w2:row id="row4" style="">
    							<w2:column displayMode="label" id="userId" inputType="text" style="" value="" width="70"></w2:column>
    							<w2:column displayMode="label" id="passwd" inputType="text" style="" value="" width="120"></w2:column>
    							<w2:column displayMode="label" id="clntNo" inputType="text" style="" value="" width="120"></w2:column>
    							<w2:column displayMode="label" id="clntNm" inputType="text" style="" value="" width="100"></w2:column>
    							<w2:column displayMode="label" id="crn" inputType="text" style="" value="" width="120"></w2:column>
    						</w2:row>
    					</w2:gBody>
    				</w2:gridView>
    				<xf:group class="grid-bottom " id="" style="">
    					<xf:group class="left" id="" style="">
    						<xf:group class="grid-total" id="">
    							<w2:textbox class="" id="" label="총" style="" tagname="span"></w2:textbox>
    							<w2:textbox class="num" dataType="number" displayFormat="#,##0" id="spanTotal" label="0" style="" tagname="span">
    							</w2:textbox>
    							<w2:textbox class="" id="" label="건" style="" tagname="span"></w2:textbox>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    		</xf:group>
    	</xf:group>
    </body>
</html>

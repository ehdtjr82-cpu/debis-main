    	<w2:layoutInfo />
    	<w2:publicInfo method="" />
    	<script lazy="false" type="text/javascript"><![CDATA[

scwin.onpageload = function() {
    const codeOptions = [
        { grpCd : "ZZ784", compID : "lc_logisticCenter, gr_master:logisticCenter"  },
    ];
    $c.data.setCommonCode(codeOptions);
};

scwin.ondataload = function(e) {
    lc_useYn.setValue("1");
};

// 조회
scwin.f_Retrieve = function() {
    $c.sbm.execute(sbm_retrieve);
};

//행추가
scwin.f_AddRow = function() {
    var rowIndex = ds_master.getTotalRow();
    ds_master.insertRow(rowIndex);
    ds_master.setCellData(rowIndex, "useYn", "1");
    ds_master.setCellData(rowIndex, "logisticCenter", lc_logisticCenter.getValue());
    gr_master.setFocusedCell(rowIndex, 0);
};

//  행삭제
scwin.f_DeleteRow = function() {
    $c.data.deleteRow(ds_master);
    gr_master.setFocusedCell(ds_master.getRowPosition(), 0);
};

// 취소
scwin.f_UndoRow = function() {
    // ds_master.Undo(ds_master.RowPosition);
    $c.data.undoRow(ds_master, "Y");
};

//저장
scwin.f_Save = async function() {
    // 필수입력사항 확인
    // let ret = await $c.gus.cfValidate([gr_master])
    // if (!ret) {
    //     return;
    // }

    // 변경된 사항이 있는지 확인.
    if (ds_master.getModifiedIndex().length == 0) {
        await $c.win.alert("변경된 사항이 없습니다.");
        return;
    }

    let validArry = [
         {id:"logisticCenter", name: "물류센터", mandatory:true}
        ,{id:"userNm", name: "담당자", mandatory:true}
        ,{id:"userMpNo", name: "연락처", mandatory:true}
        ,{id:"email", name: "메일주소", mandatory:true}
    ];
    let gridName = "경조용품 물류센터 담당자";
    if(!await $c.gus.cfValidateGrid(gr_master, null, null, validArry, gridName)){
        return false;
    }    

    let confirmResult = await $c.win.confirm(MSG_CM_CRM_001);
    if (confirmResult) {
        $c.sbm.execute(sbm_save);
    }    
};

// 그리드 데이터 엑셀로 다운
scwin.f_runExcel = function() {
    let sheetTitle = "경조용품 물류센터 담당자";
    const options = {
        fileName: sheetTitle + ".xlsx",
        sheetName: sheetTitle
    };
    $c.data.downloadGridViewExcel(gr_master, options);
};

scwin.sbm_save_submitdone = function (e) {
    scwin.f_Retrieve();
    $c.win.alert(MSG_CM_INF_001);	// 성공적으로 저장하였습니다
};

scwin.sbm_retrieve_submitdone = function (e) {
    var rowCnt = ds_master.getRowCount();
    spanTotal.setLabel(rowCnt);
    gr_master.setFocusedCell(0, 0);
    if (rowCnt == 0) {
        $c.win.alert(MSG_CM_ERR_003);
    }
};
]]></script>

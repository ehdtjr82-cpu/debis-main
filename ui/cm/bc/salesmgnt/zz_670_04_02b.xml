//-------------------------------------------------------------------------
// function name : f_Save
// function desc : 저장
//-------------------------------------------------------------------------
scwin.f_Save = async function() {     

	//변경한 데이터가 있는지 체크한다. 
    if(ds_tplPrivilege.getModifiedIndex().length == 0 && ds_mResultList.getModifiedIndex().length == 0){
        //$c.gus.cfAlertMsg(MSG_CM_ERR_002);    // 필수값 메세지
        $c.win.alert("변경된 사항이 없습니다.");
        return;
    } 
    
    let ret;
    ret = await $c.win.confirm(MSG_CM_CRM_001);
    if ( ret ) {
        //tr_save.Post();
        $c.sbm.execute(sbm_save);
    }
	
}


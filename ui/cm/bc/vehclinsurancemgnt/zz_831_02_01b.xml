    rd_chkNewDataYn.setSelectedIndex(0);
};

//-------------------------------------------------------------------------
// 엑셀저장
//-------------------------------------------------------------------------
scwin.f_downExcelSheet = async function () {	    
    let cntRow = ds_CarInsuranceInfoList.getRowCount();
    if(cntRow == 0)
        return;

    let fileName = "자동차보험내역";
    let sheetTitle = "자동차보험내역";
    await $c.data.downloadGridViewExcel(gr_CarInsuranceInfoList, { fileName: fileName + ".xlsx", sheetName: sheetTitle });
};

scwin.sbm_search_submitdone = async function (e) {
    let rowCnt = ds_CarInsuranceInfoList.getRowCount();
    spanTotal.setValue(rowCnt);
    if (rowCnt == 0) {
        await $c.win.alert(MSG_CM_WRN_002);
        return;
    }
};


scwin.gr_CarInsuranceInfoList_onheaderclick = async function (headerId) {
    var allCheck = false;
    var vapprvStsCd;
    if ( "hchkBox" == headerId ) {
        if(gr_CarInsuranceInfoList.getHeaderValue(headerId)) {
            for(var i=0; i<ds_CarInsuranceInfoList.getTotalRow(); i++) {
                vapprvStsCd = ds_CarInsuranceInfoList.getCellData(i, "apprvStsCd");
                if(vapprvStsCd != '' && vapprvStsCd != '01' && vapprvStsCd != '03') {
                    allCheck = true;
                }
            }
        }
    }

    if(allCheck) {
        await $c.win.alert('전자결재 상태가 미상신, 대기, 반려인 경우에만 삭제가 가능합니다.');
        ds_CarInsuranceInfoList.undoAll();
    }
};

scwin.gr_CarInsuranceInfoList_oncellclick = async function (rowIndex, columnIndex, columnId) {
    if("chkBox" == columnId) {
        var vchkBox = ds_CarInsuranceInfoList.getCellData( rowIndex, "chkBox" );
        var vapprvStsCd = ds_CarInsuranceInfoList.getCellData( rowIndex, "apprvStsCd" );
		if(vchkBox == "T"){
			if(vapprvStsCd != '' && vapprvStsCd != '01' && vapprvStsCd != '03')
			{ // 전자결재 상태가 미상신, 대기, 반려 인 경우만 삭제 가능
				await $c.win.alert('전자결재 상태가 미상신, 대기, 반려인 경우에만 삭제가 가능합니다.')
				ds_CarInsuranceInfoList.setCellData(rowIndex, "chkBox", "F");
				return;
			}
		}
    }
};


scwin.f_Delete = function() {
    var userJson = gr_CarInsuranceInfoList.getCheckedJSON("chkBox");
    var count = userJson.length;
    if (count > 0) {
        $c.sbm.execute(sbm_delete);
    }
};

scwin.sbm_delete_submitdone = async function (e) {
    await $c.win.alert( "삭제가 완료 되었습니다.");
    ds_CarInsuranceInfoList.removeAll();
    scwin.f_Retrieve();  
};

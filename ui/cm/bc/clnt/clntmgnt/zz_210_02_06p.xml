scwin.onpageload = function() {
    scwin.params = $c.data.getParameter();
    if ( scwin.params != "" && scwin.params != undefined ) { 
        scwin.clntNo = scwin.params["clntNo"] == null ? "" : scwin.params["clntNo"];
    }
    scwin.f_Retrieve();
};

//-------------------------------------------------------------------------
// 거래처 조회
//-------------------------------------------------------------------------
scwin.f_Retrieve = function() {
    // scwin.clntNo = "112905";
    dma_search.set("clntNo", scwin.clntNo);
    $c.sbm.execute(sbm_customer);
}

scwin.sbm_customer_submitdone = function (e) {
    var json = e.responseJSON;
    dma_customer.setJSON(json["GAUCE"][0]);
};

scwin.btn_Close_onclick = function (e) {
    $c.win.closePopup();
};
]]></script>

<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Debis Main Application</display-name>
    <distributable/>

    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>org.apache.catalina.filters.CorsFilter</filter-class>
        <init-param>
            <param-name>cors.allowed.origins</param-name>
            <param-value>http://localhost:8080</param-value>
        </init-param>
        <init-param>
            <param-name>cors.allowed.methods</param-name>
            <param-value>GET,POST,HEAD,OPTIONS</param-value>
        </init-param>
        <init-param>
		    <param-name>cors.allowed.headers</param-name>
		    <param-value>Content-Type,X-Requested-With,accept,Origin,Access-Control-Request-Method,Access-Control-Request-Headers,submissionid,x-file-name,postMsg</param-value>
		</init-param>
        <init-param>
            <param-name>cors.exposed.headers</param-name>
            <param-value>Access-Control-Allow-Origin,Access-Control-Allow-Methods</param-value>
        </init-param>
        <init-param>
            <param-name>cors.support.credentials</param-name>
            <param-value>true</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    
    <servlet>
        <servlet-name>websquareDispatcher</servlet-name>
        <servlet-class>websquare.http.DefaultRequestDispatcher</servlet-class>
        <load-on-startup>1</load-on-startup> </servlet>
    <servlet-mapping>
        <servlet-name>websquareDispatcher</servlet-name>
        <url-pattern>*.wq</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>Check Auth Filter</filter-name>
        <filter-class>dbl.cm.fw.servlet.DCheckAuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>Check Auth Filter</filter-name>
        <url-pattern>*.jsp</url-pattern>
    </filter-mapping>
    
    <servlet>
        <servlet-name>action</servlet-name>
        <servlet-class>dbl.cm.fw.servlet.DActionServlet</servlet-class>
        <init-param>
            <param-name>configFile</param-name>
            <param-value>appconfig</param-value>
        </init-param>
        <init-param>
            <param-name>debug</param-name>
            <param-value>3</param-value>
        </init-param>
        <init-param>
            <param-name>detail</param-name>
            <param-value>3</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>action</servlet-name>
        <url-pattern>*.do</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MemberControl</servlet-name>
        <servlet-class>dbl.ncall.cm.bc.comnmgnt.usermgnt.util.member.n4th.dongwon.member.servlet.MemberControl</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MemberControl</servlet-name>
        <url-pattern>/MemberControl</url-pattern>
    </servlet-mapping>

    <!-- AS-IS 에서쓰던설정, TO-BE 화면에서는 이 주소를 호출안함
    <servlet>
        <servlet-name>DFileUploadServlet</servlet-name>
        <servlet-class>dbl.cm.fw.servlet.DFileUploadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DFileUploadServlet</servlet-name>
        <url-pattern>/DFileUpload</url-pattern>
    </servlet-mapping>
    -->
	<servlet>
	    <servlet-name>S3UploadServlet</servlet-name>
	    <servlet-class>com.dongwon.debis.sample.S3UploadServlet</servlet-class>
	</servlet>
	<servlet-mapping>
	    <servlet-name>S3UploadServlet</servlet-name>
	    <url-pattern>/s3upload.do</url-pattern>
	</servlet-mapping>

    <servlet>
        <servlet-name>DFileDownloadServlet</servlet-name>
        <servlet-class>dbl.cm.fw.servlet.DFileDownloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DFileDownloadServlet</servlet-name>
        <url-pattern>/DFileDownload</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DFileDrmUploadServlet</servlet-name>
        <servlet-class>dbl.cm.fw.util.drm.DFileDrmUploadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DFileDrmUploadServlet</servlet-name>
        <url-pattern>/DFileDrmUpload</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>default</servlet-name>
        <servlet-class>org.apache.catalina.servlets.DefaultServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.html</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>60</session-timeout>
    </session-config>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>

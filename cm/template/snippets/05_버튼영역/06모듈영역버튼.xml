<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
        <w2:type>COMPONENT</w2:type>
        <w2:buildDate/>
        <w2:MSA/>
        <xf:model>
            <w2:dataCollection baseNode="map"/>
            <w2:workflowCollection/>
        </xf:model>
        <w2:layoutInfo/>
        <w2:publicInfo method=""/>
        <script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function() {
	
};
]]></script>
    </head>
    <body ev:onpageload="scwin.onpageload">
    	<xf:group class="form-group" id="" style="">
    		<xf:trigger class="btn map" id="" style="" title="지도보기" type="button">
    			<xf:label><![CDATA[지도보기(물량)]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn align" id="" style="" title="정렬" type="button">
    			<xf:label><![CDATA[정렬]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn file-up" id="" style="" title="파일업로드" type="button">
    			<xf:label><![CDATA[파일 업로드]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn file-del" id="" style="" title="파일삭제" type="button">
    			<xf:label><![CDATA[파일 삭제]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn file-down" id="" style="" title="파일 다운로드" type="button">
    			<xf:label><![CDATA[파일 다운로드]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn excel-up" id="" style="" title="엑셀 업로드" type="button">
    			<xf:label><![CDATA[엑셀 업로드]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn excel-down" id="" style="" title="엑셀 다운로드" type="button">
    			<xf:label><![CDATA[엑셀 다운로드]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn form" id="" style="" title="양식 다운로드" type="button">
    			<xf:label><![CDATA[양식 다운로드]]></xf:label>
    		</xf:trigger>
    		<xf:trigger class="btn template" id="" style="" title="템플릿 다운로드" type="button">
    			<xf:label><![CDATA[템플릿 다운로드]]></xf:label>
    		</xf:trigger>
    	</xf:group>
    </body>
</html>

<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head meta_screenId="index" meta_screenName="퍼블가이드" meta_desc=" ">
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map">
    			<w2:dataMap baseNode="map" id="dma_dataMap1">
    				<w2:keyInfo>
    					<w2:key id="grpCode" name="name1" dataType="text"></w2:key>
    					<w2:key id="key2" name="name2" dataType="text"></w2:key>
    					<w2:key id="key3" name="name3" dataType="text"></w2:key>
    				</w2:keyInfo>
    			</w2:dataMap>
    			<w2:dataList baseNode="list" repeatNode="map" id="dlt_dataList1" saveRemovedData="true">
    				<w2:columnInfo>
    					<w2:column id="col1" name="" dataType="text"></w2:column>
    					<w2:column id="col2" name="name2" dataType="text"></w2:column>
    					<w2:column id="col3" name="name3" dataType="text"></w2:column>
    				</w2:columnInfo>
    				<w2:data use="true">
    					<w2:row>
    						<col1><![CDATA[HX]]></col1>
    					</w2:row>
    					<w2:row>
    						<col1><![CDATA[HY]]></col1>
    						<col3><![CDATA[]]></col3>
    					</w2:row>
    					<w2:row></w2:row>
    				</w2:data>
    			</w2:dataList>
    		</w2:dataCollection>
    		<w2:workflowCollection />
    		<xf:submission id="sbm_test" action="/cmn/selectGrpCdList.do" method="get" mediatype="application/json" ref=""
    			target='data:json,{"id":"dlt_dataList1","key":"response"}' encoding="UTF-8" instance="" replace="" errorHandler="" customHandler=""
    			mode="asynchronous" processMsg="" ev:submit="" ev:submitdone="scwin.sbm_submission1_submitdone" ev:submiterror="" abortTrigger="">
    		</xf:submission>

    	</xf:model>
    	<w2:layoutInfo />
    	<w2:publicInfo method="" /> 
    	<script lazy="false" type="text/javascript"><![CDATA[ 
            scwin.btn_fmsite_onclick = function (e) {
                $(".fs-sub").toggleClass("sub-show")
            };
            ]]></script>
    	<w2:require as="udc_topGrdBtn" type="page" variableClone="true" src="/cm/udc/topGrdBtn.xml"></w2:require>
    	<w2:require as="udc_comCode" type="page" variableClone="true" src="/cm/udc/comCode.xml"></w2:require>
    </head>
    <body ev:onpageload="scwin.onpageload" class="ebiz-login">
    	<xf:group style="" id="" class="login-wrap">
    		<xf:group style="" id="" tagname="header">
    			<xf:group id="" style="" tagname="h1"></xf:group>
    		</xf:group>
    		<xf:group id="" style="" class="login-cont">
    			<xf:group id="" style="" class="left">
    				<w2:textbox id="" label="LOEX&lt;br/&gt;CONNECTS&lt;br/&gt;THE WORLD" style="" escape="false" class="copy" ref="">
    				</w2:textbox>
    				<xf:group id="" style="" class="link-box">
    					<w2:anchor outerDiv="false" id="" style="" escape="false" class="link01 active">
    						<xf:label><![CDATA[본선 스케줄<br/>조회]]></xf:label>
    					</w2:anchor>
    					<w2:anchor escape="false" id="" outerDiv="false" style="" class="link02">
    						<xf:label><![CDATA[COPINO<br/>송신확인]]></xf:label>
    					</w2:anchor>
    					<w2:anchor escape="false" id="" outerDiv="false" style="" class="link03">
    						<xf:label><![CDATA[컨테이너<br/>화물조회]]></xf:label>
    					</w2:anchor>
    					<w2:anchor escape="false" id="" outerDiv="false" style="" class="link04">
    						<xf:label><![CDATA[Booking<br/>/BL 추적]]></xf:label>
    					</w2:anchor>
    					<w2:anchor escape="false" id="" outerDiv="false" style="" class="link05">
    						<xf:label><![CDATA[수입화물<br/>비용확인]]></xf:label>
    					</w2:anchor>
    				</xf:group>
    			</xf:group>
    			<xf:group id="" style="" class="right">
    				<xf:group id="" style="" class="login-box">
    					<w2:textbox id="" label=" 로그인 &lt;span&gt;LOGIN&lt;/span&gt;" style="" escape="false" class="login-title"></w2:textbox>
    					<xf:input id="" style="" placeholder="아이디를 입력해주세요."></xf:input>
    					<xf:group id="" class="input_pw">                             				
    						<w2:searchbox style="" id="" placeholder="비밀번호를 입력해주세요." type="password"></w2:searchbox>
                             <!-- 비밀번호 보기 class="btn-eye"  / 감추기 class="btn-eye-close" -->  		
                            <xf:trigger type="button" id="" style="display: none;" class="btn-eye"><xf:label></xf:label></xf:trigger>
    					</xf:group>
    					<xf:select appearance="full" class="" cols="1" id="" ref="" renderType="checkboxgroup" rows="" selectedindex="0"
    						style="">
    						<xf:choices>
    							<xf:item>
    								<xf:label><![CDATA[아이디 저장]]></xf:label>
    								<xf:value><![CDATA[]]></xf:value>
    							</xf:item>
    						</xf:choices>
    					</xf:select>
    					<xf:trigger class="" id="" style="" title="로그인" type="button">
    						<xf:label><![CDATA[로그인]]></xf:label>
    					</xf:trigger>
    					<w2:anchor class="" escape="false" id="" outerDiv="false" style="">
    						<xf:label><![CDATA[비밀번호 찾기]]></xf:label>
    					</w2:anchor>
    				</xf:group>
    				<xf:group class="login-box" id="" style="">
    					<w2:textbox class="login-title" escape="false" id="" label="QUICK TRACKING" style=""></w2:textbox>
    					<xf:group class="tabbox " id="" style="">
    						<w2:tabControl alwaysDraw="false" class="" id="" style="">
    							<w2:tabs disabled="false" id="tabs1" label="B/L No." style=""></w2:tabs>
    							<w2:tabs disabled="false" id="tabs2" label="컨테이너 No." style=""></w2:tabs>
    							<w2:content alwaysDraw="false" id="content1" style="height: auto;">
    								<xf:input id="" placeholder="B/L No. 입력" style=""></xf:input>
    								<xf:trigger class="" id="" style="" title="조회하기" type="button">
    									<xf:label><![CDATA[조회하기]]></xf:label>
    								</xf:trigger>
    							</w2:content>
    							<w2:content alwaysDraw="false" id="content2" style="">
    								<xf:input id="" placeholder="컨테이너 No. 입력" style=""></xf:input>
    								<xf:trigger class="" id="" style="" title="엑셀 UP" type="button">
    									<xf:label><![CDATA[조회하기]]></xf:label>
    								</xf:trigger>
    							</w2:content>
    						</w2:tabControl>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    		</xf:group>    		
    		<xf:group id="" style="" tagname="footer">
    			<xf:group id="" style="" class="left">
    				<xf:group id="" class="familysite">
    					<xf:trigger type="button" id="btn_fmsite" style="" class="" ev:onclick="scwin.btn_fmsite_onclick">
    						<xf:label><![CDATA[familysite]]></xf:label>
    					</xf:trigger>
    				<xf:group id="" style="" class="fs-sub"><xf:trigger style="" id="" type="button">
    						<xf:label><![CDATA[동원로엑스 홈페이지]]></xf:label>
    					</xf:trigger><xf:trigger style="" id="" type="button">
    						<xf:label><![CDATA[동원글로벌터미널부산]]></xf:label>
    					</xf:trigger></xf:group></xf:group>
    				<w2:textbox class="" escape="false" id=""
    					label="COPYRIGHTⓒDONGWON LOEX. ALL RIGHT RESERVED WORLDWIDE. FOR MORE INFORMATION CONTACT WEBASTER" ref="" style="">
    				</w2:textbox>
    			</xf:group>
    			<xf:group id="" style="" class="right">
    				<w2:textbox class="mark01" escape="false" id="" label="" ref="" style=""></w2:textbox>
    				<w2:textbox class="mark02" escape="false" id="" label="" ref="" style=""></w2:textbox>
    				<w2:textbox class="mark03" escape="false" id="" label="" ref="" style=""></w2:textbox>
    				<w2:textbox class="mark04" escape="false" id="" label="" ref="" style=""></w2:textbox>
    				<w2:textbox class="mark05" escape="false" id="" label="" ref="" style=""></w2:textbox>
    				<w2:textbox class="mark06" escape="false" id="" label="" ref="" style=""></w2:textbox>
    			</xf:group>
    		</xf:group>
    	</xf:group>
    </body>
</html>

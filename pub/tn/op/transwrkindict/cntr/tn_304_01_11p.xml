    								submenuSize="auto" allOption="" chooseOption="" ref="">
    								<w2:choices>
    									<w2:item>
    										<w2:label><![CDATA[NO]]></w2:label>
    										<w2:value><![CDATA[N]]></w2:value>
    									</w2:item>
    									<w2:item>
    										<w2:label><![CDATA[YES]]></w2:label>
    										<w2:value><![CDATA[Y]]></w2:value>
    									</w2:item>
    								</w2:choices>
    							</w2:autoComplete>
    						</xf:group>
    						<xf:group class="w2tb_th" tagname="th">

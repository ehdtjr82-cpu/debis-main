    							<w2:column displayMode="label" id="column17" inputType="text" value="협력업체" width="120"></w2:column>
    							<w2:column displayMode="label" id="column15" inputType="text" value="등록&lt;br/&gt;점소" width="70"></w2:column>
    							<w2:column displayMode="label" id="column13" inputType="text" value="차량종류" width="100"></w2:column>
    							<w2:column displayMode="label" id="column11" inputType="text" value="차량규격" width="100"></w2:column>
    							<w2:column displayMode="label" id="column9" inputType="text" value="기사명" width="80"></w2:column>
    							<w2:column displayMode="label" id="column3" inputType="text" value="핸드폰" width="100"></w2:column>
    							<w2:column displayMode="label" id="column5" inputType="text" value="차량정기검사&lt;br/&gt;만료일" width="120"></w2:column>

    							<w2:column displayMode="label" id="vehclClntNm" inputType="text" width="120" textAlign="left"></w2:column>
    							<w2:column displayMode="label" id="assgnLobranCd" inputType="text" width="70" textAlign="left"></w2:column>
    							<w2:column displayMode="label" id="eqKndNm" inputType="text" width="100" textAlign="left"></w2:column>
    							<w2:column displayMode="label" id="eqNrmNm" inputType="text" width="100" textAlign="left"></w2:column>
    							<w2:column displayMode="label" id="drvNm" inputType="text" width="80"></w2:column>
    							<w2:column displayMode="label" id="mpNo" inputType="text" width="100"></w2:column>
    							<w2:column displayMode="label" id="rglintInspExpireDt" inputType="text" width="120" dataType="text" displayFormat="####/##/##"></w2:column>
    							<w2:column displayMode="label" id="chassisVehclNo" inputType="text" width="100"></w2:column>
    							<w2:column displayMode="label" id="chassisKndNm" inputType="text" width="100" textAlign="left"></w2:column>
    							<w2:column width="120" inputType="text" id="chassisRglintInspExpireDt" displayMode="label" dataType="text" displayFormat="####/##/##"></w2:column>
    						</w2:row>
    					</w2:gBody>

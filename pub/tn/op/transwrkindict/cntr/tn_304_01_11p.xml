    					<w2:key id="spotYn" name="name2" dataType="text"></w2:key>
    				</w2:keyInfo>
    			</w2:dataMap>
    			<w2:dataList baseNode="list" repeatNode="map" id="ds_results" saveRemovedData="true">
    				<w2:columnInfo>
    					<w2:column id="vehclNo" name="차량번호" dataType="text"></w2:column>
                        <w2:column id="vehclClntNm" name="협력업체" dataType="text"></w2:column>
                        <w2:column id="assgnLobranCd" name="등록;점소" dataType="text"></w2:column>

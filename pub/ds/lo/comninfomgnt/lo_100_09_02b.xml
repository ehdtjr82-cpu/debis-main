<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
    	<w2:type>COMPONENT</w2:type>
    	<w2:buildDate />
    	<w2:MSA />
    	<xf:model>
    		<w2:dataCollection baseNode="map" />
    		<w2:workflowCollection />
    	</xf:model>
    	<w2:layoutInfo />
    	<w2:publicInfo method="" />
    	<script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function() {
	
};
]]></script>
    	<w2:require as="udc_topGrdBtn" type="page" variableClone="true" src="/cm/udc/topGrdBtn.xml"></w2:require>
    	<w2:require as="udc_bottomGrdBtn" type="page" variableClone="true" src="/cm/udc/bottomGrdBtn.xml"></w2:require>
    </head>
    <body ev:onpageload="scwin.onpageload">
    	<xf:group class="sub_contents" id="" style="">
    		<w2:wframe id="" src="/cm/xml/contentHeader.xml" style=""></w2:wframe>
    		<xf:group class="round-box" id="" style="">
    			<xf:group id="grd_section1" class="lybox flex_no col3">
    				<xf:group id="" class="col">
    					<xf:group style="" id="" class="title-wrap">
    						<xf:group id="" class="title">
    							<w2:textbox tagname="h3" style="" id="" label="권역Tree" class="tit"></w2:textbox>
    						</xf:group>
    						<xf:group id="" class="right">
    							<w2:udc_topGrdBtn grp="grd_section1" style=""></w2:udc_topGrdBtn>
    						</xf:group>
    					</xf:group>
    					<xf:group id="" class="tvw-wrap">
    						<w2:treeview tooltipGroupClass="false" dataType="listed" style="" id="tv_treeview1"
    							renderType="virtual" class="h-full">
    						</w2:treeview>
    					</xf:group>
    				</xf:group>
    				<xf:group id="" class="col">
    					<xf:group style="" id="" class="title-wrap">
    						<xf:group id="" class="title">
    							<w2:textbox tagname="h3" style="" id="" label="권역" class="tit"></w2:textbox>
    						</xf:group>
    						<xf:group id="" class="right">
    							<w2:udc_topGrdBtn grp="grd_section1" style=""></w2:udc_topGrdBtn>
    						</xf:group>
    					</xf:group>
    					<xf:group adaptiveThreshold="" style="" id="" class="gvwbox">
    						<w2:gridView visibleRowNumFix="true" checkAllType="false" dataList="" style="" autoFit="allColumn"
    							id="gr_gridView1" visibleRowNum="15" class="wq_gvw">
    							<w2:caption style="" id="caption1" value="this is a grid caption."></w2:caption>
    							<w2:header style="" id="header1">
    								<w2:row style="" id="row1">
    									<w2:column width="100" inputType="text" id="column1" value="권역코드" displayMode="label" class="txt-red"></w2:column>
    									<w2:column width="140" inputType="text" id="column17" value="권역명" displayMode="label" class="txt-red"></w2:column>
    									<w2:column width="140" inputType="text" id="column15" value="비고" displayMode="label" class="txt-blue"></w2:column>
    								</w2:row>
    							</w2:header>
    							<w2:gBody style="" id="gBody1">
    								<w2:row style="" id="row2">
    									<w2:column width="100" inputType="text" id="column2" displayMode="label"></w2:column>
    									<w2:column width="140" inputType="text" id="column18" displayMode="label" textAlign="left"></w2:column>
    									<w2:column width="140" inputType="text" id="column16" displayMode="label" textAlign="left"></w2:column>
    								</w2:row>
    							</w2:gBody>
    						</w2:gridView>
    						<xf:group style="" id="" class="grid-bottom ">
    							<xf:group id="" class="left">
    								<xf:group id="" class="grid-total">
    									<w2:textbox tagname="span" style="" id="" label="총" class=""></w2:textbox>
    									<w2:textbox tagname="span" dataType="number" displayFormat="#,##0" style="" id="" label="0"
    										class="num">
    									</w2:textbox>
    									<w2:textbox tagname="span" style="" id="" label="건" class=""></w2:textbox>
    								</xf:group>
    							</xf:group>
    							<xf:group style="" id="" class="right">
    								<w2:udc_bottomGrdBtn style=""></w2:udc_bottomGrdBtn>
    							</xf:group>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    				<xf:group class="col" id="" style="">
    					<xf:group class="title-wrap" id="" style="">
    						<xf:group class="title" id="">
    							<w2:textbox class="tit" id="" label="ALL-단일권역" style="" tagname="h3"></w2:textbox>
    						</xf:group>
    						<xf:group class="right" id="">
    							<w2:udc_topGrdBtn grp="grd_section1" style=""></w2:udc_topGrdBtn>
    						</xf:group>
    					</xf:group>
    					<xf:group adaptiveThreshold="" class="gvwbox" id="" style="">
    						<w2:gridView autoFit="allColumn" checkAllType="false" class="wq_gvw" dataList="" id="gr_gridView2" style=""
    							visibleRowNum="15" visibleRowNumFix="true">
    							<w2:caption id="caption2" style="" value="this is a grid caption."></w2:caption>
    							<w2:header id="header1" style="">
    								<w2:row id="row1" style="">
    									<w2:column displayMode="label" id="column1" inputType="text" style="" value="지역코드" width="100" class="txt-red"></w2:column>
    									<w2:column displayMode="label" id="column17" inputType="text" style="" value="지역명" width="140" class="txt-red"></w2:column>
    								</w2:row>
    							</w2:header>
    							<w2:gBody id="gBody1" style="">
    								<w2:row id="row2" style="">
    									<w2:column displayMode="label" id="column2" inputType="text" style="" value="" width="100"></w2:column>
    									<w2:column displayMode="label" id="column18" inputType="text" style="" value="" width="140" textAlign="left"></w2:column>
    								</w2:row>
    							</w2:gBody>
    						</w2:gridView>
    						<xf:group class="grid-bottom " id="" style="">
    							<xf:group class="left" id="">
    								<xf:group class="grid-total" id="">
    									<w2:textbox class="" id="" label="총" style="" tagname="span"></w2:textbox>
    									<w2:textbox class="num" dataType="number" displayFormat="#,##0" id="" label="0" style=""
    										tagname="span">
    									</w2:textbox>
    									<w2:textbox class="" id="" label="건" style="" tagname="span"></w2:textbox>
    								</xf:group>
    							</xf:group>
    							<xf:group class="right" id="" style="">
    								<w2:udc_bottomGrdBtn style=""></w2:udc_bottomGrdBtn>
    							</xf:group>
    						</xf:group>
    					</xf:group>
    				</xf:group>
    			</xf:group>
    			<xf:group class="btnbox" id="">
    				<xf:group class="right" id="">
    					<xf:trigger class="btn" id="btn_save" label="저장" style="" type="button">
    						<xf:label>저장</xf:label>
    					</xf:trigger>
    				</xf:group>
    			</xf:group>
    		</xf:group>
    	</xf:group>
    </body>
</html>

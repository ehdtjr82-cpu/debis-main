    	<script lazy="false" type="text/javascript"><![CDATA[scwin.args = $c.data.getParameter();
scwin.lobranCd = args[0];
scwin.qryStDt = args[1];
scwin.qryEndDt = args[2];
scwin.posnClsCd  = args[3];
scwin.hveqKndCd  = args[4];
scwin.copCoCd = args[5];
scwin.hveqClsCd = args[6];
scwin.sellLodeptCd = args[7];


scwin.onpageload = function() {
	scwin.f_Retrieve();
};

scwin.f_Retrieve = function(){
    scwin.f_init();
    $c.sbm.execute(sbm_tr_retrieve);
}

scwin.f_init = function() {
    ds_QueryCondition.removeAll();
    ds_QueryCondition.insertRow(0);
	
    ds_QueryCondition.setCellData(0,"lobranCd",scwin.lobranCd);			    // 물류점소코드
    ds_QueryCondition.setCellData(0,"qryStDt",scwin.qryStDt);				// 조회시작일자
    ds_QueryCondition.setCellData(0,"qryEndDt",scwin.qryEndDt);			    // 조회종료일자
    ds_QueryCondition.setCellData(0,"posnClsCd",scwin.posnClsCd);			// 소유구분코드
    ds_QueryCondition.setCellData(0,"hveqKndCd",scwin.hveqKndCd);			// 중기종류코드
    ds_QueryCondition.setCellData(0,"copCoCd",scwin.copCoCd);				// 협력업체코드 copCoCd
    ds_QueryCondition.setCellData(0,"hveqClsCd",scwin.hveqClsCd);			// 중기/이적차량 구분코드
    ds_QueryCondition.setCellData(0,"sellLodeptCd",scwin.sellLodeptCd);	    // 회계부서
}

scwin.f_toExcel = function() {
	//sheet명, 저장파일명, 저장 다이얼로그
	$c.gus.cfGridToExcel(gr_RetrieveWorkResult , "중기별 전체 상세 작업실적" , "중기별 전체 상세 작업실적.xls" , 4+8+16);
}

scwin.f_WinClose = function() {
	scwin.closePopup();
}
scwin.sbm_tr_retrieve_submitdone = function (e) {
    if( ds_RetrieveWorkResult.getRowCount() == 0 ){
		$c.gus.cfAlertMsg("[중기별 전체 상세 작업실적] "+MSG_CM_ERR_003);
  	}
  	
  	//cfShowTotalRows(totalRows,rowCnt);
    spa_totCnt.setValue(ds_RetrieveWorkResult.getRowCount());
};
]]></script>
